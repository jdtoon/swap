<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Local packages built from this repository -->
    <add key="Swap Local" value=".nuget" />
    <!-- Fallback to official NuGet -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <!-- Allow pre-release packages -->
    <add key="includePreRelease" value="true" />
  </config>
</configuration>
