# Nuget Packages
*.nupkg
*.snupkg

# Local NuGet repository (packages rebuilt via setup script)
.nuget/

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm64/
bld/
