# Visual Studio Code cache/settings
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Rider files
.idea/

# Dotnet files
project.lock.json
project.assets.json
publish/

# Sample apps directory (showcase apps - committed for demonstration)
# sampleApps/ - Intentionally committed to show CLI capabilities

# Dogfooding apps (temporary validation apps - NOT committed)
dogfood/
*Dogfood*/app.db
*Dogfood*/app.db-shm
*Dogfood*/app.db-wal

# Test apps (temporary testing - NOT committed)
testApps/
E2ETest*/
E2EValidation*/
*ModuleTest*/
IdentityModuleTest/

# Node.js dependencies
node_modules/
**/node_modules/

# NPM/Yarn files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Compiled CSS (generated from Tailwind)
**/wwwroot/css/*.min.css
**/wwwroot/css/*.css.map

# SQLite databases (sample/test apps)
*.db
*.db-shm
*.db-wal
**/app.db
**/app.db-shm
**/app.db-wal

# LibMan cache
**/wwwroot/lib/