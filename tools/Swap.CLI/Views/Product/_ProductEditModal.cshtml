@model Product

<div class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Edit Product</h3>
        
        <form hx-post="@Url.Action("Edit", new { id = Model.Id })" 
              hx-target="#modal-container" 
              hx-swap="innerHTML">
            
            <input type="hidden" name="Id" value="@Model.Id" />
            
            @await Html.PartialAsync("_ProductForm", Model)
            
            <div class="modal-action">
                <button type="button" 
                        class="btn" 
                        onclick="document.getElementById('modal-container').innerHTML = ''">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">
                    Update
                </button>
            </div>
        </form>
    </div>
    <div class="modal-backdrop" onclick="document.getElementById('modal-container').innerHTML = ''"></div>
</div>
