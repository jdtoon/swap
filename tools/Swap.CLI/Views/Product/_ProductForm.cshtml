@model Product

<div asp-validation-summary="All" class="alert alert-error mb-4" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

<div class="form-control">
                <label class="label">
                    <span class="label-text">Name</span>
                </label>
                <input type="text" 
                       name="Name" 
                       placeholder="Name"
                       value="@Model.Name"
                       class="input input-bordered" 
                       required />
                <span asp-validation-for="Name" class="text-error text-sm"></span>
            </div>

<div class="form-control">
                <label class="label">
                    <span class="label-text">Price</span>
                </label>
                <input type="number" 
                       name="Price" 
                       placeholder="Price"
                       value="@Model.Price"
                       step="any"
                       class="input input-bordered" 
                       required />
                <span asp-validation-for="Price" class="text-error text-sm"></span>
            </div>

<div class="form-control">
                <label class="label">
                    <span class="label-text">SKU</span>
                </label>
                <input type="text" 
                       name="SKU" 
                       placeholder="SKU"
                       value="@Model.SKU"
                       class="input input-bordered" 
                       required />
                <span asp-validation-for="SKU" class="text-error text-sm"></span>
            </div>

<div class="form-control">
                <label class="label cursor-pointer">
                    <span class="label-text">InStock</span>
                    <input type="checkbox" name="InStock" value="true" class="checkbox checkbox-primary" @(Model.InStock ? "checked" : "") />
                </label>
                <input type="hidden" name="InStock" value="false" />
            </div>

<div class="form-control">
                <label class="label">
                    <span class="label-text">CreatedDate</span>
                </label>
                <input type="datetime-local" 
                       name="CreatedDate" 
                       placeholder="CreatedDate"
                       value="@Model.CreatedDate.ToString("yyyy-MM-ddTHH:mm")"
                       class="input input-bordered" 
                       required />
                <span asp-validation-for="CreatedDate" class="text-error text-sm"></span>
            </div>
