<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- Global Tool Configuration -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>swap</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>
    
    <!-- Package Metadata -->
    <PackageId>Swap.CLI</PackageId>
    <Description>Command-Line Interface for the Swap Framework. Scaffold modules, generate CRUD features, and more.</Description>
    <PackageTags>swap;cli;scaffolding;code-generation;htmx</PackageTags>
    
    <!-- Assembly Information -->
    <AssemblyVersion>0.1.0.0</AssemblyVersion>
    <FileVersion>0.1.0.0</FileVersion>
    <InformationalVersion>0.1.0</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- CLI Framework - handles argument parsing, help generation -->
    <PackageReference Include="System.CommandLine" Version="2.0.0-rc.2.25502.107" />
    
    <!-- Rich Terminal UI - progress bars, spinners, colors (KEEP: Amazing DX) -->
    <PackageReference Include="Spectre.Console" Version="0.49.1" />
    
    <!-- Code Generation - Roslyn API for C# code modification (KEEP: Essential for code gen) -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.14.0" />
    
    <!-- JSON Serialization - for module.json, config files -->
    <PackageReference Include="System.Text.Json" Version="9.0.10" />
  </ItemGroup>

  <ItemGroup>
    <!-- Include templates in the NuGet package -->
    <Content Include="..\..\templates\**\*.*" PackagePath="templates/" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>

