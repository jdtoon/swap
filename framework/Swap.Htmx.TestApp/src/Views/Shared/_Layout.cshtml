<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Swap.Htmx Test App</title>
    <link rel="stylesheet" href="~/css/app.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/htmx-toast.css" asp-append-version="true" />
    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true"></script>
</head>
<body>
    <header>
        <nav class="navbar bg-base-100 shadow-lg">
            <div class="container mx-auto">
                <div class="navbar-start">
                    <a class="btn btn-ghost text-xl" href="/">Swap.Htmx Test App</a>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" class="container mx-auto p-4">
        @RenderBody()
    </main>

    <footer class="footer footer-center p-4 bg-base-300 text-base-content mt-8">
        <aside>
            <p>Minimal test app for <strong>Swap.Htmx</strong> framework features</p>
        </aside>
    </footer>

    @await Html.PartialAsync("_ToastContainer")

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

