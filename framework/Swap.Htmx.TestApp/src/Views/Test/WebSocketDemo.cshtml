@{
    ViewData["Title"] = "WebSocket Chat Demo";
}

<div class="container mx-auto p-4">
    <h1 class="text-3xl font-bold mb-4">WebSocket Chat</h1>
    
    <div class="bg-gray-100 p-4 rounded-lg mb-4">
        <p class="mb-2">This demo shows bidirectional WebSocket communication using HTMX.</p>
        <ul class="list-disc list-inside text-sm text-gray-600">
            <li>Type a message and click Send (or press Enter)</li>
            <li>Messages are broadcast to all connected users in real-time</li>
            <li>Open multiple browser windows to see live updates</li>
        </ul>
    </div>

    <div class="grid grid-cols-1 gap-4">
        <!-- Chat Messages -->
        <div class="bg-white rounded-lg shadow-lg p-4">
            <h2 class="text-xl font-semibold mb-4">Messages</h2>
            
            <div id="chat-messages" 
                 class="h-96 overflow-y-auto border border-gray-300 rounded p-4 mb-4"
                 hx-ext="ws" 
                 ws-connect="/ws/chat"
                 hx-swap="beforeend">
                <!-- Messages will appear here -->
            </div>

            <!-- Send Message Form -->
            <form id="chat-form" hx-ext="ws" ws-send>
                <div class="flex gap-2">
                    <input type="text" 
                           name="username" 
                           placeholder="Your name" 
                           class="px-4 py-2 border rounded flex-shrink-0 w-32"
                           value="User" />
                    
                    <input type="text" 
                           name="message" 
                           placeholder="Type a message..." 
                           class="px-4 py-2 border rounded flex-1" />
                    
                    <button type="submit" 
                            class="px-6 py-2 bg-blue-500 text-white rounded hover:bg-blue-600">
                        Send
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Clear message input after sending
document.getElementById('chat-form').addEventListener('submit', function(e) {
    e.preventDefault();
    setTimeout(() => {
        const messageInput = document.querySelector('input[name="message"]');
        if (messageInput) messageInput.value = '';
    }, 10);
});
</script>
