@{
    ViewData["Title"] = "SSE Demo";
}

<div class="container">
    <section class="section">
        <h1 class="title">Server-Sent Events Demo</h1>
        <p class="subtitle">Real-time HTML streaming with HTMX SSE</p>

        <div class="box">
            <h2 class="title is-4">How it works</h2>
            <div class="content">
                <p>
                    This demo uses <strong>Server-Sent Events (SSE)</strong> to stream HTML updates from the server.
                    Click the button below to establish a connection and receive live notifications.
                </p>
                <ul>
                    <li><code>hx-sse="connect:/test/sse/stream"</code> - Establishes SSE connection</li>
                    <li><code>hx-sse="swap:notification"</code> - Swaps content when "notification" event received</li>
                    <li>Server sends HTML fragments at regular intervals</li>
                    <li>HTMX automatically handles reconnection if connection drops</li>
                </ul>
            </div>
        </div>

        <div id="sse-controls">
            <div class="buttons">
                <button class="button is-primary" 
                        hx-get="/test/sse/start"
                        hx-target="#sse-controls"
                        hx-swap="outerHTML">
                    Start Live Feed
                </button>
            </div>
        </div>

        <div id="notification-area"></div>
    </section>
</div>
