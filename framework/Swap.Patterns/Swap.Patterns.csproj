<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    
    <!-- Package Metadata -->
    <PackageId>Swap.Patterns</PackageId>
    <Version>0.1.0</Version>
    <Description>Common patterns for ASP.NET Core applications: soft delete, audit trails, slug generation, and more.</Description>
    <PackageTags>swap;patterns;soft-delete;auditable;sluggable;aspnetcore;entity-framework</PackageTags>
    <PackageProjectUrl>https://github.com/jdtoon/swap</PackageProjectUrl>
    <RepositoryUrl>https://github.com/jdtoon/swap</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Authors>jdtoon</Authors>
  </PropertyGroup>

  <ItemGroup>
    <!-- EF Core for query filters and interceptors -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.10" />
  </ItemGroup>

</Project>
