<Project>
  <PropertyGroup>
    <RepoRoot>$(MSBuildThisFileDirectory)</RepoRoot>
    <!-- Detect if project is under template-test folder to skip local generator reference -->
    <IsTemplateTestProject>false</IsTemplateTestProject>
    <IsTemplateTestProject Condition="$(MSBuildProjectDirectory.Contains('template-test'))">true</IsTemplateTestProject>
  </PropertyGroup>
  <ItemGroup Condition="'$(MSBuildProjectName)' != 'Swap.Htmx.Generators' AND '$(IsTemplateTestProject)' != 'true'">
    <ProjectReference Include="$(RepoRoot)framework\Swap.Htmx.Generators\Swap.Htmx.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
