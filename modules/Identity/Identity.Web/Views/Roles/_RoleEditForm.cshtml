@model Identity.Application.Contracts.Roles.UpdateRoleDto

<h2 class="subtitle">Edit Role</h2>

@if (ViewBag.IsSystemRole)
{
    <div class="notification is-warning">
        <p><strong>Warning:</strong> This is a system role and cannot be modified.</p>
    </div>
}
else
{
    <form hx-post="/Roles/Update/@ViewBag.RoleId" hx-swap="none">
        <div asp-validation-summary="All" class="notification is-danger is-light"></div>

        <div class="field">
            <label class="label" asp-for="Name"></label>
            <div class="control has-icons-left">
                <input class="input" type="text" asp-for="Name" placeholder="Administrator" required />
                <span class="icon is-small is-left">
                    <i class="fas fa-tag"></i>
                </span>
            </div>
            <span asp-validation-for="Name" class="help is-danger"></span>
        </div>

        <div class="field">
            <label class="label" asp-for="Description"></label>
            <div class="control">
                <textarea class="textarea" asp-for="Description" placeholder="Role description..." rows="3"></textarea>
            </div>
            <span asp-validation-for="Description" class="help is-danger"></span>
        </div>

        <div class="field is-grouped">
            <div class="control">
                <button type="submit" class="button is-primary">
                    <span class="icon">
                        <i class="fas fa-save"></i>
                    </span>
                    <span>Update Role</span>
                </button>
            </div>
            <div class="control">
                <button type="button" 
                        class="button is-light"
                        onclick="document.getElementById('role-form-container').innerHTML = '<p class=\'has-text-grey has-text-centered\'>Select \'Add Role\' or click \'Edit\' on a role to begin</p>'">
                    Cancel
                </button>
            </div>
        </div>
    </form>
}
