@model NetMX.Identity.Contracts.Users.CreateUserDto

<form hx-post="/account/register" 
      hx-target="#register-container" 
      hx-swap="outerHTML"
      hx-indicator="#register-spinner">
    
    @Html.AntiForgeryToken()
    
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="notification is-danger is-light">
            <button class="delete"></button>
            @Html.ValidationSummary(true)
        </div>
    }

    <div class="field">
        <label class="label" for="UserName">Username</label>
        <div class="control has-icons-left">
            <input class="input" 
                   type="text" 
                   id="UserName"
                   name="UserName"
                   value="@Model?.UserName"
                   placeholder="Choose a username" 
                   required
                   autofocus>
            <span class="icon is-small is-left">
                <i class="fas fa-user"></i>
            </span>
        </div>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.UserName)</span>
    </div>

    <div class="field">
        <label class="label" for="Email">Email</label>
        <div class="control has-icons-left">
            <input class="input" 
                   type="email" 
                   id="Email"
                   name="Email"
                   value="@Model?.Email"
                   placeholder="your.email@example.com" 
                   required>
            <span class="icon is-small is-left">
                <i class="fas fa-envelope"></i>
            </span>
        </div>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.Email)</span>
    </div>

    <div class="columns">
        <div class="column">
            <div class="field">
                <label class="label" for="FirstName">First Name</label>
                <div class="control">
                    <input class="input" 
                           type="text" 
                           id="FirstName"
                           name="FirstName"
                           value="@Model?.FirstName"
                           placeholder="John">
                </div>
                <span class="help is-danger">@Html.ValidationMessageFor(m => m.FirstName)</span>
            </div>
        </div>
        <div class="column">
            <div class="field">
                <label class="label" for="LastName">Last Name</label>
                <div class="control">
                    <input class="input" 
                           type="text" 
                           id="LastName"
                           name="LastName"
                           value="@Model?.LastName"
                           placeholder="Doe">
                </div>
                <span class="help is-danger">@Html.ValidationMessageFor(m => m.LastName)</span>
            </div>
        </div>
    </div>

    <div class="field">
        <label class="label" for="Password">Password</label>
        <div class="control has-icons-left">
            <input class="input" 
                   type="password" 
                   id="Password"
                   name="Password"
                   placeholder="Create a strong password" 
                   required>
            <span class="icon is-small is-left">
                <i class="fas fa-lock"></i>
            </span>
        </div>
        <p class="help">Must be at least 8 characters with uppercase, lowercase, number, and special character</p>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.Password)</span>
    </div>

    <div class="field">
        <div class="control">
            <label class="checkbox">
                <input type="checkbox" required>
                I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>
            </label>
        </div>
    </div>

    <div class="field">
        <div class="control">
            <button type="submit" class="button is-primary is-fullwidth">
                <span id="register-spinner" class="htmx-indicator">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
                <span>Create Account</span>
            </button>
        </div>
    </div>
</form>

<style>
    .htmx-indicator {
        display: none;
        margin-right: 0.5rem;
    }
    
    .htmx-request .htmx-indicator {
        display: inline;
    }
    
    .htmx-request.htmx-indicator {
        display: inline;
    }
</style>
