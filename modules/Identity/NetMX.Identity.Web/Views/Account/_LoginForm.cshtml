@model NetMX.Identity.Contracts.Users.LoginDto

<form hx-post="/account/login" 
      hx-target="#login-container" 
      hx-swap="outerHTML"
      hx-indicator="#login-spinner">
    
    @Html.AntiForgeryToken()
    
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="notification is-danger is-light">
            <button class="delete"></button>
            @Html.ValidationSummary(true)
        </div>
    }

    <div class="field">
        <label class="label" for="UserName">Username or Email</label>
        <div class="control has-icons-left">
            <input class="input" 
                   type="text" 
                   id="UserName"
                   name="UserName"
                   value="@Model?.UserName"
                   placeholder="Enter your username or email" 
                   required
                   autofocus>
            <span class="icon is-small is-left">
                <i class="fas fa-user"></i>
            </span>
        </div>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.UserName)</span>
    </div>

    <div class="field">
        <label class="label" for="Password">Password</label>
        <div class="control has-icons-left">
            <input class="input" 
                   type="password" 
                   id="Password"
                   name="Password"
                   placeholder="Enter your password" 
                   required>
            <span class="icon is-small is-left">
                <i class="fas fa-lock"></i>
            </span>
        </div>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.Password)</span>
    </div>

    <div class="field">
        <div class="control">
            <label class="checkbox">
                <input type="checkbox" 
                       name="RememberMe"
                       value="true"
                       @(Model?.RememberMe == true ? "checked" : "")>
                Remember me for 30 days
            </label>
        </div>
    </div>

    <div class="field">
        <div class="control">
            <button type="submit" class="button is-primary is-fullwidth">
                <span id="login-spinner" class="htmx-indicator">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
                <span>Sign In</span>
            </button>
        </div>
    </div>

    <div class="field">
        <div class="control has-text-centered">
            <a href="/account/forgot-password" class="is-size-7">Forgot your password?</a>
        </div>
    </div>
</form>

<style>
    .htmx-indicator {
        display: none;
        margin-right: 0.5rem;
    }
    
    .htmx-request .htmx-indicator {
        display: inline;
    }
    
    .htmx-request.htmx-indicator {
        display: inline;
    }
</style>
