@model NetMX.Identity.Contracts.Users.LoginDto

@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="section">
    <div class="container">
        <div class="columns is-centered">
            <div class="column is-5-tablet is-4-desktop">
                <div class="box">
                    <h1 class="title has-text-centered">Welcome Back</h1>
                    <p class="subtitle has-text-centered has-text-grey">Sign in to your account</p>

                    <div id="login-container" hx-target="this" hx-swap="outerHTML">
                        @await Html.PartialAsync("_LoginForm", Model ?? new LoginDto())
                    </div>

                    <div class="has-text-centered mt-5">
                        <p>
                            Don't have an account? 
                            <a href="/account/register" class="has-text-weight-bold">Sign up</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Listen for successful login
        document.body.addEventListener('login:success', function(evt) {
            console.log('Login successful', evt.detail);
        });

        // Listen for HX-Redirect header (HTMX automatically handles this)
        document.body.addEventListener('htmx:beforeOnLoad', function(evt) {
            if (evt.detail.xhr.getResponseHeader('HX-Redirect')) {
                console.log('Redirecting...');
            }
        });
    </script>
}
