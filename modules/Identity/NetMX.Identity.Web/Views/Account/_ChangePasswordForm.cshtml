@model NetMX.Identity.Contracts.Users.ChangePasswordDto

<form hx-post="/account/change-password" 
      hx-target="#password-container" 
      hx-swap="outerHTML"
      hx-indicator="#password-spinner">
    
    @Html.AntiForgeryToken()
    
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="notification is-danger is-light">
            <button class="delete"></button>
            @Html.ValidationSummary(true)
        </div>
    }

    <div class="field">
        <label class="label" for="CurrentPassword">Current Password</label>
        <div class="control">
            <input class="input" 
                   type="password" 
                   id="CurrentPassword"
                   name="CurrentPassword"
                   placeholder="Enter your current password"
                   required>
        </div>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.CurrentPassword)</span>
    </div>

    <div class="field">
        <label class="label" for="NewPassword">New Password</label>
        <div class="control">
            <input class="input" 
                   type="password" 
                   id="NewPassword"
                   name="NewPassword"
                   placeholder="Enter your new password"
                   required>
        </div>
        <p class="help">Must be at least 8 characters with uppercase, lowercase, number, and special character</p>
        <span class="help is-danger">@Html.ValidationMessageFor(m => m.NewPassword)</span>
    </div>

    <div class="field">
        <div class="control">
            <button type="submit" class="button is-warning">
                <span id="password-spinner" class="htmx-indicator">
                    <i class="fas fa-spinner fa-spin"></i>
                </span>
                <span>Change Password</span>
            </button>
        </div>
    </div>
</form>

<style>
    .htmx-indicator {
        display: none;
        margin-right: 0.5rem;
    }
    
    .htmx-request .htmx-indicator {
        display: inline;
    }
</style>
