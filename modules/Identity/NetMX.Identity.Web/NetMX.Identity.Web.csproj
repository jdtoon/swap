<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    
    <!-- NuGet Package Metadata -->
    <PackageId>NetMX.Identity.Web</PackageId>
    <Description>Identity module for NetMX framework providing user authentication, registration, and profile management with ASP.NET Core Identity integration.</Description>
    <PackageTags>netmx;identity;authentication;aspnetcore;htmx</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- Framework dependencies via NuGet -->
    <PackageReference Include="NetMX.Core" Version="0.2.0-local" />
    <PackageReference Include="NetMX.AspNetCore.Mvc" Version="0.2.0-local" />
    <PackageReference Include="NetMX.Events" Version="0.2.0-local" />
  </ItemGroup>

  <ItemGroup>
    <!-- Module dependencies - ProjectReferences within module -->
    <ProjectReference Include="..\NetMX.Identity.Core\NetMX.Identity.Core.csproj" />
    <ProjectReference Include="..\NetMX.Identity.Application\NetMX.Identity.Application.csproj" />
    <ProjectReference Include="..\NetMX.Identity.Contracts\NetMX.Identity.Contracts.csproj" />
  </ItemGroup>

</Project>
