<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- NuGet Package Metadata -->
    <PackageId>NetMX.Identity.Core</PackageId>
    <Description>Core domain entities and value objects for NetMX Identity module. Includes AppUser, AppRole, and ASP.NET Core Identity integration.</Description>
    <PackageTags>netmx;identity;domain;ddd;entities</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Framework dependencies via NuGet -->
    <PackageReference Include="NetMX.Ddd.Domain" Version="0.2.0-local" />
    
    <!-- Microsoft Identity - authentication and authorization -->
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="9.0.10" />
    <PackageReference Include="Microsoft.Extensions.Identity.Stores" Version="9.0.10" />
  </ItemGroup>

</Project>
