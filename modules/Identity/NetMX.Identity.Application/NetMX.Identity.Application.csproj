<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- NuGet Package Metadata -->
    <PackageId>NetMX.Identity.Application</PackageId>
    <Description>Application services for NetMX Identity module. Provides user management, role management, and authentication services.</Description>
    <PackageTags>netmx;identity;application;services;ddd</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Development: Use ProjectReferences for active development -->
    <ProjectReference Include="..\..\..\framework\NetMX.Core\NetMX.Core.csproj" />
    <ProjectReference Include="..\..\..\framework\NetMX.Ddd.Application\NetMX.Ddd.Application.csproj" />
    <ProjectReference Include="..\..\..\framework\NetMX.EntityFrameworkCore\NetMX.EntityFrameworkCore.csproj" />
    <!-- TODO: Switch to PackageReferences when publishing to NuGet -->
    <!--
    <PackageReference Include="NetMX.Core" Version="0.1.0-*" />
    <PackageReference Include="NetMX.Ddd.Application" Version="0.1.0-*" />
    <PackageReference Include="NetMX.EntityFrameworkCore" Version="0.1.0-*" />
    -->
    
    <!-- Microsoft Identity -->
    <PackageReference Include="Microsoft.Extensions.Identity.Core" Version="9.0.10" />
  </ItemGroup>

  <ItemGroup>
    <!-- Module dependencies - use ProjectReferences for local development -->
    <ProjectReference Include="..\NetMX.Identity.Core\NetMX.Identity.Core.csproj" />
    <ProjectReference Include="..\NetMX.Identity.Contracts\NetMX.Identity.Contracts.csproj" />
  </ItemGroup>

</Project>
