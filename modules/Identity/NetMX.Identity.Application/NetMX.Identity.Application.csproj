<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <!-- NuGet Package Metadata -->
    <PackageId>NetMX.Identity.Application</PackageId>
    <Description>Application services for NetMX Identity module. Provides user management, role management, and authentication services.</Description>
    <PackageTags>netmx;identity;application;services;ddd</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Framework dependencies via NuGet -->
    <PackageReference Include="NetMX.Core" Version="0.2.0-local" />
    <PackageReference Include="NetMX.Ddd.Application" Version="0.2.0-local" />
    <PackageReference Include="NetMX.EntityFrameworkCore" Version="0.2.0-local" />
    
    <!-- Microsoft Identity -->
    <PackageReference Include="Microsoft.Extensions.Identity.Core" Version="9.0.10" />
  </ItemGroup>

  <ItemGroup>
    <!-- Module dependencies - use ProjectReferences for local development -->
    <ProjectReference Include="..\NetMX.Identity.Core\NetMX.Identity.Core.csproj" />
    <ProjectReference Include="..\NetMX.Identity.Contracts\NetMX.Identity.Contracts.csproj" />
  </ItemGroup>

</Project>
