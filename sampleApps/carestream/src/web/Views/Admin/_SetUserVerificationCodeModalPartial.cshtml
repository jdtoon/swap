@using carestream.core.dtos.admin
@model SetVerificationCodeInputDto
@{
    Layout = null;
}

<form method="dialog">
    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" type="button" onclick="admin_generic_modal.close()">✕</button>
</form>
<h3 class="font-bold text-lg">Set/Reset Verification Code</h3>
<p class="py-2 text-sm">For User: <span class="font-semibold">@Model.UserName</span> (ID: @Model.UserId)</p>

@if (!string.IsNullOrEmpty(ViewData["SetCodeErrorMessage"] as string))
{
    <div class="alert alert-error text-xs p-2 mb-3">@ViewData["SetCodeErrorMessage"]</div>
}
else if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
{
    <div class="alert alert-warning text-xs p-2 mb-3">
        <p>Please correct the following errors:</p>
        <ul class="list-disc list-inside ml-4">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}


<form id="set-verification-code-form"
      hx-post="@Url.Action("SetVerificationCode", "Admin")"
      hx-target="#admin_generic_modal_content" @* Target the modal content for re-render on error *@
      hx-swap="innerHTML"
      hx-indicator="#set-code-indicator">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="UserName" /> @* Pass username back if form re-renders *@

    <div class="form-control mb-3">
        <label asp-for="NewVerificationCode" class="label pb-1"><span class="label-text">New 4-6 Digit Code</span></label>
        <input type="password" asp-for="NewVerificationCode" class="input input-bordered input-sm w-full max-w-xs" autocomplete="new-password" />
        <span asp-validation-for="NewVerificationCode" class="text-error text-xs mt-1"></span>
    </div>

    <div class="form-control mb-4">
        <label asp-for="ConfirmNewVerificationCode" class="label pb-1"><span class="label-text">Confirm New Code</span></label>
        <input type="password" asp-for="ConfirmNewVerificationCode" class="input input-bordered input-sm w-full max-w-xs" autocomplete="new-password" />
        <span asp-validation-for="ConfirmNewVerificationCode" class="text-error text-xs mt-1"></span>
    </div>

    <div class="modal-action">
        <button class="btn btn-sm btn-ghost" type="button" onclick="admin_generic_modal.close()">Cancel</button>
        <button type="submit" class="btn btn-sm btn-primary">
            Set Code
            <span id="set-code-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
        </button>
    </div>
</form>

<script>
    // Script to handle modal closing via HX-Trigger
    // This assumes the modal has id 'admin_generic_modal'
    const setCodeForm = document.getElementById('set-verification-code-form');
    if (setCodeForm) {
        setCodeForm.addEventListener('htmx:afterSwap', function(evt) {
            if (evt.detail.xhr && evt.detail.xhr.getResponseHeader("HX-Trigger-After-Swap")) {
                try {
                    const triggers = JSON.parse(evt.detail.xhr.getResponseHeader("HX-Trigger-After-Swap"));
                    if (triggers.closeSetCodeModal) {
                        const modal = document.getElementById('admin_generic_modal');
                        if (modal && typeof modal.close === 'function') {
                            modal.close();
                        }
                    }
                } catch (e) { console.error("Error parsing HX-Trigger for modal close", e); }
            }
        });
    }
</script>