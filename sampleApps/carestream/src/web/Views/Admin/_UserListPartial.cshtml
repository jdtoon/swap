@using carestream.core.dtos.admin
@model AdminUserManagementViewModel
@{
    Layout = null;
}

<div class="card bg-base-100 shadow-xl">
    <div class="card-body">
        <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
            <h2 class="card-title"><i data-feather="users" class="mr-2"></i>User Management</h2>
            <div class="flex flex-col sm:flex-row items-center gap-2">
                <form hx-get="@Url.Action("UserListPartial", "Admin")"
                      hx-target="#admin-content-area"
                      hx-swap="innerHTML"
                      hx-trigger="submit"
                      class="join">
                    <input type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Search users..." class="input input-sm input-bordered join-item" />
                    <button type="submit" class="btn btn-sm btn-primary join-item">Search</button>
                </form>

                <button class="btn btn-sm btn-success"
                        hx-get="@Url.Action("CreateUserModal", "Admin")"
                        hx-target="#admin_generic_modal_content"
                        hx-swap="innerHTML"
                        onclick="admin_generic_modal.showModal()">
                    <i data-feather="plus" class="w-4 h-4"></i> Create User
                </button>
            </div>
        </div>

        <div id="user-table-container">
            @if (Model.Users.Any())
            {
                <div class="overflow-x-auto">
                    <table class="table table-sm table-zebra w-full">
                        <thead>
                            <tr>
                                <th>User ID</th>
                                <th>Force No.</th>
                                <th>Full Name</th>
                                <th>Rank</th>
                                <th>Department</th>
                                <th>Facility</th>
                                <th>Logto Linked</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td>@user.UserId</td>
                                    <td>@user.ForceNumber</td>
                                    <td>@user.FullName</td>
                                    <td>@(user.Rank ?? "-")</td>
                                    <td>@(user.Department ?? "-")</td>
                                    <td>@(user.FacilityName ?? "N/A")</td>
                                    <td>
                                        @if (user.IsLinkedToLogto)
                                        {
                                            <span class="badge badge-success badge-xs" title="@user.LogtoSub">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning badge-xs">No</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(user.IsActive ? "badge-success" : "badge-error") badge-xs">
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-xs btn-outline btn-info"
                                                hx-get="@Url.Action("UserDetailModal", "Admin", new { userId = user.UserId })"
                                                hx-target="#admin_generic_modal_content"
                                                hx-swap="innerHTML"
                                                onclick="admin_generic_modal.showModal()">
                                            View Details
                                        </button>
                                        @if (!user.IsLinkedToLogto)
                                        {
                                            <button class="btn btn-xs btn-outline btn-secondary ml-1"
                                                    hx-get="@Url.Action("LinkUserModal", "Admin", new { userId = user.UserId })"
                                                    hx-target="#admin_generic_modal_content"
                                                    hx-swap="innerHTML"
                                                    onclick="admin_generic_modal.showModal()">
                                                Link Logto ID
                                            </button>
                                        }
                                        <button class="btn btn-xs btn-outline btn-accent ml-1"
                                                hx-get="@Url.Action("SetVerificationCodeModal", "Admin", new { userId = user.UserId })"
                                                hx-target="#admin_generic_modal_content"
                                                hx-swap="innerHTML"
                                                onclick="admin_generic_modal.showModal()">
                                            Set/Reset Code
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center py-4">No users found @(!string.IsNullOrEmpty(Model.SearchTerm) ? "matching your search." : ".")</p>
            }
        </div>
    </div>
</div>
<script>if(typeof feather !== 'undefined') feather.replace();</script>