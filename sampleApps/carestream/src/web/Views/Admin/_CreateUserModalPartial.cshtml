@using carestream.core.dtos.admin
@using carestream.core.dtos.facility
@model CreateUserInputDto
@{
    Layout = null;
    var allActiveFacilities = ViewData["AllActiveFacilities"] as List<FacilityDto> ?? new List<FacilityDto>();
}

<form method="dialog">
    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" type="button" onclick="admin_generic_modal.close()">✕</button>
</form>
<h3 class="font-bold text-lg">Create New User</h3>
<p class="py-2 text-sm">Fill in the details for the new Carestream application user. A Logto ID can be linked later.</p>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
{
    <div class="alert alert-warning text-xs p-2 mb-3">
        <p>Please correct the following errors:</p>
        <ul class="list-disc list-inside ml-4">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}
@if (!string.IsNullOrEmpty(ViewData["ErrorMessage"] as string)) // For general server-side errors not tied to model state
{
    <div class="alert alert-error text-xs p-2 mb-3">@ViewData["ErrorMessage"]</div>
}

<form id="create-user-form"
      hx-post="@Url.Action("CreateUser", "Admin")"
      hx-target="#admin_generic_modal_content" @* Target modal content for validation errors *@
      hx-swap="innerHTML"
      hx-indicator="#create-user-indicator">

    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-2 mt-4">
        <div class="form-control">
            <label asp-for="ForceNumber" class="label pb-0"><span class="label-text">Force Number</span></label>
            <input type="text" asp-for="ForceNumber" class="input input-sm input-bordered w-full" />
            <span asp-validation-for="ForceNumber" class="text-error text-xs mt-1"></span>
        </div>
        <div class="form-control">
            <label asp-for="FirstName" class="label pb-0"><span class="label-text">First Name</span></label>
            <input type="text" asp-for="FirstName" class="input input-sm input-bordered w-full" />
            <span asp-validation-for="FirstName" class="text-error text-xs mt-1"></span>
        </div>
        <div class="form-control">
            <label asp-for="LastName" class="label pb-0"><span class="label-text">Last Name</span></label>
            <input type="text" asp-for="LastName" class="input input-sm input-bordered w-full" />
            <span asp-validation-for="LastName" class="text-error text-xs mt-1"></span>
        </div>
        <div class="form-control">
            <label asp-for="Rank" class="label pb-0"><span class="label-text">Rank (Optional)</span></label>
            <input type="text" asp-for="Rank" class="input input-sm input-bordered w-full" />
            <span asp-validation-for="Rank" class="text-error text-xs mt-1"></span>
        </div>
        <div class="form-control">
            <label asp-for="Department" class="label pb-0"><span class="label-text">Department (Optional)</span></label>
            <input type="text" asp-for="Department" class="input input-sm input-bordered w-full" />
            <span asp-validation-for="Department" class="text-error text-xs mt-1"></span>
        </div>
        <div class="form-control">
            <label asp-for="InitialFacilityId" class="label pb-0"><span class="label-text">Initial Facility</span></label>
            <select asp-for="InitialFacilityId" class="select select-sm select-bordered w-full" required>
                <option value="">Select an initial facility</option>
                @foreach (var facility in allActiveFacilities)
                {
                    <option value="@facility.FacilityId">@facility.Name (@facility.ShortCode)</option>
                }
            </select>
            <span asp-validation-for="InitialFacilityId" class="text-error text-xs mt-1"></span>
        </div>
        <div class="form-control md:col-span-2 flex items-center justify-start flex-row mt-2">
            <input type="checkbox" asp-for="IsActive" class="checkbox checkbox-primary" />
            <label asp-for="IsActive" class="label pl-3"><span class="label-text cursor-pointer">Active User</span></label>
            <span asp-validation-for="IsActive" class="text-error text-xs mt-1"></span>
        </div>
    </div>

    <div class="modal-action mt-6">
        <button class="btn btn-sm btn-ghost" type="button" onclick="admin_generic_modal.close()">Cancel</button>
        <button type="submit" class="btn btn-sm btn-primary">
            Create User
            <span id="create-user-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
        </button>
    </div>
</form>