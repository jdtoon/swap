@using carestream.core.dtos.admin
@model AdminUserListItemDto
@{
    Layout = null;
}

<form method="dialog">
    @* Allows DaisyUI modal close button to work *@
    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
</form>
<h3 class="font-bold text-lg">Link Logto ID for @Model.FullName</h3>
<p class="py-2 text-sm">User ID: @Model.UserId | Force Number: @Model.ForceNumber</p>
@if (!string.IsNullOrEmpty(ViewData["LinkErrorMessage"] as string))
{
    <div class="alert alert-error text-xs p-2 mb-2">@ViewData["LinkErrorMessage"]</div>
}

<form id="link-user-form"
      hx-post="@Url.Action("LinkUser", "Admin")"
      hx-target="#admin-content-area" @* Target the whole user list section to refresh it *@
      hx-swap="innerHTML"
      hx-indicator="#link-user-indicator">

    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" value="@Model.UserId" />

    <div class="form-control mb-4">
        <label for="logtoSubInput" class="label"><span class="label-text">Logto Subject ID (sub claim)</span></label>
        <input type="text" id="logtoSubInput" name="logtoSub" value="@Model.LogtoSub" class="input input-bordered" required />
        <label class="label">
            <span class="label-text-alt">Find this in the Logto Admin Console</span>
        </label>
    </div>

    <div class="modal-action">
        <form method="dialog" class="inline-block">
            @* For DaisyUI close button if needed w/o JS *@
            <button class="btn btn-sm">Cancel</button>
        </form>
        <button type="submit" class="btn btn-sm btn-primary">
            Link User
            <span id="link-user-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
        </button>
    </div>
</form>
<script>
    // If the HX-Trigger for closeLinkUserModal is used by the controller on success
    // and the modal ID is 'admin_generic_modal'
    const linkUserForm = document.getElementById('link-user-form');
    if (linkUserForm) {
        linkUserForm.addEventListener('htmx:afterSwap', function(evt) {
            // Check if a specific header or event detail signals to close the modal
            if (evt.detail.xhr && evt.detail.xhr.getResponseHeader("HX-Trigger-After-Swap")) {
                try {
                    const triggers = JSON.parse(evt.detail.xhr.getResponseHeader("HX-Trigger-After-Swap"));
                    if (triggers.closeLinkUserModal) {
                        const modal = document.getElementById('admin_generic_modal');
                        if (modal && typeof modal.close === 'function') {
                            modal.close();
                        }
                    }
                } catch (e) { console.error("Error parsing HX-Trigger for modal close", e); }
            }
        });
    }
</script>