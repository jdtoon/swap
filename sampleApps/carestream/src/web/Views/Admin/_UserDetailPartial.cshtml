@using carestream.core.dtos.admin
@using carestream.core.dtos.facility
@model AdminUserDetailDto
@{
    Layout = null; // This partial is loaded into a modal
}

<form method="dialog">
    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" type="button" onclick="admin_generic_modal.close()">✕</button>
</form>
<h3 class="font-bold text-lg mb-4">User Details: @Model.FullName</h3>
<p class="py-2 text-sm">User ID: <span class="font-semibold">@Model.UserId</span> | Force Number: <span class="font-semibold">@Model.ForceNumber</span></p>

@* Container for Personal Info Display/Edit *@
<div id="user-personal-info-@Model.UserId" class="mb-6 p-4 border rounded-md bg-base-100 shadow-sm"
     hx-get="@Url.Action("GetUserPersonalInfoDisplayPartial", "Admin", new { userId = Model.UserId })" @* Changed to call the new display partial action *@
     hx-trigger="load once"
     hx-swap="innerHTML">
    <div class="text-center">Loading personal information...</div> @* Placeholder for initial load *@
</div>

@* Container for Linked Facilities Display/Management *@
<div id="user-facilities-@Model.UserId" class="mb-6 p-4 border rounded-md bg-base-100 shadow-sm"
     hx-get="@Url.Action("GetUserFacilitiesPartial", "Admin", new { userId = Model.UserId })" @* Changed to call the new facilities partial action *@
     hx-trigger="load once"
     hx-swap="innerHTML">
    <div class="text-center">Loading linked facilities...</div>
</div>

<div class="modal-action mt-4">
    <button class="btn btn-sm" onclick="admin_generic_modal.close()">Close</button>
</div>

<script>
    // No specific JS needed here, Alpine and HTMX handle interactivity.
    // Feather icons will be replaced on _UserDetailPartial's htmx:afterSwap via _Layout's listener.
</script>