@using carestream.core.dtos.patient
@model PatientDetailDto
@{ Layout = null; }

<div id="personal-info-display-area-@Model.PatientId">
    <div class="p-2 bg-base-200 rounded-md mb-2">
        <div class="flex justify-between items-center">
            <h3 class="font-semibold text-lg">Personal Information</h3>
            <button class="btn btn-xs btn-outline btn-secondary"
                    hx-get="@Url.Action("EditPersonalInfoForm", "Patient", new { patientId = Model.PatientId })"
                    hx-target="#personal-info-display-area-@Model.PatientId" @* Target this display area for replacement *@
                    hx-swap="outerHTML"> @* Replace with the edit form *@
                <i data-feather="edit-2" class="w-3 h-3 mr-1"></i> Edit
            </button>
        </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-1 text-sm px-2">
        <span><strong>Rank:</strong> @(Model.Rank ?? "N/A")</span>
        <span><strong>Force Number:</strong> @Model.ForceNumber</span>
        <span><strong>First Name:</strong> @Model.FirstName</span>
        <span><strong>Last Name:</strong> @Model.LastName</span>
        <span><strong>Date of Birth:</strong> @(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "N/A")</span>
        <span><strong>Gender:</strong> @(Model.Gender ?? "N/A")</span>
        <span class="md:col-span-2"><strong>Unit:</strong> @(Model.Unit ?? "N/A")</span>
    </div>
</div>
<script>if(typeof feather !== 'undefined') feather.replace();</script>