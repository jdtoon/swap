@{
    Layout = null; // This partial is loaded into #main-content
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">All Patients</h1>
    <p class="text-gray-500">View and manage all patient records.</p>
</div>

<!-- Container for the patient list and pagination - loaded via HTMX -->
<div id="patient-list-container" class="mt-2"
     hx-get="@Url.Action("AllPatients", "Patient")"
     hx-trigger="load once, refreshPatientList from:body"
     hx-swap="innerHTML">
    <div class="flex justify-center items-center p-10 card bg-base-100 shadow">
        <span class="loading loading-lg loading-spinner table-loading-indicator"></span>
        <p class="ml-2">Loading patient list...</p>
    </div>
</div>

<script>
    // Ensure Feather Icons are rendered
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>