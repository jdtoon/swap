@using carestream.core.dtos.patient
@model CreatePatientInputDto
@{
    Layout = null; // This is a partial view, loaded into #main-content or a modal
}

<div id="register-patient-form-container">
    <div class="mb-6">
        <h1 class="text-2xl font-semibold text-gray-700">Register New Patient</h1>
        <p class="text-gray-500">Enter the patient's demographic and contact details to create a new record.</p>
    </div>

    @* Display general model errors from ModelState *@
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty] != null && ViewData!.ModelState[string.Empty]!.Errors.Any())
    {
        <div class="alert alert-error shadow-lg mb-4">
            <div>
                <i data-feather="alert-circle" class="w-6 h-6 mr-2"></i>
                <span>@ViewData!.ModelState[string.Empty]!.Errors.First().ErrorMessage</span>
            </div>
        </div>
    }

    <form hx-post="@Url.Action("RegisterNewPatient", "Patient")"
          hx-target="#register-patient-form-container"
          hx-swap="innerHTML"
          hx-indicator="#register-patient-indicator">

        @Html.AntiForgeryToken()

        <div class="card bg-base-100 shadow-xl">
            <div class="card-body">
                <h2 class="card-title text-lg mb-4">Patient Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="form-control">
                        <label asp-for="ForceNumber" class="label"><span class="label-text">Force Number <span class="text-error">*</span></span></label>
                        <input asp-for="ForceNumber" type="text" placeholder="e.g., 12345678" class="input input-bordered" required />
                        <span asp-validation-for="ForceNumber" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="Rank" class="label"><span class="label-text">Rank <span class="text-error">*</span></span></label>
                        <input asp-for="Rank" type="text" placeholder="e.g., Pte" class="input input-bordered" required />
                        <span asp-validation-for="Rank" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="FirstName" class="label"><span class="label-text">First Name <span class="text-error">*</span></span></label>
                        <input asp-for="FirstName" type="text" placeholder="e.g., John" class="input input-bordered" required />
                        <span asp-validation-for="FirstName" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="LastName" class="label"><span class="label-text">Last Name <span class="text-error">*</span></span></label>
                        <input asp-for="LastName" type="text" placeholder="e.g., Doe" class="input input-bordered" required />
                        <span asp-validation-for="LastName" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="DateOfBirth" class="label"><span class="label-text">Date of Birth</span></label>
                        <input asp-for="DateOfBirth" type="date" class="input input-bordered" />
                        <span asp-validation-for="DateOfBirth" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="Gender" class="label"><span class="label-text">Gender</span></label>
                        <input asp-for="Gender" type="text" placeholder="e.g., Male" class="input input-bordered" />
                        <span asp-validation-for="Gender" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control md:col-span-2">
                        <label asp-for="Unit" class="label"><span class="label-text">Unit</span></label>
                        <input asp-for="Unit" type="text" placeholder="e.g., 1st Infantry Division" class="input input-bordered" />
                        <span asp-validation-for="Unit" class="text-error text-xs mt-1"></span>
                    </div>
                </div>

                <div class="divider my-6"></div>

                <h2 class="card-title text-lg mb-4">Contact Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="form-control">
                        <label asp-for="EmailAddress" class="label"><span class="label-text">Email Address</span></label>
                        <input asp-for="EmailAddress" type="email" placeholder="e.g., patient@example.com" class="input input-bordered" />
                        <span asp-validation-for="EmailAddress" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="PrimaryPhoneNumber" class="label"><span class="label-text">Primary Phone Number</span></label>
                        <input asp-for="PrimaryPhoneNumber" type="tel" placeholder="e.g., +27821234567" class="input input-bordered" />
                        <span asp-validation-for="PrimaryPhoneNumber" class="text-error text-xs mt-1"></span>
                    </div>
                </div>

                <div class="divider my-6"></div>

                <h2 class="card-title text-lg mb-4">Emergency Contact</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="form-control">
                        <label asp-for="EmergencyContactName" class="label"><span class="label-text">Name</span></label>
                        <input asp-for="EmergencyContactName" type="text" placeholder="e.g., Jane Doe" class="input input-bordered" />
                        <span asp-validation-for="EmergencyContactName" class="text-error text-xs mt-1"></span>
                    </div>
                    <div class="form-control">
                        <label asp-for="EmergencyContactPhone" class="label"><span class="label-text">Phone Number</span></label>
                        <input asp-for="EmergencyContactPhone" type="tel" placeholder="e.g., +27821234568" class="input input-bordered" />
                        <span asp-validation-for="EmergencyContactPhone" class="text-error text-xs mt-1"></span>
                    </div>
                </div>

                <div class="card-actions justify-end mt-8">
                    <button type="button" class="btn btn-ghost"
                            hx-get="@Url.Action("AllPatients", "Patient")"
                            hx-target="#main-content"
                            hx-swap="innerHTML transition:true"
                            hx-push-url="true">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        Register Patient
                        <span id="register-patient-indicator" class="htmx-indicator loading loading-spinner loading-sm ml-2"></span>
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>