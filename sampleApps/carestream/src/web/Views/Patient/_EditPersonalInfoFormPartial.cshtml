@using carestream.core.dtos.patient
@model EditPatientPersonalInfoDto
@{
    Layout = null;
}

<div id="personal-info-edit-area-@Model.PatientId" class="p-2 border border-accent rounded-md bg-base-100/50">
    <h4 class="font-semibold text-accent mb-2">Edit Personal Information</h4>
    <form hx-post="@Url.Action("UpdatePersonalInfo", "Patient")"
          hx-target="#personal-info-edit-area-@Model.PatientId" @* Target the display area for replacement on success *@
          hx-swap="outerHTML" @* Replace the whole display area *@
          hx-indicator="#personal-info-save-indicator-@Model.PatientId">

        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PatientId" />
        <input type="hidden" asp-for="ForceNumber" /> @* Keep ForceNumber, but it's not edited *@

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-warning alert-sm p-2 text-xs mb-3">
                <ul class="list-disc list-inside">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }


        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-2 text-sm">
            <div class="form-control">
                <label asp-for="ForceNumber" class="label pb-0"><span class="label-text">Force Number</span></label>
                <input type="text" asp-for="ForceNumber" class="input input-sm input-bordered" readonly />
            </div>
            <div class="form-control">
                <label asp-for="Rank" class="label pb-0"><span class="label-text">Rank</span></label>
                <input type="text" asp-for="Rank" class="input input-sm input-bordered" />
                <span asp-validation-for="Rank" class="text-error text-xs"></span>
            </div>
            <div class="form-control">
                <label asp-for="FirstName" class="label pb-0"><span class="label-text">First Name</span></label>
                <input type="text" asp-for="FirstName" class="input input-sm input-bordered" />
                <span asp-validation-for="FirstName" class="text-error text-xs"></span>
            </div>
            <div class="form-control">
                <label asp-for="LastName" class="label pb-0"><span class="label-text">Last Name</span></label>
                <input type="text" asp-for="LastName" class="input input-sm input-bordered" />
                <span asp-validation-for="LastName" class="text-error text-xs"></span>
            </div>
            <div class="form-control">
                <label asp-for="DateOfBirth" class="label pb-0"><span class="label-text">Date of Birth</span></label>
                <input type="date" asp-for="DateOfBirth" class="input input-sm input-bordered" />
                <span asp-validation-for="DateOfBirth" class="text-error text-xs"></span>
            </div>
            <div class="form-control">
                <label asp-for="Gender" class="label pb-0"><span class="label-text">Gender</span></label>
                <input type="text" asp-for="Gender" class="input input-sm input-bordered" />
                <span asp-validation-for="Gender" class="text-error text-xs"></span>
            </div>
            <div class="form-control md:col-span-2">
                <label asp-for="Unit" class="label pb-0"><span class="label-text">Unit</span></label>
                <input type="text" asp-for="Unit" class="input input-sm input-bordered" />
                <span asp-validation-for="Unit" class="text-error text-xs"></span>
            </div>
        </div>
        <div class="mt-4 flex justify-end gap-2">
            <button type="button" class="btn btn-sm btn-ghost"
                    hx-get="@Url.Action("PersonalDisplayPartial", "Patient", new { patientId = Model.PatientId })" @* Action to get display view *@
                    hx-target="#personal-info-edit-area-@Model.PatientId" @* Replace this form area with display *@
                    hx-swap="outerHTML">
                Cancel
            </button>
            <button type="submit" class="btn btn-sm btn-primary">
                Save Changes
                <span id="personal-info-save-indicator-@Model.PatientId" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
            </button>
        </div>
    </form>
</div>