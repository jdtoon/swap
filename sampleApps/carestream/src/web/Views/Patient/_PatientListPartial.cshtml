@using carestream.core.dtos.patient
@using carestream.core.dtos.shared
@model PatientListViewModel
@{
    Layout = null;
}

<div id="patient-list-container">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
                <h2 class="card-title">
                    <i data-feather="users" class="mr-2"></i>Patient Records
                </h2>
                <!-- Search Form -->
                <form id="patient-list-filter-form"
                      hx-get="@Url.Action("AllPatients", "Patient")"
                      hx-target="#patient-list-container"
                      hx-swap="innerHTML"
                      class="join">
                    <input type="search" name="SearchTerm1" value="@Model.Filters.SearchTerm1" placeholder="Search by name or force no." class="input input-sm input-bordered join-item" />
                    <input type="hidden" name="pageNumber" value="1" />
                    <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                    <button type="submit" class="btn btn-sm btn-primary join-item">
                        <i data-feather="search" class="w-4 h-4"></i>
                    </button>
                </form>
                <!-- New Patient Button -->
                <button class="btn btn-sm btn-success"
                        hx-get="@Url.Action("RegisterNewPatientForm", "Patient")"
                        hx-target="#main-content"
                        hx-swap="innerHTML transition:true"
                        hx-push-url="true">
                    <i data-feather="plus" class="w-4 h-4 mr-1"></i> Register New Patient
                </button>
            </div>

            @if (Model.Patients.Any())
            {
                <div class="overflow-x-auto">
                    <table class="table table-sm table-zebra w-full">
                        <thead>
                            <tr>
                                <th>Patient ID</th>
                                <th>Force No.</th>
                                <th>Full Name</th>
                                <th>Rank</th>
                                <th>Gender</th>
                                <th>Age</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model.Patients)
                            {
                                <tr>
                                    <td>@patient.PatientId</td>
                                    <td>@patient.ForceNumber</td>
                                    <td class="font-bold">@patient.FullName</td>
                                    <td>@(patient.Rank ?? "N/A")</td>
                                    <td>@(patient.Gender ?? "N/A")</td>
                                    <td>@(patient.DateOfBirth.HasValue ? (DateTime.Today.Year - patient.DateOfBirth.Value.Year).ToString() : "N/A")</td>
                                    <td>
                                        <button class="btn btn-xs btn-outline btn-info"
                                                hx-post="@Url.Action("LookupPatient", "SickReport", new { forceNumber = patient.ForceNumber, showActions = false })"
                                                hx-target="#view-patient-detail-screen"
                                                hx-swap="innerHTML transition:true"
                                                hx-push-url="true">
                                            View Details
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pagination Controls -->
                var routeValues = new Dictionary<string, string>();
                if (!string.IsNullOrWhiteSpace(Model.Filters.SearchTerm1)) { routeValues["SearchTerm1"] = Model.Filters.SearchTerm1; }
                <partial name="_PaginationControls" model="Model.Pagination"
                         view-data='new ViewDataDictionary(ViewData) { { "AdditionalRouteValues", routeValues } }' />
            }
            else
            {
                <p class="text-center py-4">No patients found @(!string.IsNullOrEmpty(Model.Filters.SearchTerm1) ? "matching your search." : "in the system.")</p>
            }
        </div>
    </div>
</div>

<div id="view-patient-detail-screen"></div>

<script>
    if (typeof feather !== 'undefined') { feather.replace(); }
    document.body.addEventListener('refreshPatientList', function(evt) {
        const url = new URL('@Url.Action("AllPatients", "Patient")', window.location.origin);
        url.searchParams.set('pageNumber', @(Model.Pagination?.CurrentPage ?? 1));
        url.searchParams.set('pageSize', @(Model.Pagination?.PageSize ?? 25));
        if ('@Model.Filters.SearchTerm1' !== '') { // Use JS logic for string comparison
            url.searchParams.set('SearchTerm1', '@Model.Filters.SearchTerm1');
        }

        htmx.ajax('GET', url.toString(), {
            target: '#patient-list-container',
            swap: 'innerHTML'
        });
    });
</script>