@using carestream.core.dtos.consultation
@model IEnumerable<Icd10CodeDto>
@{
    Layout = null;
}

@if (Model != null && Model.Any())
{
    <ul class="menu menu-sm bg-base-100 p-0">
        @foreach (var icd in Model)
        {
            <li>
                <button type="button"
                        class="w-full text-left justify-start rounded-md hover:bg-base-200 focus:bg-primary focus:text-primary-content icd10-select-btn"
                        data-id="@icd.Icd10CodeId"
                        data-code="@icd.Code"
                        data-description="@icd.Description"
                        _="on click call addIcd10Tag(my.dataset.id as Number, my.dataset.code, my.dataset.description)">
                    <span class="font-medium">@icd.Code</span>
                    <span class="text-xs text-base-content text-opacity-60">@icd.Description</span>
                </button>
            </li>
        }
    </ul>
}
else
{
    <p class="p-2 text-xs text-center text-base-content text-opacity-60">No ICD-10 codes found matching your search. Try a different term.</p>
}