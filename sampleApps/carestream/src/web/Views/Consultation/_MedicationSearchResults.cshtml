@using carestream.core.dtos.medication
@model IEnumerable<MedicationSearchResultDto>
@{
    Layout = null;
    var visitId = ViewData["VisitId"];
    var patientId = ViewData["PatientId"];
}

@if (Model != null && Model.Any())
{
    <ul class="menu menu-sm bg-base-100 p-0">
        @foreach (var med in Model)
        {
            <li>
                <button type="button"
                        class="w-full text-left justify-start rounded-md hover:bg-base-200 focus:bg-primary focus:text-primary-content"
                        _="on click trigger populatemedicationform(medicationId: @med.MedicationId, medicationName: '@med.DisplayName', visitId: @visitId, patientId: @patientId)">
                    <span class="font-medium">@med.DisplayName</span>
                    @if (!string.IsNullOrEmpty(med.Strength) || !string.IsNullOrEmpty(med.Form))
                    {
                        <span class="text-xs text-base-content text-opacity-60">
                        </span>
                    }
                </button>
            </li>
        }
    </ul>
}
else
{
    <p class="p-2 text-xs text-center text-base-content text-opacity-60">No medications found matching your search. Try a different term.</p>
}