@using carestream.core.dtos.consultation
@model ConsultationMedicationsViewModel
@{
    Layout = null;
}

<div id="medications-tab-content-wrapper">
    <h3 class="text-lg font-semibold mb-4">Prescribe Medications</h3>

    @* Section for Medication Search and Add Form *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        @* Medication Search Column *@
        <div>
            <h4 class="font-medium mb-2">1. Search Medication</h4>
            <form id="medication-search-form"
                  hx-post="@Url.Action("SearchMedications", "Consultation")"
                  hx-trigger="keyup changed delay:300ms, search"
                  hx-target="#medication-search-results-container"
                  hx-swap="innerHTML"
                  hx-indicator="#tab-load-indicator">

                <input type="hidden" name="visitId" value="@Model.VisitId" />
                <input type="hidden" name="patientId" value="@Model.PatientId" />

                <div class="form-control">
                    <input type="search"
                           name="searchTerm"
                           class="input input-bordered w-full"
                           placeholder="Search by name or category..."
                           value="@Model.MedicationSearchTerm" />
                </div>
            </form>
            <div id="medication-search-results-container" class="mt-2 max-h-60 overflow-y-auto border rounded-md border-base-300 p-1">
                <p class="p-2 text-xs text-base-content text-opacity-60">Enter at least 2 characters to search.</p>
            </div>
        </div>

        @* Add Prescription Item Form Column *@
        <div id="add-prescription-item-form-container">
            <partial name="_AddPrescriptionItemFormPartial" model="Model.NewPrescriptionItem" />
        </div>
    </div>


    <div class="divider"></div>

    @* Section for Currently Added Prescription Items *@
    <h4 class="font-medium mb-2 text-lg">Current Prescription for this Visit</h4>
    <div id="current-prescription-items-list" class="mb-6">
        <partial name="_CurrentPrescriptionItems" model="Model.CurrentPrescriptionItems" />
    </div>


    <div class="flex justify-end items-center gap-2 mt-6">
        <div id="send-pharmacy-status" class="text-sm mr-auto"></div>
        <form hx-post="@Url.Action("SendPrescriptionToPharmacy", "Consultation")"
              hx-target="#medications-tab-content-wrapper"
              hx-swap="innerHTML"
              hx-confirm="Are you sure you want to finalize and send this prescription to pharmacy? This action cannot be undone."
              hx-indicator="#send-pharmacy-indicator">
            <input type="hidden" name="visitId" value="@Model.VisitId" />
            @Html.AntiForgeryToken()
            <button type="submit"
                    id="send-to-pharmacy-button"
                    class="btn btn-primary"
                    @if (Model.CurrentPrescriptionItems == null || !Model.CurrentPrescriptionItems.Any())
                    {
                        <text>disabled</text>
                    }>
                Send to Pharmacy
                <span id="send-pharmacy-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
            </button>
        </form>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }

    // Listener for when a medication is selected from search results
    document.body.addEventListener('populatemedicationform', function (evt) {
        const detail = evt.detail;
        if (detail) {

            const formContainer = document.getElementById('add-prescription-item-form-container');
            if (formContainer) {
                const medicationIdInput = formContainer.querySelector('input[name="MedicationId"]');
                const selectedMedNameDisplay = formContainer.querySelector('#selected-medication-name');
                const dosageInput = formContainer.querySelector('input[name="Dosage"]');
                const formFieldsWrapper = formContainer.querySelector('.p-3.border.rounded-md');
                const addButton = formContainer.querySelector('button[type="submit"]');

                if (medicationIdInput) {
                    medicationIdInput.value = detail.medicationId;
                }
                if (selectedMedNameDisplay) {
                    selectedMedNameDisplay.textContent = detail.medicationName;
                }

                // Enable the form and button
                if (formFieldsWrapper) {
                    formFieldsWrapper.classList.remove('opacity-50', 'pointer-events-none');
                }
                if (addButton) {
                    addButton.removeAttribute('disabled');
                }

                // Focus on the first input field for convenience
                if (dosageInput) {
                    dosageInput.focus();
                }

                // Clear search results and search input
                const searchResultsContainer = document.getElementById('medication-search-results-container');
                if (searchResultsContainer) {
                    searchResultsContainer.innerHTML = '<p class="p-2 text-xs text-base-content text-opacity-60">Enter at least 2 characters to search.</p>';
                }
                const searchInput = document.getElementById('medication-search-form')?.querySelector('input[name="searchTerm"]');
                if (searchInput) {
                    searchInput.value = '';
                }
            }
        }
    });

    // Listener for clearing the add prescription form after successful addition
    document.body.addEventListener('clear-add-prescription-form', function() {
        const form = document.getElementById('add-prescription-item-form');
        if (form) {
            // Explicitly clear each input field
            form.querySelector('input[name="MedicationId"]').value = '';
            form.querySelector('input[name="Dosage"]').value = '';
            form.querySelector('input[name="Frequency"]').value = '';
            form.querySelector('input[name="Duration"]').value = '';
            form.querySelector('input[name="QuantityPrescribed"]').value = '';
            form.querySelector('textarea[name="SpecialInstructions"]').value = '';


            // Clear the selected medication display and re-disable fields
            const selectedMedNameDisplay = form.querySelector('#selected-medication-name');
            const formFieldsWrapper = form.querySelector('.p-3.border.rounded-md');
            const addButton = form.querySelector('button[type="submit"]');

            if (selectedMedNameDisplay) selectedMedNameDisplay.textContent = 'Select medication from search';

            if (formFieldsWrapper) {
                formFieldsWrapper.classList.add('opacity-50', 'pointer-events-none');
            }
            if (addButton) {
                addButton.setAttribute('disabled', 'true');
            }
        }
    });

    document.body.addEventListener('prescription-items-updated', function (evt) {
        const hasNoItems = evt.detail.hasNoItems;

        const sendToPharmacyButton = document.getElementById('send-to-pharmacy-button'); // USE DIRECT ID
        if (sendToPharmacyButton) {
            if (hasNoItems === true) {
                sendToPharmacyButton.removeAttribute('disabled');
            } else {
                sendToPharmacyButton.setAttribute('disabled', 'true');
            }
        }
    });

    // Initial check on DOMContentLoaded
    document.addEventListener('DOMContentLoaded', function() {
        const currentItemsList = document.getElementById('current-prescription-items-list');
        const hasItemsInitially = currentItemsList && currentItemsList.querySelector('table tbody tr') !== null;
        const sendToPharmacyButton = document.getElementById('send-to-pharmacy-button'); // USE DIRECT ID

        if (sendToPharmacyButton) {
            if (!hasItemsInitially) {
                sendToPharmacyButton.setAttribute('disabled', 'true');
            } else {
                sendToPharmacyButton.removeAttribute('disabled');
            }
        }
    });

</script>