@using carestream.core.dtos.consultation
@model ConsultationViewModel
@{
    Layout = null;
}

@if (Model == null)
{
    <div class="alert alert-info">
        <i data-feather="info" class="w-6 h-6 mr-2"></i>
        <span>No vital signs were recorded for this visit, or they could not be retrieved.</span>
    </div>
}
else
{
    <div class="flex justify-between items-center mb-3">
        <h3 class="text-lg font-semibold">
            Vital Signs
            <span class="text-sm font-normal text-base-content text-opacity-70">(Recorded: @Model.VitalsData!.RecordedAt?.ToLocalTime().ToString("g") by @(Model.VitalsData.RecordedByUserName ?? "N/A"))</span>
        </h3>
    </div>


    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-3 mb-4 text-sm">
        <div><strong>BP:</strong> <span class="font-medium">@Model.VitalsData!.BloodPressureDisplay</span></div>
        <div><strong>Heart Rate:</strong> <span class="font-medium">@Model.VitalsData!.HeartRateDisplay</span></div>
        <div><strong>Temp:</strong> <span class="font-medium">@Model.VitalsData!.TemperatureDisplay</span></div>
        <div><strong>Resp. Rate:</strong> <span class="font-medium">@Model.VitalsData!.RespiratoryRateDisplay</span></div>
        <div><strong>SpO2:</strong> <span class="font-medium">@Model.VitalsData!.OxygenSaturationDisplay</span></div>
        <div><strong>Pain Level:</strong> <span class="font-medium">@Model.VitalsData!.PainLevelDisplay</span></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisColor) || !string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisClarity) || Model.VitalsData!.UrinalysisSpecificGravity.HasValue || Model.VitalsData!.UrinalysisPh.HasValue || !string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisProtein) || !string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisGlucose))
    {
        <h4 class="font-semibold mt-4 mb-2 text-md">Urinalysis:</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-3 mb-4 text-sm">
            @if (!string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisColor))
            {
                <div><strong>Color:</strong> <span class="font-medium">@Model.VitalsData!.UrinalysisColor</span></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisClarity))
            {
                <div><strong>Clarity:</strong> <span class="font-medium">@Model.VitalsData!.UrinalysisClarity</span></div>
            }
            @if (Model.VitalsData!.UrinalysisSpecificGravity.HasValue)
            {
                <div><strong>SG:</strong> <span class="font-medium">@Model.VitalsData!.UrinalysisSpecificGravity</span></div>
            }
            @if (Model.VitalsData!.UrinalysisPh.HasValue)
            {
                <div><strong>pH:</strong> <span class="font-medium">@Model.VitalsData!.UrinalysisPh</span></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisProtein))
            {
                <div><strong>Protein:</strong> <span class="font-medium">@Model.VitalsData!.UrinalysisProtein</span></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.VitalsData!.UrinalysisGlucose))
            {
                <div><strong>Glucose:</strong> <span class="font-medium">@Model.VitalsData!.UrinalysisGlucose</span></div>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.VitalsData!.ClinicalNotesFromVitals))
    {
        <h4 class="font-semibold mt-4 mb-2 text-md">Nurse's Clinical Notes:</h4>
        <div class="text-sm bg-base-200 p-3 rounded-md prose prose-sm max-w-none">@Model.VitalsData!.ClinicalNotesFromVitals</div>
    }

    <div class="mt-4 space-x-2">
        @if (Model.VitalsData!.RequiresFollowUp)
        {
            <span class="badge badge-lg badge-outline badge-warning"><i data-feather="alert-triangle" class="w-3 h-3 mr-1"></i>Requires Follow-up</span>
        }
        @if (Model.VitalsData!.MarkAsUrgent)
        {
            <span class="badge badge-lg badge-outline badge-error"><i data-feather="zap" class="w-3 h-3 mr-1"></i>Marked as Urgent by Nurse</span>
        }
    </div>

    <div class="divider my-6"></div>

    @* ICD-10 Diagnosis Section (FR-DN-010) *@
    <div id="icd10-diagnosis-section" class="mb-6">
        <h4 class="font-semibold text-md mb-2">ICD-10 Diagnosis</h4>
        <div class="form-control mb-2">
            <div class="join w-full">
                <input type="search"
                       id="icd10-search-input"
                       name="searchTerm"
                       placeholder="Search ICD-10 codes by code or description..."
                       class="input input-bordered input-sm join-item w-full"
                       hx-get="@Url.Action("SearchIcd10Codes", "Consultation")"
                       hx-trigger="keyup changed delay:300ms, search"
                       hx-target="#icd10-search-results"
                       hx-swap="innerHTML"
                       hx-indicator="#icd10-search-indicator" />
                <button type="button" class="btn btn-sm btn-ghost join-item icd10-clear-search"
                        hx-indicator="#icd10-search-indicator">
                    <i data-feather="x-circle" class="w-4 h-4"></i>
                </button>
            </div>
            <span id="icd10-search-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
        </div>
        <div id="icd10-search-results" class="mb-4 max-h-48 overflow-y-auto border rounded-md border-base-300 p-1">
            <!-- Search results will load here -->
            <p class="p-2 text-xs text-base-content text-opacity-60">Start typing to search ICD-10 codes.</p>
        </div>

        <div id="selected-icd10-tags-container" class="mb-4 flex flex-wrap gap-2">
            <!-- Selected ICD-10 codes will appear here as tags/chips -->
            @if (Model.SavedIcd10Codes != null)
            {
                foreach (var icdCode in Model.SavedIcd10Codes)
                {
                    <div class="badge badge-outline badge-primary flex items-center gap-1" data-id="@icdCode.Icd10CodeId">
                        <span>@icdCode.Code - @(icdCode.Description.Length > 50 ? icdCode.Description.Substring(0, 50) + "..." : icdCode.Description)</span>
                        <button type="button" class="btn btn-xs btn-ghost btn-circle"
                                onclick="removeIcd10Tag(@icdCode.Icd10CodeId)">
                            <i data-feather="x" class="w-3 h-3"></i>
                        </button>
                    </div>
                }
            }
        </div>

        <form id="save-diagnosis-form"
              hx-post="@Url.Action("SaveDiagnosis", "Consultation")"
              hx-target="this"
              hx-swap="none"
              hx-indicator="#save-diagnosis-indicator">
            @Html.AntiForgeryToken()
            <input type="hidden" name="visitId" value="@Model.PatientBanner.VisitId" />
            <input type="hidden" name="patientId" value="@Model.PatientBanner.PatientId" />
            <!-- Hidden input to hold comma-separated ICD-10 IDs -->
            <input type="hidden" id="selectedIcd10Ids" name="icd10CodeIds"
                   value="@(string.Join(",", Model.SavedIcd10Codes!.Select(c => c.Icd10CodeId)))" />
            <div class="flex justify-end">
                <button type="submit" class="btn btn-sm btn-primary">
                    Save Diagnosis
                    <span id="save-diagnosis-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
                </button>
            </div>
        </form>
    </div>

    <div class="divider my-6"></div>

    @* Procedures Section (FR-DN-011) *@
    <div id="procedures-section" class="mb-6">
        <h4 class="font-semibold text-md mb-2">Procedures</h4>
        <div class="form-control mb-2">
            <div class="join w-full">
                <input type="search"
                       id="procedure-search-input"
                       name="searchTerm"
                       placeholder="Search procedures by code or name..."
                       class="input input-bordered input-sm join-item w-full"
                       hx-get="@Url.Action("SearchProcedures", "Consultation")"
                       hx-trigger="keyup changed delay:300ms, search"
                       hx-target="#procedure-search-results"
                       hx-swap="innerHTML"
                       hx-indicator="#procedure-search-indicator" />
                <button type="button" class="btn btn-sm btn-ghost join-item procedure-clear-search"
                        hx-indicator="#procedure-search-indicator">
                    <i data-feather="x-circle" class="w-4 h-4"></i>
                </button>
            </div>
            <span id="procedure-search-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
        </div>
        <div id="procedure-search-results" class="mb-4 max-h-48 overflow-y-auto border rounded-md border-base-300 p-1">
            <!-- Search results will load here -->
            <p class="p-2 text-xs text-base-content text-opacity-60">Start typing to search procedures.</p>
        </div>

        <div id="selected-procedures-tags-container" class="mb-4 flex flex-wrap gap-2">
            <!-- Selected procedures will appear here as tags/chips -->
            @if (Model.SavedProcedures != null)
            {
                foreach (var procedure in Model.SavedProcedures)
                {
                    <div class="badge badge-outline badge-accent flex items-center gap-1" data-id="@procedure.ProcedureId">
                        <span>@procedure.Code - @(procedure.Name.Length > 50 ? procedure.Name.Substring(0, 50) + "..." : procedure.Name)</span>
                        <button type="button" class="btn btn-xs btn-ghost btn-circle"
                                onclick="removeProcedureTag(@procedure.ProcedureId)">
                            <i data-feather="x" class="w-3 h-3"></i>
                        </button>
                    </div>
                }
            }
        </div>

        <form id="save-procedures-form"
              hx-post="@Url.Action("SaveProcedures", "Consultation")"
              hx-target="this"
              hx-swap="none"
              hx-indicator="#save-procedures-indicator">
            @Html.AntiForgeryToken()
            <input type="hidden" name="visitId" value="@Model.PatientBanner.VisitId" />
            <input type="hidden" name="patientId" value="@Model.PatientBanner.PatientId" />
            <!-- Hidden input to hold comma-separated Procedure IDs -->
            <input type="hidden" id="selectedProcedureIds" name="procedureIds"
                   value="@(string.Join(",", Model.SavedProcedures!.Select(p => p.ProcedureId)))" />
            <div class="flex justify-end">
                <button type="submit" class="btn btn-sm btn-primary">
                    Save Procedures
                    <span id="save-procedures-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
                </button>
            </div>
        </form>
    </div>

    <div class="divider my-6"></div>

    @* Doctor's Notes Section (FR-DN-012) *@
    <div id="doctor-notes-section" class="mt-6">
        <h4 class="font-semibold text-md mb-2">Doctor's Consultation Notes</h4>
        <form hx-post="@Url.Action("SaveDoctorNotes", "Consultation")"
              hx-target="#doctor-notes-status"
              hx-swap="innerHTML"
              hx-indicator="#notes-save-indicator">

            <input type="hidden" name="visitId" value="@Model.PatientBanner.VisitId" />
            <textarea name="doctorNotes"
                      class="textarea textarea-bordered w-full h-32"
                      placeholder="Enter consultation notes, findings, and assessment plan here...">@Model.DoctorNotes</textarea>

            <div class="mt-2 flex items-center justify-end">
                <div id="doctor-notes-status" class="mr-2"></div>
                <button type="submit" class="btn btn-sm btn-primary">
                    Save Notes
                    <span id="notes-save-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
                </button>
            </div>
        </form>
    </div>
}

<script>
    // This is called once on initial load for all feather icons
    if (typeof feather !== 'undefined') {
        feather.replace();
    }

    // The addIcd10Tag and addProcedureTag functions only need to be adjusted
    // to not clear the search input/results when they are called from Razor directly
    // (which we are no longer doing for initial load, but it's good practice
    // to keep them resilient to being called in other contexts where a search input isn't relevant).
    // The previous version already had this logic with the `if (icd10SearchInput && icd10SearchInput.value !== '')` check.

    function addIcd10Tag(id, code, description) {
        const container = document.getElementById('selected-icd10-tags-container');
        const hiddenInput = document.getElementById('selectedIcd10Ids');
        let selectedIds = hiddenInput.value ? hiddenInput.value.split(',').map(Number) : [];

        // Ensure we don't add duplicates (important for programmatic additions)
        if (!selectedIds.includes(id)) {
            selectedIds.push(id);
            hiddenInput.value = selectedIds.join(',');

            const tagDiv = document.createElement('div');
            tagDiv.className = 'badge badge-outline badge-primary flex items-center gap-1';
            tagDiv.dataset.id = id;

            const span = document.createElement('span');
            span.textContent = `${code} - ${description.substring(0, 50)}${description.length > 50 ? '...' : ''}`;
            tagDiv.appendChild(span);

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-xs btn-ghost btn-circle';
            // Attach event listener directly
            button.addEventListener('click', () => removeIcd10Tag(id));

            const icon = document.createElement('i');
            icon.dataset.feather = 'x';
            icon.className = 'w-3 h-3';
            button.appendChild(icon);

            tagDiv.appendChild(button);
            container.appendChild(tagDiv);

            // Feather replace for the newly added icon
            if (typeof feather !== 'undefined') {
                feather.replace();
            }

            // Only clear search input and results if the call originated from a search selection
            // This is handled by the HTMX swap for search results, but the JavaScript part
            // of `addIcd10Tag` would typically clear the input if it was called directly from a search result click.
            // Since the search results HTML itself often contains the call, it becomes less critical here.
            // However, keeping the defensive check is still good.
            const icd10SearchInput = document.getElementById('icd10-search-input');
            const icd10SearchResults = document.getElementById('icd10-search-results');
            if (icd10SearchInput && icd10SearchResults && icd10SearchInput.value.trim() !== '') {
                icd10SearchInput.value = '';
                icd10SearchResults.innerHTML = '<p class="p-2 text-xs text-base-content text-opacity-60">Start typing to search ICD-10 codes.</p>';
            }
        }
    }

    function removeIcd10Tag(id) {
        const hiddenInput = document.getElementById('selectedIcd10Ids');
        let selectedIds = hiddenInput.value.split(',').map(Number);

        selectedIds = selectedIds.filter(item => item !== id);
        hiddenInput.value = selectedIds.join(',');

        const tagToRemove = document.getElementById('selected-icd10-tags-container').querySelector(`div[data-id='${id}']`);
        if (tagToRemove) {
            tagToRemove.remove();
        }
    }

    function addProcedureTag(id, code, name) {
        const container = document.getElementById('selected-procedures-tags-container');
        const hiddenInput = document.getElementById('selectedProcedureIds');
        let selectedIds = hiddenInput.value ? hiddenInput.value.split(',').map(Number) : [];

        // Ensure we don't add duplicates (important for programmatic additions)
        if (!selectedIds.includes(id)) {
            selectedIds.push(id);
            hiddenInput.value = selectedIds.join(',');

            const tagDiv = document.createElement('div');
            tagDiv.className = 'badge badge-outline badge-accent flex items-center gap-1';
            tagDiv.dataset.id = id;

            const span = document.createElement('span');
            span.textContent = `${code} - ${name.substring(0, 50)}${name.length > 50 ? '...' : ''}`;
            tagDiv.appendChild(span);

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-xs btn-ghost btn-circle';
            button.addEventListener('click', () => removeProcedureTag(id));

            const icon = document.createElement('i');
            icon.dataset.feather = 'x';
            icon.className = 'w-3 h-3';
            button.appendChild(icon);

            tagDiv.appendChild(button);
            container.appendChild(tagDiv);

            if (typeof feather !== 'undefined') {
                feather.replace();
            }

            const procedureSearchInput = document.getElementById('procedure-search-input');
            const procedureSearchResults = document.getElementById('procedure-search-results');
            if (procedureSearchInput && procedureSearchResults && procedureSearchInput.value.trim() !== '') {
                procedureSearchInput.value = '';
                procedureSearchResults.innerHTML = '<p class="p-2 text-xs text-base-content text-opacity-60">Start typing to search procedures.</p>';
            }
        }
    }

    function removeProcedureTag(id) {
        const hiddenInput = document.getElementById('selectedProcedureIds');
        let selectedIds = hiddenInput.value.split(',').map(Number);

        selectedIds = selectedIds.filter(item => item !== id);
        hiddenInput.value = selectedIds.join(',');

        const tagToRemove = document.getElementById('selected-procedures-tags-container').querySelector(`div[data-id='${id}']`);
        if (tagToRemove) {
            tagToRemove.remove();
        }
    }

    // --- Event Listeners for Clear Search Buttons (replaces _ attributes) ---
    document.addEventListener('DOMContentLoaded', () => {
        const icd10ClearButton = document.querySelector('.icd10-clear-search');
        if (icd10ClearButton) {
            icd10ClearButton.addEventListener('click', () => {
                const input = document.getElementById('icd10-search-input');
                input.value = '';
                if (window.htmx) {
                    htmx.trigger(input, 'search');
                }
            });
        }

        const procedureClearButton = document.querySelector('.procedure-clear-search');
        if (procedureClearButton) {
            procedureClearButton.addEventListener('click', () => {
                const input = document.getElementById('procedure-search-input');
                input.value = '';
                if (window.htmx) {
                    htmx.trigger(input, 'search');
                }
            });
        }

        // Feather replace on DOMContentLoaded is good for all static icons in the HTML
        // No need for the loop that called feather.replace() inside the loop.
        // It's called once at the top of the script.
    });

</script>