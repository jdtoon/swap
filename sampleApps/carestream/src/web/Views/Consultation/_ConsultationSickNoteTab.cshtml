@using carestream.core.dtos.consultation
@model SickNoteInputDto
@{
    Layout = null;
    var patientId = ViewData["PatientId"] as int? ?? 0; // Get patientId from ViewData passed by controller
    var isExistingNote = Model.SickNoteId.HasValue && Model.SickNoteId.Value > 0;
}

<div id="sick-note-form-container">
    @* HTMX will target this for form re-render on error/success *@
    <form hx-post="@Url.Action("SaveSickNote", "Consultation")"
          hx-target="#sick-note-form-container"
          hx-swap="outerHTML"
          hx-indicator="#sicknote-save-indicator">

        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="VisitId" />
        @if (isExistingNote)
        {
            <input type="hidden" asp-for="SickNoteId" />
        }

        <div class="space-y-4">
            <div class="prose prose-sm max-w-none mb-3">
                <h4>Issue Medical Certificate (Sick Note)</h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label asp-for="StartDate" class="label pb-1"><span class="label-text">Start Date</span></label>
                    <input type="date" asp-for="StartDate" class="input input-bordered input-sm" />
                    <span asp-validation-for="StartDate" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="EndDate" class="label pb-1"><span class="label-text">End Date</span></label>
                    <input type="date" asp-for="EndDate" class="input input-bordered input-sm" />
                    <span asp-validation-for="EndDate" class="text-error text-xs mt-1"></span>
                </div>
            </div>

            <div class="form-control">
                <label asp-for="Diagnosis" class="label pb-1"><span class="label-text">Diagnosis</span></label>
                <textarea asp-for="Diagnosis" class="textarea textarea-bordered h-24" placeholder="Enter diagnosis stated on the sick note..."></textarea>
                <span asp-validation-for="Diagnosis" class="text-error text-xs mt-1"></span>
            </div>

            <div class="form-control">
                <label asp-for="Recommendations" class="label pb-1"><span class="label-text">Recommendations / Fitness for Duty</span></label>
                <textarea asp-for="Recommendations" class="textarea textarea-bordered h-32" placeholder="Enter any recommendations, fitness for duty notes, or restrictions..."></textarea>
                <span asp-validation-for="Recommendations" class="text-error text-xs mt-1"></span>
            </div>

            @if (isExistingNote && Model.IssuedAt.HasValue)
            {
                <div class="text-xs text-base-content text-opacity-70 mt-2 p-2 bg-base-200 rounded-md">
                    Last @(Model.SickNoteId.HasValue && Model.SickNoteId > 0 && Model.IssuedByUserName != null ? "updated" : "issued")
                    @if (!string.IsNullOrEmpty(Model.IssuedByUserName))
                    {
                        <text>by <strong>@Model.IssuedByUserName</strong></text>
                    }
                    on @Model.IssuedAt.Value.ToLocalTime().ToString("f")
                </div>
            }

            <div id="sicknote-status-message" class="my-2">
                @* This div can be targeted by HX-Trigger from server for inline status messages,
                   or client-side JS can populate it based on toast events.
                   The controller currently returns the whole form partial on save.
                *@
            </div>


            <div class="flex flex-wrap justify-between items-center gap-2 mt-4">
                <div>
                    @if (isExistingNote && (Model.StartDate.HasValue || !string.IsNullOrWhiteSpace(Model.Diagnosis)))
                    {
                        <button type="button" class="btn btn-xs btn-outline" disabled>
                            <i data-feather="printer" class="w-3 h-3 mr-1"></i> Print
                        </button>
                        <button type="button" class="btn btn-xs btn-outline" disabled>
                            <i data-feather="mail" class="w-3 h-3 mr-1"></i> Email
                        </button>
                    }
                </div>
                <button type="submit" class="btn btn-sm btn-primary">
                    <i data-feather="save" class="w-4 h-4 mr-1"></i>
                    @(isExistingNote ? "Update Sick Note" : "Issue Sick Note")
                    <span id="sicknote-save-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-2"></span>
                </button>
            </div>
        </div>
    </form>
</div>