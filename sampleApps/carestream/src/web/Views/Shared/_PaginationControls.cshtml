@using carestream.core.dtos.shared
@model PaginationDto
@{
    Layout = null;
    // Determine number of page links to show
    int PagingLinkRadius = 2; // Show CurrentPage +/- 2 links, plus first/last if far
    int StartPage = Math.Max(1, Model.CurrentPage - PagingLinkRadius);
    int EndPage = Math.Min(Model.TotalPages, Model.CurrentPage + PagingLinkRadius);

    // Adjust start/end if they are too close to the boundaries
    if (Model.CurrentPage - StartPage < PagingLinkRadius)
    {
        EndPage = Math.Min(Model.TotalPages, EndPage + (PagingLinkRadius - (Model.CurrentPage - StartPage)));
    }
    if (EndPage - Model.CurrentPage < PagingLinkRadius)
    {
        StartPage = Math.Max(1, StartPage - (PagingLinkRadius - (EndPage - Model.CurrentPage)));
    }
}

@if (Model.TotalPages > 1)
{
    <div class="flex flex-col sm:flex-row justify-between items-center mt-4 text-sm gap-2">
        <div class="text-base-content text-opacity-70">
            Page @Model.CurrentPage of @Model.TotalPages (Total Items: @Model.TotalItems)
        </div>

        <div class="join">
            @if (Model.HasPreviousPage)
            {
                <button class="join-item btn btn-sm btn-outline"
                        hx-get="@Model.HxGetUrl"
                        hx-vals='{"pageNumber": @(Model.CurrentPage - 1), "pageSize": @Model.PageSize}' @* Add other filter hx-vals if needed *@
                        hx-target="@Model.HxTarget"
                        hx-swap="@Model.HxSwap"
                        hx-indicator=".table-loading-indicator">
                    @* Generic indicator class *@
                    « Prev
                </button>
            }
            else
            {
                <button class="join-item btn btn-sm btn-outline" disabled>« Prev</button>
            }

            @if (StartPage > 1)
            {
                <button class="join-item btn btn-sm btn-outline"
                        hx-get="@Model.HxGetUrl"
                        hx-vals='{"pageNumber": 1, "pageSize": @Model.PageSize}'
                        hx-target="@Model.HxTarget" hx-swap="@Model.HxSwap" hx-indicator=".table-loading-indicator">
                    1
                </button>
                @if (StartPage > 2)
                {
                    <button class="join-item btn btn-sm btn-disabled">...</button>
                }
            }

            @for (int i = StartPage; i <= EndPage; i++)
            {
                <button class="join-item btn btn-sm @(i == Model.CurrentPage ? "btn-primary" : "btn-outline")"
                        hx-get="@Model.HxGetUrl"
                        hx-vals='{"pageNumber": @i, "pageSize": @Model.PageSize}'
                        hx-target="@Model.HxTarget" hx-swap="@Model.HxSwap" hx-indicator=".table-loading-indicator"
                        disabled="@(i == Model.CurrentPage)">
                    @i
                </button>
            }

            @if (EndPage < Model.TotalPages)
            {
                @if (EndPage < Model.TotalPages - 1)
                {
                    <button class="join-item btn btn-sm btn-disabled">...</button>
                }
                <button class="join-item btn btn-sm btn-outline"
                        hx-get="@Model.HxGetUrl"
                        hx-vals='{"pageNumber": @Model.TotalPages, "pageSize": @Model.PageSize}'
                        hx-target="@Model.HxTarget" hx-swap="@Model.HxSwap" hx-indicator=".table-loading-indicator">
                    @Model.TotalPages
                </button>
            }

            @if (Model.HasNextPage)
            {
                <button class="join-item btn btn-sm btn-outline"
                        hx-get="@Model.HxGetUrl"
                        hx-vals='{"pageNumber": @(Model.CurrentPage + 1), "pageSize": @Model.PageSize}'
                        hx-target="@Model.HxTarget" hx-swap="@Model.HxSwap" hx-indicator=".table-loading-indicator">
                    Next »
                </button>
            }
            else
            {
                <button class="join-item btn btn-sm btn-outline" disabled>Next »</button>
            }
        </div>

        @* Items per page selector (optional) *@
        <div class="hidden sm:flex items-center">
            <span class="mr-2 text-base-content text-opacity-70">Items per page:</span>
            <select class="select select-sm select-bordered"
                    name="pageSize"
                    hx-get="@Model.HxGetUrl" @* Base URL with filters *@
                    hx-target="@Model.HxTarget"
                    hx-swap="@Model.HxSwap"
                    hx-vals='{"pageNumber": 1}' @* This will be merged with query params from HxGetUrl *@
                    hx-trigger="change"
                    hx-indicator=".table-loading-indicator">
                @foreach (var size in new[] { 10, 25, 50, 100 })
                {
                    <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                }
            </select>
        </div>
    </div>
}