@using System.Security.Claims;
<!DOCTYPE html>
<html lang="en" data-theme="carestream">
<head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex">
    <meta name="googlebot" content="noindex">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
    <title>CareStream</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="~/lib/toastify-js/toastify.min.css" asp-append-version="true">
    @await RenderSectionAsync("HeadContent", required: false)
</head>
<body class="bg-base-200" hx-boost="true" hx-swap="innerHTML transition:true">

    <div class="drawer lg:drawer-open">
        <input id="sidebar-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col min-h-screen">
            <header class="navbar bg-base-100 shadow-md sticky top-0 z-30">
                <div class="flex-none lg:hidden">
                    <label for="sidebar-drawer" aria-label="open sidebar" class="btn btn-square btn-ghost">
                        <i data-feather="menu" class="inline-block w-6 h-6 stroke-current"></i>
                    </label>
                </div>
                <div class="flex-1 px-2 mx-2 font-bold text-lg">
                </div>
                <div class="flex-none gap-2">

                    @* All header right-side items are now in one flex container to align them *@
                    <div class="flex items-center space-x-2">

                        <div _="on click from <button/> in me toggle .dropdown-open on me end on click from document remove .dropdown-open from me unless me contains event.target or event.target is me end on click from <ul/> in me if event.target.tagName is 'A' remove .dropdown-open from me"
                             class="dropdown dropdown-end">
                            <button tabindex="0" role="button" class="btn btn-ghost btn-circle">
                                <div class="indicator">
                                    <i data-feather="bell" class="h-5 w-5"></i>
                                    <span class="badge badge-xs badge-primary indicator-item">3</span>
                                </div>
                            </button>
                            <ul tabindex="0"
                                class="mt-3 z-[20] p-2 shadow menu menu-sm dropdown-content bg-base-100 rounded-box w-72 origin-top-right">
                                <li class="menu-title"><span>Notifications</span></li>
                                <li><a>Notification 1</a></li>
                                <li><a>Notification 2</a></li>
                                <li class="mt-2 border-t border-base-300"><a class="text-center">View All</a></li>
                            </ul>
                        </div>

                        @* Facility Selector - INTEGRATION POINT *@
                        <div id="facility-selector-root"
                             hx-get="@Url.Action("GetFacilitySelectorPartial", "FacilitySelection")"
                             hx-trigger="load once"
                             hx-swap="innerHTML">
                            <span class="badge badge-info">Loading Facility...</span>
                        </div>

                        <div _="on click from <button/> in me toggle .dropdown-open on me end on click from document remove .dropdown-open from me unless me contains event.target or event.target is me end on click from <ul/> in me if event.target.tagName is 'A' remove .dropdown-open from me"
                             class="dropdown dropdown-end">
                            <button tabindex="0" role="button" class="btn btn-ghost flex items-center px-2">
                                <div class="avatar placeholder">
                                    <div class="bg-neutral text-neutral-content rounded-full w-8 h-8 flex items-center justify-center">
                                        <span class="text-xs">@(User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")</span>
                                    </div>
                                </div>
                                <div class="text-left text-sm hidden md:block">
                                    <div>@(User.FindFirst("name")?.Value ?? User.Identity?.Name)</div>
                                    <div class="text-xs opacity-70">@(User.FindFirst(ClaimTypes.Role)?.Value ?? "User Role")</div>
                                </div>
                            </button>
                            <ul tabindex="0"
                                class="mt-3 z-[20] p-2 shadow menu menu-sm dropdown-content bg-base-100 rounded-box w-52 origin-top-right">
                                <li>
                                    <a hx-get="/Profile/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true">
                                        <i data-feather="user" class="w-4 h-4"></i> Profile
                                    </a>
                                </li>
                                <li>
                                    <a hx-get="/Settings/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true">
                                        <i data-feather="settings" class="w-4 h-4"></i> Settings
                                    </a>
                                </li>
                                <li class="mt-1 border-t border-base-300">
                                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutFormHeader" class="w-full" hx-boost="false">
                                        <button type="submit" class="flex items-center w-full text-left text-error p-2 rounded">
                                            <i data-feather="log-out" class="w-4 h-4"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </header>

            <main class="flex-grow p-4 lg:p-6">
                <div id="main-content">
                    @RenderBody()
                </div>
            </main>

        </div>
        <aside class="drawer-side z-40">
            <label for="sidebar-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
            <nav class="menu p-4 w-60 lg:w-64 min-h-full bg-primary text-primary-content border-r border-primary-300">
                <div class="flex-1 px-2 mx-2 font-bold text-lg" style="display: flex; align-items: center;">
                    <img src="/images/samhs-logo.png" alt="SAMHS Logo" class="h-8 w-8 mr-2">
                    Care Stream
                </div>

                @if (User.IsInRole("PatientAdmin"))
                {
                    <li class="menu-title text-primary-content"><span>Patient Admin</span></li>
                    <li><a hx-get="/Dashboard/PatientAdminDashboard" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="grid" class="w-5 h-5"></i> Dashboard</a></li>
                    <li><a hx-get="/SickReport/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="clipboard" class="w-5 h-5"></i> Sick Report</a></li>
                    <li>
                        <a hx-get="@Url.Action("Index", "EmergencyContact")"
                           hx-target="#main-content"
                           hx-swap="innerHTML transition:true"
                           hx-push-url="true"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "EmergencyContact" ? "active" : "")">
                            <i data-feather="alert-octagon" class="w-5 h-5"></i>
                            Emergency Contact
                        </a>
                    </li>
                    <li>
                        <a hx-get="@Url.Action("AllPatients", "Patient")"
                           hx-target="#main-content"
                           hx-swap="innerHTML transition:true"
                           hx-push-url="true"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" && ViewContext.RouteData.Values["action"]?.ToString() == "AllPatients" ? "active" : "")">
                            <i data-feather="users" class="w-5 h-5"></i> Patients
                        </a>
                    </li>
                    <li><a hx-get="/StaffReports/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="file-text" class="w-5 h-5"></i> Staff Reports</a></li>
                    <li><a hx-get="/Messages/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="message-square" class="w-5 h-5"></i> Messages</a></li>
                    <li><a hx-get="/Reports/GenerateDD50" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="printer" class="w-5 h-5"></i> Print DD 50</a></li>
                    @* <li><a hx-get="/Analytics/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="bar-chart-2" class="w-5 h-5"></i> Analytics</a></li> *@
                }
                @if (User.IsInRole("Nurse"))
                {
                    <li class="menu-title text-primary-content"><span>Nurse</span></li>
                    <li><a hx-get="/Dashboard/NurseDashboard" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="activity" class="w-5 h-5"></i> Dashboard / Vitals</a></li>
                    <li>
                        <a hx-get="@Url.Action("Index", "EmergencyContact")"
                           hx-target="#main-content"
                           hx-swap="innerHTML transition:true"
                           hx-push-url="true"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "EmergencyContact" ? "active" : "")">
                            <i data-feather="alert-octagon" class="w-5 h-5"></i> Emergency Contact
                        </a>
                    </li>
                    <li><a hx-get="/StaffReports/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="file-text" class="w-5 h-5"></i> Staff Reports</a></li>
                    <li><a hx-get="/Messages/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="message-square" class="w-5 h-5"></i> Messages</a></li>
                }
                @if (User.IsInRole("Doctor"))
                {
                    <li class="menu-title text-primary-content"><span>Doctor</span></li>
                    <li><a hx-get="/Dashboard/DoctorDashboard" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="user-check" class="w-5 h-5"></i> Dashboard / Queue</a></li>
                    <li><a hx-get="/StaffReports/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="file-text" class="w-5 h-5"></i> Staff Reports</a></li>
                    <li><a hx-get="/Messages/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="message-square" class="w-5 h-5"></i> Messages</a></li>
                    <li><a hx-get="/Reports/GenerateDD50" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="printer" class="w-5 h-5"></i> Print DD 50</a></li>
                }
                @if (User.IsInRole("Pharmacist"))
                {
                    <li class="menu-title text-primary-content"><span>Pharmacy</span></li>
                    <li><a hx-get="/Dashboard/PharmacistDashboard" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="shopping-bag" class="w-5 h-5"></i> Dashboard</a></li>
                    <li><a hx-get="/Pharmacy/Inventory" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="archive" class="w-5 h-5"></i> Inventory</a></li>
                    <li>
                        <a hx-get="@Url.Action("AllPatients", "Patient")"
                           hx-target="#main-content"
                           hx-swap="innerHTML transition:true"
                           hx-push-url="true"
                           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" && ViewContext.RouteData.Values["action"]?.ToString() == "AllPatients" ? "active" : "")">
                            <i data-feather="users" class="w-5 h-5"></i> Patients
                        </a>
                    </li>
                    <li><a hx-get="/Messages/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="message-square" class="w-5 h-5"></i> Messages</a></li>
                    <li>
                        <a hx-get="@Url.Action("DispensedHistory", "Pharmacy")" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true">
                            <i data-feather="archive" class="w-5 h-5"></i> Dispensed History
                        </a>
                    </li>
                }
                @if (User.IsInRole("SystemAdmin"))
                {
                    <li class="menu-title text-primary-content"><span>Administration</span></li>
                    <li>
                        <a hx-get="@Url.Action("Index", "Admin")" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true">
                            <i data-feather="shield" class="w-5 h-5"></i> Admin Panel
                        </a>
                    </li>
                }

                <div class="flex-grow"></div>
                <li><a hx-get="/Settings/Index" hx-target="#main-content" hx-swap="innerHTML transition:true" hx-push-url="true"><i data-feather="settings" class="w-5 h-5"></i> Settings</a></li>

                <li class="menu-title text-primary-content"><span>Access</span></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutFormSidebar" class="w-full" hx-boost="false">
                        <button type="submit" class="flex items-center w-full text-left rounded">
                            <i data-feather="log-out" class="w-5 h-5 mr-2"></i> Logout
                        </button>
                    </form>
                </li>
            </nav>
        </aside>
    </div>

    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true"></script>
    <script src="~/lib/hyperscript/_hyperscript.min.js" defer asp-append-version="true"></script>
    <script src="~/lib/feather-icons/feather.min.js" asp-append-version="true"></script>
    <script src="~/lib/toastify-js/toastify.min.js" asp-append-version="true"></script>

    <script>
        // Initial call for icons present on full page load
        document.addEventListener('DOMContentLoaded', function () {
            feather.replace({
                width: '1em', // Default width for icons if not overridden by class
                height: '1em' // Default height
            });

            function displayToast(detailObject, defaultType) {
                let message = 'An operation completed.';
                let type = defaultType || 'info';

                if (typeof detailObject === 'string') { // HX-Trigger: eventName (no detail value)
                    message = detailObject; // Or set a default message based on eventName
                } else if (typeof detailObject === 'object' && detailObject !== null) {
                    // Try to find a message within the object, e.g., from {"showToastSuccess": "My Message"}
                    // The key of the first property in detail can be the message if it's a string
                    const keys = Object.keys(detailObject);
                    if (keys.length > 0 && typeof detailObject[keys[0]] === 'string') {
                        message = detailObject[keys[0]];
                    } else if (detailObject.message) { // Or if there's a 'message' property
                        message = detailObject.message;
                    } else if (detailObject.value) { // Or if there's a 'value' property
                         message = detailObject.value;
                    }
                }

                let backgroundColor = "#2196F3"; // Info blue (default)
                if (type === 'success') backgroundColor = "#4CAF50";
                else if (type === 'error') backgroundColor = "#F44336";
                else if (type === 'warning') backgroundColor = "#FF9800";

                Toastify({
                    text: message,
                    duration: 3500,
                    close: true,
                    gravity: "top",
                    position: "right",
                    stopOnFocus: true,
                    style: { background: backgroundColor, },
                    onClick: function () { }
                }).showToast();
            }

            document.body.addEventListener('showToastSuccess', function (evt) {
                displayToast(evt.detail, 'success');
            });

            document.body.addEventListener('showToastError', function (evt) {
                displayToast(evt.detail, 'error');
            });

            document.body.addEventListener('showToastWarning', function (evt) {
                displayToast(evt.detail, 'warning');
            });

            document.body.addEventListener('showToastInfo', function (evt) {
                displayToast(evt.detail, 'info');
            });

            // Universal modal close handler (for admin_generic_modal)
            document.body.addEventListener('closeAdminGenericModal', function() {
                const modal = document.getElementById('admin_generic_modal');
                if (modal && typeof modal.close === 'function') {
                    modal.close();
                }
            });
        });

        // Re-initialize Feather Icons after HTMX swaps new content into the DOM
        document.body.addEventListener('htmx:afterSwap', function (event) {
            if (event.detail.target) {
                 feather.replace({
                     width: '1em', // Default width for icons if not overridden by class
                     height: '1em' // Default height
                 });
            } else {
                 feather.replace({ width: '1em', height: '1em' });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>