@using carestream.core.dtos.consultation
@model CreateUpdateVisitAssessmentDto
@{
    Layout = null; // Loaded into a tab/main content area
    // PatientId and VisitId are passed in the DTO for POST, but also for context
    int patientId = Model.PatientId; // From DTO
    int visitId = Model.VisitId;     // From DTO
    string title = Model.VisitAssessmentId > 0 ? "Edit Visit Assessment" : "Create New Visit Assessment";
}

<div id="visit-assessment-form-container">
    <div class="card-body">
        <h2 class="card-title text-lg mb-4">@title</h2>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any(k => ViewData.ModelState[k]?.Errors?.Any() == true))
        {
            <div class="alert alert-warning text-xs p-2 mb-3">
                <ul class="list-disc list-inside">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form hx-post="@Url.Action("SaveAssessment", "VisitAssessment")"
              hx-target="#visit-assessment-form-container" @* Target the parent container to swap in the updated form *@
              hx-swap="innerHTML"
              hx-indicator="#assessment-save-indicator">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="VisitAssessmentId" />
            <input type="hidden" asp-for="VisitId" />
            <input type="hidden" asp-for="PatientId" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div class="form-control md:col-span-2">
                    <label asp-for="PhysicalExamFindings" class="label"><span class="label-text">Physical Examination Findings</span></label>
                    <textarea asp-for="PhysicalExamFindings" class="textarea textarea-bordered h-24" placeholder="Document general and specific physical examination findings..."></textarea>
                    <span asp-validation-for="PhysicalExamFindings" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="CardiovascularNotes" class="label"><span class="label-text">Cardiovascular Notes</span></label>
                    <textarea asp-for="CardiovascularNotes" class="textarea textarea-bordered h-20" placeholder="e.g., HR regular, no murmurs..."></textarea>
                    <span asp-validation-for="CardiovascularNotes" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="RespiratoryNotes" class="label"><span class="label-text">Respiratory Notes</span></label>
                    <textarea asp-for="RespiratoryNotes" class="textarea textarea-bordered h-20" placeholder="e.g., Clear lungs, no cough..."></textarea>
                    <span asp-validation-for="RespiratoryNotes" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="MusculoskeletalNotes" class="label"><span class="label-text">Musculoskeletal Notes</span></label>
                    <textarea asp-for="MusculoskeletalNotes" class="textarea textarea-bordered h-20" placeholder="e.g., Full ROM, no joint pain..."></textarea>
                    <span asp-validation-for="MusculoskeletalNotes" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="NeurologicalNotes" class="label"><span class="label-text">Neurological Notes</span></label>
                    <textarea asp-for="NeurologicalNotes" class="textarea textarea-bordered h-20" placeholder="e.g., Alert and oriented x3..."></textarea>
                    <span asp-validation-for="NeurologicalNotes" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="PsychologicalNotes" class="label"><span class="label-text">Psychological Notes</span></label>
                    <textarea asp-for="PsychologicalNotes" class="textarea textarea-bordered h-20" placeholder="e.g., Appears calm, cooperative..."></textarea>
                    <span asp-validation-for="PsychologicalNotes" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="OtherSystemsNotes" class="label"><span class="label-text">Other Systems Notes</span></label>
                    <textarea asp-for="OtherSystemsNotes" class="textarea textarea-bordered h-20" placeholder="Any other relevant system notes..."></textarea>
                    <span asp-validation-for="OtherSystemsNotes" class="text-error text-xs mt-1"></span>
                </div>
            </div>

            <div class="divider my-6"></div>

            <h2 class="card-title text-lg mb-4">Medical Classification & Deployment</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                    <label asp-for="MedicalClassification" class="label"><span class="label-text">Medical Classification</span></label>
                    <input asp-for="MedicalClassification" type="text" placeholder="e.g., P2, S1, A1" class="input input-bordered" />
                    <span asp-validation-for="MedicalClassification" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="DeploymentStatus" class="label"><span class="label-text">Deployment Status</span></label>
                    <input asp-for="DeploymentStatus" type="text" placeholder="e.g., Fit, Unfit" class="input input-bordered" />
                    <span asp-validation-for="DeploymentStatus" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="ValidityPeriodMonths" class="label"><span class="label-text">Validity Period (Months)</span></label>
                    <input asp-for="ValidityPeriodMonths" type="number" min="0" placeholder="e.g., 12" class="input input-bordered" />
                    <span asp-validation-for="ValidityPeriodMonths" class="text-error text-xs mt-1"></span>
                </div>
                <div class="form-control">
                    <label asp-for="Restrictions" class="label"><span class="label-text">Restrictions</span></label>
                    <textarea asp-for="Restrictions" class="textarea textarea-bordered h-20" placeholder="e.g., No heavy lifting, Light duty only..."></textarea>
                    <span asp-validation-for="Restrictions" class="text-error text-xs mt-1"></span>
                </div>
            </div>

            <div class="card-actions justify-end mt-8">
                <button type="button" class="btn btn-ghost"
                        hx-get="@Url.Action("VitalsTab", "Consultation", new { visitId = Model.VisitId, patientId = Model.PatientId })"
                        hx-target="#consultation-tab-content"
                        hx-swap="innerHTML transition:true"
                        hx-push-url="false">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">
                    Save Assessment
                    <span id="assessment-save-indicator" class="htmx-indicator loading loading-spinner loading-sm ml-2"></span>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>