@{
    Layout = null;
    int visitId = ViewData["VisitId"] as int? ?? 0;
    int patientId = ViewData["PatientId"] as int? ?? 0;
}

<div class="mb-4">
    <h3 class="text-lg font-semibold">Visit Assessment</h3>
</div>

<div id="visit-assessment-form-container" class="card bg-base-100 shadow-xl"
     hx-get="@Url.Action("Index", "VisitAssessment", new { visitId = visitId, patientId = patientId })"
     hx-trigger="load once" @* Only load once, as the form handles its own re-rendering/updates *@
     hx-swap="innerHTML">
    <div class="card-body">
        <div class="flex justify-center items-center p-10">
            <span class="loading loading-lg loading-spinner"></span>
            <p class="ml-2">Loading assessment form...</p>
        </div>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>