@using carestream.core.dtos.pharmacy
@model ViewPrescriptionViewModel
@{
    Layout = null; // This is a partial view
}

<div class="mb-4">
    <button class="btn btn-sm btn-ghost mb-2"
            hx-get="@Url.Action("PharmacistDashboard", "Dashboard")"
            hx-target="#main-content"
            hx-swap="innerHTML"
            hx-push-url="true">
        @* Push URL back to dashboard *@
        <i data-feather="arrow-left" class="w-4 h-4 mr-1"></i> Back to Dashboard
    </button>
    <h1 class="text-2xl font-semibold text-gray-700">Prescription Details - @Model.Header.PrescriptionIdentifier</h1>
</div>

@* Prescription Header Info (FR-PH-005) *@
<div class="card bg-base-100 shadow-md mb-6">
    <div class="card-body p-4">
        <h2 class="card-title text-lg">Patient & Prescriber Information</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm mt-2">
            <div>
                <p><strong>Patient:</strong> @Model.Header.PatientName (@(Model.Header.PatientRank ?? "N/A"))</p>
                <p><strong>Force No:</strong> @(Model.Header.PatientForceNumber ?? "N/A") | <strong>Age:</strong> @(Model.Header.PatientAge?.ToString() ?? "N/A")</p>
                <p><strong>Visit ID:</strong> @Model.Header.VisitId | <strong>Patient ID:</strong> @Model.Header.PatientId</p>
            </div>
            <div>
                <p><strong>Prescriber:</strong> @Model.Header.PrescriberName (@(Model.Header.PrescriberRank ?? "N/A"))</p>
                <p><strong>Department:</strong> @(Model.Header.PrescriberDepartment ?? "N/A")</p>
                <p><strong>Prescription Date:</strong> @Model.Header.PrescriptionDate.ToLocalTime().ToString("f")</p>
            </div>
        </div>
    </div>
</div>

@* Prescribed Items List (FR-PH-005) *@
<div class="card bg-base-100 shadow-xl">
    <div class="card-body">
        <div class="flex justify-between items-center mb-4">
            <h2 class="card-title">
                <i data-feather="package" class="mr-2"></i>Prescribed Medications
            </h2>
            @* Placeholder for any actions like "Print Prescription Label" *@
        </div>

        @if (Model.Items != null && Model.Items.Any())
        {
            <div class="overflow-x-auto">
                <table class="table table-zebra table-sm w-full">
                    <thead>
                        <tr>
                            <th>Medication</th>
                            <th>Dosage</th>
                            <th>Frequency</th>
                            <th>Duration</th>
                            <th>Qty Prescribed</th>
                            <th>Instructions</th>
                            @* Add columns for Stock, Dispense Qty later *@
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="font-medium">@item.MedicationName</td>
                                <td>@item.Dosage</td>
                                <td>@item.Frequency</td>
                                <td>@(item.Duration ?? "-")</td>
                                <td>@item.QuantityPrescribed</td>
                                <td>@(item.SpecialInstructions ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-8">
                <i data-feather="alert-circle" class="w-12 h-12 mx-auto text-gray-400"></i>
                <p class="mt-2 text-gray-500">No medication items found for this prescription.</p>
            </div>
        }

        @* Placeholder for Dispensing Actions (FR-PH-006) *@
        <div class="card-actions justify-end mt-6">
            <button class="btn btn-primary"
                    hx-get="@Url.Action("StartDispensing", "Pharmacy", new { visitId = Model.Header.VisitId })"
                    hx-target="#main-content" @* Target to load the dispense form *@
                    hx-swap="innerHTML transition:true"
                    hx-push-url="true">
                @* Push URL to dispensing state *@
                <i data-feather="play-circle" class="w-4 h-4 mr-1"></i> Start Dispensing Process
            </button>
        </div>
    </div>
</div>
