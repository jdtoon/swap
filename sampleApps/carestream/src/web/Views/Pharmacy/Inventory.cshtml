@{
    Layout = null; // This partial is loaded into #main-content
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Medication Inventory</h1>
    <p class="text-gray-500">View and manage medication stock levels.</p>
</div>

<!-- Container for the inventory list and pagination - loaded via HTMX -->
<div id="inventory-list-container" class="mt-2"
     hx-get="@Url.Action("InventoryListPartial", "Pharmacy")"
     hx-trigger="load once, refreshInventoryList from:body"
     hx-swap="innerHTML">
    <div class="flex justify-center items-center p-10 card bg-base-100 shadow">
        <span class="loading loading-lg loading-spinner table-loading-indicator"></span>
        <p class="ml-2">Loading inventory...</p>
    </div>
</div>

<dialog id="admin_generic_modal" class="modal">
    <div id="admin_generic_modal_content" class="modal-box w-11/12 max-w-lg">
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<script>
    // No specific JS needed here. Feather icons will be replaced by _Layout.
</script>