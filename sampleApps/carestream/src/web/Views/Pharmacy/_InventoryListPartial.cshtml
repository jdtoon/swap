@using carestream.core.dtos.medication
@using carestream.core.dtos.shared
@model MedicationInventoryViewModel
@{
    Layout = null;
}

<div class="card bg-base-100 shadow-xl">
    <div class="card-body">
        <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
            <h2 class="card-title">
                <i data-feather="archive" class="mr-2"></i>Current Stock Levels
            </h2>
            <div class="flex items-center gap-2">
                <!-- Low Stock Items Count -->
                @if (Model.LowStockItemsCount > 0)
                {
                    <span class="badge badge-error badge-lg">
                        <i data-feather="alert-triangle" class="w-4 h-4 mr-1"></i> @Model.LowStockItemsCount low stock items
                    </span>
                }
                <!-- Search Form -->
                <form id="inventory-filter-form"
                      hx-get="@Url.Action("InventoryListPartial", "Pharmacy")"
                      hx-target="#inventory-list-container"
                      hx-swap="innerHTML"
                      class="join">
                    <input type="search" name="SearchTerm1" value="@Model.Filters.SearchTerm1" placeholder="Search medication..." class="input input-sm input-bordered join-item" />
                    <input type="hidden" name="pageNumber" value="1" /> <!-- Reset to page 1 on new filter -->
                    <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                    <button type="submit" class="btn btn-sm btn-primary join-item">
                        <i data-feather="search" class="w-4 h-4"></i>
                    </button>
                </form>
            </div>
        </div>

        @if (Model.InventoryItems.Any())
        {
            <div class="overflow-x-auto">
                <table class="table table-sm table-zebra w-full">
                    <thead>
                        <tr>
                            <th>Medication Name</th>
                            <th>Strength / Form</th>
                            <th>Category</th>
                            <th>Current Stock</th>
                            <th>Min Level</th>
                            <th>Status</th>
                            <th>Last Updated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.InventoryItems)
                        {
                            <tr>
                                <td class="font-bold">@item.Name</td>
                                <td>@(item.Strength ?? "-") @(item.Form != null ? $" / {item.Form}" : "")</td>
                                <td>@(item.Category ?? "-")</td>
                                <td>@item.QuantityOnHand</td>
                                <td>@item.MinimumStockLevel</td>
                                <td>
                                    @{
                                        string stockBadgeClass = item.StockStatus.ToLower() switch
                                        {
                                            "in stock" => "badge-success",
                                            "low stock" => "badge-warning",
                                            "out of stock" => "badge-error",
                                            _ => "badge-neutral"
                                        };
                                    }
                                    <span class="badge @stockBadgeClass badge-sm">@item.StockStatus</span>
                                </td>
                                <td>@item.LastUpdatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    <button class="btn btn-xs btn-outline btn-info"
                                            hx-get="@Url.Action("AdjustStockModal", "Pharmacy", new { medicationId = item.MedicationId })"
                                            hx-target="#admin_generic_modal_content"
                                            hx-swap="innerHTML"
                                            onclick="admin_generic_modal.showModal()">
                                        Adjust Stock
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Pagination Controls -->
            var routeValues = new Dictionary<string, string>();
            if (!string.IsNullOrWhiteSpace(Model.Filters.SearchTerm1)) { routeValues["SearchTerm1"] = Model.Filters.SearchTerm1; }
            <partial name="_PaginationControls" model="Model.Pagination"
                     view-data='new ViewDataDictionary(ViewData) { { "AdditionalRouteValues", routeValues } }' />
        }
        else
        {
            <p class="text-center py-4">No medications found @(!string.IsNullOrEmpty(Model.Filters.SearchTerm1) ? "matching your search." : "in the inventory.")</p>
        }
    </div>
</div>
<script type="text/javascript">
    if (typeof feather !== 'undefined') { feather.replace(); }
    document.body.addEventListener('refreshInventoryList', function(evt) {
        const url = new URL('@Url.Action("InventoryListPartial", "Pharmacy")', window.location.origin);
        url.searchParams.set('pageNumber', @(Model.Pagination?.CurrentPage ?? 1));
        url.searchParams.set('pageSize', @(Model.Pagination?.PageSize ?? 25));
        if ('@Model.Filters.SearchTerm1' !== '') {
            url.searchParams.set('SearchTerm1', '@Model.Filters.SearchTerm1');
        }
        htmx.ajax('GET', url.toString(), {
            target: '#inventory-list-container',
            swap: 'innerHTML'
        });
    });
</script>