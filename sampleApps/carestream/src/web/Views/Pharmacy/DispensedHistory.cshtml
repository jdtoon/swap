@using carestream.core.dtos.pharmacy
@model DispensedHistoryViewModel
@{
    Layout = null; // This view is loaded into #main-content
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Dispensed Medication History</h1>
    <p class="text-gray-500">Review and search past dispensations.</p>
</div>

@* Filter Section *@
<form id="dispensed-history-filter-form"
      hx-get="@Url.Action("DispensedHistoryList", "Pharmacy")"
      hx-target="#dispensed-history-list-container"
      hx-swap="innerHTML"
      hx-indicator="#filter-indicator"
      class="card bg-base-100 shadow mb-6">
    <div class="card-body p-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
            <div class="form-control">
                <label class="label pb-1"><span class="label-text">Patient (Name/Force No.)</span></label>
                <input type="search" name="SearchTerm1" value="@Model.FilterPatientSearch" class="input input-sm input-bordered" placeholder="Patient search..." />
            </div>
            <div class="form-control">
                <label class="label pb-1"><span class="label-text">Medication</span></label>
                <input type="search" name="SearchTerm2" value="@Model.FilterMedicationSearch" class="input input-sm input-bordered" placeholder="Medication name..." />
            </div>
            <div class="form-control">
                <label class="label pb-1"><span class="label-text">Dispensed From</span></label>
                <input type="date" name="StartDate" value="@Model.FilterStartDate?.ToString("yyyy-MM-dd")" class="input input-sm input-bordered" />
            </div>
            <div class="form-control">
                <label class="label pb-1"><span class="label-text">Dispensed To</span></label>
                <input type="date" name="EndDate" value="@Model.FilterEndDate?.ToString("yyyy-MM-dd")" class="input input-sm input-bordered" />
            </div>
        </div>
        <div class="mt-4 flex justify-end items-center">
            <input type="hidden" name="pageNumber" value="1" /> @* Always go to page 1 on new filter submit *@
            <input type="hidden" name="pageSize" value="@(Model.PaginationInfo?.PageSize ?? 25)" /> @* Maintain current page size or default *@
            <button type="button" class="btn btn-xs btn-ghost mr-2" onclick="document.getElementById('dispensed-history-filter-form').reset(); htmx.trigger('#dispensed-history-filter-form', 'submit');">
                Clear Filters
            </button>
            <button type="submit" class="btn btn-sm btn-primary">
                <i data-feather="filter" class="w-4 h-4 mr-1"></i> Apply Filters
                <span id="filter-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
            </button>
        </div>
    </div>
</form>

@* Container for the list and pagination - loaded via HTMX *@
<div id="dispensed-history-list-container"
     hx-get="@Url.Action("DispensedHistoryList", "Pharmacy", new {
                SearchTerm1 = Model.FilterPatientSearch,
                SearchTerm2 = Model.FilterMedicationSearch,
                StartDate = Model.FilterStartDate,
                EndDate = Model.FilterEndDate,
                PageNumber = Model.PaginationInfo?.CurrentPage ?? 1,
                PageSize = Model.PaginationInfo?.PageSize ?? 25
            })"
     hx-trigger="load"
     hx-swap="innerHTML">
    <div class="flex justify-center items-center p-10 card bg-base-100 shadow">
        <span class="loading loading-lg loading-spinner table-loading-indicator"></span>
        <p class="ml-2">Loading dispensed history...</p>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>