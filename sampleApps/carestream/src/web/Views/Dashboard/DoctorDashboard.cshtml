@using carestream.core.dtos.doctor
@model DoctorDashboardViewModel
@{
    Layout = null; // This is a partial view

    // Helper function to calculate wait time string and get color class
    // (Could be moved to a shared location or view component later)
    (string waitTime, string colorClass) GetWaitTimeDisplay(DateTime readyTime)
    {
        var waitDuration = DateTime.UtcNow - readyTime;
        string timeString;
        if (waitDuration.TotalMinutes < 1) timeString = "< 1 min";
        else if (waitDuration.TotalHours >= 1) timeString = $"{(int)waitDuration.TotalHours}h {(int)waitDuration.Minutes}m";
        else timeString = $"{(int)waitDuration.TotalMinutes} min";

        string color = "text-success"; // Default: Green < 15 min for doctors
        if (waitDuration.TotalMinutes >= 30) color = "text-error";   // Red > 30 min
        else if (waitDuration.TotalMinutes >= 15) color = "text-warning"; // Orange 15-30 min

        return (timeString, color);
    }
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Doctor's Dashboard - Consultation Queue</h1>
    <p class="text-gray-500">View and manage patients ready for consultation.</p>
</div>

@* Stats Section (FR-DN-001 - partial implementation) *@
@if (Model?.Stats != null)
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-primary"><i data-feather="users" class="w-8 h-8"></i></div>
                <div class="stat-title">Waiting for Consultation</div>
                <div class="stat-value">@Model.Stats.TotalWaitingForDoctor</div>
            </div>
        </div>
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-error"><i data-feather="alert-triangle" class="w-8 h-8"></i></div>
                <div class="stat-title">Urgent Cases</div>
                <div class="stat-value text-error">@Model.Stats.UrgentCasesCount</div>
            </div>
        </div>
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-warning"><i data-feather="alert-octagon" class="w-8 h-8"></i></div>
                <div class="stat-title">High Priority Cases</div>
                <div class="stat-value text-warning">@Model.Stats.HighPriorityCasesCount</div>
            </div>
        </div>
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-info"><i data-feather="clock" class="w-8 h-8"></i></div>
                <div class="stat-title">Avg. Wait Time</div>
                <div class="stat-value text-info">@Model.Stats.AverageWaitTime</div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mb-6">
        <i data-feather="loader" class="animate-spin mr-2"></i>
        <span>Loading consultation stats...</span>
    </div>
}

@* --- My Active Consultations Section --- *@
@if (Model?.InProgressConsultations != null && Model.InProgressConsultations.Any())
{
    <div class="card bg-base-100 shadow-xl mb-6">
        <div class="card-body">
            <div class="flex justify-between items-center mb-4">
                <h2 class="card-title text-info">
                    <i data-feather="activity" class="w-6 h-6 mr-2"></i> @* Example: activity icon *@
                    My Active Consultations
                </h2>
            </div>
            <div class="overflow-x-auto">
                <table class="table table-zebra table-sm w-full">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Rank</th>
                            <th>Started / Wait Time</th>
                            <th>Priority</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.InProgressConsultations)
                        {
                            // Using ReadyForDoctorTimestamp for now, as it's what DoctorQueueItemDto has.
                            // Ideally, InProgressConsultations might have a "ConsultationStartTime" if different.
                            var (waitTimeDisplay, waitTimeColorClass) = GetWaitTimeDisplay(item.ReadyForDoctorTimestamp);
                            <tr>
                                <td>
                                    <div class="font-bold">@item.PatientName</div>
                                    <div class="text-xs opacity-70">Patient ID: @item.PatientId / Visit ID: @item.VisitId</div>
                                </td>
                                <td>@(item.Rank ?? "N/A")</td>
                                <td class="@waitTimeColorClass font-semibold">@waitTimeDisplay (In Progress)</td>
                                <td>
                                    <span class="badge @(item.Priority == "Urgent" ? "badge-error" : (item.Priority == "High" ? "badge-warning" : "badge-ghost")) badge-sm">
                                        @item.Priority
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-xs btn-info"
                                            hx-get="@Url.Action("StartConsultation", "Consultation", new { visitId = item.VisitId, patientId = item.PatientId })"
                                            hx-target="#main-content"
                                            hx-swap="innerHTML transition:true"
                                            hx-push-url="true">
                                        <i data-feather="arrow-right-circle" class="w-4 h-4 mr-1"></i> @* Example: arrow-right-circle *@
                                        Resume Consultation
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


@* Doctor's Patient Queue Table (Patients "Ready for Doctor") - FR-DN-002 *@
<div class="card bg-base-100 shadow-xl">
    <div class="card-body">
        <div class="flex justify-between items-center mb-4">
            <h2 class="card-title">
                <i data-feather="list" class="mr-2"></i>Patients Ready for Consultation
            </h2>
            <button class="btn btn-xs btn-ghost"
                    hx-get="@Url.Action("DoctorDashboard", "Dashboard")"
                    hx-target="#main-content"
                    hx-swap="innerHTML">
                <i data-feather="refresh-cw" class="w-4 h-4 mr-1"></i> Refresh
            </button>
        </div>

        @if (Model?.PatientQueue != null && Model.PatientQueue.Any())
        {
            <div class="overflow-x-auto">
                <table class="table table-zebra table-sm w-full">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Rank</th>
                            <th>Age</th>
                            <th>Gender</th>
                            <th>Wait Time</th>
                            <th>Priority</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PatientQueue)
                        {
                            var (waitTimeDisplay, waitTimeColorClass) = GetWaitTimeDisplay(item.ReadyForDoctorTimestamp);
                            <tr>
                                <td>
                                    <div class="font-bold">@item.PatientName</div>
                                    <div class="text-xs opacity-70">Patient ID: @item.PatientId / Visit ID: @item.VisitId</div>
                                </td>
                                <td>@(item.Rank ?? "N/A")</td>
                                <td>@(item.Age?.ToString() ?? "N/A")</td>
                                <td>@(item.Gender ?? "N/A")</td>
                                <td class="@waitTimeColorClass font-semibold">@waitTimeDisplay</td>
                                <td>
                                    <span class="badge @(item.Priority == "Urgent" ? "badge-error" : (item.Priority == "High" ? "badge-warning" : "badge-ghost")) badge-sm">
                                        @item.Priority
                                    </span>
                                </td>
                                <td>
                                    @* FR-DN-006: Button to select patient for consultation *@
                                    <button class="btn btn-xs btn-primary"
                                            hx-get="@Url.Action("StartConsultation", "Consultation", new { visitId = item.VisitId, patientId = item.PatientId })"
                                            hx-target="#main-content"
                                            hx-swap="innerHTML transition:true"
                                            hx-push-url="true">
                                        <i data-feather="play-circle" class="w-4 h-4 mr-1"></i> Start Consultation
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-8">
                <i data-feather="inbox" class="w-12 h-12 mx-auto text-gray-400"></i>
                <p class="mt-2 text-gray-500">No patients are currently waiting for consultation.</p>
            </div>
        }
    </div>
</div>