@using carestream.core.dtos.pharmacy
@model PharmacistDashboardViewModel
@{
    Layout = null; // This is a partial view loaded into #main-content
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Pharmacist Dashboard</h1>
    <p class="text-gray-500">Manage pending prescriptions and dispensing workflow.</p>
</div>

@* Stats Section (FR-PH-001) *@
@if (Model?.Stats != null)
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-primary"><i data-feather="alert-circle" class="w-8 h-8"></i></div>
                <div class="stat-title">Pending Prescriptions</div>
                <div class="stat-value">@Model.Stats.PendingPrescriptionsCount</div>
                @* <div class="stat-desc">To be processed</div> *@
            </div>
        </div>
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-secondary"><i data-feather="users" class="w-8 h-8"></i></div>
                <div class="stat-title">Patients Waiting Collection</div>
                <div class="stat-value text-secondary">@Model.Stats.PatientsWaitingCollection</div>
                @* <div class="stat-desc">Prescriptions ready</div> *@
            </div>
        </div>
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-success"><i data-feather="check-circle" class="w-8 h-8"></i></div>
                <div class="stat-title">Dispensed Today</div>
                <div class="stat-value text-success">@Model.Stats.DispensedTodayCount</div>
                @* <div class="stat-desc">↗︎ 2 (10%)</div> *@
            </div>
        </div>
        <div class="stats shadow bg-base-100">
            <div class="stat">
                <div class="stat-figure text-info"><i data-feather="clock" class="w-8 h-8"></i></div>
                <div class="stat-title">Avg. Prep Time</div>
                <div class="stat-value text-info">@Model.Stats.AveragePreparationTime</div>
                @* <div class="stat-desc">This shift</div> *@
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mb-6">
        <i data-feather="loader" class="animate-spin mr-2"></i>
        <span>Loading pharmacy statistics...</span>
    </div>
}

@* Pending Prescriptions List (FR-PH-003, FR-PH-004) *@
<div id="pending-prescriptions-container" class="card bg-base-100 shadow-xl">
    <div class="card-body">
        <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
            <h2 class="card-title">
                <i data-feather="list" class="mr-2"></i>Pending Prescriptions
            </h2>
            @* TODO: Add Search/Filter inputs here later *@
            <div class="form-control hidden">
                @* Placeholder for search *@
                <input type="text" placeholder="Search by patient name/ID..." class="input input-sm input-bordered w-full max-w-xs" />
            </div>
            <button class="btn btn-xs btn-ghost"
                    hx-get="@Url.Action("PharmacistDashboard", "Dashboard")" @* Pass current page/size if needed *@
                    hx-target="#main-content" @* Target this section for refresh *@
                    hx-swap="innerHTML"
                    hx-indicator="#pending-rx-refresh-indicator">
                <i data-feather="refresh-cw" class="w-4 h-4 mr-1"></i> Refresh List
                <span id="pending-rx-refresh-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
            </button>
        </div>

        @if (Model?.PendingPrescriptions != null && Model.PendingPrescriptions.Any())
        {
            <div class="overflow-x-auto">
                <table class="table table-zebra table-sm w-full">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Rank / Force No.</th>
                            <th>Prescribed At</th>
                            <th>Prescribing Doctor</th>
                            <th class="text-center">Items</th>
                            <th class="text-center">Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rx in Model.PendingPrescriptions)
                        {
                            <tr>
                                <td>
                                    <div class="font-bold">@rx.PatientName</div>
                                    <div class="text-xs opacity-70">Patient ID: @rx.PatientId</div>
                                </td>
                                <td>
                                    <div>@(rx.PatientRank ?? "N/A")</div>
                                    <div class="text-xs opacity-70">@(rx.PatientForceNumber ?? "N/A")</div>
                                </td>
                                <td>@rx.PrescribedAt.ToLocalTime().ToString("g")</td>
                                <td>@(rx.PrescribingDoctorName ?? "N/A")</td>
                                <td class="text-center">@rx.NumberOfMedications</td>
                                <td class="text-center"><span class="badge badge-warning badge-sm">@rx.Status</span></td>
                                <td>
                                    @* FR-PH-005: Selecting a pending prescription must display its full details *@
                                    <button class="btn btn-xs btn-outline btn-primary"
                                            hx-get="@Url.Action("ViewPrescriptionDetails", "Pharmacy", new { visitId = rx.VisitId })" @* Placeholder controller/action *@
                                            hx-target="#main-content" @* Or a modal, or a side panel *@
                                            hx-swap="innerHTML transition:true"
                                            hx-push-url="true">
                                        <i data-feather="eye" class="w-4 h-4 mr-1"></i> View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-8">
                <i data-feather="inbox" class="w-12 h-12 mx-auto text-gray-400"></i>
                <p class="mt-2 text-gray-500">No prescriptions currently pending dispense.</p>
            </div>
        }

        @* TODO: Add Pagination Controls Partial View here later *@
        <div class="mt-4 text-center hidden">
            @* Placeholder for pagination controls *@
            <span>Page X of Y</span>
            <button class="btn btn-xs btn-outline">Previous</button>
            <button class="btn btn-xs btn-outline">Next</button>
        </div>
    </div>
</div>