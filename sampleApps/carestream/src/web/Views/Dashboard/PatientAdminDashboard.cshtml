@{
    Layout = null; // This view itself is loaded into #main-content
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Patient Administration Dashboard</h1>
    <p class="text-gray-500">Manage patient registrations and administrative activities</p>
</div>

<!-- Stats Section - Load via HTMX -->
<div class="min-h-[100px]"
     hx-get="@Url.Action("StatsPartial", "Dashboard")"
     hx-trigger="load"
     hx-swap="outerHTML transition:true">
    <!-- Placeholder while loading - DaisyUI Skeleton -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="skeleton h-24 w-full"></div>
        <div class="skeleton h-24 w-full"></div>
        <div class="skeleton h-24 w-full"></div>
    </div>
</div>


<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="min-h-[200px]"
         hx-get="@Url.Action("RecentPatientsPartial", "Dashboard")"
         hx-trigger="load"
         hx-swap="outerHTML transition:true">
        <div class="skeleton h-48 w-full"></div>
    </div>

    <div class="min-h-[200px]"
         hx-get="@Url.Action("RecentReportsPartial", "Dashboard")"
         hx-trigger="load"
         hx-swap="outerHTML transition:true">
        <div class="skeleton h-48 w-full"></div>
    </div>
</div>