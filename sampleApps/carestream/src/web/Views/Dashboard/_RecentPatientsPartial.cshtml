@using carestream.core.dtos.dashboard
@model IEnumerable<RecentPatientDto>
@{
    Layout = null;
}

@{
    // Helper functions for badge styling
    string GetStatusBadgeClass(string status) => status switch
    {
        "Discharged" => "badge-ghost",
        "In Treatment" => "badge-info",
        "Pending Checkin" => "badge-warning",
        _ => "badge-neutral"
    };
}

<div class="card bg-base-100 shadow-xl h-full">
    <div class="card-body">
        <div class="flex justify-between items-center mb-4">
            <h2 class="card-title">Recent Patients</h2>
            <button class="btn btn-xs btn-ghost"
                    hx-get="@Url.Action("AllPatients", "Patient")"
                    hx-target="#main-content"
                    hx-swap="innerHTML transition:true"
                    hx-push-url="true">
                View all patients →
            </button>
        </div>
        <div class="overflow-x-auto">
            @if (Model != null && Model.Any())
            {
                <table class="table table-sm">
                    <thead>
                        <tr> <th>Name</th> <th>Reason</th> <th>Status</th> <th>Time</th> </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in Model)
                        {
                            <tr>
                                <td>@patient.Name</td>
                                <td>@patient.BriefReason</td>
                                <td><span class="badge @GetStatusBadgeClass(patient.Status)">@patient.Status</span></td>
                                <td>@patient.VisitTimestamp.ToString("HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-center text-gray-500 py-4">No recent patients found.</p>
            }
        </div>
    </div>
</div>