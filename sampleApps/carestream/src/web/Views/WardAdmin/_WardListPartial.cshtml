@using carestream.core.dtos.admin.facility
@using carestream.core.dtos.shared
@model WardListViewModel
@{
    Layout = null;
    var departmentsMap = Model.AllDepartments.ToDictionary(d => d.DepartmentId, d => d.Name);
}
<div id="ward-list-container">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
                <h2 class="card-title">Wards in @Model.FacilityName</h2>
                <div class="flex items-center gap-2">
                    <form hx-get="@Url.Action("Index", "WardAdmin", new { facilityId = Model.FacilityId })"
                    hx-target="#ward-list-container"
                    hx-swap="innerHTML"
                    class="join">
                        <input type="search" name="SearchTerm1" value="@Model.CurrentFilters.SearchTerm1" placeholder="Search wards..." class="input input-sm input-bordered join-item" />
                        <select name="SearchTerm2" class="select select-sm select-bordered join-item">
                            @if (string.IsNullOrWhiteSpace(Model.CurrentFilters.SearchTerm2))
                            {
                                <option value="" selected>All Departments</option>
                            }
                            else
                            {
                                <option value="">All Departments</option>
                            }
                            @if (Model.CurrentFilters.SearchTerm2 == "0")
                            {
                                <option value="0" selected>Unassigned</option>
                            }
                            else
                            {
                                if (!string.IsNullOrWhiteSpace(Model.CurrentFilters.SearchTerm2))
                                {
                                    <option value="0">Unassigned</option>
                                }
                            }
                            <option value="0">Unassigned</option>
                            @foreach (var dept in Model.AllDepartments.OrderBy(d => d.Name))
                            {
                                @if (Model.CurrentFilters.SearchTerm2 == dept.DepartmentId.ToString())
                                {
                                    <option value="@dept.DepartmentId" selected>@dept.Name</option>
                                }
                                else
                                {
                                    <option value="@dept.DepartmentId">@dept.Name</option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary join-item">
                            <i data-feather="search" class="w-4 h-4"></i>
                        </button>
                    </form>
                    <button class="btn btn-sm btn-success"
                            hx-get="@Url.Action("CreateEditModal", "WardAdmin", new { facilityId = Model.FacilityId })"
                            hx-target="#admin_generic_modal_content"
                            hx-swap="innerHTML"
                            onclick="admin_generic_modal.showModal()">
                        <i data-feather="plus" class="w-4 h-4 mr-1"></i> New Ward
                    </button>
                </div>
            </div>

            @if (Model.Wards.Any())
            {
                <div class="overflow-x-auto">
                    <table class="table table-sm table-zebra w-full">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ward in Model.Wards)
                            {
                                <tr>
                                    <td>@ward.WardId</td>
                                    <td>@ward.Name</td>
                                    <td>@(ward.DepartmentName ?? "N/A")</td>
                                    <td>
                                        <span class="badge @(ward.IsActive ? "badge-success" : "badge-error") badge-xs">
                                            @(ward.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-xs btn-outline btn-info"
                                                hx-get="@Url.Action("CreateEditModal", "WardAdmin", new { facilityId = Model.FacilityId, wardId = ward.WardId })"
                                                hx-target="#admin_generic_modal_content"
                                                hx-swap="innerHTML"
                                                onclick="admin_generic_modal.showModal()">
                                            Edit
                                        </button>
                                        @if (ward.IsActive)
                                        {
                                            <form hx-post="@Url.Action("Deactivate", "WardAdmin")"
                                                  hx-vals='{"wardId": @ward.WardId}'
                                                  hx-confirm="Are you sure you want to deactivate @ward.Name?"
                                                  hx-target="this" hx-swap="none"
                                                  hx-indicator="#deactivate-indicator-@ward.WardId"
                                                  class="inline-block ml-1">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-xs btn-outline btn-warning">
                                                    Deactivate
                                                    <span id="deactivate-indicator-@ward.WardId" class="htmx-indicator loading loading-spinner loading-xs"></span>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <partial name="_PaginationControls" model="Model.PaginationInfo"
                         view-data='new ViewDataDictionary(ViewData) { { "AdditionalRouteValues", new Dictionary<string, string> { { "SearchTerm1", Model.CurrentFilters.SearchTerm1 ?? "" }, { "SearchTerm2", Model.CurrentFilters.SearchTerm2 ?? "" }, { "facilityId", Model.FacilityId.ToString() } } } }' />
            }
            else
            {
                <p class="text-center py-4">No wards found @(!string.IsNullOrEmpty(Model.CurrentFilters.SearchTerm1) ? "matching your search." : "for this facility.")</p>
            }
        </div>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') { feather.replace(); }
    document.body.addEventListener('refreshWardList', function() {
        htmx.ajax('GET', '@Url.Action("Index", "WardAdmin", new { facilityId = Model.FacilityId, searchTerm1 = Model.CurrentFilters.SearchTerm1, searchTerm2 = Model.CurrentFilters.SearchTerm2, pageNumber = Model.PaginationInfo.CurrentPage, pageSize = Model.PaginationInfo.PageSize })', {
            target: '#ward-list-container',
            swap: 'innerHTML'
        });
    });
</script>