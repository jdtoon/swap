@using carestream.core.dtos.admin.facility
@model WardListViewModel
@{
    Layout = null;
}

@if (Model.FacilityId <= 0)
{
    <div class="alert alert-info text-center mb-4">
        <i data-feather="info" class="w-6 h-6 mr-2"></i>
        <span>Please select a Facility to view and manage its Wards.</span>
    </div>
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <h2 class="card-title mb-4">Select Facility</h2>
            <form hx-get="@Url.Action("Index", "WardAdmin")"
                  hx-target="#ward-list-main-content-container" @* Target the parent div to reload this section *@
                  hx-swap="innerHTML">
                <div class="form-control">
                    <label class="label"><span class="label-text">Select Facility</span></label>
                    <select name="facilityId" class="select select-bordered w-full max-w-xs" required>
                        <option value="">Choose a facility</option>
                        @foreach (var facility in Model.AllFacilities.OrderBy(f => f.Name))
                        {
                            <option value="@facility.FacilityId">@facility.Name (@(facility.ShortCode ?? "N/A"))</option>
                        }
                    </select>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">View Wards</button>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div id="ward-list-container"
         hx-get="@Url.Action("Index", "WardAdmin", new { facilityId = Model.FacilityId })"
         hx-trigger="load once, refreshWardList from:body" @* Event to refresh the list *@
         hx-swap="innerHTML">
        <div class="flex justify-center items-center p-10">
            <span class="loading loading-lg loading-spinner"></span>
            <p class="ml-2">Loading wards for @Model.FacilityName...</p>
        </div>
    </div>
}

<script>
    if (typeof feather !== 'undefined') { feather.replace(); }
</script>