@using carestream.core.dtos.messaging
@model IEnumerable<ConversationDto>
@{
    Layout = null;
    // Get active conversation ID from query string or a custom trigger (like setActiveConversation)
    int activeConversationId = 0;
    if (Context.Request.Query.ContainsKey("convId"))
    {
        int.TryParse(Context.Request.Query["convId"], out activeConversationId);
    }
    // If not from query string, check if a value was explicitly passed via ViewData (e.g., from an HX-Trigger)
    else if (ViewData["ActiveConversationId"] is int activeIdFromViewData)
    {
        activeConversationId = activeIdFromViewData;
    }
}

<div class="flex justify-between items-center mb-4">
    <h2 class="card-title text-lg"><i data-feather="message-square" class="mr-2"></i> Conversations</h2>
    <button type="button"
            class="btn btn-primary btn-sm"
            hx-get="@Url.Action("UserSearchPartial", "Messages")"
            hx-target="#conversation-list-panel"
            hx-swap="innerHTML">
        <i data-feather="user-plus" class="w-4 h-4"></i> New Chat
    </button>
</div>

@if (Model != null && Model.Any())
{
    <ul class="menu menu-sm bg-base-100 w-full p-0">
        @foreach (var conv in Model.OrderByDescending(c => c.LastMessageAt))
        {
            <li>
                <button type="button"
                        class="w-full text-left flex justify-between items-center @(activeConversationId == conv.ConversationId ? "active" : "")"
                        hx-get="@Url.Action("MessagePanelPartial", "Messages", new { conversationId = conv.ConversationId })"
                        hx-target="#message-panel-container"
                        hx-swap="innerHTML"
                        hx-push-url="?convId=@conv.ConversationId"
                        hx-on::after-swap="document.getElementById('conversation-list-panel').querySelectorAll('button').forEach(btn => btn.classList.remove('active')); this.classList.add('active');">
                    <div class="flex-1 overflow-hidden">
                        <span class="font-medium truncate">@(conv.Name ?? "Direct Chat")</span>
                        @if (conv.IsGroupChat)
                        {
                            <span class="badge badge-outline badge-xs ml-1">Group</span>
                        }
                        <div class="text-xs text-base-content text-opacity-60 truncate">Last: @conv.LastMessageAt.ToLocalTime().ToString("g")</div>
                    </div>
                    @if (conv.UnreadCount > 0)
                    {
                        <span class="badge badge-primary">@conv.UnreadCount</span>
                    }
                </button>
            </li>
        }
    </ul>
}
else
{
    <div class="text-center py-4 text-sm text-gray-500">No conversations found. Click "New Chat" to start one!</div>
}

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
    // Listener for refreshing the conversation list
    // This event can carry an active conversation ID (e.g., from StartConversation)
    document.body.addEventListener('refreshConversationList', function(evt) {
        let convIdToActivate = 0;
        if (evt.detail && evt.detail.setActiveConversation) {
            convIdToActivate = evt.detail.setActiveConversation;
        }

        // Reload the conversation list partial, potentially passing the ID to activate
        htmx.ajax('GET', `@Url.Action("ConversationListPartial", "Messages")` + (convIdToActivate > 0 ? `?convId=${convIdToActivate}` : ''), {
            target: '#conversation-list-panel',
            swap: 'innerHTML'
        });
    });

    // Listener for 'setActiveConversation' to ensure the correct conversation is highlighted.
    // This is useful as a fallback or to explicitly handle UI state.
    document.body.addEventListener('setActiveConversation', function(evt) {
        const convId = evt.detail.setActiveConversation;
        if (convId) {
            // Update the URL to reflect the new conversation ID if it's not already there
            if (window.location.search.indexOf(`convId=${convId}`) === -1) {
                window.history.pushState(null, '', `?convId=${convId}`);
            }

            // Find the button for the conversation and add the 'active' class
            const buttons = document.querySelectorAll('#conversation-list-panel button');
            buttons.forEach(button => {
                const hxGetAttr = button.getAttribute('hx-get');
                if (hxGetAttr && hxGetAttr.includes(`conversationId=${convId}`)) {
                    button.classList.add('active');
                } else {
                    button.classList.remove('active');
                }
            });
        }
    });

    // Ensure feather icons are replaced on initial load for conversation list
    document.addEventListener('DOMContentLoaded', feather.replace);
</script>