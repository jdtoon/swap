@{
    Layout = null;
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Messages</h1>
    <p class="text-gray-500">Communicate securely with other staff members.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <!-- Conversation List Panel (Left side) -->
    <div id="conversation-list-panel" class="md:col-span-1 bg-base-100 shadow-xl rounded-box p-4"
         hx-get="@Url.Action("ConversationListPartial", "Messages")"
         hx-trigger="load once, refreshConversationList from:body"
         hx-swap="innerHTML">
        <h2 class="card-title text-lg mb-4"><i data-feather="message-square" class="mr-2"></i> Conversations</h2>
        <div class="flex justify-center items-center p-4">
            <span class="loading loading-md loading-spinner"></span>
            <p class="ml-2">Loading conversations...</p>
        </div>
    </div>

    <!-- Message Panel (Right side) -->
    <div id="message-panel-container" class="md:col-span-3 bg-base-100 shadow-xl rounded-box p-4 flex flex-col min-h-[500px]">
        <h2 class="card-title text-lg mb-4"><i data-feather="message-circle" class="mr-2"></i> Select a Conversation</h2>
        <div class="flex-grow flex items-center justify-center text-gray-500">
            <p>Select a conversation from the left panel to view messages.</p>
        </div>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
    // Listener for refreshing the conversation list
    document.body.addEventListener('refreshConversationList', function(evt) {
        htmx.ajax('GET', '@Url.Action("ConversationListPartial", "Messages")', {
            target: '#conversation-list-panel',
            swap: 'innerHTML'
        });
    });
</script>