@using carestream.core.dtos.admin
@model IEnumerable<AdminUserListItemDto>
@{
    Layout = null;
}

@if (Model != null && Model.Any())
{
    <ul class="menu menu-sm bg-base-100 w-full p-0">
        @foreach (var user in Model)
        {
            <li>
                <button type="button"
                        class="w-full text-left flex justify-between items-center add-user-btn"
                        data-user-id="@user.UserId"
                        data-user-name="@user.FullName"
                        data-user-rank="@user.Rank"
                        data-user-dept="@user.Department">
                    <div class="flex-1 overflow-hidden">
                        <span class="font-medium">@user.FullName</span>
                        <div class="text-xs text-base-content text-opacity-60">@user.Rank @user.Department</div>
                    </div>
                    <i data-feather="plus-circle" class="w-5 h-5 text-success"></i>
                </button>
            </li>
        }
    </ul>
}
else
{
    <div class="text-center py-4 text-sm text-gray-500">No users found. Try a different search term.</div>
}

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>