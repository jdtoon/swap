@* File: src/carestream.web/Views/EmergencyContact/Index.cshtml *@
@using carestream.core.dtos.emergency
@model EmergencyContactViewModel
@{
    Layout = null; // This is a partial view, assumed to be loaded into a main content area
}

<div class="mb-6">
    <h2 class="text-2xl font-bold text-base-content">Emergency Contacts</h2>
    <p class="text-sm text-base-content text-opacity-70">Important: For immediate assistance, please contact the appropriate emergency service below.</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var contact in Model.Contacts)
    {
        <div class="card card-compact bg-base-100 shadow-md">
            <div class="card-body p-4">
                <h3 class="card-title text-lg">@contact.Name</h3>
                <p class="text-sm text-base-content text-opacity-70">
                    @(contact.Description ?? contact.Type)
                </p>
                <div class="flex items-center gap-2 mt-2">
                    <i data-feather="phone" class="w-4 h-4 text-primary"></i>
                    <span class="text-base font-semibold">@contact.PhoneNumber</span>
                </div>
                <div class="card-actions justify-end mt-4">
                    <a href="tel:@contact.PhoneNumber" class="btn btn-sm btn-outline btn-info">
                        <i data-feather="phone-call" class="w-4 h-4 mr-1"></i> Call Now
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-8">
    <h3 class="text-lg font-semibold mb-3">Important Notice</h3>
    <ul class="list-disc list-inside text-sm text-base-content text-opacity-80 space-y-2">
        @foreach (var notice in Model.ImportantNotices)
        {
            <li>@notice</li>
        }
    </ul>
</div>

<script>
    // Ensure Feather Icons are rendered after HTMX swap
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>