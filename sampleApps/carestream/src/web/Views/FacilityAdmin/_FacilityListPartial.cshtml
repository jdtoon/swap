@using carestream.core.dtos.admin.facility
@using carestream.core.dtos.shared
@model FacilityListViewModel
@{
    Layout = null;
}
<div id="facility-list-container">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
                <h2 class="card-title">Facilities</h2>
                <div class="flex items-center gap-2">
                    <form hx-get="@Url.Action("Index", "FacilityAdmin")"
                          hx-target="#admin-content-area"
                          hx-swap="innerHTML"
                          class="join">
                        <input type="search" name="SearchTerm1" value="@Model.CurrentFilters.SearchTerm1" placeholder="Search facilities..." class="input input-sm input-bordered join-item" />
                        <button type="submit" class="btn btn-sm btn-primary join-item">
                            <i data-feather="search" class="w-4 h-4"></i>
                        </button>
                    </form>
                    <button class="btn btn-sm btn-success"
                            hx-get="@Url.Action("CreateEditModal", "FacilityAdmin")"
                            hx-target="#admin_generic_modal_content"
                            hx-swap="innerHTML"
                            onclick="admin_generic_modal.showModal()">
                        <i data-feather="plus" class="w-4 h-4 mr-1"></i> New Facility
                    </button>
                </div>
            </div>

            @if (Model.Facilities.Any())
            {
                <div class="overflow-x-auto">
                    <table class="table table-sm table-zebra w-full">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Code</th>
                                <th>City</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var facility in Model.Facilities)
                            {
                                <tr>
                                    <td>@facility.FacilityId</td>
                                    <td>@facility.Name</td>
                                    <td>@(facility.ShortCode ?? "-")</td>
                                    <td>@(facility.City ?? "-")</td>
                                    <td>
                                        <span class="badge @(facility.IsActive ? "badge-success" : "badge-error") badge-xs">
                                            @(facility.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-xs btn-outline btn-info"
                                                hx-get="@Url.Action("CreateEditModal", "FacilityAdmin", new { facilityId = facility.FacilityId })"
                                                hx-target="#admin_generic_modal_content"
                                                hx-swap="innerHTML"
                                                onclick="admin_generic_modal.showModal()">
                                            Edit
                                        </button>
                                        @if (facility.IsActive)
                                        {
                                            <form hx-post="@Url.Action("Deactivate", "FacilityAdmin")"
                                                  hx-vals='{"facilityId": @facility.FacilityId}'
                                                  hx-confirm="Are you sure you want to deactivate @facility.Name? This will affect all linked data."
                                                  hx-target="this" hx-swap="none"
                                                  hx-indicator="#deactivate-indicator-@facility.FacilityId"
                                                  class="inline-block ml-1">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-xs btn-outline btn-warning">
                                                    Deactivate
                                                    <span id="deactivate-indicator-@facility.FacilityId" class="htmx-indicator loading loading-spinner loading-xs"></span>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <partial name="_PaginationControls" model="Model.PaginationInfo"
                         view-data='new ViewDataDictionary(ViewData) { { "AdditionalRouteValues", new Dictionary<string, string> { { "SearchTerm1", Model.CurrentFilters.SearchTerm1 ?? "" } } } }' />
            }
            else
            {
                <p class="text-center py-4">No facilities found @(!string.IsNullOrEmpty(Model.CurrentFilters.SearchTerm1) ? "matching your search." : ".")</p>
            }
        </div>
    </div>
</div>
<script>
    if (typeof feather !== 'undefined') { feather.replace(); }
    document.body.addEventListener('refreshFacilityList', function() {
        htmx.ajax('GET', '@Url.Action("Index", "FacilityAdmin", new { searchTerm1 = Model.CurrentFilters.SearchTerm1, pageNumber = Model.PaginationInfo.CurrentPage, pageSize = Model.PaginationInfo.PageSize })', {
            target: '#admin-content-area',
            swap: 'innerHTML'
        });
    });
</script>