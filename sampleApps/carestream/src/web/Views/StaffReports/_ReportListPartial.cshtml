<!-- File: Views/StaffReports/_ReportListPartial.cshtml -->
<!-- This partial displays the paginated list of staff reports -->
@using carestream.core.dtos.admin.staffreport
@using carestream.core.dtos.shared
@model StaffReportListViewModel
@{ Layout = null; }

<div class="card-body">
    <div class="flex flex-col sm:flex-row justify-between items-center mb-4 gap-2">
        <h2 class="card-title">
            <i data-feather="file-text" class="mr-2"></i>All Staff Reports
        </h2>
        <div class="flex items-center gap-2">
            <!-- Search Form -->
            <form id="report-filter-form"
                  hx-get="@Url.Action("ReportListPartial", "StaffReports")"
                  hx-target="#report-list-container"
                  hx-swap="innerHTML"
                  class="join">
                <input type="search" name="SearchTerm1" value="@Model.Filters.SearchTerm1" placeholder="Search title or content..." class="input input-sm input-bordered join-item" />
                <!-- Add SearchTerm2 for priority/department if needed by service -->
                <input type="hidden" name="pageNumber" value="1" />
                <input type="hidden" name="pageSize" value="@Model.Pagination.PageSize" />
                <button type="submit" class="btn btn-sm btn-primary join-item">
                    <i data-feather="search" class="w-4 h-4"></i>
                </button>
            </form>
            <!-- New Report Button -->
            <button class="btn btn-sm btn-success"
                    hx-get="@Url.Action("CreateEditModal", "StaffReports")"
                    hx-target="#admin_generic_modal_content"
                    hx-swap="innerHTML"
                    onclick="admin_generic_modal.showModal()">
                <i data-feather="plus" class="w-4 h-4 mr-1"></i> New Report
            </button>
        </div>
    </div>

    @if (Model.Reports.Any())
    {
        <div class="overflow-x-auto">
            <table class="table table-sm table-zebra w-full">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Department</th>
                        <th>Priority</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model.Reports)
                    {
                        <tr>
                            <td class="font-bold">@report.Title</td>
                            <td>@(report.AuthorUserName ?? "N/A")</td>
                            <td>@(report.DepartmentName ?? "N/A")</td>
                            <td>
                                @{
                                    string priorityBadgeClass = report.Priority?.ToLower() switch
                                    {
                                        "high" => "badge-error",
                                        "urgent" => "badge-warning",
                                        "low" => "badge-success",
                                        _ => "badge-neutral"
                                    };
                                }
                                <span class="badge @priorityBadgeClass badge-sm">@(report.Priority ?? "-")</span>
                            </td>
                            <td>@report.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td>
                                <button class="btn btn-xs btn-outline btn-info"
                                        hx-get="@Url.Action("CreateEditModal", "StaffReports", new { reportId = report.ReportId })"
                                        hx-target="#admin_generic_modal_content"
                                        hx-swap="innerHTML"
                                        onclick="admin_generic_modal.showModal()">
                                    Edit
                                </button>
                                <form hx-post="@Url.Action("DeleteReport", "StaffReports")"
                                      hx-vals='{"reportId": @report.ReportId}'
                                      hx-confirm="Are you sure you want to delete this staff report?"
                                      hx-target="this" hx-swap="none"
                                      hx-indicator="#delete-report-indicator-@report.ReportId"
                                      class="inline-block ml-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-xs btn-outline btn-error">
                                        Delete
                                        <span id="delete-report-indicator-@report.ReportId" class="htmx-indicator loading loading-spinner loading-xs"></span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination Controls -->
        var routeValues = new Dictionary<string, string>();
        if (!string.IsNullOrWhiteSpace(Model.Filters.SearchTerm1)) { routeValues["SearchTerm1"] = Model.Filters.SearchTerm1; }
        <partial name="_PaginationControls" model="Model.Pagination"
                 view-data='new ViewDataDictionary(ViewData) { { "AdditionalRouteValues", routeValues } }' />
    }
    else
    {
        <p class="text-center py-4">No staff reports found @(!string.IsNullOrEmpty(Model.Filters.SearchTerm1) ? "matching your search." : "for this facility.")</p>
    }
</div>
<script>
    if (typeof feather !== 'undefined') { feather.replace(); }
    document.body.addEventListener('refreshReportList', function(evt) {
        const url = new URL('@Url.Action("ReportListPartial", "StaffReports")', window.location.origin);
        url.searchParams.set('pageNumber', @(Model.Pagination?.CurrentPage ?? 1));
        url.searchParams.set('pageSize', @(Model.Pagination?.PageSize ?? 25));
        if ('@Model.Filters.SearchTerm1' !== '') {
            url.searchParams.set('SearchTerm1', '@Model.Filters.SearchTerm1');
        }
        htmx.ajax('GET', url.toString(), {
            target: '#report-list-container',
            swap: 'innerHTML'
        });
    });
</script>