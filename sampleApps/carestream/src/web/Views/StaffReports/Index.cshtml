<!-- File: Views/StaffReports/Index.cshtml -->
<!-- This is the main container for the Staff Reports list -->
@{
    Layout = null;
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Staff Reports</h1>
    <p class="text-gray-500">View and manage internal staff communications and reports.</p>
</div>

<!-- Container for the report list and pagination - loaded via HTMX -->
<div id="report-list-container" class="mt-2"
     hx-get="@Url.Action("ReportListPartial", "StaffReports")"
     hx-trigger="load once, refreshReportList from:body"
     hx-swap="innerHTML">
    <div class="flex justify-center items-center p-10 card bg-base-100 shadow">
        <span class="loading loading-lg loading-spinner table-loading-indicator"></span>
        <p class="ml-2">Loading staff reports...</p>
    </div>
</div>

<dialog id="admin_generic_modal" class="modal">
    <div id="admin_generic_modal_content" class="modal-box w-11/12 max-w-lg">
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>