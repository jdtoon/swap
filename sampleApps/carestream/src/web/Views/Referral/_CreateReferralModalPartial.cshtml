@using carestream.core.dtos.consultation
@using carestream.core.dtos.admin.facility
@using carestream.core.dtos.facility
@model CreateUpdateReferralDto
@{
    Layout = null; // Loaded into a modal
    int patientId = ViewData["PatientId"] as int? ?? 0;
    int visitId = ViewData["VisitId"] as int? ?? 0;
    var allFacilities = ViewData["AllFacilities"] as IEnumerable<FacilityDto> ?? Enumerable.Empty<FacilityDto>();
    var allDepartments = ViewData["AllDepartments"] as IEnumerable<DepartmentDto> ?? Enumerable.Empty<DepartmentDto>();
}

<form method="dialog">
    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" type="button" onclick="admin_generic_modal.close()">✕</button>
</form>
<h3 class="font-bold text-lg mb-4">Create New Referral</h3>
<p class="py-2 text-sm">For Patient ID: <span class="font-semibold">@patientId</span> | Visit ID: <span class="font-semibold">@visitId</span></p>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any(k => ViewData.ModelState[k]?.Errors?.Any() == true))
{
    <div class="alert alert-warning text-xs p-2 mb-3">
        <ul class="list-disc list-inside">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form hx-post="@Url.Action("CreateReferral", "Referral")"
      hx-target="#admin_generic_modal_content" @* Target the modal content for re-render on error *@
      hx-swap="innerHTML"
      hx-indicator="#referral-save-indicator">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="VisitId" />
    <input type="hidden" asp-for="PatientId" />
    <input type="hidden" asp-for="ReferredByUserId" /> 

    <div class="form-control mb-3">
        <label asp-for="ReferralReason" class="label pb-0"><span class="label-text">Reason for Referral <span class="text-error">*</span></span></label>
        <textarea asp-for="ReferralReason" class="textarea textarea-bordered textarea-sm h-24 w-full" placeholder="Briefly state the reason for referral..." required></textarea>
        <span asp-validation-for="ReferralReason" class="text-error text-xs mt-1"></span>
    </div>

    <div class="form-control mb-3">
        <label asp-for="ReferredToFacilityId" class="label pb-0"><span class="label-text">Referred To Facility (Optional)</span></label>
        <select asp-for="ReferredToFacilityId" class="select select-bordered input-sm w-full"
                hx-get="@Url.Action("GetDepartmentsByFacilityForDropdown", "WardAdmin")" 
                hx-target="#referredToDepartmentSelect"
                hx-swap="innerHTML"
                hx-trigger="change">
        <option value="">Select Facility</option>
        @foreach (var facility in allFacilities.OrderBy(f => f.Name))
        {
            <option value="@facility.FacilityId" selected="@(Model.ReferredToFacilityId == facility.FacilityId)">@facility.Name (@(facility.ShortCode ?? "N/A"))</option>
        }
        </select>
        <span asp-validation-for="ReferredToFacilityId" class="text-error text-xs mt-1"></span>
    </div>

    <div class="form-control mb-4">
        <label asp-for="ReferredToDepartmentId" class="label pb-0"><span class="label-text">Referred To Department (Optional)</span></label>
        <select asp-for="ReferredToDepartmentId" class="select select-bordered input-sm w-full" id="referredToDepartmentSelect">
            <option value="">Select Department</option>
            @if (!Model.ReferredToFacilityId.HasValue || Model.ReferredToFacilityId == 0)
            {
                foreach (var dept in allDepartments.OrderBy(d => d.Name))
                {
                    <option value="@dept.DepartmentId" selected="@(Model.ReferredToDepartmentId == dept.DepartmentId)">@dept.Name</option>
                }
            }
        </select>
        <span asp-validation-for="ReferredToDepartmentId" class="text-error text-xs mt-1"></span>
    </div>

    <div class="form-control mb-4">
        <label asp-for="ReferralNotes" class="label pb-0"><span class="label-text">Referral Notes (Optional)</span></label>
        <textarea asp-for="ReferralNotes" class="textarea textarea-bordered textarea-sm h-20 w-full" placeholder="Any further notes or instructions for the receiving department..."></textarea>
        <span asp-validation-for="ReferralNotes" class="text-error text-xs mt-1"></span>
    </div>

    <div class="modal-action mt-6">
        <button class="btn btn-sm btn-ghost" type="button" onclick="admin_generic_modal.close()">Cancel</button>
        <button type="submit" class="btn btn-sm btn-primary">
            Create Referral
            <span id="referral-save-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
        </button>
    </div>
</form>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
    document.addEventListener('DOMContentLoaded', function() {
        const referredToFacilitySelect = document.getElementById('ReferredToFacilityId');
        if (referredToFacilitySelect && referredToFacilitySelect.value && referredToFacilitySelect.value !== "") {
            htmx.trigger(referredToFacilitySelect, 'change');
        }
    });
</script>