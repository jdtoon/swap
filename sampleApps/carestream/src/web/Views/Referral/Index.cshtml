@{
    Layout = null;
    int visitId = ViewData["VisitId"] as int? ?? 0;
    int patientId = ViewData["PatientId"] as int? ?? 0;
}

<div class="mb-4">
    <h3 class="text-lg font-semibold">Patient Referrals</h3>
</div>

<div id="referral-list-container" class="card bg-base-100 shadow-xl"
     hx-get="@Url.Action("ReferralListPartial", "Referral", new { visitId = visitId, patientId = patientId })"
     hx-trigger="load once, refreshReferralList from:body"
     hx-swap="innerHTML">
    <div class="card-body">
        <div class="flex justify-center items-center p-10">
            <span class="loading loading-lg loading-spinner"></span>
            <p class="ml-2">Loading referrals...</p>
        </div>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>