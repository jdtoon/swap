@{
    Layout = null;
    string currentViewType = ViewData["CurrentViewType"] as string ?? "list";
}

<div class="join">
    <button class="btn btn-sm join-item @(currentViewType == "list" ? "btn-active" : "")"
            hx-get="@Url.Action("Index", "PatientQueue", new { viewType = "list" })" @* NEW CONTROLLER *@
            hx-target="#patient-queue-content-container"
            hx-swap="innerHTML"
            hx-push-url="?viewType=list">
        <i data-feather="list" class="w-4 h-4 mr-1"></i> List View
    </button>
    <button class="btn btn-sm join-item @(currentViewType == "board" ? "btn-active" : "")"
            hx-get="@Url.Action("Index", "PatientQueue", new { viewType = "board" })" @* NEW CONTROLLER *@
            hx-target="#patient-queue-content-container"
            hx-swap="innerHTML"
            hx-push-url="?viewType=board">
        <i data-feather="trello" class="w-4 h-4 mr-1"></i> Board View
    </button>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>