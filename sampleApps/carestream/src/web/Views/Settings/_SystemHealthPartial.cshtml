@using carestream.core.dtos.admin.systemhealth
@model SystemHealthDashboardDto
@{ Layout = null; }

<div class="card-body">
    <div class="flex justify-between items-center mb-4">
        <h2 class="card-title text-lg">
            <i data-feather="monitor" class="mr-2"></i>System Health
        </h2>
        <button class="btn btn-xs btn-ghost"
                hx-get="@Url.Action("SystemHealthPartial", "Settings")"
                hx-target="#system-health-container"
                hx-swap="innerHTML"
                hx-indicator="#system-health-refresh-indicator">
            <i data-feather="refresh-cw" class="w-4 h-4 mr-1"></i> Refresh
            <span id="system-health-refresh-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
        </button>
    </div>

    @if (Model != null)
    {
        string overallBadgeClass = Model.OverallStatus.ToLower() switch
        {
            "operational" => "badge-success",
            "degraded" => "badge-warning",
            "critical" => "badge-error",
            "unknown" => "badge-neutral",
            _ => "badge-info"
        };
        <div class="alert @overallBadgeClass mb-4 text-sm">
            <i data-feather="@(Model.OverallStatus.ToLower() == "operational" ? "check-circle" : (Model.OverallStatus.ToLower() == "critical" ? "x-circle" : "alert-triangle"))" class="w-5 h-5"></i>
            <div>
                <h3 class="font-bold">Overall Status: @Model.OverallStatus</h3>
                <p>@Model.Message</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var component in Model.ComponentStatuses)
            {
                string componentBadgeClass = component.Status.ToLower() switch
                {
                    "healthy" => "badge-success",
                    "operational" => "badge-success",
                    "degraded" => "badge-warning",
                    "unhealthy" => "badge-error",
                    "unreachable" => "badge-error",
                    "error" => "badge-error",
                    "unknown" => "badge-neutral",
                    _ => "badge-info"
                };
                <div class="stats shadow bg-base-100">
                    <div class="stat">
                        <div class="stat-figure text-primary">
                            @if (component.Component == "Database") { <i data-feather="database" class="w-8 h-8"></i> }
                            else if (component.Component == "Logto Identity Provider") { <i data-feather="user-check" class="w-8 h-8"></i> }
                            else if (component.Component == "File Storage") { <i data-feather="hard-drive" class="w-8 h-8"></i> }
                            else { <i data-feather="settings" class="w-8 h-8"></i> }
                        </div>
                        <div class="stat-title">@component.Component</div>
                        <div class="stat-value text-sm">
                            <span class="badge @componentBadgeClass">@component.Status</span>
                        </div>
                        <div class="stat-desc text-xs">Last Checked: @component.LastChecked.ToLocalTime().ToString("g")</div>
                        @if (!string.IsNullOrWhiteSpace(component.Details))
                        {
                            <div class="stat-desc text-xs">@component.Details</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i data-feather="loader" class="animate-spin mr-2"></i>
            <span>System health data is not available.</span>
        </div>
    }
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>