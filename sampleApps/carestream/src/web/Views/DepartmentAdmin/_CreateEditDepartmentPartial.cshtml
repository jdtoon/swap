@using carestream.core.dtos.admin.facility
@model CreateUpdateDepartmentDto
@{
    Layout = null; // Loaded into a modal
    string title = Model.DepartmentId.HasValue && Model.DepartmentId.Value > 0 ? "Edit Department" : "Create New Department";
    string targetFacilityName = ViewData["TargetFacilityName"] as string ?? "Unknown Facility";
}

<form method="dialog">
    <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" type="button" onclick="admin_generic_modal.close()">✕</button>
</form>
<h3 class="font-bold text-lg mb-4">@title</h3>
<p class="py-2 text-sm">For Facility: <span class="font-semibold">@targetFacilityName</span> (ID: @Model.FacilityId)</p>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any(k => ViewData.ModelState[k]?.Errors?.Any() == true))
{
    <div class="alert alert-warning text-xs p-2 mb-3">
        <ul class="list-disc list-inside">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form hx-post="@Url.Action("CreateOrUpdate", "DepartmentAdmin")"
      hx-target="#admin_generic_modal_content"
      hx-swap="innerHTML"
      hx-indicator="#department-save-indicator">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DepartmentId" />
    <input type="hidden" asp-for="FacilityId" /> @* Hidden, as it's passed from the list view context *@

    <div class="form-control mb-3">
        <label asp-for="Name" class="label pb-0"><span class="label-text">Department Name</span></label>
        <input type="text" asp-for="Name" class="input input-bordered input-sm w-full" required />
        <span asp-validation-for="Name" class="text-error text-xs mt-1"></span>
    </div>

    <div class="form-control mb-4">
        <label asp-for="Description" class="label pb-0"><span class="label-text">Description (Optional)</span></label>
        <textarea asp-for="Description" class="textarea textarea-bordered textarea-sm h-24 w-full" placeholder="Brief description of the department..."></textarea>
        <span asp-validation-for="Description" class="text-error text-xs mt-1"></span>
    </div>

    <div class="form-control flex items-center justify-start flex-row mt-2">
        <input type="checkbox" asp-for="IsActive" class="checkbox checkbox-primary" />
        <label asp-for="IsActive" class="label pl-3"><span class="label-text cursor-pointer">Active Department</span></label>
        <span asp-validation-for="IsActive" class="text-error text-xs mt-1"></span>
    </div>

    <div class="modal-action mt-6">
        <button class="btn btn-sm btn-ghost" type="button" onclick="admin_generic_modal.close()">Cancel</button>
        <button type="submit" class="btn btn-sm btn-primary">
            Save Department
            <span id="department-save-indicator" class="htmx-indicator loading loading-spinner loading-xs ml-1"></span>
        </button>
    </div>
</form>