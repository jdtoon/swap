@{
    Layout = null;
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Sick Report - Patient Check-in / Lookup</h1>
    <p class="text-gray-500">Enter patient's Force Number / ID Number to retrieve details or check-in.</p>
</div>

<div class="card bg-base-100 shadow mb-6">
    <div class="card-body">
        <h2 class="card-title text-lg mb-4">Initial Patient Check-in</h2>
        <p class="text-sm text-base-content text-opacity-70 mb-4">Enter military ID to register patient arrival or view existing details.</p>

        <form hx-post="@Url.Action("LookupPatient", "SickReport")"
              hx-target="#patient-lookup-result"
              hx-swap="innerHTML"
              hx-indicator="#lookup-indicator">
            <div class="form-control mb-4">
                <label class="label" for="forceNumberInput">
                    <span class="label-text">Force Number / ID Number</span>
                </label>
                <input type="text" id="forceNumberInput" name="forceNumber" placeholder="Enter 8-digit Force/ID number" class="input input-bordered w-full max-w-xs" required />
            </div>
            <div class="card-actions justify-start items-center">
                <button type="submit" class="btn btn-primary">Lookup Patient</button>
                <span id="lookup-indicator" class="htmx-indicator loading loading-spinner loading-md ml-4"></span>
            </div>
        </form>
    </div>
</div>

<div id="patient-lookup-result" class="mt-6">
    @* Result partials (_PatientFound, _PatientNotFound, _CheckinConfirmation) will be loaded here *@
</div>