@using carestream.core.dtos.patient
@model PatientDetailDto
@{
    Layout = null; // This is a partial view
}

<div class="p-2 bg-base-200 rounded-md mb-2">
    <div class="flex justify-between items-center">
        <h3 class="font-semibold text-lg">Emergency Contact</h3>
        <button class="btn btn-xs btn-ghost"
                hx-get="@Url.Action("EditEmergencyContactInfoForm", "SickReport", new { patientId = Model.PatientId })"
                hx-target="#patient-emergency-contact-info-container-@Model.PatientId" @* TARGET THE STABLE CONTAINER *@
                hx-swap="innerHTML">
            @* REPLACE THE INNER HTML OF THE STABLE CONTAINER *@
            <i data-feather="edit" class="w-4 h-4 mr-1"></i> Edit Details
        </button>
    </div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-1 text-sm px-2">
    <span><strong>Name:</strong> @(Model.EmergencyContactName ?? "N/A")</span>
    <span><strong>Phone:</strong> @(Model.EmergencyContactPhone ?? "N/A")</span>
</div>

<script>
    // This script needs to run after this partial is swapped in to render new feather icons
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>