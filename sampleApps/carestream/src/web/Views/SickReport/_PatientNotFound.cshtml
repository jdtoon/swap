@model string
@{
    Layout = null;
}

<div class="alert alert-warning flex flex-col sm:flex-row items-center gap-4">
    <div class="flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        <span>Patient Not Found. Please verify the Force Number / ID Number.</span>
    </div>
    <div class="flex-none">
        <button class="btn btn-sm btn-outline mt-2"
                hx-get="@Url.Action("LookupFormPartial", "SickReport")"
                hx-target="#patient-lookup-form-and-result-container"
                hx-swap="innerHTML transition:true">
            Back to Lookup
        </button>
        <!-- NEW: Register New Patient Button (FR-PA-013) -->
        <button class="btn btn-sm btn-primary mt-2 ml-2"
                hx-get="@Url.Action("RegisterNewPatientForm", "Patient")"
                hx-target="#main-content"
                hx-swap="innerHTML transition:true"
                hx-push-url="true">
            <i data-feather="user-plus" class="w-4 h-4 mr-1"></i> Register New Patient
        </button>
    </div>
</div>
<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>