@using carestream.core.dtos.patient
@using carestream.core.dtos.visit
@using carestream.core.dtos.checkin @* Added for CheckinInputDto *@
@model PatientDetailDto
@{
    Layout = null;
    var activeVisit = ViewData["ActiveVisitData"] as ActiveVisitDto;
    bool hasActiveVisit = activeVisit != null;
    // Retrieve the input DTO if validation failed and the form is re-rendered
    var checkinInputDto = ViewData["CheckinInputDto"] as CheckinInputDto;
}

<div class="card bg-base-100 shadow-xl">
    <div class="card-body">
        <div class="alert alert-success mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span>Patient Found: @Model.Rank @Model.FirstName @Model.LastName (Force #: @Model.ForceNumber)</span>
        </div>

        @if (hasActiveVisit)
        {
            <div class="alert alert-warning mb-4 p-4 rounded-md">
                <div class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                    <h3 class="font-semibold">Active Visit Found!</h3>
                </div>
                <p class="text-sm mt-1">Current Status: <strong>@activeVisit?.Status</strong></p>
                <p class="text-xs">Visit Started: @activeVisit?.VisitTimestamp.ToLocalTime().ToString("g") (ID: @activeVisit?.VisitId)</p>
                <p class="text-sm mt-2">Please choose an action below for Visit ID: <strong>@activeVisit?.VisitId</strong></p>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6 mr-2"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>No active visit found for this patient. Ready for new check-in.</span>
            </div>
        }

        @* Personal Information Section - Loads _PatientPersonalDisplayPartial.cshtml *@
        <div id="personal-info-section-for-patient-@Model.PatientId" class="mb-4"
        hx-get="@Url.Action("PersonalDisplayPartial", "Patient", new { patientId = Model.PatientId })"
        hx-trigger="load"
        hx-swap="innerHTML">
            <div class="p-4 text-center">
                <span class="loading loading-md loading-dots"></span> Loading personal information...
            </div>
        </div>

        <div class="divider my-1"></div>

        @* Contact Information Section - NOW USES A STABLE CONTAINER *@
        <div id="patient-contact-info-container-@Model.PatientId" class="mb-4"
        hx-get="@Url.Action("ContactDisplayPartial", "SickReport", new { patientId = Model.PatientId })"
        hx-trigger="load"
        hx-swap="innerHTML">
            <div class="p-4 text-center">
                <span class="loading loading-md loading-dots"></span> Loading contact information...
            </div>
        </div>

        <div class="divider my-1"></div>

        @* Emergency Contact Section - NOW USES A STABLE CONTAINER AND IS ENABLED *@
        <div id="patient-emergency-contact-info-container-@Model.PatientId" class="mb-4"
        hx-get="@Url.Action("EmergencyContactDisplayPartial", "SickReport", new { patientId = Model.PatientId })"
        hx-trigger="load"
        hx-swap="innerHTML">
            <div class="p-4 text-center">
                <span class="loading loading-md loading-dots"></span> Loading emergency contact information...
            </div>
        </div>

        @* ADDITIONAL NOTES SECTION FOR NEW CHECK-IN - MODIFIED TO USE A FORM AND SERVER-SIDE VALIDATION *@
        @if (!hasActiveVisit)
        {
            <div class="divider my-1"></div>
            @* The form will wrap the inputs and the submit button for new check-in *@
            <form hx-post="@Url.Action("CreateNewVisitAndCheckin", "SickReport")"
            hx-target="#patient-lookup-form-and-result-container"
            hx-swap="innerHTML transition:true"
            hx-indicator="#checkin-indicator-new-form">
                @* Added indicator to form *@
                @Html.AntiForgeryToken()
                <input type="hidden" name="PatientId" value="@Model.PatientId" /> @* Pass patientId as a hidden input *@

                @* Display ModelState errors if any general ones (e.g., from service) *@
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any(k => !string.IsNullOrEmpty(k) && ViewData.ModelState[k]?.Errors?.Any() == true))
                {
                    <div class="alert alert-error mb-4 text-sm">
                        <ul class="list-disc list-inside">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                @if (Model.ShowActionButtons)
                {
                    <div class="form-control mb-4">
                        <label class="label">
                            <span class="label-text">Brief Reason for Visit <span class="text-error">*</span></span>
                        </label>
                        <input type="text" name="BriefReason" value="@(checkinInputDto?.BriefReason)" class="input input-bordered w-full @(ViewData.ModelState.ContainsKey(nameof(CheckinInputDto.BriefReason)) && ViewData.ModelState[nameof(CheckinInputDto.BriefReason)]?.Errors?.Any() == true ? "input-error" : "")" placeholder="e.g., Cold symptoms, routine check-up" required />
                        @if (ViewData.ModelState.ContainsKey(nameof(CheckinInputDto.BriefReason)))
                        {
                            <label class="label">
                                <span class="label-text-alt text-error">@Html.ValidationMessageFor(m => checkinInputDto!.BriefReason)</span>
                            </label>
                        }
                    </div>
                    <div class="form-control mb-4">
                        <label class="label">
                            <span class="label-text">Additional Notes (Optional)</span>
                            <span class="label-text-alt">For the medical staff's reference</span>
                        </label>
                        <textarea name="AdditionalNotes" class="textarea textarea-bordered h-24 w-full" placeholder="Add any additional information relevant to the check-in...">@(checkinInputDto?.AdditionalNotes)</textarea>
                        @if (ViewData.ModelState.ContainsKey(nameof(CheckinInputDto.AdditionalNotes)))
                        {
                            <label class="label">
                                <span class="label-text-alt text-error">@Html.ValidationMessageFor(m => checkinInputDto!.AdditionalNotes)</span>
                            </label>
                        }
                    </div>

                    @* Action Buttons Section - MOVED INSIDE THE FORM *@
                    <div class="card-actions justify-end mt-6">
                        <button class="btn btn-secondary"
                        hx-get="@Url.Action("LookupFormPartial", "SickReport")"
                        hx-target="#patient-lookup-form-and-result-container"
                        hx-swap="innerHTML transition:true"
                        type="button">
                            @* Changed to type="button" to prevent form submission *@
                            Cancel / New Lookup
                        </button>

                        <button type="submit" class="btn btn-primary">
                            @* Type="submit" to submit the form *@
                            Complete New Check-in
                            <span id="checkin-indicator-new-form" class="htmx-indicator loading loading-spinner loading-sm ml-2"></span>
                        </button>
                    </div>
                }
            </form>
        }
        else
        {
            @* Action Buttons Section for Existing Visits - REMAINS OUTSIDE THE NEW FORM *@
            @if (Model.ShowActionButtons)
            {
                <div class="card-actions justify-end mt-6">
                    <button class="btn btn-secondary"
                            hx-get="@Url.Action("LookupFormPartial", "SickReport")"
                            hx-target="#patient-lookup-form-and-result-container"
                            hx-swap="innerHTML transition:true"
                            type="button">
                        Cancel / New Lookup
                    </button>

                    <button class="btn btn-accent"
                            hx-post="@Url.Action("ResumeActiveVisit", "SickReport")"
                            hx-vals='{"visitId": @activeVisit!.VisitId, "patientId": @Model.PatientId}'
                            hx-target="#patient-lookup-form-and-result-container"
                            hx-swap="innerHTML transition:true"
                            hx-indicator="#checkin-indicator-resume">
                        Resume Visit (#@activeVisit.VisitId)
                        <span id="checkin-indicator-resume" class="htmx-indicator loading loading-spinner loading-sm ml-2"></span>
                    </button>
                    <button class="btn btn-warning"
                            hx-post="@Url.Action("CloseAndStartNewVisit", "SickReport")"
                            hx-vals='{"oldVisitId": @activeVisit.VisitId, "patientId": @Model.PatientId}'
                            hx-target="#patient-lookup-form-and-result-container"
                            hx-swap="innerHTML transition:true"
                            hx-indicator="#checkin-indicator-close-new">
                        Close Visit & Start New
                        <span id="checkin-indicator-close-new" class="htmx-indicator loading loading-spinner loading-sm ml-2"></span>
                    </button>
                </div>
            }
        }
    </div>
</div>
<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>