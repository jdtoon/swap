@using carestream.core.dtos.patient
@model IEnumerable<PatientMedicalHistoryDto>
@{
    Layout = null;
    int patientId = ViewData["PatientId"] as int? ?? 0;
}

<div class="card-body">
    <div class="flex justify-between items-center mb-4">
        <h2 class="card-title">
            <i data-feather="clipboard" class="mr-2"></i>Medical History Records
        </h2>
        <button class="btn btn-sm btn-primary"
                hx-get="@Url.Action("CreateEditModal", "PatientHistory", new { patientId = patientId })"
                hx-target="#admin_generic_modal_content"
                hx-swap="innerHTML"
                onclick="admin_generic_modal.showModal()">
            <i data-feather="plus" class="w-4 h-4 mr-1"></i> Add New Entry
        </button>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="overflow-x-auto">
            <table class="table table-sm table-zebra w-full">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Onset/Resolution</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Recorded By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.OrderByDescending(e => e.RecordedAt))
                    {
                        <tr>
                            <td>@entry.Type</td>
                            <td>@entry.Description</td>
                            <td>
                                @(entry.OnsetDate?.ToString("yyyy-MM-dd") ?? "N/A")
                                @if (entry.ResolutionDate.HasValue)
                                {
                                    <div class="text-xs text-opacity-70">to @entry.ResolutionDate.Value.ToString("yyyy-MM-dd")</div>
                                }
                            </td>
                            <td>@(entry.Severity ?? "-")</td>
                            <td>
                                <span class="badge @(entry.IsActive ? "badge-success" : "badge-error") badge-xs">
                                    @(entry.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                @(entry.RecordedByUserName ?? "N/A")
                                <div class="text-xs opacity-70">@entry.RecordedAt.ToLocalTime().ToString("g")</div>
                            </td>
                            <td>
                                <button class="btn btn-xs btn-outline btn-info"
                                        hx-get="@Url.Action("CreateEditModal", "PatientHistory", new { patientId = patientId, historyId = entry.HistoryId })"
                                        hx-target="#admin_generic_modal_content"
                                        hx-swap="innerHTML"
                                        onclick="admin_generic_modal.showModal()">
                                    Edit
                                </button>
                                @if (entry.IsActive)
                                {
                                    <form hx-post="@Url.Action("Deactivate", "PatientHistory")"
                                          hx-vals='{"historyId": @entry.HistoryId, "patientId": @patientId}'
                                          hx-confirm="Are you sure you want to deactivate this medical history entry? It will no longer be active in records."
                                          hx-target="this" hx-swap="none"
                                          hx-indicator="#deactivate-history-indicator-@entry.HistoryId"
                                          class="inline-block ml-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-outline btn-warning">
                                            Deactivate
                                            <span id="deactivate-history-indicator-@entry.HistoryId" class="htmx-indicator loading loading-spinner loading-xs"></span>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form hx-post="@Url.Action("Activate", "PatientHistory")"
                                          hx-vals='{"historyId": @entry.HistoryId, "patientId": @patientId}'
                                          hx-confirm="Are you sure you want to activate this medical history entry?"
                                          hx-target="this" hx-swap="none"
                                          hx-indicator="#activate-history-indicator-@entry.HistoryId"
                                          class="inline-block ml-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-outline btn-success">
                                            Activate
                                            <span id="activate-history-indicator-@entry.HistoryId" class="htmx-indicator loading loading-spinner loading-xs"></span>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-8">
            <i data-feather="file-text" class="w-12 h-12 mx-auto text-gray-400"></i>
            <p class="mt-2 text-gray-500">No medical history entries found for this patient.</p>
        </div>
    }
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>