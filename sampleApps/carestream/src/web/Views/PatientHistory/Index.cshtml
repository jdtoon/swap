@{
    Layout = null;
    int patientId = ViewData["PatientId"] as int? ?? 0;
}

<div class="mb-4">
    <h3 class="text-lg font-semibold">Patient Medical History</h3>
</div>

<div id="patient-history-list-container" class="card bg-base-100 shadow-xl"
     hx-get="@Url.Action("HistoryListPartial", "PatientHistory", new { patientId = patientId })"
     hx-trigger="load once, refreshPatientHistory from:body"
     hx-swap="innerHTML">
    <div class="card-body">
        <div class="flex justify-center items-center p-10">
            <span class="loading loading-lg loading-spinner"></span>
            <p class="ml-2">Loading medical history...</p>
        </div>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>