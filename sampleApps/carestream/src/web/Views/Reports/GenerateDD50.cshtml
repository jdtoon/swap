@model string?
@{ Layout = null; }

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-700">Medical Examination Report (DD50)</h1>
    <p class="text-gray-500">Generate a comprehensive DD50 report for a patient.</p>
</div>

<div class="card bg-base-100 shadow mb-6">
    <div class="card-body">
        <h2 class="card-title text-lg mb-4">Generate Report</h2>
        <p class="text-sm text-base-content text-opacity-70 mb-4">Enter patient's Force Number to generate the report.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error text-xs p-2 mb-3">
                <ul class="list-disc list-inside">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form hx-post="@Url.Action("DisplayDD50Report", "Reports")"
              hx-target="#dd50-report-display-area" @* Target the report display area *@
              hx-swap="innerHTML"
              hx-indicator="#dd50-generate-indicator">
            @Html.AntiForgeryToken()
            <div class="form-control mb-4">
                <label class="label" for="forceNumberInput">
                    <span class="label-text">Force Number <span class="text-error">*</span></span>
                </label>
                <input type="text" id="forceNumberInput" name="forceNumber" value="@Model" placeholder="Enter 8-digit Force number" class="input input-bordered w-full max-w-xs" required />
            </div>
            <div class="card-actions justify-start items-center">
                <button type="submit" class="btn btn-primary">
                    Generate Medical Report
                    <span id="dd50-generate-indicator" class="htmx-indicator loading loading-spinner loading-md ml-4"></span>
                </button>
            </div>
        </form>
    </div>
</div>

<div id="dd50-report-display-area" class="mt-6">
    <!-- The _DD50ReportDisplayPartial.cshtml will be loaded here -->
    <div class="text-center py-8 text-gray-500">
        <i data-feather="printer" class="w-12 h-12 mx-auto text-gray-400"></i>
        <p class="mt-2">Enter a Force Number and click "Generate" to see the report.</p>
    </div>
</div>

<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>