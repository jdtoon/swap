@using carestream.core.dtos.consultation
@model DD50ReportDto
@{
    Layout = null;
}

<div class="card bg-base-100 shadow-xl p-6">
    <div class="flex justify-between items-center mb-6 print:hidden">
        <h2 class="card-title text-xl">Generated DD50 Report</h2>
        <button class="btn btn-sm btn-primary" onclick="window.print()">
            <i data-feather="printer" class="w-4 h-4 mr-1"></i> Print Report
        </button>
    </div>

    <div class="prose max-w-none text-base-content text-sm" style="page-break-after: always;">
        <!-- Page 1 of Report (Conceptual, layout needs refinement) -->
        <h3 class="text-center text-lg font-bold mb-4">MILITARY MEDICAL EXAMINATION REPORT</h3>
        <p class="text-center text-xs text-opacity-70 mb-6">MEDICAL CONFIDENTIAL</p>

        <!-- 1. Personal Details -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2">1. Personal Details</h4>
        <div class="grid grid-cols-2 gap-x-4">
            <span><strong>Force Number:</strong> @(Model.PatientForceNumber ?? "N/A")</span>
            <span><strong>Gender:</strong> @(Model.PatientGender ?? "N/A")</span>
            <span><strong>Rank & Name:</strong> @(Model.PatientRank ?? "N/A") @(Model.PatientFirstName ?? "N/A") @(Model.PatientLastName ?? "N/A")</span>
            <span><strong>Unit:</strong> @(Model.PatientUnit ?? "N/A")</span>
            <span><strong>Date of Birth:</strong> @(Model.PatientDateOfBirth?.ToString("yyyy-MM-dd") ?? "N/A")</span>
        </div>

        <!-- 2. Medical History -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2 mt-6">2. Medical History</h4>
        <p><strong>Allergies:</strong> @(Model.Allergies ?? "None recorded")</p>
        <p class="mt-2"><strong>Previous Medical Conditions:</strong> @(Model.PreviousMedicalConditions ?? "None recorded")</p>

        <!-- 3. Physical Examination -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2 mt-6">3. Physical Examination</h4>
        <div class="grid grid-cols-2 gap-x-4">
            @* <span><strong>Height:</strong> @(Model.VitalsHeight?.ToString("0.#") ?? "N/A") cm</span> *@
            <span><strong>Pulse Rate:</strong> @(Model.VitalsHeartRate?.ToString() ?? "N/A") bpm</span>
            @* <span><strong>Weight:</strong> @(Model.VitalsWeight?.ToString("0.#") ?? "N/A") kg</span> *@
            <span><strong>Temperature:</strong> @(Model.VitalsTemperature?.ToString("0.#") ?? "N/A")°C</span>
            <span><strong>Blood Pressure:</strong> @(Model.VitalsBloodPressureSystolic?.ToString() ?? "N/A")/@(Model.VitalsBloodPressureDiastolic?.ToString() ?? "N/A") mmHg</span>
            <span><strong>Respiratory Rate:</strong> @(Model.VitalsRespiratoryRate?.ToString() ?? "N/A") breaths/min</span>
            <span><strong>Oxygen Saturation:</strong> @(Model.VitalsOxygenSaturation?.ToString() ?? "N/A")%</span>
            <span><strong>Pain Level:</strong> @(Model.VitalsPainLevel?.ToString() ?? "N/A")/10</span>
        </div>
        <p class="mt-2"><strong>Findings:</strong> @(Model.AssessmentPhysicalExamFindings ?? "N/A")</p>


        <!-- 4. Systems Review -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2 mt-6">4. Systems Review</h4>
        <div class="grid grid-cols-2 gap-x-4">
            <span><strong>Cardiovascular:</strong> @(Model.AssessmentCardiovascularNotes ?? "Normal")</span>
            <span><strong>Respiratory:</strong> @(Model.AssessmentRespiratoryNotes ?? "Normal")</span>
            <span><strong>Musculoskeletal:</strong> @(Model.AssessmentMusculoskeletalNotes ?? "Normal")</span>
            <span><strong>Neurological:</strong> @(Model.AssessmentNeurologicalNotes ?? "Normal")</span>
            <span><strong>Psychological:</strong> @(Model.AssessmentPsychologicalNotes ?? "Normal")</span>
            <span><strong>Other:</strong> @(Model.AssessmentOtherSystemsNotes ?? "Normal")</span>
        </div>
        @* <p class="mt-2"><strong>Additional Notes:</strong> @(Model.VitalsClinicalNotesFromVitals ?? "No additional notes.")</p> *@

        <!-- 5. Medical Classification -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2 mt-6">5. Medical Classification</h4>
        <p><strong>Medical Classification:</strong> @(Model.AssessmentMedicalClassification ?? "N/A")</p>
        <p><strong>Deployment Status:</strong> @(Model.AssessmentDeploymentStatus ?? "N/A")</p>
        <p><strong>Validity Period:</strong> @(Model.AssessmentValidityPeriodMonths.HasValue ? $"{Model.AssessmentValidityPeriodMonths.Value} months" : "N/A")</p>
        <p><strong>Restrictions:</strong> @(Model.AssessmentRestrictions ?? "None")</p>

        <!-- Diagnoses & Procedures Summary -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2 mt-6">Diagnoses & Procedures Summary</h4>
        <p><strong>Diagnoses:</strong> @(Model.Diagnoses ?? "No diagnoses recorded")</p>
        <p><strong>Procedures:</strong> @(Model.Procedures ?? "No procedures recorded")</p>

        <!-- Examining Officer Details -->
        <h4 class="font-bold border-b border-base-300 pb-1 mb-2 mt-6">Examining Officer Details</h4>
        <p><strong>Name:</strong> @(Model.ExaminingOfficerName ?? "N/A")</p>
        <p><strong>Rank:</strong> @(Model.ExaminingOfficerRank ?? "N/A")</p>
        <p><strong>Department:</strong> @(Model.ExaminingOfficerDepartment ?? "N/A")</p>
        <p><strong>Date:</strong> @(Model.ReportGeneratedDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))</p>
        <div class="mt-6">
            <p><strong>Signature:</strong> ___________________________________</p>
        </div>

    </div>
</div>
<script>
    if (typeof feather !== 'undefined') {
        feather.replace();
    }
</script>