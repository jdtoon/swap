<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<Version>0.0.1</Version>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UserSecretsId>aspnet-carestream.web-66bdfb80-da22-42c3-bf1e-de420e5e2d23</UserSecretsId>
		<RootNamespace>carestream.web</RootNamespace>
		<DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
		<DockerfileContext>.</DockerfileContext>
		<DockerComposeProjectPath>..\docker-compose.dcproj</DockerComposeProjectPath>
		<NpmInstalled>false</NpmInstalled>
		<NpmInstalled Condition="'$(OS)' == 'Windows_NT'">$([System.IO.File]::Exists('$(MSBuildThisFileDirectory)\node_modules\.package-lock.json'))</NpmInstalled>
		<NpmInstalled Condition="'$(OS)' != 'Windows_NT'">$([System.IO.File]::Exists('$(MSBuildThisFileDirectory)/node_modules/.package-lock.json'))</NpmInstalled>
	</PropertyGroup>

	<ItemGroup>
		<UpToDateCheckBuilt Include="wwwroot/css/theme.css" Set="Css" />
		<UpToDateCheckBuilt Include="postcss.config.js" Set="Css" />
		<UpToDateCheckBuilt Include="tailwind.config.js" Set="Css" />
	</ItemGroup>

	<ItemGroup>
		<None Include="wwwroot\lib\**\*" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="Logto.AspNetCore.Authentication" Version="0.2.0" />
	  <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" Version="9.0.4" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\core\carestream.core\carestream.core.csproj" />
	  <ProjectReference Include="..\persistence\carestream.persistence\carestream.persistence.csproj" />
	</ItemGroup>

    <!-- NPM Install Target -->
    <Target Name="NpmInstall" BeforeTargets="Build" Condition="!$(NpmInstalled)">
        <Exec Command="npm install" />
    </Target>
    
	<!-- Tailwind CSS Build Target -->
	<Target Name="Tailwind" BeforeTargets="Build" Condition="$(NpmInstalled)">
		<Exec Command="npm run css:build" />
	</Target>

	<!-- Ensure CSS directory exists -->
	<Target Name="EnsureCssDirectory" BeforeTargets="Tailwind">
		<MakeDir Directories="$(MSBuildProjectDirectory)/wwwroot/css" Condition="!Exists('$(MSBuildProjectDirectory)/wwwroot/css')" />
	</Target>
</Project>