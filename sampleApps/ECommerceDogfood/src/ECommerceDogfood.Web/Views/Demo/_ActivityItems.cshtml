@model List<ActivityViewModel>

@foreach (var activity in Model)
{
    <div class="notification is-light mb-2">
        <div class="columns is-mobile is-vcentered">
            <div class="column">
                <span class="icon has-text-info">
                    <i class="fas fa-circle"></i>
                </span>
                @activity.Message
            </div>
            <div class="column is-narrow">
                <small class="has-text-grey">@activity.Timestamp.ToString("HH:mm")</small>
            </div>
        </div>
    </div>
}

@if (ViewBag.HasMore)
{
    <div hx-get="/Demo/LoadMoreActivities?page=@(ViewBag.Page + 1)" 
         hx-trigger="revealed" 
         hx-swap="outerHTML"
         class="has-text-centered p-3">
        <span class="icon">
            <i class="fas fa-spinner fa-pulse"></i>
        </span>
        <span>Loading more...</span>
    </div>
}
else
{
    <div class="has-text-centered has-text-grey p-3">
        <span class="icon">
            <i class="fas fa-check-circle"></i>
        </span>
        <span>No more activities</span>
    </div>
}
