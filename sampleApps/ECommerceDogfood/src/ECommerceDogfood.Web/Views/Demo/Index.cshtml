@{
    ViewData["Title"] = "HTMX Showcase";
}

<div class="hero is-primary">
    <div class="hero-body">
        <p class="title">
            ⚡ HTMX Showcase
        </p>
        <p class="subtitle">
            Interactive examples demonstrating the power of HTMX in NetMX
        </p>
    </div>
</div>

<div class="container mt-5">
    
    <!-- Click to Edit -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-info">
                    <i class="fas fa-edit"></i>
                </span>
                <span>1. Click to Edit</span>
            </span>
        </h2>
        <p class="mb-3">Click the "Edit" button to swap the display with an editable form inline.</p>
        
        <div id="contact-container" hx-get="/Demo/Contact" hx-trigger="load">
            <div class="has-text-centered">
                <span class="icon is-large">
                    <i class="fas fa-spinner fa-pulse"></i>
                </span>
            </div>
        </div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-get</code> with <code>hx-swap="outerHTML"</code> to replace content inline.
        </div>
    </div>

    <!-- Delete with Confirmation -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-danger">
                    <i class="fas fa-trash"></i>
                </span>
                <span>2. Delete with Confirmation</span>
            </span>
        </h2>
        <p class="mb-3">Delete items with built-in confirmation. The row animates out on delete.</p>
        
        <div id="item-list" hx-get="/Demo/ItemList" hx-trigger="load">
            <div class="has-text-centered">
                <span class="icon is-large">
                    <i class="fas fa-spinner fa-pulse"></i>
                </span>
            </div>
        </div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-delete</code> with <code>hx-confirm</code> and <code>hx-swap="delete"</code> response.
        </div>
    </div>

    <!-- Infinite Scroll -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-success">
                    <i class="fas fa-stream"></i>
                </span>
                <span>3. Infinite Scroll</span>
            </span>
        </h2>
        <p class="mb-3">Scroll down to automatically load more items.</p>
        
        <div class="activity-feed" style="max-height: 400px; overflow-y: auto; border: 1px solid #dbdbdb; padding: 1rem; border-radius: 4px;">
            <div id="activity-list">
                <div hx-get="/Demo/LoadMoreActivities?page=1" 
                     hx-trigger="load" 
                     hx-swap="outerHTML">
                    <div class="has-text-centered">
                        <span class="icon is-large">
                            <i class="fas fa-spinner fa-pulse"></i>
                        </span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-trigger="revealed"</code> to load content when scrolled into view.
        </div>
    </div>

    <!-- Search with Debounce -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-warning">
                    <i class="fas fa-search"></i>
                </span>
                <span>4. Search with Debounce</span>
            </span>
        </h2>
        <p class="mb-3">Type to search. Results update automatically with a 500ms debounce.</p>
        
        <div class="field">
            <div class="control has-icons-left">
                <input class="input" 
                       type="text" 
                       name="q"
                       placeholder="Search products..."
                       hx-get="/Demo/SearchProducts" 
                       hx-trigger="keyup changed delay:500ms" 
                       hx-target="#search-results"
                       hx-indicator="#search-spinner">
                <span class="icon is-left">
                    <i class="fas fa-search"></i>
                </span>
            </div>
        </div>
        
        <div id="search-spinner" class="htmx-indicator has-text-centered mt-3">
            <span class="icon">
                <i class="fas fa-spinner fa-pulse"></i>
            </span>
            <span>Searching...</span>
        </div>
        
        <div id="search-results" class="mt-3"></div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-trigger="keyup changed delay:500ms"</code> for debounced search.
        </div>
    </div>

    <!-- Tab Switching -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-link">
                    <i class="fas fa-th-large"></i>
                </span>
                <span>5. Tab Switching</span>
            </span>
        </h2>
        <p class="mb-3">Switch between tabs without page reload. Content is loaded dynamically.</p>
        
        <div class="tabs is-boxed">
            <ul>
                <li class="is-active" id="tab-overview-btn">
                    <a hx-get="/Demo/TabContent?tab=overview" 
                       hx-target="#tab-content"
                       hx-on::after-request="document.querySelectorAll('.tabs li').forEach(t => t.classList.remove('is-active')); document.getElementById('tab-overview-btn').classList.add('is-active')">
                        <span class="icon is-small"><i class="fas fa-image"></i></span>
                        <span>Overview</span>
                    </a>
                </li>
                <li id="tab-features-btn">
                    <a hx-get="/Demo/TabContent?tab=features" 
                       hx-target="#tab-content"
                       hx-on::after-request="document.querySelectorAll('.tabs li').forEach(t => t.classList.remove('is-active')); document.getElementById('tab-features-btn').classList.add('is-active')">
                        <span class="icon is-small"><i class="fas fa-star"></i></span>
                        <span>Features</span>
                    </a>
                </li>
                <li id="tab-pricing-btn">
                    <a hx-get="/Demo/TabContent?tab=pricing" 
                       hx-target="#tab-content"
                       hx-on::after-request="document.querySelectorAll('.tabs li').forEach(t => t.classList.remove('is-active')); document.getElementById('tab-pricing-btn').classList.add('is-active')">
                        <span class="icon is-small"><i class="fas fa-dollar-sign"></i></span>
                        <span>Pricing</span>
                    </a>
                </li>
            </ul>
        </div>
        
        <div id="tab-content" class="p-4" hx-get="/Demo/TabContent?tab=overview" hx-trigger="load">
            Loading...
        </div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-get</code> with <code>hx-target</code> to swap tab content.
        </div>
    </div>

    <!-- Form Validation -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-primary">
                    <i class="fas fa-check-circle"></i>
                </span>
                <span>6. Form Validation</span>
            </span>
        </h2>
        <p class="mb-3">Submit the form to see server-side validation in action.</p>
        
        <div id="signup-container">
            @await Html.PartialAsync("_SignupForm", new SignupViewModel())
        </div>
        
        <div id="signup-notification" class="mt-3"></div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-post</code> with model validation and partial view updates.
        </div>
    </div>

    <!-- Out of Band Updates -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-dark">
                    <i class="fas fa-broadcast-tower"></i>
                </span>
                <span>7. Out-of-Band Updates</span>
            </span>
        </h2>
        <p class="mb-3">Update multiple parts of the page simultaneously with one request.</p>
        
        <div class="columns">
            <div class="column">
                <div class="notification is-light">
                    <strong>Header:</strong>
                    <div id="oob-header">Not updated yet</div>
                </div>
            </div>
            <div class="column">
                <div class="notification is-light">
                    <strong>Content:</strong>
                    <div id="oob-content">Not updated yet</div>
                </div>
            </div>
            <div class="column">
                <div class="notification is-light">
                    <strong>Footer:</strong>
                    <div id="oob-footer">Not updated yet</div>
                </div>
            </div>
        </div>
        
        <button class="button is-primary" 
                hx-post="/Demo/UpdateMultiple" 
                hx-target="#oob-content">
            Update All Three Sections
        </button>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-swap-oob</code> to update multiple elements in one response.
        </div>
    </div>

    <!-- Lazy Loading -->
    <div class="box">
        <h2 class="title is-4">
            <span class="icon-text">
                <span class="icon has-text-info">
                    <i class="fas fa-hourglass-half"></i>
                </span>
                <span>8. Lazy Loading</span>
            </span>
        </h2>
        <p class="mb-3">Content loads automatically when scrolled into view.</p>
        
        <div class="columns">
            <div class="column">
                <div class="card">
                    <div class="card-content">
                        <p class="title is-6">Lazy Image</p>
                        <div hx-get="/Demo/LazyImage" 
                             hx-trigger="revealed" 
                             hx-swap="outerHTML"
                             style="min-height: 150px; display: flex; align-items: center; justify-content: center;">
                            <span class="icon is-large">
                                <i class="fas fa-spinner fa-pulse"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="column">
                <div class="card">
                    <div class="card-content">
                        <p class="title is-6">Lazy Chart</p>
                        <div hx-get="/Demo/LazyChart" 
                             hx-trigger="revealed" 
                             hx-swap="outerHTML"
                             style="min-height: 150px; display: flex; align-items: center; justify-content: center;">
                            <span class="icon is-large">
                                <i class="fas fa-spinner fa-pulse"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="notification is-light is-info mt-3">
            <strong>Pattern:</strong> <code>hx-trigger="revealed"</code> to load content when visible.
        </div>
    </div>

</div>

<style>
    .htmx-indicator {
        display: none;
    }

    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator {
        display: inline-block;
    }

    /* Fade in animation for loaded content */
    [hx-get], [hx-post] {
        transition: opacity 200ms ease-in;
    }

    .htmx-swapping {
        opacity: 0;
        transition: opacity 200ms ease-out;
    }

    .htmx-settling {
        opacity: 1;
    }
</style>

<script>
    // Listen for signup success event
    document.body.addEventListener('signup-success', function(evt) {
        const notification = document.getElementById('signup-notification');
        notification.innerHTML = `
            <div class="notification is-success">
                <button class="delete"></button>
                <strong>Success!</strong> Account created for ${evt.detail.email}
            </div>
        `;
        
        // Add close functionality
        notification.querySelector('.delete').addEventListener('click', function() {
            notification.innerHTML = '';
        });
    });
</script>
