@inject IHttpContextAccessor HttpContextAccessor

<!-- Top Section -->
<div hx-get="@Url.Action("GetBurgerMenu","Home")"
     hx-trigger="load"
     hx-target="#navbar-start-placeholder"
     hx-swap="innerHtml transition:true"
     hx-indicator="#loading-indicator">
</div>

<div hx-get="@Url.Action("GetPageHeading", "Home")"
     hx-vals='{"heading": "Members" }'
     hx-target="#navbar-center-placeholder"
     hx-swap="innerHtml transition:true"
     hx-trigger="load"
     hx-indicator="#loading-indicator">
</div>

<div hx-get="@Url.Action("GetLoginPartial", "Home")"
     hx-target="#navbar-end-placeholder"
     hx-swap="innerHtml transition:true"
     hx-trigger="load"
     hx-indicator="#loading-indicator">
</div>

<div hx-get="@Url.Action("ClearDiv", "Home")"
     hx-target="#search-bar-container"
     hx-swap="innerHtml transition:true"
     hx-trigger="load"
     hx-indicator="#loading-indicator">
</div>

<div class="p-4">
    <!-- Search Form -->
    <form hx-get="@Url.Action("GetMembers", "Members")"
          hx-target="#members-list"
          hx-trigger="keyup changed delay:500ms, change from:input, change from:select"
          hx-indicator="#loading-indicator"
          class="space-y-2 mb-6">
        <input id="search-input"
               class="input input-bordered w-full"
               type="text"
               name="search"
               placeholder="Search members..." 
               value="@(HttpContextAccessor.HttpContext?.Session.GetString("SelectedSearchMembers") ?? "")" />

        <select id="status-filter"
                name="status"
                class="select select-bordered w-full">
            <option value="">All Status</option>
            <option value="Active">Active</option>
            <option value="Inactive">Inactive</option>
        </select>
    </form>

    <!-- Members List -->
    <div id="members-list"
         class="space-y-4"
         hx-get="@(string.IsNullOrEmpty(HttpContextAccessor.HttpContext?.Session.GetString("SelectedSearchMembers")) ?
            Url.Action("GetMembers", "Members") :
            Url.Action("GetMembers", "Members", new { search = HttpContextAccessor.HttpContext?.Session.GetString("SelectedSearchMembers") }))"
         hx-trigger="load"
         hx-target="#members-list">
    </div>

    <!-- Pagination -->
    <div class="flex justify-between items-center mt-6 gap-4">
        <button id="prev-page"
                class="btn bg-sky-300 flex-1 text-white"
                hx-get="@Url.Action("GetMembers", "Members")"
                hx-target="#members-list"
                hx-indicator="#loading-indicator"
                hx-vars='{
                    search: document.getElementById("search-input").value,
                    status: document.getElementById("status-filter").value,
                    page: currentPage - 1
                }'>
            Previous
        </button>

        <button id="next-page"
                class="btn bg-sky-300 flex-1 text-white"
                hx-get="@Url.Action("GetMembers", "Members")"
                hx-target="#members-list"
                hx-indicator="#loading-indicator"
                hx-vars='{
                    search: document.getElementById("search-input").value,
                    status: document.getElementById("status-filter").value,
                    page: currentPage + 1
                }'>
            Next
        </button>
    </div>
</div>

@if (ViewBag.IsHTMXRequest == true)
{
    <script defer src="~/js/members.js" asp-append-version="true"></script>
}
else
{
    @section Scripts {
    <script defer src="~/js/members.js" asp-append-version="true"></script>
    }
}