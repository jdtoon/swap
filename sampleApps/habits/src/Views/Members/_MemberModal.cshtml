@model MemberDto

<dialog id="member_modal" class="modal modal-middle" open>
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Edit Member</h3>
        <form hx-put="@Url.Action("UpdateMember", "Members")"
              hx-target="#member-@Model.Id"
              hx-swap="outerHTML transition:true"
              hx-on::after-request="member_modal.close()"
              hx-indicator="#loading-indicator"
              class="space-y-4">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-control">
                <label class="label">
                    <span class="label-text">Name</span>
                </label>
                <input type="text" name="name" value="@Model.Name" class="input input-bordered" />
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text">Surname</span>
                </label>
                <input type="text" name="surname" value="@Model.Surname" class="input input-bordered" />
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text">Role</span>
                </label>
                <select name="role" class="select select-bordered w-full">
                    <option value="member" selected="@(Model.Role == "member")">Member</option>
                    <option value="admin" selected="@(Model.Role == "admin")">Admin</option>
                    <option value="user" selected="@(Model.Role == "user")">User</option>
                </select>
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text">Color</span>
                </label>
                <input type="color" name="color" value="@Model.Color" class="input input-bordered w-full h-12" />
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text">Phone Number</span>
                </label>
                <input type="tel" name="phoneNumber" value="@Model.PhoneNumber" class="input input-bordered" />
            </div>

            <div class="form-control">
                <label class="label">
                    <span class="label-text">Email</span>
                </label>
                <input type="email" value="@Model.Email" class="input input-bordered" disabled />
            </div>

            <div class="modal-action">
                @if (User.IsInRole("admin") ||
                     User.Identity!.Name == Model.Email)
                {
                    <button type="submit" class="btn btn-primary">Save</button>
                }
                <button type="button" class="btn" onclick="member_modal.close()">Close</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>