@model MemberDto

<li id="member-@Model.Id" class="border-b border-base-300 last:border-none">
    <div class="flex justify-between items-center w-full py-2 px-4">
        <span class="flex items-center gap-2 flex-1 cursor-pointer"
              hx-get="@Url.Action("GetMemberModal", "Members")"
              hx-vals='{"id": "@Model.Id"}'
              hx-target="#modal-container"
              hx-trigger="click"
              hx-indicator="#loading-indicator">
            @if (!string.IsNullOrEmpty(Model.Name) && !string.IsNullOrEmpty(Model.Surname))
            {
                @($"{Model.Name} {Model.Surname}")
            }
            else
            {
                @Model.Email
            }
        </span>
        <span class="flex items-center gap-2">
            <partial name="_ToggleStatusButton" model="Model" />
            <span class="w-6 h-6 rounded-full" style="background-color: @Model.Color"></span>
        </span>
    </div>
</li>