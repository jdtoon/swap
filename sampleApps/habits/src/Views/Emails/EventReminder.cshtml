<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Calendar Reminder</title>
</head>
<body style="margin: 0; padding: 0;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background: linear-gradient(180deg, #FFFFFF 0%, #977abb 100%); background-color: #977abb; min-height: 100vh;">
        <tr>
            <td align="center" style="padding: 1.875rem;">
                <div style="max-width: 380px; width: 90%; background-color: white; border-radius: 24px; padding: 32px 24px; box-shadow: 0px 4px 20px rgba(0,0,0,0.05); position: relative; border: 2px solid black;">
                    <!-- Bell Icon Circle -->
                    <div style="width: 65px; height: 65px; background-color: #977abb; border-radius: 50%; position: absolute; top: -28px; left: 50%; transform: translateX(-50%); text-align: center; border: 2px solid black;">
                        <span style="font-size: 32px; color: #FFFFFF; line-height: 65px;">🔔</span>
                    </div>

                    <!-- Content -->
                    <div style="text-align: center; padding-top: 10px;">
                        <h1 style="font-family: Arial, sans-serif; font-style: italic; font-weight: 500; font-size: 34px; margin: 16px 0 8px 0; color: #000000;">Reminder</h1>
                        <h2 style="font-family: Arial, sans-serif; font-weight: 500; font-size: 20px; margin: 0 0 32px 0; color: #000000;">Upcoming Habits Calendar Event</h2>

                        <div style="text-align: left; max-width: 280px; margin: 0 auto;">
                            <!-- Star Icon and Text -->
                            <div style="margin-bottom: 16px; display: flex; align-items: center;">
                                <span style="font-size: 20px;">⭐</span>
                                <span style="margin-left: 12px; font-size: 21px; font-weight: 400; color: #000000;">@Model.Title</span>
                            </div>

                            <!-- Calendar Icon and Date -->
                            <div style="margin-bottom: 16px; display: flex; align-items: center;">
                                <span style="font-size: 20px;">📅</span>
                                <span style="margin-left: 12px; font-size: 21px; font-weight: 400; color: #000000;">@Model.StartDate.ToString("MM/dd/yy")</span>
                            </div>

                            <!-- Clock Icon and Time -->
                            <div style="margin-bottom: 16px; display: flex; align-items: center;">
                                <span style="font-size: 20px;">⏰</span>
                                <span style="margin-left: 12px; font-size: 21px; font-weight: 400; color: #000000;">@(Model.StartTime?.ToString() ?? "All Day")</span>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <!-- Location Icon and Place -->
                                <div style="margin-bottom: 16px; display: flex; align-items: center;">
                                    <span style="font-size: 20px;">📍</span>
                                    <span style="margin-left: 12px; font-size: 21px; font-weight: 400; color: #000000;">@Model.Description</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </td>
        </tr>
    </table>
</body>
</html>