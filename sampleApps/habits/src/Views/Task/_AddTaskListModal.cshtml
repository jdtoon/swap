@model TaskListDto

<dialog id="edit-modal-@Model.Id" class="modal modal-middle sm:modal-middle">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Add List</h3>
        <div class="py-4">
            <form hx-post="@Url.Action("CreateTaskList", "Task")"
                  hx-target="#task-lists-sortable"
                  hx-swap="afterbegin transition:true"
                  hx-indicator="#loading-indicator"
                  hx-headers='{"Content-Type": "application/json"}'
                  hx-on::after-swap="closeTaskModal(@Model.Id)"
                  hx-on::after-request="if(event.detail.successful) closeTaskModal(@Model.Id)"
                  class="space-y-4">
                @Html.AntiForgeryToken()
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Name</span>
                    </label>
                    <input type="text" name="name" value="@Model.Name" class="input input-bordered" required />
                </div>
                <div class="form-control">
                    <label class="label">
                        <span class="label-text">Description</span>
                    </label>
                    <textarea name="description" class="textarea textarea-bordered">@Model.Description</textarea>
                </div>
                <div class="modal-action">
                    <button type="button" class="btn" onclick="closeTaskModal(@Model.Id)">Close</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="closeTaskModal(@Model.Id)">close</button>
    </form>
</dialog>

<script>
    document.getElementById('edit-modal-@Model.Id').showModal();
</script>