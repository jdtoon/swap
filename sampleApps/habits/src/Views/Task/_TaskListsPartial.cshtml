@model TaskListDto

<div class="sortable-item" data-id="@Model.Id" data-order="@Model.Order">
    <div class="card bg-white text-gray-500 shadow-2xl w-full my-4">
        <div class="card-body p-2">
            <div class="flex items-start gap-4">
                <!-- Icon Section -->
                <div class="rounded-full bg-orange-300 w-12 h-12"
                     hx-get="@Url.Action("Index", "Item")"
                     hx-vals='{"taskListId": "@Model.Id"}'
                     hx-target="#primary-container"
                     hx-swap="innerHtml transition:true"
                     hx-trigger="click">
                     <div class="">
                        <img src="~/svg/tick-circle.svg" class="p-2"/>
                     </div>
                </div>

                <!-- Content Section -->
                <div class="flex-grow"
                     hx-get="@Url.Action("Index", "Item")"
                     hx-vals='{"taskListId": "@Model.Id"}'
                     hx-target="#primary-container"
                     hx-swap="innerHtml transition:true"
                     hx-trigger="click">
                    <div id="tasklist-content-@Model.Id" class="flex-grow">
                        <h2 class="card-title text-lg font-bold text-base-200">@Model.Name</h2>
                        <p class="text-base-content/70 text-sm mb-2">@Model.Description</p>
                    </div>

                    <div class="text-sm">
                        @if (Model.TaskListItems.Where(x => !x.IsHeader).Count() > 3)
                        {
                            <ul class="space-y-1">
                                @for (int x = 0; x < 3; x++)
                                {
                                    <li class="text-gray-500">@Model.TaskListItems[x].Task</li>
                                }
                            </ul>
                            <span class="text-gray-300 text-xs italic">plus @Model.NoOfTasks more items</span>
                        }
                        else
                        {
                            <ul class="space-y-1">
                                @foreach (var item in Model.TaskListItems.Where(x => !x.IsHeader))
                                {
                                    <li>@item.Task</li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <!-- Actions Section -->
                <div class="flex-none flex flex-col space-y-2">
                    <button class="btn btn-ghost btn-sm"
                            hx-get="@Url.Action("EditTaskList", "Task", new { id = Model.Id })"
                            hx-target="body"
                            hx-swap="beforeend transition:true">
                        <img src="~/svg/edit.svg" class="h-5 w-5" />
                    </button>
                    <button class="btn btn-ghost btn-sm"
                            hx-delete="@Url.Action("DeleteTaskList", "Task", new { id = Model.Id })"
                            hx-target="closest .card"
                            hx-swap="outerHTML transition:true"
                            hx-confirm="Are you sure you want to delete this list?"
                            title="Delete list">
                        <img src="~/svg/delete.svg" class="h-5 w-5" />
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
