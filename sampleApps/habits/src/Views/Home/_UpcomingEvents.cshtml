@model List<CalendarEventDto>

@if(Model.Count == 0)
{
    <p>No upcoming events</p>
}
else
{
    @foreach (var calendarEvent in Model)
    {
        <div class="card bg-white shadow-lg"
             hx-get="@($"/Calendar?date={calendarEvent.StartDate:yyyy-MM-dd}")"
             hx-target="#primary-container"
             hx-push-url="true"
             hx-swap="innerHTML transition:true">
            <div class="card-body p-3 flex flex-row items-center gap-3">
                <div class="bg-orange-300 rounded-full p-2">
                    <img src="@calendarEvent.EventType.IconPath" class="h-12 w-12">
                </div>
                <div class="flex flex-col">
                    <h2 class="font-bold text-gray-600">@calendarEvent.Title</h2>
                    <div class="text-sm text-gray-500">
                        @calendarEvent.StartDate.ToShortDateString()
                        @if (calendarEvent.StartTime.HasValue)
                        {
                            <text> - @DateTime.Today.Add(calendarEvent.StartTime.Value).ToString("hh:mm tt")</text>
                        }
                    </div>
                    @if (calendarEvent.Description != null)
                    {
                        <div class="text-xs text-gray-300">@calendarEvent.Description</div>
                    }
                </div>
            </div>
        </div>
    }
}

