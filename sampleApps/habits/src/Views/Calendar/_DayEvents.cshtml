@model List<CalendarEventDto>

<!-- All Day Events -->
@if (Model.Any(e => e.StartTime == null && e.EndTime == null))
{
    <div class="mb-4">
        @foreach (var evt in Model.Where(e => e.StartTime == null && e.EndTime == null))
        {
            <div id="day-viewer-evt-@evt.Id"
                 class="rounded-xl p-3 mb-1"
                 style="background-color: @evt.EventType.Color">
                <div class="flex justify-between items-center">
                    <span class="font-medium text-lg text-gray-700 truncate font-satisfy">@evt.Title</span>
                    <button class="btn btn-xs btn-ghost"
                            hx-get="@Url.Action("GetEvent", "Calendar", new { id = evt.Id })"
                            hx-target="#edit-event-modal-content">
                        <img src="~/svg/edit.svg" class="h-5 w-5" />
                    </button>
                </div>
            </div>
        }
    </div>
}

<!-- Timed Events -->
<div class="grid grid-cols-[80px_1fr] gap-0 w-full">
    @for (int hour = 0; hour < 24; hour++)
    {
        <div class="relative border-t-2 border-gray-200">
            <!-- Vertical line with dots -->
            <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-gray-200">
                @foreach (var evt in Model.Where(e => e.StartTime?.Hours == hour))
                {
                    <div class="absolute w-3 h-3 rounded-full -left-[5px] z-10" 
                         style="top: @(evt.StartTime?.Minutes ?? 0)px; background-color: @evt.EventType.Color">
                    </div>
                }
            </div>

            <!-- Time display with larger font -->
            <div class="text-2xl font-semibold text-gray-600 pt-2 pl-4 text-left">@hour.ToString("00"):00</div>
        </div>
        
        <div class="relative min-h-[60px] border-t-2 border-gray-200 pl-4 w-full">
            @foreach (var evt in Model.Where(e => e.StartTime?.Hours == hour))
            {
                @* Calculate overlapping events *@
                var overlappingEvents = Model.Where(e => 
                    e.StartTime.HasValue && evt.StartTime.HasValue &&
                    e.Id != evt.Id &&
                    ((e.EndTime.HasValue && evt.EndTime.HasValue && // Both events have end times
                        ((e.StartTime <= evt.StartTime && e.EndTime > evt.StartTime) ||
                         (e.StartTime < evt.EndTime && e.EndTime >= evt.EndTime) ||
                         (e.StartTime >= evt.StartTime && e.EndTime <= evt.EndTime))) ||
                    (!e.EndTime.HasValue && evt.EndTime.HasValue && // e has no end time
                        (e.StartTime >= evt.StartTime && e.StartTime <= evt.EndTime)) ||
                    (e.EndTime.HasValue && !evt.EndTime.HasValue && // evt has no end time
                        (e.StartTime <= evt.StartTime && e.EndTime >= evt.StartTime)) ||
                    (!e.EndTime.HasValue && !evt.EndTime.HasValue && // neither has end time
                        (Math.Abs((e.StartTime.Value - evt.StartTime.Value).TotalMinutes) < 50)))
                ).ToList();
                
                var overlapIndex = overlappingEvents.Count > 0 ? 
                    overlappingEvents.Count(e => e.Id < evt.Id) : 0;
                var totalOverlaps = overlappingEvents.Count + 1;
                
                @* Calculate width and left offset *@
                var width = 95 / totalOverlaps;
                var leftOffset = width * overlapIndex;
                
                @* Calculate height based on start/end times *@
                string heightStyle = "";
                if (evt.StartTime.HasValue && evt.EndTime.HasValue)
                {
                    var duration = evt.EndTime.Value - evt.StartTime.Value;
                    var heightInMinutes = duration.TotalMinutes;
                    heightStyle = $"height: {heightInMinutes}px;";
                }

                <div id="day-viewer-evt-@evt.Id"
                     class="absolute rounded-xl p-3 z-10 ml-2"
                     style="top: @(evt.StartTime?.Minutes ?? 0)px; 
                            @heightStyle 
                            width: @(width)%; 
                            left: @(leftOffset)%;
                            background-color: @evt.EventType.Color">
                    <div class="flex flex-wrap justify-between items-start gap-1">
                        <div class="flex-1 min-w-0">
                            <div class="font-bold text-lg text-gray-700 truncate font-satisfy">@evt.Title</div>
                            @if (!string.IsNullOrEmpty(evt.Description))
                            {
                                <div class="text-md text-gray-600 truncate font-satisfy">@evt.Description</div>
                            }
                        </div>
                        <button class="btn btn-xs btn-ghost shrink-0"
                                hx-get="@Url.Action("GetEvent", "Calendar", new { id = evt.Id })"
                                hx-target="#edit-event-modal-content">
                            <img src="~/svg/edit.svg" class="h-5 w-5" />
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>