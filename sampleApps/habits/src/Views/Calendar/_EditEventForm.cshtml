@model CalendarEventDto

<dialog id="edit-event-modal" class="modal" open>
    <div class="modal-box">
        <form hx-post="@Url.Action("UpdateEvent", "Calendar", new { id = Model.Id })"
              hx-target="#day-events-container"
              hx-swap="innerHtml transition:true"
              hx-on::after-request="if(event.detail.successful) { closeEditModal(); }">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.StartDate)
            <h3 class="font-bold text-lg mb-4">Edit Event</h3>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Start Date</span>
                </label>
                <input type="date" 
                       value="@Model.StartDate.ToString("yyyy-MM-dd")"
                       class="input input-bordered w-full"
                       disabled />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label cursor-pointer">
                    <span class="label-text">Full Day Event</span>
                    <input type="checkbox"
                           class="checkbox"
                           name="IsFullDay"
                           @((!Model.StartTime.HasValue && !Model.EndTime.HasValue) ? "checked" : "")
                           onchange="toggleEditTimeInputs(this.checked)" />
                </label>
            </div>

            <div id="edit-time-inputs" class="@((!Model.StartTime.HasValue && !Model.EndTime.HasValue) ? "hidden" : "")">
                <div class="form-control w-full mb-4">
                    <label class="label">
                        <span class="label-text">Start Time</span>
                    </label>
                    <input type="time"
                           name="StartTime"
                           value="@(Model.StartTime?.ToString(@"hh\:mm"))"
                           class="input input-bordered w-full" />
                </div>

                <div class="form-control w-full mb-4">
                    <label class="label">
                        <span class="label-text">End Time</span>
                    </label>
                    <input type="time"
                           name="EndTime"
                           value="@(Model.EndTime?.ToString(@"hh\:mm"))"
                           class="input input-bordered w-full" />
                </div>
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Title</span>
                </label>
                <input type="text"
                       name="Title"
                       value="@Model.Title"
                       class="input input-bordered w-full"
                       required />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Event Type</span>
                </label>
                <select name="CalendarEventTypeId" class="select select-bordered w-full" required>
                    @{
                        var eventTypes = JsonSerializer.Deserialize<List<CalendarEventTypeDto>>(
                            Context.Session.GetString("EventTypes") ?? "[]");
                        foreach (var type in eventTypes!)
                        {
                            @if(type.Id == Model.CalendarEventTypeId)
                            {
                                <option value="@type.Id" selected>
                                    @type.Name
                                </option>
                            }
                            else
                            {
                                <option value="@type.Id">
                                    @type.Name
                                </option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">End Date (Optional)</span>
                </label>
                <input type="datetime-local"
                       name="EndDate"
                       value="@(Model.EndDate?.ToString("yyyy-MM-ddTHH:mm"))"
                       class="input input-bordered w-full" />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Reminder? (Optional)</span>
                </label>
                <input type="datetime-local"
                       name="ReminderDateTime"
                       value="@(Model.ReminderDateTime?.ToString("yyyy-MM-ddTHH:mm"))"
                       class="input input-bordered w-full" />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Description (Optional)</span>
                </label>
                <textarea name="Description"
                          class="textarea textarea-bordered w-full"
                          rows="3">@Model.Description</textarea>
            </div>

            <div class="modal-action sticky bottom-0 bg-base-100 z-10 p-4">
                <button type="button" 
                        class="btn btn-error"
                        hx-delete="@Url.Action("DeleteEvent", "Calendar", new { id = Model.Id })"
                        hx-confirm="Are you sure you want to delete this event?"
                        hx-target="#day-viewer-evt-@Model.Id"
                        hx-swap="innerHtml transition:true"
                        hx-on::after-request="if(event.detail.successful) { closeEditModal(); }">
                    Delete
                </button>
                <button type="button" class="btn" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</dialog>