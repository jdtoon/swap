@model DayViewerDto

<dialog id="day-viewer" class="modal modal-bottom sm:modal-middle" open>
    <div class="modal-box max-w-5xl relative bg-white">
        <div class="sticky top-0 right-4 z-50 float-right">
            <button class="btn btn-sm btn-circle bg-purple-300 text-base-200"
                    hx-get="@Url.Action("ClearDiv", "Home")"
                    hx-target="#day-viewer-container"
                    hx-swap="innerHtml transition:true"
                    hx-trigger="click"
                    hx-indicator="#loading-indicator">
                ✕
            </button>
        </div>

        <div class="mb-4">
            <h2 class="text-xl font-semibold text-purple-300">@Model.Date.ToString("d MMMM yyyy")</h2>
        </div>

        <div id="day-events-container"
             hx-get="@Url.Action("GetDayViewer", "Calendar")"
             hx-trigger="eventUpdated from:body"
             hx-target="#day-viewer"
             hx-swap="innerHtml transition:true"
             hx-indicator="#loading-indicator"
             hx-vals='{"date": "@Model.Date.ToString("yyyy-MM-dd")"}'>

            <partial name="_DayEvents" model="Model.Events" />
        </div>

        <div class="modal-action sticky bottom-0 z-10 p-4">
            <button class="btn bg-purple-300 text-base-200"
                    onclick="showAddEventModal('@Model.Date.ToString("yyyy-MM-dd")')">
                Add Event
            </button>
        </div>
    </div>
</dialog>

<div id="edit-event-modal-content"></div>