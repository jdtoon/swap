<input type="checkbox" id="add-event-modal" class="modal-toggle" />
<div class="modal">
    <div class="modal-box">
        <form id="calendar-day-date"
              hx-post="@Url.Action("AddEvent", "Calendar")"
              hx-swap="none"
              hx-on::after-request="if(event.detail.successful) { closeModal(); this.reset(); }">
            @Html.AntiForgeryToken()
            <h3 class="font-bold text-lg mb-4">Add New Event</h3>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Start Date</span>
                </label>
                <input type="date"
                       name="StartDate"
                       id="startDate"
                       class="input input-bordered w-full cursor-not-allowed bg-base-200"
                       required
                       readonly />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label cursor-pointer">
                    <span class="label-text">Full Day Event</span>
                    <input type="checkbox"
                           class="checkbox"
                           id="isFullDay"
                           name="IsFullDay"
                           onchange="toggleTimeInputs(this.checked)" />
                </label>
            </div>

            <div id="timeInputs">
                <div class="form-control w-full mb-4">
                    <label class="label">
                        <span class="label-text">Start Time</span>
                    </label>
                    <input type="time"
                           name="StartTime"
                           class="input input-bordered w-full" />
                </div>

                <div class="form-control w-full mb-4">
                    <label class="label">
                        <span class="label-text">End Time</span>
                    </label>
                    <input type="time"
                           name="EndTime"
                           class="input input-bordered w-full" />
                </div>
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Title</span>
                </label>
                <input type="text"
                       name="Title"
                       class="input input-bordered w-full"
                       required />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Event Type</span>
                </label>
                <select name="CalendarEventTypeId" class="select select-bordered w-full" required>
                    <option value="">Select an event type</option>
                    @{
                        var eventTypes = JsonSerializer.Deserialize<List<CalendarEventTypeDto>>(
                        Context.Session.GetString("EventTypes") ?? "[]");
                        foreach (var type in eventTypes!)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">End Date (Optional)</span>
                </label>
                <input type="datetime-local"
                       name="EndDate"
                       class="input input-bordered w-full" />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Reminder? (Optional)</span>
                </label>
                <input type="datetime-local"
                       name="ReminderDateTime"
                       class="input input-bordered w-full" />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Description (Optional)</span>
                </label>
                <textarea name="Description"
                          class="textarea textarea-bordered w-full"
                          rows="3"></textarea>
            </div>

            <div class="modal-action sticky bottom-0 bg-base-100 z-10 p-4">
                <label for="add-event-modal" class="btn">Cancel</label>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>