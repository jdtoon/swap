@model CalendarDto
@inject IHttpContextAccessor HttpContextAccessor

<div class="w-full mx-auto rounded-lg shadow-md"
     hx-trigger="calendarUpdated from:body"
     hx-get="@Url.Action("GetCalendar", "Calendar")"
     hx-target="#primary-calendar-container"
     hx-on:htmx:config-request="if (!event.detail.parameters.date) { event.detail.parameters.date = event.detail.triggeringEvent.detail.date || ''; }">

    <div class="w-full mx-auto rounded-lg shadow-md">
        <!-- Month Navigation -->
        <div class="flex justify-between items-center mb-8 px-2">
            <button class="btn bg-purple-300 btn-sm"
                    hx-get="@Url.Action("GetCalendar", "Calendar")"
                    hx-vals='{"date": "@Model.MonthData.FirstDay.AddMonths(-1).ToString("yyyy-MM-dd")"}'>
                <img src="~/svg/arrow-left.svg" class="h-4 w-4" />
            </button>
            <h2 class="text-xl font-bold text-purple-300">
                @Model.MonthData.MonthName @Model.MonthData.Year
            </h2>
            <button class="btn bg-purple-300 btn-sm"
                    hx-get="@Url.Action("GetCalendar", "Calendar")"
                    hx-vals='{"date": "@Model.MonthData.FirstDay.AddMonths(1).ToString("yyyy-MM-dd")"}'>
                <img src="~/svg/arrow-right.svg" class="h-4 w-4" />
            </button>
        </div>

        <!-- Days of the Week -->
        <div class="grid grid-cols-7 text-center font-bold text-sm text-gray-600">
            <div>Sun</div>
            <div>Mon</div>
            <div>Tue</div>
            <div>Wed</div>
            <div>Thu</div>
            <div>Fri</div>
            <div>Sat</div>
        </div>

        <!-- Calendar Grid -->
        <div class="grid grid-cols-7 mt-4 text-center">
            @for (int i = 0; i < Model.MonthData.FirstDayOfWeek; i++)
            {
                <div class="p-4"></div>
            }

            @foreach (var day in Model.MonthData.Days)
            {
                <partial name="_CalendarDay" model="day" />
            }
        </div>

        <!-- Legend -->
        <div class="mt-8 flex flex-wrap gap-4 px-4">
            @foreach (var eventType in Model.EventTypes)
            {
                <div class="flex items-center gap-2">
                    <span>@eventType.Name</span>
                    <div class="w-3 h-3 rounded-full" style="background-color: @eventType.Color"></div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    window.eventId = window.eventId || '@HttpContextAccessor.HttpContext?.Session.GetString("SelectedSearchEventId")';
    window.date = window.date || '@HttpContextAccessor.HttpContext?.Session.GetString("SelectedSearchDate")';

    if (window.date) {
        htmx.ajax('GET', '@Url.Action("GetDayViewer", "Calendar")', {
            target: '#day-viewer-container',
            values: { date: window.date }
        });
        window.date = null;
    }

    if(window.eventId){
        htmx.ajax('GET', '@Url.Action("GetEvent", "Calendar")', {
            target: '#edit-event-modal-content',
            values: { id: window.eventId }
        });
        window.eventId = null;
    }
</script>
