<dialog id="add-card-modal" class="modal modal-middle sm:modal-middle">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Add New Card</h3>
        <div class="py-4">
            <form hx-post="@Url.Action("CreateCard", "LoyaltyCard")"
                  hx-target="#cards-list"
                  hx-swap="afterbegin transition:true"
                  hx-indicator="#loading-indicator"
                  hx-on::after-request="if(event.detail.successful) closeCardModal()">
                @Html.AntiForgeryToken()
                
                <div class="form-control w-full mb-4">
                    <label class="label">
                        <span class="label-text">Card Name</span>
                    </label>
                    <input type="text"
                           name="name"
                           class="input input-bordered w-full"
                           required />
                </div>

                <div class="form-control w-full mb-4">
                    <label class="label">
                        <span class="label-text">Scan Barcode</span>
                    </label>
                    <div class="flex gap-2">
                        <input type="text"
                               id="barcode-input"
                               name="barcode"
                               class="input input-bordered w-full"
                               required />
                        <button type="button"
                                class="btn btn-primary"
                                onclick="startBarcodeScanner()">
                            <img src="~/svg/scan.svg" class="h-5 w-5" />
                        </button>
                    </div>
                    <div id="interactive" class="viewport mt-4"></div>
                </div>

                <div class="modal-action">
                    <button type="button" class="btn" onclick="closeCardModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button onclick="closeCardModal()">close</button>
    </form>
</dialog>

<script>
    document.getElementById('add-card-modal').showModal();

    function closeCardModal() {
        Quagga.stop();
        document.getElementById('add-card-modal').close();
    }
</script> 