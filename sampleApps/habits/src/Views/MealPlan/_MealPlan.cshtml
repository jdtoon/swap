@model MealPlanDto

<div class="space-y-4 max-w-full px-2">
    <!-- Monday -->
    <div class="flex items-center space-x-2">
        <div class="bg-purple-300 rounded-full min-w-[40px] min-h-[40px] w-10 h-10 flex items-center justify-center shrink-0">
            <span class="text-white font-bold">M</span>
        </div>
        <input type="text"
               class="input input-bordered w-full min-w-0"
               value="@Model.MondayMeal"
               hx-put="@Url.Action("UpdateMeal", "MealPlan")"
               hx-vals='{"id": "@Model.Id", "day": "monday", "meal": ""}'
               oninput="this.setAttribute('hx-vals', JSON.stringify({id: '@Model.Id', day: 'monday', meal: this.value}))"
               hx-trigger="change"
               hx-swap="none">
    </div>

    <!-- Tuesday -->
