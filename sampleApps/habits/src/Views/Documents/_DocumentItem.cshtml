@model DocumentDto

<div class="card bg-white text-gray-500 shadow-xl" id="document-@Model.Id">
    <div class="card-body p-1">
        <div class="flex items-center justify-between">
            <div class="bg-orange-300 rounded-full">
                @if (Model.ContentType.StartsWith("image"))
                {
                    <img src="~/svg/image.svg" class="h-8 w-8 p-1" />
                }
                else
                {
                    <img src="~/svg/document-list.svg" class="h-8 w-8 p-1" />
                }
            </div>
            <div class="flex-1">
                <!-- Document Name (Editable) -->
                <input type="text"
                       class="input input-ghost input-sm w-full max-w-md font-semibold"
                       value="@Model.Name"
                       hx-put="@Url.Action("UpdateDocumentName", "Documents")"
                       hx-vals='{"id": "@Model.Id", "name": ""}'
                       oninput="this.setAttribute('hx-vals', JSON.stringify({id: '@Model.Id', name: this.value}))"
                       hx-trigger="change"
                       hx-target="#document-@Model.Id"
                       hx-indicator="#loading-indicator" />
            </div>

            <!-- Action Buttons -->
            <div class="flex gap-2">
                <!-- View Button -->
                <a href="@Url.Action("ViewDocument", "Documents", new { id = Model.Id })"
                   class="btn btn-ghost btn-sm btn-square"
                   title="View" target="_blank">
                    <img src="~/svg/view.svg" class="h-5 w-5" />
                </a>

                <!-- Download Button -->
                <a href="@Url.Action("DownloadDocument", "Documents", new { id = Model.Id })"
                   class="btn btn-ghost btn-sm btn-square"
                   title="Download"
                   download
                   target="_blank">
                    <img src="~/svg/download.svg" class="h-5 w-5" />
                </a>

                <!-- Delete Button -->
                <button class="btn btn-ghost btn-sm btn-square text-error"
                        title="Delete"
                        hx-delete="@Url.Action("DeleteDocument", "Documents")"
                        hx-vals='{"id": "@Model.Id"}'
                        hx-target="#document-@Model.Id"
                        hx-swap="outerHTML transition:true"
                        hx-confirm="Are you sure you want to delete this file?"
                        hx-indicator="#loading-indicator">
                    <img src="~/svg/delete.svg" class="h-5 w-5" />
                </button>
            </div>
        </div>
    </div>
</div>