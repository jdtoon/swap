@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="en" data-theme="habitstheme">
<head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex">
    <meta name="googlebot" content="noindex">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="view-transition" content="same-origin">
    <meta name="firebase-messaging-scope" content="/firebase-push/">
    <style>
        ::view-transition-old(root),
        ::view-transition-new(root) {
            animation-duration: 0.3s;
        }
    </style>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/png" sizes="512x512" href="/icons/icon-512.png">
    <link rel="apple-touch-icon" href="~/icons/iphone-icon.png">

    <title>Habits</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/update.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Satisfy&display=swap" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/@@ericblade/quagga2/dist/quagga.min.js"></script>
    <script src="~/lib/jsbarcode/JsBarcode.all.min.js"></script>
    <script src="~/lib/jsbarcode/barcodes/JsBarcode.code128.min.js"></script>

    @await RenderSectionAsync("HeadContent", required: false)
</head>
<body hx-boost="true"
      hx-swap="transition:true"
      hx-swap-oob="true"
      data-page="@ViewData["PageName"]"
      class="font-poppins">
    <div class="drawer z-50">
        <input id="slide-menu" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content">
            <header class="shadow-lg">
                <div id="main-navbar-placeholder" class="navbar bg-base-200 flex-col">
                    <!-- First row -->
                    <div class="navbar-row flex w-full items-center mt-2 mb-2">
                        <div id="navbar-start-placeholder" class="navbar-start px-4">
                        </div>

                        <div id="navbar-center-placeholder" class="navbar-center">
                        </div>

                        <div id="navbar-end-placeholder" class="navbar-end flex items-center gap-x-4">
                        </div>
                    </div>

                    <div id="search-bar-container" class="navbar-row w-full flex justify-center">
                    </div>
                </div>
            </header>
        </div>

        <!-- Slide-out menu content -->
        <div class="drawer-side">
            <label for="slide-menu" class="drawer-overlay"></label>
            <div class="menu w-80 min-h-full bg-base-200 p-4 text-base-content">
                <div class="flex flex-col space-y-4">
                    <!-- App Logo/Name -->
                    <div class="text-xl font-bold px-4 py-2 mb-4">
                        Habits App
                    </div>

                    <!-- Menu Items -->
                    <a hx-get="/Home/Index"
                       hx-target="#primary-container"
                       hx-swap="innerHtml transition:true"
                       hx-push-url="true"
                       hx-on:click="document.getElementById('slide-menu').checked = false"
                       class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                        <img src="~/svg/sticky-home.svg" class="h-6 w-6" />
                        <span>Home</span>
                    </a>

                    <a hx-get="@Url.Action("Index","Calendar")"
                       hx-target="#primary-container"
                       hx-swap="innerHtml transition:true"
                       hx-push-url="true"
                       hx-on:click="document.getElementById('slide-menu').checked = false"
                       class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                        <img src="~/svg/sticky-calendar.svg" class="h-6 w-6" />
                        <span>Calendar</span>
                    </a>

                    <a hx-get="@Url.Action("Index","Task")"
                       hx-target="#primary-container"
                       hx-swap="innerHtml transition:true"
                       hx-push-url="true"
                       hx-on:click="document.getElementById('slide-menu').checked = false"
                       class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                        <img src="~/svg/sticky-list.svg" class="h-6 w-6" />
                        <span>Lists</span>
                    </a>

                    <a hx-get="@Url.Action("Index","Documents")"
                       hx-target="#primary-container"
                       hx-swap="innerHtml transition:true"
                       hx-push-url="true"
                       hx-on:click="document.getElementById('slide-menu').checked = false"
                       class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                        <img src="~/svg/sticky-docs.svg" class="h-6 w-6" />
                        <span>Files</span>
                    </a>

                    <a hx-get="@Url.Action("Index","MealPlan")"
                       hx-target="#primary-container"
                       hx-swap="innerHtml transition:true"
                       hx-push-url="true"
                       hx-on:click="document.getElementById('slide-menu').checked = false"
                       class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                        <img src="~/svg/sticky-meal.svg" class="h-6 w-6" />
                        <span>Meal Plan</span>
                    </a>

                    <div class="divider"></div>

                    <a hx-get="@Url.Action("Index","Members")"
                       hx-target="#primary-container"
                       hx-swap="innerHtml transition:true"
                       hx-push-url="true"
                       hx-on:click="document.getElementById('slide-menu').checked = false"
                       class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                        <img src="~/svg/sticky-members.svg" class="h-6 w-6" />
                        <span>Members</span>
                    </a>

                    @if(User.IsInRole("admin"))
                    {
                        <a hx-get="@Url.Action("Admin","Home")"
                           hx-target="#primary-container"
                           hx-swap="innerHtml transition:true"
                           hx-push-url="true"
                           hx-on:click="document.getElementById('slide-menu').checked = false"
                           class="flex items-center space-x-3 p-3 rounded-lg hover:bg-base-300 transition-colors">
                            <img src="~/svg/profile-setting.svg" class="h-6 w-6" />
                            <span>Admin</span>
                        </a>
                    }

                    <div class="divider"></div>

                    <div class="flex flex-col gap-4 px-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm">Email Notifications</span>
                            <input type="checkbox" 
                                   class="toggle toggle-primary" 
                                   id="emailNotificationToggle"
                                   hx-post="/api/notifications/email"
                                   hx-swap="none"
                                   hx-trigger="change" />
                        </div>

                        @* <div class="flex items-center justify-between">
                            <span class="text-sm">Push Notifications</span>
                            <input type="checkbox" 
                                   class="toggle toggle-primary" 
                                   id="pushNotificationToggle"
                                   disabled />
                        </div> *@
                    </div>
                </div>
            </div>
        </div>
    </div>

    <main class="container mx-auto flex-grow mb-24">
        <div class="flex flex-col">
            <div id="primary-container">
                @RenderBody()
            </div>
        </div>
    </main>

    <div class="fixed bottom-0 w-full bg-base-200 z-20">
        <div class="flex justify-around py-3"
             hx-target="find img"
             hx-swap="outerHTML">
            <a hx-get="/Home/Index"
               hx-target="#primary-container"
               hx-swap="innerHtml transition:true"
               hx-push-url="true"
               class="content-center text-center mobile-center">
                <img src="/svg/home.svg" 
                     class="h-12 w-12"
                     data-active-src="/svg/home.svg"
                     data-inactive-src="/svg/sticky-home.svg"
                     data-path="/">
                <p class="text-xs">Home</p>
            </a>
            <a hx-get="@Url.Action("Index","Calendar")"
               hx-target="#primary-container"
               hx-swap="innerHtml transition:true"
               hx-push-url="true"
               class="content-center text-center mobile-center">
                <img src="/svg/sticky-calendar.svg" 
                     class="h-12 w-12"
                     data-active-src="/svg/calendar.svg"
                     data-inactive-src="/svg/sticky-calendar.svg"
                     data-path="/calendar">
                <p class="text-xs">Calendar</p>
            </a>
            <a hx-get="@Url.Action("Index","Task")"
               hx-target="#primary-container"
               hx-swap="innerHtml transition:true"
               hx-push-url="true"
               class="content-center text-center mobile-center">
                <img src="/svg/sticky-list.svg" 
                     class="h-12 w-12"
                     data-active-src="/svg/lists.svg"
                     data-inactive-src="/svg/sticky-list.svg"
                     data-path="/task">
                <p class="text-xs">Lists</p>
            </a>
            <a hx-get="@Url.Action("Index","Documents")"
               hx-target="#primary-container"
               hx-swap="innerHtml transition:true"
               hx-push-url="true"
               class="content-center text-center mobile-center">
                <img src="/svg/sticky-docs.svg" 
                     class="h-12 w-12"
                     data-active-src="/svg/documents.svg"
                     data-inactive-src="/svg/sticky-docs.svg"
                     data-path="/documents">
                <p class="text-xs">Files</p>
            </a>
        </div>
    </div>

    <div id="modal-container"></div>
    <div data-user-id="@User.FindFirst(ClaimTypes.NameIdentifier)?.Value"></div>

    <!-- Loading Indicator -->
    <div id="loading-indicator" class="htmx-indicator flex justify-center">
        <span class="loading loading-spinner loading-lg"></span>
    </div>

    <script src="~/app.js" asp-append-version="true"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true"></script>
    <script src="~/lib/sortable/Sortable.min.js" asp-append-version="true"></script>
    <script src="~/js/sticky-menu.js" asp-append-version="true"></script>
    @* <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.1.0/firebase-app.js";
        import { getMessaging, getToken } from "https://www.gstatic.com/firebasejs/11.1.0/firebase-messaging.js";
        
        // Initialize Firebase
        const app = initializeApp(window.firebaseConfig);
        const messaging = getMessaging(app);
        
        // Make Firebase available globally
        window.firebase = { app, messaging, getToken };
    </script>
    <script>
        window.firebaseConfig = {
            apiKey: '@Configuration["Firebase:ApiKey"]',
            projectId: '@Configuration["Firebase:ProjectId"]',
            messagingSenderId: '@Configuration["Firebase:MessagingSenderId"]',
            appId: '@Configuration["Firebase:AppId"]'
        };
    </script> *@
    <script defer src="~/js/notification.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>