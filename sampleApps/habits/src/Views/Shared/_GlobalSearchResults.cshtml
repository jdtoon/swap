@model GlobalSearchResultDto

@if (!string.IsNullOrEmpty(Model.SearchTerm) && Model.Results.Any())
{
    <div class="overflow-hidden rounded-lg shadow-lg border border-base-200">
        <ul class="divide-y divide-base-200">
            @foreach (var result in Model.Results)
            {
                <li class="group cursor-pointer"
                    hx-get="@result.NavigateUrl"
                    hx-target="#primary-container"
                    hx-push-url="true"
                    hx-swap="innerHTML transition:true">
                    <div class="p-4 hover:bg-base-100 transition-all duration-200 ease-in-out">
                        <div class="flex items-center justify-between">
                            <span class="text-lg font-medium text-base-content group-hover:text-primary transition-colors">
                                @result.Title
                            </span>
                            <span class="px-3 py-1 text-sm rounded-full bg-base-200 text-base-content/70 group-hover:bg-primary group-hover:text-primary-content transition-colors">
                                @result.Type
                            </span>
                        </div>
                    </div>
                </li>
            }
        </ul>
    </div>
}
else if (!string.IsNullOrEmpty(Model.SearchTerm))
{
    <div class="flex items-center justify-center p-8 rounded-lg bg-base-100 border border-base-200">
        <div class="text-center">
            <p class="text-lg font-medium text-base-content/70">
                No results found for
            </p>
            <p class="mt-1 text-xl font-semibold text-primary">
                "@Model.SearchTerm"
            </p>
        </div>
    </div>
}