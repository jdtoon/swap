@model ItemDto

@{
    var bgColor = Model.IsHeader ? "bg-orange-300" : "bg-white";
    var isHeaderReturn = !Model.IsHeader;
    var isCompletedReturn = !Model.IsCompleted;
}

<li id="item-@Model.Id" 
    class="sortable-item flex items-center justify-between @bgColor shadow-xl p-1 border-gray-400 pl-2 pr-2 border"
    data-id="@Model.Id" 
    data-order="@Model.Order">
    <!-- Checkbox Section -->
    @if(!Model.IsHeader)
    {
        <div class="flex items-center">
            <input type="checkbox"
                   class="checkbox checkbox-lg mr-4 border-gray-400 text-base-200"
                   @(Model.IsCompleted ? "checked" : "")
                   hx-post="@Url.Action("ToggleCompleted", "Item")"
                   hx-vals='{"id": "@Model.Id", "isCompleted": "@isCompletedReturn"}'
                   hx-target="#item-@Model.Id"
                   hx-swap="outerHTML transition:true"
                   hx-trigger="change"
                   hx-indicator="#loading-indicator"
                   title="Mark as completed">
        </div>
    }

    <!-- Content Section -->
    @if(Model.IsCompleted)
    {
        <div class="flex-grow">
            <h2 class="font-bold text-md line-through decoration-base-200">@Model.Task</h2>
        </div>
    }
    else
    {
        if(Model.IsHeader)
        {
            <div class="flex-grow">
                <h2 class="font-bold text-lg text-base-200">@Model.Task</h2>
            </div>
        }
        else
        {
            <div class="flex-grow">
                <h2 class="text-md text-gray-500">@Model.Task</h2>
            </div>
        }
    }

    @if (!Model.IsHeader)
    {
        <div class="flex items-center space-x-1">
            @foreach (var user in Model.AssignedUsers)
            {
                <div class="w-4 h-4 rounded-full" style="background-color: @user.Color" title="@user.Name">
                </div>
            }
        </div>
    }

    <!-- Actions Section -->
    <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-ghost btn-md">
            <img src="~/svg/morevert.svg" class="h-8 w-8" />
        </label>
        <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-white rounded-box w-52 z-50 text-black">
            <li>
                <a hx-get="@Url.Action("AssignUsers", "Item")"
                   hx-vals='{"id": "@Model.Id"}'
                   hx-target="#modal-container"
                   hx-swap="innerHtml transition:true"
                   hx-indicator="#loading-indicator"
                   title="Assign Users">
                    Assign Users
                </a>
            </li>
            <li>
                <!-- Edit Button -->
                <a hx-get="@Url.Action("EditItem", "Item")"
                   hx-vals='{"id": "@Model.Id"}'
                   hx-target="body"
                   hx-swap="beforeend transition:true"
                   hx-indicator="#loading-indicator"
                   title="Edit">
                    Edit
                </a>
            </li>
            <li>
                <!-- Mark as Header Button -->
                <a hx-post="@Url.Action("ToggleHeader", "Item")"
                   hx-vals='{"id": "@Model.Id", "isHeader": "@isHeaderReturn"}'
                   hx-target="#item-@Model.Id"
                   hx-swap="outerHTML transition:true"
                   hx-indicator="#loading-indicator"
                   title="Toggle Header">
                    @(Model.IsHeader ? "Remove Header" : "Mark as Header")
                </a>
            </li>
            <li>
                <!-- Delete Item -->
                <a hx-delete="@Url.Action("DeleteItem", "Item", new { id = Model.Id })"
                   hx-target="#item-@Model.Id"
                   hx-swap="outerHTML transition:true"
                   hx-confirm="Are you sure you want to delete this item?"
                   hx-indicator="#loading-indicator"
                   title="Delete list">
                    Delete
                </a>
            </li>
        </ul>
    </div>
</li>
