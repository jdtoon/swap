@{
    var calendarTypeFiles = JsonSerializer.Deserialize<IEnumerable<string>>(
        Context.Session.GetString("CalendarTypeFiles") ?? "[]");
}

<div hx-get="@Url.Action("GetBurgerMenu","Home")"
     hx-trigger="load"
     hx-target="#navbar-start-placeholder"
     hx-swap="innerHtml transition:true"
     hx-indicator="#loading-indicator">
</div>

<div hx-get="@Url.Action("GetPageHeading", "Home")"
     hx-vals='{"heading": "Types" }'
     hx-target="#navbar-center-placeholder"
     hx-swap="innerHtml transition:true"
     hx-trigger="load"
     hx-indicator="#loading-indicator">
</div>

<div hx-get="@Url.Action("GetLoginPartial", "Home")"
     hx-target="#navbar-end-placeholder"
     hx-swap="innerHtml transition:true"
     hx-trigger="load"
     hx-indicator="#loading-indicator">
</div>

<div hx-get="@Url.Action("ClearDiv", "Home")"
     hx-target="#search-bar-container"
     hx-swap="innerHtml transition:true"
     hx-trigger="load"
     hx-indicator="#loading-indicator">
</div>

<div class="p-4">
    <!-- Add Event Type Button -->
    <div class="flex justify-end mb-4">
        <label for="add-event-type-modal" class="btn bg-purple-300 btn-sm">
            <img src="~/svg/add.svg" class="h-5 w-5" />
        </label>
    </div>

    <!-- Search Form -->
    <form hx-get="@Url.Action("GetEventTypes", "CalendarEventTypes")"
          hx-target="#event-types-list"
          hx-trigger="keyup changed delay:500ms"
          hx-indicator="#loading-indicator"
          class="mb-4">
        <input id="search-input"
               class="input input-bordered w-full"
               type="text"
               name="search"
               placeholder="Search event types..." />
    </form>

    <!-- Event Types List -->
    <div id="event-types-list"
         class="space-y-3"
         hx-get="@Url.Action("GetEventTypes", "CalendarEventTypes")"
         hx-trigger="load"
         hx-target="#event-types-list"
         hx-indicator="#loading-indicator">
    </div>
</div>

<!-- Add Event Type Modal -->
<input type="checkbox" id="add-event-type-modal" class="modal-toggle" />
<div class="modal">
    <div class="modal-box">
        <form hx-post="@Url.Action("AddEventType", "CalendarEventTypes")"
              hx-target="#event-types-list"
              hx-swap="afterbegin transition:true"
              hx-indicator="#loading-indicator"
              hx-on::after-request="if(event.detail.successful) { document.getElementById('add-event-type-modal').checked = false; this.reset(); }">
            @Html.AntiForgeryToken()
            <h3 class="font-bold text-lg mb-4">Add New Event Type</h3>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Name</span>
                </label>
                <input type="text"
                       name="name"
                       class="input input-bordered w-full"
                       required />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Color</span>
                </label>
                <input type="color"
                       name="color"
                       class="input input-bordered w-full h-12"
                       required />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label">
                    <span class="label-text">Icon</span>
                </label>
                <div class="flex gap-2">
                    <select name="iconPath" class="select select-bordered w-full" required>
                        <option value="">Select an icon</option>
                        @foreach (var svgPath in calendarTypeFiles!)
                        {
                            var pathParts = svgPath.Split('/');
                            var fileName = pathParts[pathParts.Length - 1].Replace(".svg", "");
                            var displayName = System.Globalization.CultureInfo.CurrentCulture.TextInfo
                            .ToTitleCase(fileName.Substring(5).Replace("_", " "));

                            <option value="@svgPath">@displayName</option>
                        }
                    </select>

                    <img id="iconPreview" src="" class="h-10 w-10 hidden"
                         onerror="this.classList.add('hidden')"
                         onload="this.classList.remove('hidden')" />
                </div>
            </div>

            <div class="modal-action">
                <label for="add-event-type-modal" class="btn">Cancel</label>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.IsHTMXRequest == true)
{
    <script defer src="~/js/calendar-event-types.js" asp-append-version="true"></script>
}
else
{
    @section Scripts {
    <script defer src="~/js/calendar-event-types.js" asp-append-version="true"></script>
    }
}