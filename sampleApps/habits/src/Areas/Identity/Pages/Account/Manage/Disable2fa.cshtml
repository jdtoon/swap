@page
@model Disable2faModel
@{
    ViewData["Title"] = "Disable two-factor authentication (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="container mx-auto p-1">
    <partial name="_StatusMessage" for="StatusMessage" />
    <div class="alert alert-warning mb-6">
        <img src="~/svg/information.svg" class="h-6 w-6" />
        <div>
            <p class="font-bold">This action only disables 2FA.</p>
            <p>
                Disabling 2FA does not change the keys used in authenticator apps. If you wish to change the key
                used in an authenticator app you should <a asp-page="./ResetAuthenticator" class="link link-primary">reset your authenticator keys.</a>
            </p>
        </div>
    </div>

    <form method="post">
        <button class="btn btn-error" type="submit">Disable 2FA</button>
    </form>
</div>