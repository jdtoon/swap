@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="container mx-auto p-1">
    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="card bg-base-100 shadow-xl max-w-xl">
        <div class="card-body p-2">
            <form id="profile-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-error" role="alert"></div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text" asp-for="Username"></span>
                    </label>
                    <input asp-for="Username"
                           class="input input-bordered w-full"
                           placeholder="Please choose your username."
                           disabled />
                </div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text" asp-for="Input.PhoneNumber"></span>
                    </label>
                    <input asp-for="Input.PhoneNumber"
                           class="input input-bordered w-full"
                           placeholder="Please enter your phone number." />
                    <label class="label">
                        <span asp-validation-for="Input.PhoneNumber" class="label-text-alt text-error"></span>
                    </label>
                </div>

                <div class="form-control mt-6">
                    <button id="update-profile-button" type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
}