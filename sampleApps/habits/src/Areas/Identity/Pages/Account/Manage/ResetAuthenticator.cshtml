@page
@model ResetAuthenticatorModel
@{
    ViewData["Title"] = "Reset authenticator key";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="container mx-auto p-1">
    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="alert alert-warning mb-6">
        <img src="~/svg/information.svg" class="h-6 w-6" />
        <div>
            <p class="font-bold">If you reset your authenticator key your authenticator app will not work until you reconfigure it.</p>
            <p>This process disables 2FA until you verify your authenticator app. If you do not complete your authenticator app configuration you may lose access to your account.</p>
        </div>
    </div>

    <form id="reset-authenticator-form" method="post">
        <button id="reset-authenticator-button" class="btn btn-error" type="submit">Reset authenticator key</button>
    </form>
</div>