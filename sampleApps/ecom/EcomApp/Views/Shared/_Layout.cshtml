<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcomApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <style>
        .product-card {
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .product-card .card-content {
            flex: 1;
        }
        .product-image {
            height: 200px;
            object-fit: cover;
            background-color: #f5f5f5;
        }
        .cart-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background-color: #f14668;
            color: white;
            border-radius: 50%;
            padding: 4px 8px;
            font-size: 0.75rem;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <nav class="navbar is-primary" role="navigation" aria-label="main navigation">
        <div class="container">
            <div class="navbar-brand">
                <a class="navbar-item" href="/">
                    <strong>EcomApp</strong>
                </a>
            </div>
            
            <div class="navbar-menu">
                <div class="navbar-start">
                    <a class="navbar-item" href="/">
                        Home
                    </a>
                    <a class="navbar-item" href="/Products">
                        Products
                    </a>
                    <a class="navbar-item" href="/Orders">
                        Orders
                    </a>
                </div>
                
                <div class="navbar-end">
                    <div class="navbar-item">
                        <div class="buttons">
                            <a class="button is-light" href="/Cart" style="position: relative;">
                                <span class="icon">
                                    <i class="fas fa-shopping-cart"></i>
                                </span>
                                <span>Cart</span>
                                <span class="cart-badge" id="cart-count" 
                                      hx-get="/Cart/Count" 
                                      hx-trigger="load, cartUpdated from:body"
                                      hx-swap="innerHTML">0</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>
    
    <section class="section">
        <div class="container">
            @RenderBody()
        </div>
    </section>
    
    <footer class="footer">
        <div class="content has-text-centered">
            <p>
                <strong>EcomApp</strong> - Built with NetMX & HTMX
            </p>
        </div>
    </footer>
</body>
</html>
