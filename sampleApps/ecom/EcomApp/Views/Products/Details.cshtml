@model EcomApp.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<nav class="breadcrumb" aria-label="breadcrumbs">
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/Products">Products</a></li>
        <li class="is-active"><a href="#" aria-current="page">@Model.Name</a></li>
    </ul>
</nav>

<div class="columns">
    <div class="column is-half">
        <figure class="image is-square">
            <img src="@Model.ImageUrl" alt="@Model.Name" style="object-fit: cover;">
        </figure>
    </div>
    
    <div class="column is-half">
        <h1 class="title is-2">@Model.Name</h1>
        <p class="subtitle is-4">@Model.Category?.Name</p>
        
        <div class="content">
            <p>@Model.Description</p>
        </div>
        
        <div class="box">
            <p class="title is-3 has-text-primary">$@Model.Price.ToString("F2")</p>
            
            @if (Model.Stock > 0)
            {
                <p class="subtitle is-6">
                    <span class="tag is-success is-medium">In Stock (@Model.Stock available)</span>
                </p>
                
                <div class="field has-addons">
                    <div class="control">
                        <input class="input" type="number" value="1" min="1" max="@Model.Stock" id="quantity" style="width: 100px;">
                    </div>
                    <div class="control">
                        <button class="button is-primary is-medium"
                                hx-post="/Cart/Add?productId=@Model.Id"
                                hx-include="#quantity"
                                hx-target="#cart-items"
                                hx-swap="outerHTML">
                            <span class="icon">
                                <i class="fas fa-cart-plus"></i>
                            </span>
                            <span>Add to Cart</span>
                        </button>
                    </div>
                </div>
                
                <div id="add-to-cart-message" class="notification is-success is-light mt-3" style="display: none;">
                    <button class="delete"></button>
                    Product added to cart!
                </div>
            }
            else
            {
                <p class="subtitle is-6">
                    <span class="tag is-danger is-medium">Out of Stock</span>
                </p>
            }
        </div>
        
        <a href="/Products" class="button is-light">
            <span class="icon">
                <i class="fas fa-arrow-left"></i>
            </span>
            <span>Back to Products</span>
        </a>
    </div>
</div>

<script>
document.body.addEventListener('cartUpdated', function() {
    var msg = document.getElementById('add-to-cart-message');
    if (msg) {
        msg.style.display = 'block';
        setTimeout(function() {
            msg.style.display = 'none';
        }, 3000);
    }
});
</script>
