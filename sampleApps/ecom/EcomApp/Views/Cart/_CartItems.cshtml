@model EcomApp.Models.Cart
@{
    var total = ViewBag.Total as decimal? ?? 0;
}

@if (!Model.Items.Any())
{
    <div class="notification is-info">
        <p class="is-size-5">Your cart is empty</p>
        <a href="/Products" class="button is-primary mt-3">Continue Shopping</a>
    </div>
}
else
{
    <div class="table-container">
        <table class="table is-fullwidth is-hoverable">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="is-flex is-align-items-center">
                                <figure class="image is-64x64 mr-3">
                                    <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name">
                                </figure>
                                <div>
                                    <p class="has-text-weight-bold">@item.Product?.Name</p>
                                    <p class="is-size-7 has-text-grey">@item.Product?.Category?.Name</p>
                                </div>
                            </div>
                        </td>
                        <td class="is-vcentered">$@item.PriceAtAdd.ToString("F2")</td>
                        <td class="is-vcentered">
                            <div class="field has-addons">
                                <div class="control">
                                    <input class="input is-small" 
                                           type="number" 
                                           value="@item.Quantity" 
                                           min="1" 
                                           max="@item.Product?.Stock"
                                           style="width: 80px;"
                                           hx-patch="/Cart/UpdateQuantity?id=@item.Id"
                                           hx-trigger="change"
                                           hx-include="this"
                                           hx-target="#cart-items"
                                           hx-swap="outerHTML"
                                           name="quantity">
                                </div>
                            </div>
                        </td>
                        <td class="is-vcentered has-text-weight-bold">$@((item.Quantity * item.PriceAtAdd).ToString("F2"))</td>
                        <td class="is-vcentered">
                            <button class="button is-small is-danger is-outlined"
                                    hx-delete="/Cart/Remove?id=@item.Id"
                                    hx-target="#cart-items"
                                    hx-swap="outerHTML"
                                    hx-confirm="Remove this item from cart?">
                                <span class="icon is-small">
                                    <i class="fas fa-trash"></i>
                                </span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="has-text-right"><strong>Total:</strong></td>
                    <td colspan="2"><strong class="is-size-5 has-text-primary">$@total.ToString("F2")</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
}
