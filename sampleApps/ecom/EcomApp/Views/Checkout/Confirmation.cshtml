@model EcomApp.Models.Order
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="hero is-success">
    <div class="hero-body has-text-centered">
        <span class="icon is-large">
            <i class="fas fa-check-circle fa-3x"></i>
        </span>
        <p class="title mt-3">
            Order Confirmed!
        </p>
        <p class="subtitle">
            Thank you for your purchase
        </p>
    </div>
</div>

<section class="section">
    <div class="container">
        <div class="box">
            <h2 class="title is-4">Order Details</h2>
            
            <div class="columns">
                <div class="column">
                    <p><strong>Order Number:</strong> @Model.OrderNumber</p>
                    <p><strong>Order Date:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    <p><strong>Status:</strong> <span class="tag is-warning">@Model.Status</span></p>
                </div>
                <div class="column">
                    <p><strong>Customer:</strong> @Model.CustomerName</p>
                    <p><strong>Email:</strong> @Model.CustomerEmail</p>
                    <p><strong>Shipping Address:</strong> @Model.ShippingAddress</p>
                </div>
            </div>
        </div>
        
        <div class="box">
            <h2 class="title is-4">Order Items</h2>
            
            <table class="table is-fullwidth">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Product?.Name</td>
                            <td>$@item.PriceAtOrder.ToString("F2")</td>
                            <td>@item.Quantity</td>
                            <td>$@((item.Quantity * item.PriceAtOrder).ToString("F2"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="has-text-right"><strong>Total:</strong></td>
                        <td><strong class="is-size-4 has-text-primary">$@Model.TotalAmount.ToString("F2")</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        
        <div class="notification is-info is-light">
            <p>A confirmation email has been sent to <strong>@Model.CustomerEmail</strong></p>
        </div>
        
        <div class="buttons">
            <a href="/" class="button is-primary">
                <span class="icon">
                    <i class="fas fa-home"></i>
                </span>
                <span>Back to Home</span>
            </a>
            <a href="/Orders" class="button is-light">
                <span class="icon">
                    <i class="fas fa-list"></i>
                </span>
                <span>View All Orders</span>
            </a>
        </div>
    </div>
</section>
