@model EcomApp.Models.Order
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
}

<nav class="breadcrumb" aria-label="breadcrumbs">
    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/Orders">Orders</a></li>
        <li class="is-active"><a href="#" aria-current="page">@Model.OrderNumber</a></li>
    </ul>
</nav>

<h1 class="title">Order Details</h1>

<div class="columns">
    <div class="column is-two-thirds">
        <div class="box">
            <h2 class="title is-4">Order Information</h2>
            
            <div class="columns">
                <div class="column">
                    <p><strong>Order Number:</strong> @Model.OrderNumber</p>
                    <p><strong>Order Date:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                    <p><strong>Status:</strong> 
                        @switch (Model.Status)
                        {
                            case EcomApp.Models.OrderStatus.Pending:
                                <span class="tag is-warning">Pending</span>
                                break;
                            case EcomApp.Models.OrderStatus.Processing:
                                <span class="tag is-info">Processing</span>
                                break;
                            case EcomApp.Models.OrderStatus.Shipped:
                                <span class="tag is-link">Shipped</span>
                                break;
                            case EcomApp.Models.OrderStatus.Delivered:
                                <span class="tag is-success">Delivered</span>
                                break;
                            case EcomApp.Models.OrderStatus.Cancelled:
                                <span class="tag is-danger">Cancelled</span>
                                break;
                        }
                    </p>
                </div>
                <div class="column">
                    <p><strong>Customer:</strong> @Model.CustomerName</p>
                    <p><strong>Email:</strong> @Model.CustomerEmail</p>
                    <p><strong>Shipping Address:</strong> @Model.ShippingAddress</p>
                </div>
            </div>
        </div>
        
        <div class="box">
            <h2 class="title is-4">Order Items</h2>
            
            <table class="table is-fullwidth">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div>
                                    <p class="has-text-weight-bold">@item.Product?.Name</p>
                                    <p class="is-size-7 has-text-grey">@item.Product?.Category?.Name</p>
                                </div>
                            </td>
                            <td>$@item.PriceAtOrder.ToString("F2")</td>
                            <td>@item.Quantity</td>
                            <td><strong>$@((item.Quantity * item.PriceAtOrder).ToString("F2"))</strong></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="has-text-right"><strong>Total:</strong></td>
                        <td><strong class="is-size-4 has-text-primary">$@Model.TotalAmount.ToString("F2")</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    
    <div class="column">
        <div class="box">
            <h2 class="title is-5">Order Summary</h2>
            
            <div class="content">
                <p><strong>Total Items:</strong> @Model.Items.Sum(i => i.Quantity)</p>
                <p><strong>Total Amount:</strong> <span class="has-text-primary">$@Model.TotalAmount.ToString("F2")</span></p>
            </div>
        </div>
        
        <a href="/Orders" class="button is-light is-fullwidth">
            <span class="icon">
                <i class="fas fa-arrow-left"></i>
            </span>
            <span>Back to Orders</span>
        </a>
    </div>
</div>
