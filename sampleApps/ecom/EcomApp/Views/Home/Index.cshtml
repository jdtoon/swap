@model List<EcomApp.Models.Product>
@{
    ViewData["Title"] = "Home";
}

<div class="hero is-info">
    <div class="hero-body">
        <p class="title">
            Welcome to EcomApp
        </p>
        <p class="subtitle">
            Browse our amazing products
        </p>
    </div>
</div>

<section class="section">
    <h2 class="title is-4">Featured Products</h2>
    
    <div class="columns is-multiline">
        @foreach (var product in Model.Take(6))
        {
            <div class="column is-one-third">
                <div class="card product-card">
                    <div class="card-image">
                        <figure class="image is-4by3">
                            <img src="@product.ImageUrl" alt="@product.Name" class="product-image">
                        </figure>
                    </div>
                    <div class="card-content">
                        <p class="title is-5">@product.Name</p>
                        <p class="subtitle is-6">@product.Category?.Name</p>
                        <div class="content">
                            @product.Description
                        </div>
                        <p class="title is-4 has-text-primary">$@product.Price.ToString("F2")</p>
                    </div>
                    <footer class="card-footer">
                        <a href="/Products/Details/@product.Id" class="card-footer-item">View Details</a>
                        <a class="card-footer-item" 
                           hx-post="/Cart/Add?productId=@product.Id&quantity=1"
                           hx-target="#cart-items"
                           hx-swap="outerHTML">
                            <span class="icon">
                                <i class="fas fa-cart-plus"></i>
                            </span>
                            <span>Add to Cart</span>
                        </a>
                    </footer>
                </div>
            </div>
        }
    </div>
    
    <div class="has-text-centered mt-5">
        <a href="/Products" class="button is-primary is-medium">View All Products</a>
    </div>
</section>
