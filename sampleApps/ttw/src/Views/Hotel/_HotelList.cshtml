@model PagedResult<Hotel>

<div class="overflow-x-auto">
    <div class="mb-4">
        <input type="text" 
               placeholder="Quick Search ..." 
               class="input input-bordered w-full max-w-xs"
               value="@ViewBag.CurrentSearch"
               hx-trigger="keyup changed delay:500ms"
               hx-get="@Url.Action("GetHotelList")"
               hx-target="#hotelList"
               hx-indicator="#loading-indicator"
               hx-on::after-settle="this.focus();"
               autofocus
               name="search" />
    </div>

    <table class="table w-full">
        <thead>
            <tr>
                <th>Hotel Name</th>
                <th>City</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hotel in Model.Data)
            {
                <tr id="hotel-@hotel.Id">
                    <td>@hotel.Name</td>
                    <td>@hotel.City?.Name</td>
                    <td class="space-x-2">
                        <button class="btn btn-sm btn-info"
                                hx-get="@Url.Action("EditModal", new { id = hotel.Id })"
                                hx-target="#modalContainer"
                                hx-indicator="#loading-indicator">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-error"
                                hx-delete="@Url.Action("Delete", new { id = hotel.Id })"
                                hx-target="#hotel-@hotel.Id"
                                hx-confirm="Are you sure you want to delete this hotel?"
                                hx-swap="outerHTML"
                                hx-indicator="#loading-indicator">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.HasMore)
    {
        <div class="text-center mt-4">
            <button class="btn btn-ghost"
                    hx-get="@Url.Action("GetHotelList", new { take = Model.CurrentPage + 10, search = ViewBag.CurrentSearch })"
                    hx-target="#hotelList"
                    hx-indicator="#loading-indicator"
                    hx-swap="innerHTML">
                Load More
            </button>
        </div>
    }
</div> 