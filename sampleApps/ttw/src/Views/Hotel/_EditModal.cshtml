@model Hotel

<dialog id="editModal" class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Edit Hotel</h3>
        <form hx-post="@Url.Action("Edit")" 
              hx-target="#hotelList"
              hx-swap="innerHTML"
              hx-indicator="#loading-indicator"
              hx-on::after-request="document.getElementById('editModal').remove();">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Hotel Name</span>
                </label>
                <input type="text" name="Name" 
                       value="@Model.Name" 
                       class="input input-bordered" 
                       required 
                       maxlength="50" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">City</span>
                </label>
                <select name="MapCityId" class="select select-bordered" required>
                    <option value="">Select a city</option>
                    @foreach (SelectListItem item in (ViewData["Cities"] as SelectList)!)
                    {
                        if (item.Value == Model.City?.Id.ToString())
                        {
                            <option value="@item.Value" selected>
                                @item.Text
                            </option>
                        }
                        else
                        {
                            <option value="@item.Value">
                                @item.Text
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="modal-action">
                <button type="button" 
                        class="btn btn-ghost"
                        onclick="closeModal('editModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Update</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function closeModal(modalId) {
        document.getElementById(modalId).remove();
    }

    document.body.addEventListener('closeModal', function() {
        closeModal('editModal');
    });
</script> 