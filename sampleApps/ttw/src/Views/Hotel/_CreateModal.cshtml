@model Hotel

<dialog id="createModal" class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Add New Hotel</h3>
        <form hx-post="@Url.Action("Create")" 
              hx-target="#hotelList"
              hx-swap="innerHTML"
              hx-indicator="#loading-indicator"
              hx-on::after-request="document.getElementById('createModal').remove();">
            @Html.AntiForgeryToken()
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Hotel Name</span>
                </label>
                <input type="text" name="Name" 
                       class="input input-bordered" 
                       required 
                       maxlength="50" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">City</span>
                </label>
                <select name="MapCityId" class="select select-bordered" required>
                    <option value="">Select a city</option>
                    @foreach (SelectListItem item in (ViewData["Cities"] as SelectList)!)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>

            <div class="modal-action">
                <button type="button" 
                        class="btn btn-ghost"
                        onclick="closeModal('createModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function closeModal(modalId) {
        document.getElementById(modalId).remove();
    }

    document.body.addEventListener('closeModal', function() {
        closeModal('createModal');
    });
</script> 