@model PagedResult<City>

<div class="overflow-x-auto">
    <div class="mb-4">
        <input type="text" 
               placeholder="Quick Search ..." 
               class="input input-bordered w-full max-w-xs"
               value="@ViewBag.CurrentSearch"
               hx-trigger="keyup changed delay:500ms"
               hx-get="@Url.Action("GetCityList")"
               hx-target="#cityList"
               hx-indicator="#loading-indicator"
               hx-on::after-settle="this.focus();"
               autofocus
               name="search" />
    </div>

    <table class="table w-full">
        <thead>
            <tr>
                <th>City Name</th>
                <th>Image</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var city in Model.Data)
            {
                <tr id="city-@city.Id">
                    <td>@city.Name</td>
                    <td>
                        <img src="@city.Image" alt="@city.Name" class="w-8 h-8 object-cover rounded"/>
                    </td>
                    <td class="space-x-2">
                        <button class="btn btn-sm btn-info"
                                hx-get="@Url.Action("EditModal", new { id = city.Id })"
                                hx-target="#modalContainer"
                                hx-indicator="#loading-indicator">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-error"
                                hx-delete="@Url.Action("Delete", new { id = city.Id })"
                                hx-target="#city-@city.Id"
                                hx-confirm="Are you sure you want to delete this city?"
                                hx-swap="outerHTML"
                                hx-indicator="#loading-indicator">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.HasMore)
    {
        <div class="text-center mt-4">
            <button class="btn btn-ghost"
                    hx-get="@Url.Action("GetCityList", new { take = Model.CurrentPage + 10, search = ViewBag.CurrentSearch })"
                    hx-target="#cityList"
                    hx-swap="innerHTML"
                    hx-indicator="#loading-indicator">
                Load More
            </button>
        </div>
    }
</div> 