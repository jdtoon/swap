@model ChangePasswordDto

<form hx-post="@Url.Action("ChangePassword", "Identity")"
      hx-target="#primary-container"
      hx-push-url="true"
      hx-indicator="#loading-indicator">
    
    <div asp-validation-summary="ModelOnly" class="text-error" role="alert"></div>

    <div class="form-control w-full">
        <label class="label">
            <span class="label-text">Current Password</span>
        </label>
        <input asp-for="OldPassword"
               type="password"
               class="input input-bordered w-full"
               autocomplete="current-password" />
        <label class="label">
            <span asp-validation-for="OldPassword" class="label-text-alt text-error"></span>
        </label>
    </div>

    <div class="form-control w-full">
        <label class="label">
            <span class="label-text">New Password</span>
        </label>
        <input asp-for="NewPassword"
               type="password"
               class="input input-bordered w-full"
               autocomplete="new-password" />
        <label class="label">
            <span asp-validation-for="NewPassword" class="label-text-alt text-error"></span>
        </label>
    </div>

    <div class="form-control w-full">
        <label class="label">
            <span class="label-text">Confirm Password</span>
        </label>
        <input asp-for="ConfirmPassword"
               type="password"
               class="input input-bordered w-full"
               autocomplete="new-password" />
        <label class="label">
            <span asp-validation-for="ConfirmPassword" class="label-text-alt text-error"></span>
        </label>
    </div>

    <div class="form-control mt-6">
        <button type="submit" class="btn btn-primary">Change password</button>
    </div>

    <div class="mt-4">
        <a hx-get="@Url.Action("Profile", "Identity")"
           hx-target="#primary-container"
           hx-push-url="true"
           hx-indicator="#loading-indicator"
           class="link link-primary">Back to Profile</a>
    </div>
</form> 