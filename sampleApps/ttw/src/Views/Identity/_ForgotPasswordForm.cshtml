@model string

<form hx-post="@Url.Action("ForgotPassword", "Identity")"
      hx-target="#primary-container"
      hx-push-url="true"
      hx-indicator="#loading-indicator">
    
    <div asp-validation-summary="ModelOnly" class="text-error mb-4" role="alert"></div>

    <div class="form-control w-full mb-4">
        <label class="label">
            <span class="label-text">Email</span>
        </label>
        <input name="email"
               type="email"
               class="input input-bordered w-full"
               autocomplete="username"
               placeholder="name@example.com" />
    </div>

    <div class="form-control mt-6">
        <button type="submit" class="btn btn-primary">Reset Password</button>
    </div>

    <div class="mt-4 text-center">
        <a hx-get="@Url.Action("Login", "Identity")"
           hx-target="#primary-container"
           hx-push-url="true"
           hx-indicator="#loading-indicator"
           class="link link-primary">Back to Login</a>
    </div>
</form> 