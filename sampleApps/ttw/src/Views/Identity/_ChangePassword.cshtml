@model ChangePasswordDto

<form hx-post="@Url.Action("ChangePassword", "Identity")"
      hx-target="#change-password-content"
      hx-push-url="true">

    <div class="text-error mb-4" role="alert">
        <div asp-validation-summary="ModelOnly"></div>
    </div>

    <div class="form-control w-full mb-4">
        <label class="label">
            <span class="label-text">Current Password</span>
        </label>
        <input asp-for="OldPassword"
               type="password"
               class="input input-bordered w-full"
               autocomplete="current-password" />
        <label class="label">
            <span asp-validation-for="OldPassword" class="label-text-alt text-error"></span>
        </label>
    </div>

    <div class="form-control w-full mb-4">
        <label class="label">
            <span class="label-text">New Password</span>
        </label>
        <input asp-for="NewPassword"
               type="password"
               class="input input-bordered w-full"
               autocomplete="new-password" />
        <label class="label">
            <span asp-validation-for="NewPassword" class="label-text-alt text-error"></span>
        </label>
    </div>

    <div class="form-control w-full mb-6">
        <label class="label">
            <span class="label-text">Confirm New Password</span>
        </label>
        <input asp-for="ConfirmPassword"
               type="password"
               class="input input-bordered w-full"
               autocomplete="new-password" />
        <label class="label">
            <span asp-validation-for="ConfirmPassword" class="label-text-alt text-error"></span>
        </label>
    </div>

    <div class="form-control">
        <button type="submit" class="btn btn-primary">Change Password</button>
    </div>
</form> 