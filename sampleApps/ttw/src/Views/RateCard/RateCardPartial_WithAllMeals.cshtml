@model RateCardPartialViewModel

@{
    // Store initial counts for JS to use/update
    var initialCommentColSpan = Model.NoOfRoomTypes + 3; // FROM, TO, Type + Room Types
}

@* Keep the main ID, add class 'rate-card' and data-card-id *@
<div id="card_@Model.CardId" class="card rate-card bg-base-100 shadow-xl mb-6" data-card-id="@Model.CardId">
    <div class="card-body">
        <div class="flex justify-between items-center mb-4">
            @* Card level actions *@
            <div class="flex gap-2">
                <button type="button" class="btn btn-xs btn-error" onclick="removeCard(this)">Remove Card</button>
                <button type="button" class="btn btn-xs btn-success" onclick="moveOrder(this, true)">Move Up</button>
                <button type="button" class="btn btn-xs" onclick="moveOrder(this, false)">Move Down</button>
            </div>
            @* Add Row/Column Actions *@
            <div class="flex gap-2">
                <button type="button" class="btn btn-xs btn-info" onclick="promptForRowType(this)">+ Add Date Range</button>
                <button type="button" class="btn btn-xs btn-warning" onclick="addColumn(this)">+ Add Room Type</button>
            </div>
        </div>

        @* Use classes instead of IDs for hidden fields *@
        <input type="hidden" class="js-no-of-rows" value="@Model.NoOfDates" />
        <input type="hidden" class="js-no-of-rooms" value="@Model.NoOfRoomTypes" />
        <input type="hidden" class="js-meal-per-row-value" value="@Model.MealPerRow.ToString()" />
        <input type="hidden" class="js-placement-order" value="@Model.CardId" />
        @* Store available RoomTypes for dynamic column adding (assuming ViewBag.RoomTypes is available) *@
        <script type="application/json" class="js-room-type-options">
            @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.RoomTypes as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>())))
        </script>

        <div class="overflow-x-auto">
            <table class="table table-compact w-full js-rate-table">
                @* Added js-rate-table class *@
                <thead>
                    <tr class="js-header-row-main">
                        @* Class to identify main header row *@
                        <th class="w-px"></th> @* Extra cell for remove row buttons *@
                        <th colspan="2">@Html.DropDownList("Hotels", null, htmlAttributes: new { @class = "select select-xs select-bordered w-full bg-error text-white js-hotel-select" })</th>
                        <th>@Html.DropDownList("Suppliers", null, htmlAttributes: new { @class = "select select-xs select-bordered w-full bg-primary text-white js-supplier-select" })</th>
                        @* Placeholder for room types - JS will populate/add here *@
                        @for (int roomIdx = 0; roomIdx < Model.NoOfRoomTypes; roomIdx++)
                        {
                            <th class="js-room-header">
                                @* Class to identify room headers *@
                                @Html.DropDownList("RoomTypes", null, htmlAttributes: new { @class = "select select-xs select-bordered w-full js-room-type-select", data_room_index = roomIdx })
                                <button type="button" class="btn btn-xs btn-ghost text-error p-0 ml-1" onclick="removeColumn(this)" title="Remove Room Type">X</button>
                            </th>
                        }
                        <th class="js-meal-header">Meal Notes</th> @* Meal per row, so header always present *@
                    </tr>
                    <tr class="js-header-row-sub">
                        @* Class to identify sub header row *@
                        <th></th> @* Cell for remove row buttons header - empty *@
                        <th>FROM</th>
                        <th>TO</th>
                        <th>Type</th>
                        @* Render empty THs matching initial room types - JS will add more if needed *@
                        @for (int roomIdx = 0; roomIdx < Model.NoOfRoomTypes; roomIdx++)
                        {
                            <th data-room-index="@roomIdx"></th> @* Empty TH for alignment under room type select/remove button *@
                        }
                        <th></th> @* Empty header for alignment with Meal Notes column *@
                    </tr>
                </thead>
                <tbody class="js-rate-table-body">
                    @* Class to identify tbody *@
                    @for (int rowIdx = 0; rowIdx < Model.NoOfDates; rowIdx++)
                    {
                        var rateInfo = Model.RowRates[rowIdx];
                        var isFlatRate = rateInfo.Selection == RowRateCard.FlatRate;

                        <input type="hidden" class="js-rate-type-enum" data-row-index="@rowIdx" value="@((int)rateInfo.Selection)" />

                        @if (isFlatRate)
                        {
                            <tr class="js-rate-row" data-row-index="@rowIdx">
                                @* Class and index for row *@
                                <td><button type="button" class="btn btn-xs btn-ghost text-error p-0" onclick="removeRow(this)" title="Remove Date Range">X</button></td>
                                <td><input type="date" class="input input-xs input-bordered w-full js-from-date" data-row-index="@rowIdx" /></td>
                                <td><input type="date" class="input input-xs input-bordered w-full js-to-date" data-row-index="@rowIdx" /></td>
                                <td>Flat</td>
                                @for (int roomIdx = 0; roomIdx < Model.NoOfRoomTypes; roomIdx++)
                                {
                                    <td data-room-index="@roomIdx"><input type="number" class="input input-xs input-bordered w-full text-center js-rate1" data-row-index="@rowIdx" data-room-index="@roomIdx" /></td>
                                }
                                <td class="js-meal-cell" data-row-index="@rowIdx">
                                    <input type="text" class="input input-xs input-bordered w-full js-meal-note-row" data-row-index="@rowIdx" placeholder="...meal notes..." />
                                </td>
                            </tr>
                        }
                        else // Weekend/Weekday Rate
                        {
                            <tr class="js-rate-row js-wd-row" data-row-index="@rowIdx">
                                @* Class and index for row (WD part) *@
                                <td rowspan="2"><button type="button" class="btn btn-xs btn-ghost text-error p-0" onclick="removeRow(this)" title="Remove Date Range">X</button></td>
                                <td rowspan="2"><input type="date" class="input input-xs input-bordered w-full js-from-date" data-row-index="@rowIdx" /></td>
                                <td rowspan="2"><input type="date" class="input input-xs input-bordered w-full js-to-date" data-row-index="@rowIdx" /></td>
                                <td>W/D</td>
                                @for (int roomIdx = 0; roomIdx < Model.NoOfRoomTypes; roomIdx++)
                                {
                                    <td data-room-index="@roomIdx"><input type="number" class="input input-xs input-bordered w-full text-center js-rate1" data-row-index="@rowIdx" data-room-index="@roomIdx" /></td>
                                }
                                <td class="js-meal-cell" rowspan="2" data-row-index="@rowIdx">
                                    <input type="text" class="input input-xs input-bordered w-full js-meal-note-row" data-row-index="@rowIdx" placeholder="...meal notes..." />
                                </td>
                            </tr>
                            <tr class="js-rate-row js-we-row" data-row-index="@rowIdx">
                                @* Class and index for row (WE part) *@
                                <td>W/E</td>
                                @for (int roomIdx = 0; roomIdx < Model.NoOfRoomTypes; roomIdx++)
                                {
                                    <td data-room-index="@roomIdx"><input type="number" class="input input-xs input-bordered w-full text-center js-rate2" data-row-index="@rowIdx" data-room-index="@roomIdx" /></td>
                                }
                                @* Meal note cell is spanned from W/D row *@
                            </tr>
                        }
                    }
                </tbody>
                <tfoot>
                    <tr class="js-footer-row">
                        @* Class to identify footer row *@
                        <td class="js-comment-cell" colspan="@initialCommentColSpan"><input class="input input-xs input-bordered w-full js-additional-notes" placeholder="... additional notes ..." /></td>
                        <td class="js-comment-meal-spacer"></td> @* Empty cell to fill Meal Notes column space *@
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>