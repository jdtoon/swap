@model RateCardEditModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var token = Antiforgery.GetAndStoreTokens(Context);
    ViewBag.Title = "Edit Rate Card";

    // Prepare initial state for JavaScript
    int currentCardCount = Model?.Model?.Count ?? 0;
    string initialCardListJs = currentCardCount > 0
        ? string.Join(",", Enumerable.Range(1, currentCardCount).Select(i => $"'{i}'"))
        : "";
    int nextNewCardId = currentCardCount + 1;
}

<input type="hidden" name="__RequestVerificationToken" value="@token.RequestToken" />

<div class="p-4">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold">Edit Rate Card</h2>
    </div>

    <div class="form-control w-full max-w-lg mb-6">
        <label class="label">
            <span class="label-text">Name <span class="text-error">*</span></span>
        </label>
        <input type="text" value="@Model.Name" class="input input-bordered w-full js-rate-card-name" />
    </div>

    <div class="flex gap-2 mb-6">
        <button type="button" class="btn btn-ghost" onclick="showModal('addHotelStep1')">Add Hotel</button>
        <button type="button" class="btn btn-error" onclick="saveCardProgress(false)">Save Progress</button>
        <button type="button" class="btn btn-primary" onclick="saveCardProgress(true)">Save & Close</button>
    </div>

    <div class="js-rate-card-container">
        <input type="hidden" value="@Model.Id" class="js-rate-card-id" />

        @* Loop through existing card data from the Model *@
        @for (int cardIndex = 0; cardIndex < currentCardCount; cardIndex++)
        {
            var cardModel = Model.Model[cardIndex];
            int displayCardNo = cardIndex + 1;

            var flatRateCount = cardModel.rows?.Count(x => x.selection == RowRateCard.FlatRate) ?? 0;
            var weekendRateCount = cardModel.rows?.Count(x => x.selection == RowRateCard.WeekendRate) ?? 0;
            var initialMealRowSpan = cardModel.mealPerRow ? 1 : (weekendRateCount * 2) + flatRateCount; // Adjust for meal per row logic
            var initialCommentColSpan = cardModel.numberOfRooms + 3;

            <div class="card rate-card bg-base-100 shadow-xl mb-6" data-card-id="@displayCardNo">
                <div class="card-body">
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex gap-2">
                            <button type="button" class="btn btn-xs btn-error" onclick="removeCard(this)">Remove Card</button>
                            <button type="button" class="btn btn-xs btn-success" onclick="moveOrder(this, true)">Move Up</button>
                            <button type="button" class="btn btn-xs" onclick="moveOrder(this, false)">Move Down</button>
                        </div>
                        <div class="flex gap-2">
                            <button type="button" class="btn btn-xs btn-info" onclick="promptForRowType(this)">+ Add Date Range</button>
                            <button type="button" class="btn btn-xs btn-warning" onclick="addColumn(this)">+ Add Room Type</button>
                        </div>
                    </div>

                    <input type="hidden" class="js-no-of-rows" value="@cardModel.numberOfRows" />
                    <input type="hidden" class="js-no-of-rooms" value="@cardModel.numberOfRooms" />
                    <input type="hidden" class="js-meal-per-row-value" value="@cardModel.mealPerRow.ToString()" />
                    <input type="hidden" class="js-placement-order" value="@displayCardNo" />
                    <script type="application/json" class="js-room-type-options">
                        @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.RoomTypes as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>())))
                    </script>

                    <div class="overflow-x-auto">
                        <table class="table table-compact w-full js-rate-table">
                            <thead>
                                <tr class="js-header-row-main">
                                    <th class="w-px"></th>
                                    <th colspan="2">
                                        @Html.DropDownListFor(m => cardModel.selectedHotel,
                                                 cardModel.Hotels as SelectList, // Make sure this is populated in your Controller for Edit
                                                 new { @class = "select select-xs select-bordered w-full bg-error text-white js-hotel-select" })
                                    </th>
                                    <th>
                                        @Html.DropDownListFor(m => cardModel.selectedSupplier,
                                                 cardModel.Suppliers as SelectList, // Make sure this is populated in your Controller for Edit
                                                 new { @class = "select select-xs select-bordered w-full bg-primary text-white js-supplier-select" })
                                    </th>
                                    @for (int roomIndex = 0; roomIndex < cardModel.numberOfRooms; roomIndex++)
                                    {
                                        <th class="js-room-header">
                                            @Html.DropDownListFor(m => cardModel.selectedRooms[roomIndex],
                                                     new SelectList(ViewBag.RoomTypes, "Value", "Text", cardModel.selectedRooms[roomIndex]), // Assuming Value/Text properties
                                                     new { @class = "select select-xs select-bordered w-full js-room-type-select", data_room_index = roomIndex })
                                            <button type="button" class="btn btn-xs btn-ghost text-error p-0 ml-1" onclick="removeColumn(this)" title="Remove Room Type">X</button>
                                        </th>
                                    }
                                    @if (cardModel.mealPerRow)
                                    {
                                        <th class="js-meal-header">Meal Notes</th>
                                    }
                                    else
                                    {
                                        <th class="js-meal-header">Meal Notes</th>
                                        // Keep header even if global
                                    }
                                </tr>
                                <tr class="js-header-row-sub">
                                    <th></th>
                                    <th>FROM</th>
                                    <th>TO</th>
                                    <th>Type</th>
                                    @for (int roomIndex = 0; roomIndex < cardModel.numberOfRooms; roomIndex++)
                                    {
                                        <th data-room-index="@roomIndex"></th>
                                    }
                                    <th></th> @* Alignment for meal column *@
                                </tr>
                            </thead>
                            <tbody class="js-rate-table-body">
                                @for (int rowIndex = 0; rowIndex < cardModel.numberOfRows; rowIndex++)
                                {
                                    var rowData = cardModel.rows[rowIndex];
                                    var isFlatRate = rowData.selection == RowRateCard.FlatRate;

                                    <input type="hidden" class="js-rate-type-enum" data-row-index="@rowIndex" value="@((int)rowData.selection)" />

                                    if (isFlatRate)
                                    {
                                        <tr class="js-rate-row" data-row-index="@rowIndex">
                                            <td><button type="button" class="btn btn-xs btn-ghost text-error p-0" onclick="removeRow(this)" title="Remove Date Range">X</button></td>
                                            <td><input type="date" class="input input-xs input-bordered w-full js-from-date" data-row-index="@rowIndex" value="@rowData.from" /></td>
                                            <td><input type="date" class="input input-xs input-bordered w-full js-to-date" data-row-index="@rowIndex" value="@rowData.to" /></td>
                                            <td>Flat</td>
                                            @for (int roomIndex = 0; roomIndex < cardModel.numberOfRooms; roomIndex++)
                                            {
                                                var rateData = rowData.rates[roomIndex];
                                                <td data-room-index="@roomIndex"><input type="number" class="input input-xs input-bordered w-full text-center js-rate1" data-row-index="@rowIndex" data-room-index="@roomIndex" value="@rateData.rate1" /></td>
                                            }
                                            @if (cardModel.mealPerRow)
                                            {
                                                <td class="js-meal-cell" data-row-index="@rowIndex"><input type="text" class="input input-xs input-bordered w-full js-meal-note-row" data-row-index="@rowIndex" placeholder="...meal notes..." value="@rowData.mealNote" /></td>
                                            }
                                            else if (rowIndex == 0) // Global meal notes
                                            {
                                                <td class="js-global-meal-cell" rowspan="@initialMealRowSpan"><input type="text" class="input input-xs input-bordered w-full js-meal-notes" placeholder="...meal notes..." value="@cardModel.mealNotes" /></td>
                                            }
                                        </tr>
                                    }
                                    else // Weekend/Weekday
                                    {
                                        <tr class="js-rate-row js-wd-row" data-row-index="@rowIndex">
                                            <td rowspan="2"><button type="button" class="btn btn-xs btn-ghost text-error p-0" onclick="removeRow(this)" title="Remove Date Range">X</button></td>
                                            <td rowspan="2"><input type="date" class="input input-xs input-bordered w-full js-from-date" data-row-index="@rowIndex" value="@rowData.from" /></td>
                                            <td rowspan="2"><input type="date" class="input input-xs input-bordered w-full js-to-date" data-row-index="@rowIndex" value="@rowData.to" /></td>
                                            <td>W/D</td>
                                            @for (int roomIndex = 0; roomIndex < cardModel.numberOfRooms; roomIndex++)
                                            {
                                                var rateData = rowData.rates[roomIndex];
                                                <td data-room-index="@roomIndex"><input type="number" class="input input-xs input-bordered w-full text-center js-rate1" data-row-index="@rowIndex" data-room-index="@roomIndex" value="@rateData.rate1" /></td>
                                            }
                                            @if (cardModel.mealPerRow)
                                            {
                                                <td class="js-meal-cell" rowspan="2" data-row-index="@rowIndex"><input type="text" class="input input-xs input-bordered w-full js-meal-note-row" data-row-index="@rowIndex" placeholder="...meal notes..." value="@rowData.mealNote" /></td>
                                            }
                                            else if (rowIndex == 0) // Global meal notes
                                            {
                                                <td class="js-global-meal-cell" rowspan="@initialMealRowSpan"><input type="text" class="input input-xs input-bordered w-full js-meal-notes" placeholder="...meal notes..." value="@cardModel.mealNotes" /></td>
                                            }
                                        </tr>
                                        <tr class="js-rate-row js-we-row" data-row-index="@rowIndex">
                                            <td>W/E</td>
                                            @for (int roomIndex = 0; roomIndex < cardModel.numberOfRooms; roomIndex++)
                                            {
                                                var rateData = rowData.rates[roomIndex];
                                                <td data-room-index="@roomIndex"><input type="number" class="input input-xs input-bordered w-full text-center js-rate2" data-row-index="@rowIndex" data-room-index="@roomIndex" value="@rateData.rate2" /></td>
                                            }
                                            @* Meal cell spanned from W/D row *@
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr class="js-footer-row">
                                    <td class="js-comment-cell" colspan="@initialCommentColSpan"><input class="input input-xs input-bordered w-full js-additional-notes" value="@cardModel.additionalNotes" placeholder="... additional notes ..." /></td>
                                    <td class="js-comment-meal-spacer"></td> @* Alignment for meal column *@
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        } @* End of loop through existing cards *@
    </div> @* End of js-rate-card-container *@
</div>

@* --- Modals (Same as before, ensure classes are present) --- *@
<dialog id="addHotelStep1" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Add Hotel - Basic Details</h3>
        <div class="py-4">
            <div class="form-control w-full">
                <label class="label"><span class="label-text">No of Dates</span></label>
                <input type="number" min="1" value="1" class="input input-bordered w-full js-modal-no-of-dates" />
            </div>
            <div class="form-control w-full">
                <label class="label"><span class="label-text">No of Room Types</span></label>
                <input type="number" min="1" value="1" class="input input-bordered w-full js-modal-no-of-room-types" />
            </div>
            <div class="form-control w-full">
                <label class="label"><span class="label-text">City</span></label>
                @Html.DropDownList("CityList", null, new { @class = "select select-bordered w-full js-modal-city-select" })
            </div>
            <div class="form-control">
                <label class="label cursor-pointer">
                    <span class="label-text">Meal Per Row?</span>
                    <input type="checkbox" class="checkbox js-modal-meal-per-row" />
                </label>
            </div>
        </div>
        <div class="modal-action">
            <button type="button" class="btn btn-primary" onclick="handleStep1(this)">Next</button>
            <button type="button" class="btn" onclick="closeModal('addHotelStep1')">Close</button>
        </div>
    </div>
</dialog>

<dialog id="addHotelStep2" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Room - Row Details</h3>
        <div class="py-4">
            <div class="space-y-4 js-step2-form"></div>
        </div>
        <div class="modal-action">
            <button type="button" class="btn btn-primary" onclick="handleStep2(this)">Done</button>
            <button type="button" class="btn" onclick="closeModal('addHotelStep2')">Close</button>
        </div>
    </div>
</dialog>

<dialog id="addRowTypeModal" class="modal">
    <div class="modal-box w-auto max-w-xs"> @* Smaller modal *@
        <h3 class="font-bold text-lg text-center mb-4">Select Rate Type</h3>
        <div class="flex flex-col gap-3">
            <button type="button" class="btn btn-primary" onclick="doAddRowWithType('1')">
                Add Flat Rate Row
            </button>
            <button type="button" class="btn btn-secondary" onclick="doAddRowWithType('2')">
                Add Weekend/Weekday Row
            </button>
        </div>
        <div class="modal-action mt-6">
            <button class="btn btn-sm btn-ghost" onclick="closeModal('addRowTypeModal')">Cancel</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>

@* --- Script Loading and Initialization --- *@
@if (ViewBag.IsHTMXRequest == true)
{
    <script src="~/js/ratecard.js" class="js-rate-card-scripts-marker" asp-append-version="true"></script>
    <script defer>
        if (!document.querySelector('.js-rate-card-scripts-marker[data-initialized="true"]')) {
             window.initializeRateCard({
                cardId: @nextNewCardId,
                cardList: [@Html.Raw(initialCardListJs)]
            });
            const scriptTag = document.querySelector('.js-rate-card-scripts-marker');
            if(scriptTag) scriptTag.dataset.initialized = 'true';
        }
    </script>
}
else
{
    @section Scripts {
    <script src="~/js/ratecard.js" class="js-rate-card-scripts-marker" asp-append-version="true"></script>
    <script defer>
        if (!document.querySelector('.js-rate-card-scripts-marker[data-initialized="true"]')) {
             window.initializeRateCard({
                cardId: @nextNewCardId,
                cardList: [@Html.Raw(initialCardListJs)]
            });
            const scriptTag = document.querySelector('.js-rate-card-scripts-marker');
            if(scriptTag) scriptTag.dataset.initialized = 'true';
        }
    </script>
    }
}