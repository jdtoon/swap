<!DOCTYPE html>
<html lang="en" data-theme="cupcake">
<head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex">
    <meta name="googlebot" content="noindex">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" sizes="512x512" href="/icons/icon-512.png">
    <title>App</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadContent", required: false)
</head>
<body>
    <main>
        <div class="drawer lg:drawer-open">
            <input id="main-drawer" type="checkbox" class="drawer-toggle" />
            
            <div class="drawer-content flex flex-col">
                <!-- Navbar -->
                <div class="w-full navbar bg-base-300">
                    <div class="flex-none lg:hidden">
                        <label for="main-drawer" class="btn btn-square btn-ghost">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                            </svg>
                        </label>
                    </div>
                    <div class="flex-1 px-2 mx-2 font-bold">TTW Management</div>
                    <div class="flex-none">
                        <div class="dropdown dropdown-end">
                            <label tabindex="0" class="btn btn-ghost btn-circle avatar">
                                <div class="w-10 rounded-full">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                    </svg>
                                </div>
                            </label>
                            <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
                                <li>
                                    <a hx-get="@Url.Action("ChangePassword", "Identity")"
                                       hx-target="#main-content"
                                       hx-push-url="true">
                                        Change Password
                                    </a>
                                </li>
                                <li>
                                    <form asp-controller="Identity" asp-action="Logout" method="post" class="w-full"
                                          hx-post="@Url.Action("Logout", "Identity")"
                                          hx-trigger="click"
                                          hx-indicator="#loading-indicator"
                                          hx-on::after-request="window.location.href = '/'">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="w-full text-left">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Main Content -->
                <div id="main-content" class="p-4">
                    @RenderBody()
                </div>
            </div>

            <div class="drawer-side">
                <label for="main-drawer" class="drawer-overlay"></label>
                <div id="nav-content" class="menu p-4 w-80 min-h-full bg-base-200">
                    @await Html.PartialAsync("_Navigation")
                </div>
            </div>
        </div>
    </main>

    <!-- Loading Indicator -->
    <div id="loading-indicator" class="htmx-indicator flex justify-center">
        <span class="loading loading-spinner loading-lg"></span>
    </div>

    <script src="~/lib/htmx/htmx.min.js"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>