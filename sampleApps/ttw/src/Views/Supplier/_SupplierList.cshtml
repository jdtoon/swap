@model PagedResult<Supplier>

<div class="overflow-x-auto">
    <div class="mb-4">
        <input type="text" 
               placeholder="Quick Search ..." 
               class="input input-bordered w-full max-w-xs"
               value="@ViewBag.CurrentSearch"
               hx-trigger="keyup changed delay:500ms"
               hx-get="@Url.Action("GetSupplierList")"
               hx-target="#supplierList"
               hx-on::after-settle="this.focus();"
               autofocus
               name="search" />
    </div>

    <table class="table w-full">
        <thead>
            <tr>
                <th>Supplier Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var supplier in Model.Data)
            {
                <tr id="supplier-@supplier.Id">
                    <td>@supplier.Name</td>
                    <td class="space-x-2">
                        <button class="btn btn-sm btn-info"
                                hx-get="@Url.Action("EditModal", new { id = supplier.Id })"
                                hx-target="#modalContainer">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-error"
                                hx-delete="@Url.Action("Delete", new { id = supplier.Id })"
                                hx-target="#supplier-@supplier.Id"
                                hx-confirm="Are you sure you want to delete this supplier?"
                                hx-swap="outerHTML">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.HasMore)
    {
        <div class="text-center mt-4">
            <button class="btn btn-ghost"
                    hx-get="@Url.Action("GetSupplierList", new { take = Model.CurrentPage + 10, search = ViewBag.CurrentSearch })"
                    hx-target="#supplierList"
                    hx-swap="innerHTML">
                Load More
            </button>
        </div>
    }
</div> 