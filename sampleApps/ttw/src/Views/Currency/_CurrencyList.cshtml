@model PagedResult<Currency>

<div class="overflow-x-auto">
    <div class="mb-4">
        <input type="text" 
               placeholder="Quick Search ..." 
               class="input input-bordered w-full max-w-xs"
               value="@ViewBag.CurrentSearch"
               hx-trigger="keyup changed delay:500ms"
               hx-get="@Url.Action("GetCurrencyList")"
               hx-target="#currencyList"
               hx-indicator="#loading-indicator"
               hx-on::after-settle="this.focus();"
               autofocus
               name="search" />
    </div>

    <table class="table w-full">
        <thead>
            <tr>
                <th>Currency</th>
                <th>Long Name</th>
                <th>Rate</th>
                <th>Round Off</th>
                <th>Markup</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var currency in Model.Data)
            {
                <tr id="currency-@currency.Id">
                    <td>@currency.Name</td>
                    <td>@currency.LongName</td>
                    <td>@currency.Rate.ToString("0.00")</td>
                    <td>@currency.RoundOff</td>
                    <td>@currency.Markup%</td>
                    <td class="space-x-2">
                        <button class="btn btn-sm btn-info"
                                hx-get="@Url.Action("EditModal", new { id = currency.Id })"
                                hx-target="#modalContainer"
                                hx-indicator="#loading-indicator">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-error"
                                hx-delete="@Url.Action("Delete", new { id = currency.Id })"
                                hx-target="#currency-@currency.Id"
                                hx-indicator="#loading-indicator"
                                hx-confirm="Are you sure you want to delete this currency?"
                                hx-swap="outerHTML">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.HasMore)
    {
        <div class="text-center mt-4">
            <button class="btn btn-ghost"
                    hx-get="@Url.Action("Index", new { take = Model.CurrentPage + 10, search = ViewBag.CurrentSearch })"
                    hx-target="#currencyList"
                    hx-indicator="#loading-indicator"
                    hx-swap="innerHTML">
                Load More
            </button>
        </div>
    }
</div> 