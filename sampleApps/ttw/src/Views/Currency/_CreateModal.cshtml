@model Currency

<dialog id="createModal" class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Add New Currency</h3>
        <form hx-post="@Url.Action("Create")" 
              hx-target="#currencyList"
              hx-swap="innerHTML"
              hx-indicator="#loading-indicator"
              hx-on::after-request="document.getElementById('createModal').remove();">
            @Html.AntiForgeryToken()
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Currency Code</span>
                </label>
                <input type="text" name="Name" class="input input-bordered" required 
                       maxlength="50" placeholder="e.g., USD" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Long Name</span>
                </label>
                <input type="text" name="LongName" class="input input-bordered" required 
                       maxlength="100" placeholder="e.g., United States Dollar" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Exchange Rate</span>
                </label>
                <input type="text" name="Rate" class="input input-bordered" required 
                       placeholder="e.g., 1.00" 
                       pattern="[0-9]*[.,]?[0-9]+"
                       onkeypress="return validateDecimalInput(event)"
                       onblur="formatDecimal(this)" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Round Off</span>
                </label>
                <input type="number" name="RoundOff" class="input input-bordered" required 
                       step="1" min="0" placeholder="e.g., 2" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Markup (%)</span>
                </label>
                <input type="number" name="Markup" class="input input-bordered" required 
                       step="1" min="0" placeholder="e.g., 5" />
            </div>

            <div class="modal-action">
                <button type="button" 
                        class="btn btn-ghost"
                        onclick="closeModal('createModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function closeModal(modalId) {
        document.getElementById(modalId).remove();
    }

    document.body.addEventListener('closeModal', function() {
        closeModal('createModal');
    });

    function validateDecimalInput(event) {
        const charCode = (event.which) ? event.which : event.keyCode;
        const value = event.target.value;
        
        // Allow numbers
        if (charCode >= 48 && charCode <= 57) return true;
        
        // Allow decimal separator (both . and ,) only once
        if ((charCode === 46 || charCode === 44) && !value.includes('.') && !value.includes(',')) 
            return true;
            
        return false;
    }

    function formatDecimal(input) {
        let value = input.value.replace(',', '.');
        if (value && !isNaN(parseFloat(value))) {
            input.value = parseFloat(value).toFixed(2);
        }
    }
</script> 