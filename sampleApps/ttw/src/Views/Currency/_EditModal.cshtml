@model Currency

<dialog id="editModal" class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Edit Currency</h3>
        <form hx-post="@Url.Action("Edit")" 
              hx-target="#currencyList"
              hx-swap="innerHTML"
              hx-indicator="#loading-indicator"
              hx-on::after-request="document.getElementById('editModal').remove();">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Currency Code</span>
                </label>
                <input type="text" name="Name" value="@Model.Name" 
                       class="input input-bordered" required 
                       maxlength="50" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Long Name</span>
                </label>
                <input type="text" name="LongName" value="@Model.LongName" 
                       class="input input-bordered" required 
                       maxlength="100" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Exchange Rate</span>
                </label>
                <input type="text" name="Rate" 
                       value="@Model.Rate.ToString("F2", System.Globalization.CultureInfo.CurrentCulture)" 
                       class="input input-bordered" required 
                       pattern="[0-9]*[.,]?[0-9]+"
                       onkeypress="return validateDecimalInput(event)"
                       onblur="formatDecimal(this)" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Round Off</span>
                </label>
                <input type="number" name="RoundOff" value="@Model.RoundOff" 
                       class="input input-bordered" required 
                       step="1" min="0" />
            </div>

            <div class="form-control mt-4">
                <label class="label">
                    <span class="label-text">Markup (%)</span>
                </label>
                <input type="number" name="Markup" value="@Model.Markup" 
                       class="input input-bordered" required 
                       step="1" min="0" />
            </div>

            <div class="modal-action">
                <button type="button" 
                        class="btn btn-ghost"
                        onclick="closeModal('editModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Update</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function closeModal(modalId) {
        document.getElementById(modalId).remove();
    }

    document.body.addEventListener('closeModal', function() {
        closeModal('editModal');
    });

    function validateDecimalInput(event) {
        const charCode = (event.which) ? event.which : event.keyCode;
        const value = event.target.value;
        
        // Allow numbers
        if (charCode >= 48 && charCode <= 57) return true;
        
        // Allow decimal separator (both . and ,) only once
        if ((charCode === 46 || charCode === 44) && !value.includes('.') && !value.includes(',')) 
            return true;
            
        return false;
    }

    function formatDecimal(input) {
        let value = input.value.replace(',', '.');
        if (value && !isNaN(parseFloat(value))) {
            input.value = parseFloat(value).toFixed(2);
        }
    }
</script> 