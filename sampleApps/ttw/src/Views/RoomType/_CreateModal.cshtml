@model RoomType

<dialog id="createModal" class="modal modal-open">
    <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Add New Room Type</h3>
        <form hx-post="@Url.Action("Create")" 
              hx-target="#roomTypeList"
              hx-swap="innerHTML"
              hx-on::after-request="document.getElementById('createModal').remove();">
            @Html.AntiForgeryToken()
            
            <div class="form-control">
                <label class="label">
                    <span class="label-text">Room Type Name</span>
                </label>
                <input type="text" name="Name" 
                       class="input input-bordered" 
                       required 
                       maxlength="50" />
            </div>

            <div class="modal-action">
                <button type="button" 
                        class="btn btn-ghost"
                        onclick="closeModal('createModal')">
                    Cancel
                </button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function closeModal(modalId) {
        document.getElementById(modalId).remove();
    }

    document.body.addEventListener('closeModal', function() {
        closeModal('createModal');
    });
</script> 