@{
    ViewData["Title"] = "Conditional Swaps";
}
@model SwapLab.Models.ConditionalSwapViewModel

<hgroup>
    <h1>Conditional OOB Swaps</h1>
    <p>Skip out-of-band swaps when targets don't exist or conditions aren't met</p>
</hgroup>

<h2>Live Demo: AlsoUpdateIfExists</h2>
<div class="demo-area">
    <p class="text-muted mb-3">
        Try clicking the buttons. The notification panel may or may not exist depending on the toggle.
        <code>AlsoUpdateIfExists()</code> gracefully skips updates when targets are missing.
    </p>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Actions</div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-primary"
                                hx-post="@Url.Action("TriggerWithNotification", "Patterns")"
                                hx-target="#action-result">
                            Do Action (with notification)
                        </button>
                        
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="show-notifications" checked
                                   onchange="document.getElementById('notification-panel').style.display = this.checked ? 'block' : 'none'">
                            <label class="form-check-label" for="show-notifications">
                                Show notification panel
                            </label>
                        </div>
                        
                        <div id="action-result" class="mt-3">
                            <span class="text-muted">Click a button to see the result</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div id="notification-panel" class="card border-info">
                <div class="card-header bg-info text-white">
                    <i class="bi bi-bell me-2"></i>Notification Panel
                </div>
                <div class="card-body" id="notification-content">
                    <span class="text-muted">Notifications will appear here</span>
                </div>
            </div>
        </div>
    </div>
</div>

<h2>How AlsoUpdateIfExists Works</h2>
<div class="code-view">
<pre>// Standard AlsoUpdate - throws if target missing
return this.SwapResponse()
    .WithView("_Result", model)
    .AlsoUpdate("notification", "_Notification", message)  // Fails if #notification missing
    .Build();

// AlsoUpdateIfExists - gracefully skips if target missing
return this.SwapResponse()
    .WithView("_Result", model)
    .AlsoUpdateIfExists("notification", "_Notification", message)  // Safe!
    .Build();</pre>
</div>

<h2>Live Demo: AlsoUpdateIf</h2>
<div class="demo-area">
    <p class="text-muted mb-3">
        <code>AlsoUpdateIf()</code> conditionally includes OOB swaps based on server-side logic.
    </p>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Order Actions</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">User Role</label>
                        <select id="user-role" class="form-select"
                                hx-post="@Url.Action("ConditionalUpdate", "Patterns")"
                                hx-target="#order-result"
                                hx-include="#user-role, #order-value"
                                name="role">
                            <option value="customer">Customer</option>
                            <option value="manager">Manager</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Order Value</label>
                        <input type="number" id="order-value" name="orderValue" class="form-control" value="100"
                               hx-post="@Url.Action("ConditionalUpdate", "Patterns")"
                               hx-target="#order-result"
                               hx-include="#user-role, #order-value"
                               hx-trigger="change">
                    </div>
                    <div id="order-result">
                        <span class="text-muted">Select a role and enter an order value</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Dashboard Panels (Updated Conditionally)</div>
                <div class="card-body">
                    <div id="manager-panel" class="alert alert-warning mb-2" style="display: none;">
                        <strong>Manager Panel:</strong> <span id="manager-content">Waiting...</span>
                    </div>
                    <div id="admin-panel" class="alert alert-danger mb-2" style="display: none;">
                        <strong>Admin Panel:</strong> <span id="admin-content">Waiting...</span>
                    </div>
                    <div id="high-value-alert" class="alert alert-info" style="display: none;">
                        <strong>High Value Alert:</strong> <span id="high-value-content">Waiting...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<h2>How AlsoUpdateIf Works</h2>
<div class="code-view">
<pre>[HttpPost]
public IActionResult ProcessOrder(string role, decimal orderValue)
{
    var isManager = role == "manager" || role == "admin";
    var isAdmin = role == "admin";
    var isHighValue = orderValue > 500;
    
    return this.SwapResponse()
        .WithView("_OrderResult", new { role, orderValue })
        // Only managers and admins see the manager panel
        .AlsoUpdateIf(isManager, "manager-panel", "_ManagerPanel", stats)
        // Only admins see the admin panel
        .AlsoUpdateIf(isAdmin, "admin-panel", "_AdminPanel", auditLog)
        // High-value orders trigger an alert for everyone
        .AlsoUpdateIf(isHighValue, "high-value-alert", "_HighValueAlert", orderValue)
        .Build();
}</pre>
</div>

<h2>Comparison</h2>
<table>
    <thead>
        <tr>
            <th>Method</th>
            <th>Use Case</th>
            <th>Behavior</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><code>AlsoUpdate()</code></td>
            <td>Target always exists</td>
            <td>Always includes the OOB swap</td>
        </tr>
        <tr>
            <td><code>AlsoUpdateIfExists()</code></td>
            <td>Target may or may not be in DOM</td>
            <td>Marks swap to skip if target missing (client-side check)</td>
        </tr>
        <tr>
            <td><code>AlsoUpdateIf(condition, ...)</code></td>
            <td>Server-side conditional logic</td>
            <td>Only includes swap when condition is true</td>
        </tr>
    </tbody>
</table>

<h2>Real-World Examples</h2>
<ul>
    <li><strong>Notifications:</strong> User can close/minimize notification area</li>
    <li><strong>Role-based updates:</strong> Only show admin panels to admins</li>
    <li><strong>Feature flags:</strong> Only update UI for users with feature enabled</li>
    <li><strong>Lazy-loaded components:</strong> Component may not be loaded yet</li>
</ul>
