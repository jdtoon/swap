@{
    ViewData["Title"] = "URL State";
    Layout = Context.Request.Headers.ContainsKey("HX-Request") ? "_PartialLayout" : "_Layout";
}

<hgroup>
    <h1>URL State</h1>
    <p>Sync state with URL for bookmarkable pages</p>
</hgroup>

<h2>Live Demo</h2>
<div class="demo-area">
    <p style="color: var(--color-text-muted);">
        Try the tabs below and watch your browser's address bar update.
        You can use back/forward to navigate between states.
    </p>

    <div class="tabs" style="margin-bottom: 1.5rem;">
        <button class="active"
                hx-get="/Patterns/UrlStateTab?tab=products"
                hx-target="#tab-content"
                hx-push-url="true">
            Products
        </button>
        <button hx-get="/Patterns/UrlStateTab?tab=orders"
                hx-target="#tab-content"
                hx-push-url="true">
            Orders
        </button>
        <button hx-get="/Patterns/UrlStateTab?tab=settings"
                hx-target="#tab-content"
                hx-push-url="true">
            Settings
        </button>
    </div>

    <div id="tab-content" style="padding: 1rem; background: var(--color-bg-tertiary); border-radius: var(--radius);">
        <h4>Products Tab</h4>
        <p>This is the products content. Notice the URL hasn't changed yet.</p>
        <p style="color: var(--color-text-muted); margin: 0;">Click another tab to see URL state in action.</p>
    </div>

    <p style="font-size: 0.875rem; color: var(--color-text-muted); margin-top: 1rem;">
        ℹ️ Check your browser's address bar as you click tabs
    </p>
</div>

<h2>URL State Management</h2>
<p>
    Use <code>hx-push-url</code> to update the browser URL when making HTMX requests.
    This enables bookmarkable pages and browser back/forward navigation.
</p>

<h2>Key Attributes</h2>
<ul>
    <li><code>hx-push-url="true"</code> — Push current URL to history</li>
    <li><code>hx-push-url="/custom/path"</code> — Push custom URL</li>
    <li><code>Response.HxPushUrl()</code> — Server-side URL push</li>
</ul>

<h2>Controller Code</h2>
<div class="code-view">
<pre>[HttpGet]
public IActionResult Search(string? q, int page = 1)
{
    var results = SearchProducts(q, page);
    
    // Push URL with query params
    Response.HxPushUrl($"/search?q={q}&amp;page={page}");
    
    return this.SwapResponse()
        .WithView("_Results", results)
        .Build();
}</pre>
</div>

<h2>Key Points</h2>
<ul>
    <li>URL state enables bookmarkable/shareable page views</li>
    <li>Browser back/forward navigation works naturally</li>
    <li>Best for search, filter, and tabbed interfaces</li>
    <li>Combine with hidden fields for complex state</li>
</ul>
