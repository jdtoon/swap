@{
    ViewData["Title"] = "Basic Swap";
    
}

<hgroup>
    <h1>Basic Swap</h1>
    <p>The simplest HTMX + Swap.Htmx interaction</p>
</hgroup>

<h2>Live Demo</h2>
<div class="demo-area">
    <div id="message-container">
        <p>Click the button to load a message from the server.</p>
        <button hx-get="/Patterns/GetMessage" 
                hx-target="#@PatternIds.MessageContainer" 
                hx-swap="innerHTML">
            Load Message
        </button>
    </div>
</div>

<h2>How It Works</h2>
<ol>
    <li>Button has <code>hx-get="/Patterns/GetMessage"</code> to make a GET request</li>
    <li>Response targets <code>#message-container</code></li>
    <li>Server returns a partial view using <code>SwapResponse().WithView()</code></li>
</ol>

<h2>Controller Code</h2>
<div class="code-view">
<pre>[HttpGet]
public IActionResult GetMessage()
{
    return this.SwapResponse()
        .WithView("_Message", new { 
            Message = $"Hello! The time is {DateTime.Now:HH:mm:ss}" 
        })
        .Build();
}</pre>
</div>

<h2>View Code</h2>
<div class="code-view">
<pre>&lt;div id="message-container"&gt;
    &lt;button hx-get="/Patterns/GetMessage" 
            hx-target="#message-container" 
            hx-swap="innerHTML"&gt;
        Load Message
    &lt;/button&gt;
&lt;/div&gt;</pre>
</div>

<h2>Partial View (_Message.cshtml)</h2>
<div class="code-view">
<pre>@@model dynamic
&lt;p&gt;@@Model.Message&lt;/p&gt;
&lt;button hx-get="/Patterns/GetMessage" 
        hx-target="#message-container" 
        hx-swap="innerHTML"&gt;
    Refresh
&lt;/button&gt;</pre>
</div>

<h2>Key Points</h2>
<ul>
    <li><code>SwapResponse()</code> is the extension method for building responses</li>
    <li><code>.WithView()</code> renders a Razor partial view</li>
    <li>The response replaces only the targeted element</li>
</ul>
