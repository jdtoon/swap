@{
    ViewData["Title"] = "Loading States";
    ViewData["Description"] = "Provide visual feedback during HTMX requests";
}

<div class="row">
    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Why Loading States?</h5>
            </div>
            <div class="card-body">
                <p>
                    Users need feedback when something is happening. HTMX provides the 
                    <code>htmx-request</code> class automatically, and you can use indicators
                    for more complex feedback.
                </p>

                <h6>Methods:</h6>
                <ul>
                    <li><strong>CSS-based:</strong> Use <code>.htmx-request</code> class</li>
                    <li><strong>Indicator:</strong> Use <code>hx-indicator</code> attribute</li>
                    <li><strong>Disabled state:</strong> Prevent double-clicks</li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-code-slash me-2"></i>CSS Approach</h5>
            </div>
            <div class="card-body">
<pre class="bg-light p-3 rounded"><code>/* Hide button text, show spinner during request */
.htmx-request .btn-text { display: none; }
.htmx-request .spinner { display: inline-block; }
.spinner { display: none; }

/* Disable pointer events during request */
.htmx-request { 
    pointer-events: none;
    opacity: 0.7;
}</code></pre>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-play-circle me-2"></i>Live Demo</h5>
            </div>
            <div class="card-body">
                <h6>Button with Spinner</h6>
                <p class="text-muted small">Click to see the loading state (simulated 1.5s delay)</p>
                
                <button class="btn btn-primary mb-4"
                        hx-post="@Url.Action("SlowAction", "Patterns")"
                        hx-target="#slow-result"
                        hx-swap="innerHTML">
                    <span class="btn-text">
                        <i class="bi bi-send me-2"></i>Submit
                    </span>
                    <span class="spinner">
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Loading...
                    </span>
                </button>

                <div id="slow-result" class="mb-4">
                    <p class="text-muted">Result will appear here...</p>
                </div>

                <hr>

                <h6>External Indicator</h6>
                <p class="text-muted small">Uses hx-indicator to show separate loading element</p>
                
                <div class="d-flex align-items-center gap-3 mb-4">
                    <button class="btn btn-outline-primary"
                            hx-post="@Url.Action("SlowAction", "Patterns")"
                            hx-target="#indicator-result"
                            hx-swap="innerHTML"
                            hx-indicator="#loading-indicator">
                        <i class="bi bi-arrow-repeat me-2"></i>Fetch Data
                    </button>
                    <div id="loading-indicator" class="htmx-indicator">
                        <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                        <span class="text-muted">Loading...</span>
                    </div>
                </div>

                <div id="indicator-result">
                    <p class="text-muted">Result will appear here...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .htmx-request .btn-text { display: none; }
    .htmx-request .spinner { display: inline-block !important; }
    .spinner { display: none; }
    .htmx-indicator { display: none; }
    .htmx-request .htmx-indicator,
    .htmx-request.htmx-indicator { display: inline-flex !important; }
</style>
