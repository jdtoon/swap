@model SwapLab.Models.RateCardPickerViewModel
@addTagHelper *, Swap.Htmx

<div id="rate-card-picker">
    <swap-state state="Model.State" />
    
    <h3 style="margin-bottom: 1rem;">Select Rate Cards</h3>
    
    <div id="rate-card-list" style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
        @foreach (var card in Model.RateCards)
        {
            var isSelected = Model.State.GetSelectedIdList().Contains(card.Id);
            <label class="picker-item @(isSelected ? "selected" : "")"
                   style="display: flex; align-items: center; gap: 1rem; padding: 1rem; background: var(--color-bg-secondary); border-radius: var(--radius); cursor: pointer; border: 2px solid @(isSelected ? "var(--color-primary)" : "transparent"); transition: all 0.2s;"
                   hx-post="/Patterns/ToggleRateCard?id=@card.Id"
                   hx-target="#rate-card-picker"
                   hx-swap="outerHTML"
                   hx-include="#rate-card-picker-state">
                <input type="checkbox" @(isSelected ? "checked" : "") style="width: 1.25rem; height: 1.25rem;" onclick="event.stopPropagation();" />
                <div style="flex: 1;">
                    <div style="font-weight: 600;">@card.Name</div>
                    <div style="font-size: 0.875rem; color: var(--color-text-muted);">@card.Description</div>
                </div>
                <div style="font-weight: 600; color: var(--color-primary);">@card.Price.ToString("C")</div>
            </label>
        }
    </div>
    
    <div id="selection-summary" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: var(--color-bg-tertiary); border-radius: var(--radius);">
        <div>
            <strong>Selected:</strong> @Model.SelectedCount items
            @if (Model.SelectedTotal > 0)
            {
                <span style="margin-left: 1rem;"><strong>Total:</strong> @Model.SelectedTotal.ToString("C")</span>
            }
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <button class="secondary"
                    hx-post="/Patterns/ClearRateCardSelection"
                    hx-target="#rate-card-picker"
                    hx-swap="outerHTML"
                    hx-include="#rate-card-picker-state"
                    @(Model.SelectedCount == 0 ? "disabled" : "")>
                Clear
            </button>
            <button hx-post="/Patterns/ConfirmRateCardSelection"
                    hx-target="#rate-card-picker"
                    hx-swap="outerHTML"
                    hx-include="#rate-card-picker-state"
                    @(Model.SelectedCount == 0 ? "disabled" : "")>
                Continue →
            </button>
        </div>
    </div>
</div>
