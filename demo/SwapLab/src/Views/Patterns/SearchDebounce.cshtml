@{
    ViewData["Title"] = "Search with Debounce";
}
@model IReadOnlyList<SwapLab.Models.Product>

<div class="sidebar">
    <div class="logo">Swap<span>Lab</span></div>
    <h3>Basics</h3>
    <a href="/Patterns/BasicSwap">Basic Swap</a>
    <a href="/Patterns/BasicPost">Form POST</a>
    <a href="/Patterns/OobSwap">Out-of-Band Swaps</a>
    <a href="/Patterns/Toasts">Toast Notifications</a>
