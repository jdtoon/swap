@{
    ViewData["Title"] = "Infinite Scroll";
    ViewData["Description"] = "Load more content as the user scrolls";
}

<div class="row">
    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-arrow-down-circle me-2"></i>How It Works</h5>
            </div>
            <div class="card-body">
                <p>
                    Infinite scroll uses <code>hx-trigger="revealed"</code> to load more
                    content when an element becomes visible in the viewport.
                </p>

                <h6>Key Attributes:</h6>
                <ul>
                    <li><code>hx-trigger="revealed"</code> - Fires when element is visible</li>
                    <li><code>hx-swap="outerHTML"</code> - Replace the trigger element</li>
                    <li><code>hx-get</code> - Endpoint returns more items + new trigger</li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-code-slash me-2"></i>The Pattern</h5>
            </div>
            <div class="card-body">
<pre class="bg-light p-3 rounded"><code>// Partial view pattern
@@foreach (var item in Model.Items)
{
    &lt;div class="item"&gt;@@item.Name&lt;/div&gt;
}

@@if (Model.HasMore)
{
    &lt;div hx-get="/load-more?page=@@Model.NextPage"
         hx-trigger="revealed"
         hx-swap="outerHTML"&gt;
        Loading more...
    &lt;/div&gt;
}</code></pre>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-primary text-white d-flex justify-content-between">
                <h5 class="mb-0"><i class="bi bi-play-circle me-2"></i>Live Demo</h5>
                <button class="btn btn-sm btn-light" onclick="location.reload()">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </button>
            </div>
            <div class="card-body p-0">
                <div id="scroll-container" class="overflow-auto" style="max-height: 400px;">
                    <div id="item-list">
                        @await Html.PartialAsync("_InfiniteScrollItems", new SwapLab.Models.InfiniteScrollViewModel 
                        { 
                            Items = Enumerable.Range(1, 10).Select(i => new SwapLab.Models.ScrollItem { Id = i, Title = $"Item {i}" }).ToList(),
                            CurrentPage = 1,
                            HasMore = true
                        })
                    </div>
                </div>
            </div>
            <div class="card-footer text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                Scroll down to load more items automatically
            </div>
        </div>
    </div>
</div>
