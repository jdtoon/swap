@{
    ViewData["Title"] = "Form Validation";
    ViewData["Description"] = "Real-time validation patterns with HTMX and Swap.Htmx";
}

<div class="row">
    <div class="col-lg-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-check2-square me-2"></i>Validation Patterns</h5>
            </div>
            <div class="card-body">
                <p>
                    HTMX enables several validation strategies:
                </p>
                <ul>
                    <li><strong>On-blur validation:</strong> Validate individual fields</li>
                    <li><strong>Real-time feedback:</strong> Show errors as user types</li>
                    <li><strong>Server-side validation:</strong> Full form validation on submit</li>
                </ul>

                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong>Always validate server-side!</strong> Client validation is for UX only.
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-play-circle me-2"></i>Live Demo</h5>
            </div>
            <div class="card-body">
                <form hx-post="@Url.Action("ValidateForm", "Patterns")"
                      hx-target="#form-result"
                      hx-swap="innerHTML">
                    
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" 
                               class="form-control" 
                               id="username" 
                               name="username"
                               placeholder="Enter username"
                               hx-post="@Url.Action("ValidateUsername", "Patterns")"
                               hx-trigger="blur changed"
                               hx-target="#username-feedback"
                               hx-swap="innerHTML">
                        <div id="username-feedback" class="form-text"></div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" 
                               class="form-control" 
                               id="email" 
                               name="email"
                               placeholder="Enter email"
                               hx-post="@Url.Action("ValidateEmail", "Patterns")"
                               hx-trigger="blur changed"
                               hx-target="#email-feedback"
                               hx-swap="innerHTML">
                        <div id="email-feedback" class="form-text"></div>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" 
                               class="form-control" 
                               id="password" 
                               name="password"
                               placeholder="Enter password"
                               hx-post="@Url.Action("ValidatePassword", "Patterns")"
                               hx-trigger="keyup changed delay:300ms"
                               hx-target="#password-feedback"
                               hx-swap="innerHTML">
                        <div id="password-feedback" class="form-text"></div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-person-plus me-2"></i>Create Account
                    </button>
                </form>

                <div id="form-result" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>
