@model IEnumerable<SwapLab.Models.Product>
@{
    ViewData["Title"] = "Modal Forms";
    
}

<hgroup>
    <h1>Modal Forms</h1>
    <p>Edit forms in modal dialogs</p>
</hgroup>

<h2>Live Demo</h2>
<div class="demo-area">
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: var(--color-bg-tertiary);">
                <th style="padding: 0.75rem 1rem; text-align: left;">Name</th>
                <th style="padding: 0.75rem 1rem; text-align: right;">Price</th>
                <th style="padding: 0.75rem 1rem; text-align: right;">Stock</th>
                <th style="padding: 0.75rem 1rem; text-align: center;">Action</th>
            </tr>
        </thead>
        <tbody id="products-table">
            @foreach (var product in Model.Take(5))
            {
                <tr id="product-row-@product.Id" style="border-bottom: 1px solid var(--color-border);">
                    <td style="padding: 0.75rem 1rem;">@product.Name</td>
                    <td style="padding: 0.75rem 1rem; text-align: right;">$@product.Price.ToString("F2")</td>
                    <td style="padding: 0.75rem 1rem; text-align: right;">@product.Stock</td>
                    <td style="padding: 0.75rem 1rem; text-align: center;">
                        <button class="secondary"
                                style="padding: 0.25rem 0.75rem; font-size: 0.875rem;"
                                hx-get="/Patterns/EditProductModal?id=@product.Id"
                                hx-target="#modal-container"
                                hx-swap="innerHTML">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Modal Container -->
    <div id="modal-container"></div>
</div>

<h2>Modal Form Pattern</h2>
<p>
    Load edit forms into a modal dialog, then update the underlying
    data when the form is submitted.
</p>

<h2>Pattern Steps</h2>
<ol>
    <li>Click edit → Load form into modal</li>
    <li>Submit form → Close modal + update row</li>
    <li>Use OOB swap to update the row in place</li>
</ol>

<h2>Controller Code</h2>
<div class="code-view">
<pre>// Load modal content
[HttpGet]
public IActionResult EditModal(int id)
{
    var item = GetItem(id);
    return PartialView("_EditModal", item);
}

// Save and update row
[HttpPost]
public IActionResult Save(Item item)
{
    SaveItem(item);
    return this.SwapResponse()
        .WithView("_ModalClosed")
        .AlsoUpdate($"#row-{item.Id}", 
            "_Row", item)
        .WithSuccessToast("Saved!")
        .Build();
}</pre>
</div>

<h2>Key Points</h2>
<ul>
    <li>Modal loads via HTMX into a container div</li>
    <li>Form submits via HTMX, closes modal via OOB swap</li>
    <li>Row updates in place without page reload</li>
    <li>Toast notification confirms the action</li>
</ul>

<style>
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    
    .modal-dialog {
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        width: 100%;
        max-width: 400px;
        box-shadow: var(--shadow-lg);
    }
    
    .modal-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--color-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .modal-body {
        padding: 1.25rem;
    }
    
    .modal-footer {
        padding: 0.75rem 1.25rem;
        border-top: 1px solid var(--color-border);
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
    }
</style>
