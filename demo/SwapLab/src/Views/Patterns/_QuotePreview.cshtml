@model SwapLab.Models.QuoteBuilderViewModel
@addTagHelper *, Swap.Htmx

<div id="quote-preview" style="background: var(--color-bg-secondary); padding: 1.5rem; border-radius: var(--radius);">
    <swap-state state="Model.State" />
    
    <div style="background: white; color: #1a1a1a; padding: 2rem; border-radius: var(--radius); font-family: Georgia, serif;">
        <div style="text-align: center; margin-bottom: 2rem; border-bottom: 2px solid #333; padding-bottom: 1rem;">
            <h2 style="margin: 0; font-size: 1.5rem; letter-spacing: 0.1em;">QUOTE #QT-2025-001</h2>
            <div style="color: #666; margin-top: 0.5rem;">Generated @DateTime.Now.ToString("MMM dd, yyyy")</div>
        </div>
        
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 1.5rem;">
            <thead>
                <tr style="border-bottom: 1px solid #ddd;">
                    @if (Model.State.ShowImages)
                    {
                        <th style="text-align: left; padding: 0.5rem 0; width: 50px;"></th>
                    }
                    <th style="text-align: left; padding: 0.5rem 0;">Item</th>
                    <th style="text-align: right; padding: 0.5rem 0;">Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr style="border-bottom: 1px solid #eee;">
                        @if (Model.State.ShowImages)
                        {
                            <td style="padding: 0.75rem 0;">
                                <div style="width: 40px; height: 40px; background: #f0f0f0; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                                    📦
                                </div>
                            </td>
                        }
                        <td style="padding: 0.75rem 0;">
                            <div style="font-weight: 600;">@item.Name</div>
                            @if (Model.State.ShowDescriptions && !string.IsNullOrEmpty(item.Description))
                            {
                                <div style="font-size: 0.875rem; color: #666;">@item.Description</div>
                            }
                        </td>
                        <td style="text-align: right; padding: 0.75rem 0;">@Model.FormatCurrency(item.BasePrice)</td>
                    </tr>
                }
            </tbody>
        </table>
        
        <div style="border-top: 2px solid #333; padding-top: 1rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                <span>Subtotal</span>
                <span>@Model.FormatCurrency(Model.Subtotal)</span>
            </div>
            @if (Model.State.MarkupPercent > 0)
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; color: #666;">
                    <span>Markup (@Model.State.MarkupPercent%)</span>
                    <span>@Model.FormatCurrency(Model.MarkupAmount)</span>
                </div>
            }
            @if (Model.State.IncludeTax)
            {
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; color: #666;">
                    <span>Tax (8%)</span>
                    <span>@Model.FormatCurrency(Model.TaxAmount)</span>
                </div>
            }
            <div style="display: flex; justify-content: space-between; font-size: 1.25rem; font-weight: bold; margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid #ddd;">
                <span>Total</span>
                <span>@Model.FormatCurrency(Model.Total)</span>
            </div>
        </div>
    </div>
</div>
