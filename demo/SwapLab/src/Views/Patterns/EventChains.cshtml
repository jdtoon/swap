@{
    ViewData["Title"] = "Event Chains";
    Layout = Context.Request.Headers.ContainsKey("HX-Request") ? "_PartialLayout" : "_Layout";
}
@model SwapLab.Models.ProductGridViewModel

<hgroup>
    <h1>Event Chains</h1>
    <p>Configure cascading updates with ISwapEventConfiguration</p>
</hgroup>

<h2>Live Demo</h2>
<div class="demo-area">
    <p>When you change tabs, the "TabChanged" event triggers a chain that updates:</p>
    <ul>
        <li>Product Grid</li>
        <li>Product Count</li>
        <li>Pagination</li>
    </ul>
    
    <!-- State Container -->
    <div id="state-container">
        <input type="hidden" name="Tab" value="@Model.State.Tab" />
        <input type="hidden" name="Page" value="@Model.State.Page" />
    </div>
    
    <!-- Tabs that trigger events -->
    <div class="tabs">
        <button class="@(Model.State.Tab == "all" ? "active" : "")"
                hx-post="/Patterns/ChangeTab?tab=all"
                hx-target="#product-grid"
                hx-include="#state-container">
            All Products
        </button>
        <button class="@(Model.State.Tab == "electronics" ? "active" : "")"
                hx-post="/Patterns/ChangeTab?tab=electronics"
                hx-target="#product-grid"
                hx-include="#state-container">
            Electronics
        </button>
        <button class="@(Model.State.Tab == "furniture" ? "active" : "")"
                hx-post="/Patterns/ChangeTab?tab=furniture"
                hx-target="#product-grid"
                hx-include="#state-container">
            Furniture
        </button>
    </div>
    
    <div id="product-count" style="margin-bottom: 1rem;">
        @Model.TotalCount products
    </div>
    
    <div id="product-grid">
        @await Html.PartialAsync("_ProductGrid", Model)
    </div>
    
    <div id="pagination">
        @await Html.PartialAsync("_Pagination", Model)
    </div>
</div>

<h2>How Event Chains Work</h2>
<ol>
    <li>Controller triggers an event with <code>.WithTrigger("TabChanged")</code></li>
    <li>Swap.Htmx looks up the event chain configuration</li>
    <li>Each configured partial is rendered and added to the response</li>
    <li>All targets are updated in a single round-trip</li>
</ol>

<h2>Event Configuration</h2>
<div class="code-view">
<pre>public class ProductEvents : ISwapEventConfiguration
{
    public void Configure(SwapEventBuilder builder)
    {
        // When tab changes, update multiple components
        builder.On("TabChanged")
            .RefreshPartial("_ProductGrid", "#product-grid")
            .RefreshPartial("_ProductCount", "#product-count")
            .RefreshPartial("_Pagination", "#pagination");
    }
}</pre>
</div>

<h2>Registration in Program.cs</h2>
<div class="code-view">
<pre>builder.Services.AddSwapHtmx(options =>
{
    options.Events.Add&lt;ProductEvents&gt;();
});</pre>
</div>

<h2>Controller Code</h2>
<div class="code-view">
<pre>[HttpPost]
public IActionResult ChangeTab(string tab, ProductSearchState state)
{
    state.Tab = tab;
    state.Page = 1;
    
    var results = FilterProducts(state);
    
    return this.SwapResponse()
        .WithView("_ProductGrid", viewModel)
        .WithTrigger("TabChanged")  // Triggers the event chain!
        .Build();
}</pre>
</div>

<h2>Event Chain vs AlsoUpdate()</h2>
<table>
    <thead>
        <tr>
            <th>Approach</th>
            <th>Use When</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><code>.AlsoUpdate()</code></td>
            <td>One-off additional updates in a specific action</td>
        </tr>
        <tr>
            <td><code>ISwapEventConfiguration</code></td>
            <td>Reusable patterns triggered from multiple places</td>
        </tr>
    </tbody>
</table>

<h2>Key Points</h2>
<ul>
    <li><strong>Centralized</strong> — Event chains are defined once, used everywhere</li>
    <li><strong>Type-Safe</strong> — Use <code>EventKey</code> constants for event names</li>
    <li><strong>Testable</strong> — Event configurations can be unit tested</li>
    <li><strong>Efficient</strong> — All updates happen in a single response</li>
</ul>
