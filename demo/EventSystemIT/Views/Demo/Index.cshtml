@{
    ViewData["Title"] = "Event System Demo";
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <section class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title">Create Todo (emits todo.created)</h2>
      <form hx-post="/Home/AddTodo" hx-target="#todo-list" class="flex gap-2">
        <input type="text" name="title" class="input input-bordered flex-1" placeholder="New task title" required />
        <button type="submit" class="btn btn-primary">Add</button>
      </form>
      <p class="text-sm text-base-content/60 mt-2">On success, the server emits <code>todo.created</code> which chains to: <code>ui.todo.refreshList</code>, <code>ui.toast.success</code>, <code>ui.stats.refresh</code>, <code>ui.activity.append</code>.</p>
    </div>
  </section>

  <section class="card bg-base-100 shadow">
    <div class="card-body">
    <h2 class="card-title">Stats</h2>
    @await Html.PartialAsync("~/Views/Demo/_StatsPanel.cshtml")
    </div>
  </section>

  <section class="card bg-base-100 shadow lg:col-span-2">
    <div class="card-body">
    <h2 class="card-title">Todo List</h2>
    @await Html.PartialAsync("~/Views/Demo/_TodoListPanel.cshtml")
    </div>
  </section>

  <section class="card bg-base-100 shadow">
    <div class="card-body">
    <h2 class="card-title">Toasts</h2>
    @await Html.PartialAsync("~/Views/Demo/_ToastsPanel.cshtml")
    </div>
  </section>

  <section class="card bg-base-100 shadow">
    <div class="card-body">
    <h2 class="card-title">Activity</h2>
    @await Html.PartialAsync("~/Views/Demo/_ActivityPanel.cshtml")
    </div>
  </section>

  <section class="card bg-base-100 shadow lg:col-span-2">
    <div class="card-body">
      <h2 class="card-title">More demos</h2>
      <div class="flex gap-3">
        <a class="btn" href="/Demo/Dynamic" hx-get="/Demo/Dynamic" hx-target="#main-content" hx-push-url="true">Dynamic Components</a>
        <a class="btn" href="/Demo/Bulk" hx-get="/Demo/Bulk" hx-target="#main-content" hx-push-url="true">Bulk Operations</a>
      </div>
    </div>
  </section>
</div>
