@using SwapStateDemo.Models
@model Product

<!-- Extracted Product Card Component -->
<div class="product-card" style="border: 1px solid #eee; padding: 1rem; border-radius: 8px; font-family: sans-serif; max-width: 300px;">
    <div style="height: 150px; background: #f5f5f5; border-radius: 4px; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; color: #999;">
        Image Placeholder
    </div>
    <h3 style="margin: 0 0 0.5rem 0;">@Model.Name</h3>
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem;">
        <span style="font-size: 1.25rem; font-weight: bold;">$@Model.Price</span>
        <span style="font-size: 0.875rem; color: #666; background: #eee; padding: 2px 6px; border-radius: 4px;">@Model.Category</span>
    </div>
    @if (Model.InStock)
    {
        <button style="width: 100%; padding: 0.5rem; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">Add to Cart</button>
    }
    else
    {
        <button disabled style="width: 100%; padding: 0.5rem; background: #ccc; color: #666; border: none; border-radius: 4px; cursor: not-allowed;">Out of Stock</button>
    }
</div>
