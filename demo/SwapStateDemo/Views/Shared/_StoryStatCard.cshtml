@using SwapStateDemo.Models
@model DashboardCard

<div class="stat-card" style="border: 1px solid #e0e0e0; padding: 1.5rem; border-radius: 8px; display: flex; align-items: flex-start; gap: 1rem; font-family: sans-serif; background: white;">
    <div style="font-size: 2rem; background: #f8f9fa; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">
        @Model.Icon
    </div>
    <div>
        <div style="color: #666; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">@Model.Title</div>
        <div style="font-size: 1.75rem; font-weight: 700; margin: 0.25rem 0;">@Model.Summary</div>
        <div style="color: #28a745; font-size: 0.875rem;">↗ Trending up</div>
    </div>
</div>
