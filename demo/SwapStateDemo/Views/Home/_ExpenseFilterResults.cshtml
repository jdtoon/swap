@using SwapStateDemo.Models
@model ExpenseListModel

<div id="expense-filter-container">
    <!-- swap-hidden auto-formats dates to yyyy-MM-dd -->
    <swap-hidden name="startDate" value="@Model.StartDate" />
    <swap-hidden name="endDate" value="@Model.EndDate" />
    <swap-hidden name="category" value="@Model.Category" />
    
    <div class="form-row">
        <label>From:</label>
        <input type="date" value="@Model.StartDate.ToString("yyyy-MM-dd")"
               hx-get="/Home/ExpenseFilter"
               hx-include="closest div"
               hx-target="#expense-filter-container"
               hx-trigger="change"
               hx-vals='js:{"startDate": event.target.value}' />
        
        <label>To:</label>
        <input type="date" value="@Model.EndDate.ToString("yyyy-MM-dd")"
               hx-get="/Home/ExpenseFilter"
               hx-include="closest div"
               hx-target="#expense-filter-container"
               hx-trigger="change"
               hx-vals='js:{"endDate": event.target.value}' />
        
        <select hx-get="/Home/ExpenseFilter"
                hx-include="closest div"
                hx-target="#expense-filter-container"
                hx-trigger="change"
                hx-vals='js:{"category": event.target.value}'>
            @{
                var categories = new[] { ("all", "All Categories"), ("IT", "IT"), ("Operations", "Operations"), ("HR", "HR"), ("Marketing", "Marketing") };
            }
            @foreach (var (val, text) in categories)
            {
                if (val == Model.Category)
                {
                    <option value="@val" selected>@text</option>
                }
                else
                {
                    <option value="@val">@text</option>
                }
            }
        </select>
    </div>
    
    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var expense in Model.Expenses)
            {
                <tr>
                    <td>@expense.Description</td>
                    <td><span class="badge badge-blue">@expense.Category</span></td>
                    <td>$@expense.Amount.ToString("N2")</td>
                    <td>@expense.Date.ToString("MMM d, yyyy")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="2"><strong>Total</strong></td>
                <td><strong>$@Model.Total.ToString("N2")</strong></td>
                <td></td>
            </tr>
        </tfoot>
    </table>
    
    <div class="state-display">
        <strong>Current State:</strong> 
        startDate=@Model.StartDate.ToString("yyyy-MM-dd"), 
        endDate=@Model.EndDate.ToString("yyyy-MM-dd"), 
        category=@Model.Category
    </div>
</div>
