@model SwapStateDemo.Models.ProductViewModel
<!DOCTYPE html>
<html>
<head>
    <title>SwapState Test</title>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <style>
        body { font-family: sans-serif; padding: 2rem; max-width: 800px; margin: 0 auto; }
        .state-debug { background: #fffbe6; border: 1px solid #ffe58f; padding: 1rem; margin: 1rem 0; font-family: monospace; font-size: 0.9rem; }
        table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
        th, td { padding: 0.5rem; border: 1px solid #ddd; text-align: left; }
        th { background: #f5f5f5; }
        button { padding: 0.5rem 1rem; margin: 0.25rem; cursor: pointer; }
        button.active { background: #1890ff; color: white; border: none; }
        .filters { margin: 1rem 0; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
    </style>
</head>
<body>
    <h1>SwapState Test</h1>
    <p>Testing if <code>[FromSwapState]</code> and <code>.WithState()</code> actually work.</p>

    <!-- THE STATE CONTAINER - this is what we're testing -->
    <swap-state state="Model.State" />

    <!-- Debug: Show what the state container ID is -->
    <div class="state-debug">
        <strong>State Container ID:</strong> #@Model.State.ContainerId<br>
        <strong>Current State:</strong> Category=@Model.State.Category, Page=@Model.State.Page, Search=@(Model.State.Search ?? "(null)")
    </div>

    <!-- Filter Buttons - test if clicking updates state -->
    <div class="filters">
        <strong>Category:</strong>
        <button class="@(Model.State.Category == "all" ? "active" : "")"
                hx-get="/Home/Filter"
                hx-target="#product-grid"
                hx-include="#@Model.State.ContainerId"
                hx-vals='{"Category": "all", "Page": 1}'>
            All
        </button>
        <button class="@(Model.State.Category == "Electronics" ? "active" : "")"
                hx-get="/Home/Filter"
                hx-target="#product-grid"
                hx-include="#@Model.State.ContainerId"
                hx-vals='{"Category": "Electronics", "Page": 1}'>
            Electronics
        </button>
        <button class="@(Model.State.Category == "Furniture" ? "active" : "")"
                hx-get="/Home/Filter"
                hx-target="#product-grid"
                hx-include="#@Model.State.ContainerId"
                hx-vals='{"Category": "Furniture", "Page": 1}'>
            Furniture
        </button>
        <button class="@(Model.State.Category == "Office" ? "active" : "")"
                hx-get="/Home/Filter"
                hx-target="#product-grid"
                hx-include="#@Model.State.ContainerId"
                hx-vals='{"Category": "Office", "Page": 1}'>
            Office
        </button>
    </div>

    <!-- Search input -->
    <div class="filters">
        <strong>Search:</strong>
        <input type="text" 
               placeholder="Type to search..." 
               value="@Model.State.Search"
               hx-get="/Home/Filter"
               hx-target="#product-grid"
               hx-include="#@Model.State.ContainerId"
               hx-trigger="keyup changed delay:300ms"
               hx-vals='{"Page": 1}'
               name="Search" />
    </div>

    <!-- Product Grid -->
    <div id="product-grid">
        @await Html.PartialAsync("_ProductGrid", Model)
    </div>

    <hr>
    <h2>Test Instructions</h2>
    <ol>
        <li>Click a category button (e.g., "Electronics")</li>
        <li>Check the server console - does it show <code>[FromSwapState] Category=Electronics</code>?</li>
        <li>Does the "Current State" debug box update after the response?</li>
        <li>Click another category - does the previous category state persist?</li>
    </ol>
    
    <h2>What Should Happen</h2>
    <ul>
        <li><code>&lt;swap-state&gt;</code> renders hidden fields in a div with id="product-filter-state"</li>
        <li><code>hx-include</code> sends those hidden fields with the request</li>
        <li><code>[FromSwapState]</code> binds those values to the ProductFilterState object</li>
        <li><code>.WithState(state)</code> sends an OOB swap to update the hidden fields</li>
    </ul>
</body>
</html>
