@model SwapStateDemo.Models.ProductViewModel
@{
    var state = Model.State;
}
<!DOCTYPE html>
<html>
<head>
    <title>SwapState Test</title>
    <script src="https://unpkg.com/htmx.org@2.0.8"></script>
    <style>
        body { font-family: sans-serif; padding: 2rem; max-width: 900px; margin: 0 auto; }
        .state-debug { background: #fffbe6; border: 1px solid #ffe58f; padding: 1rem; margin: 1rem 0; font-family: monospace; font-size: 0.85rem; white-space: pre-wrap; }
        table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
        th, td { padding: 0.5rem; border: 1px solid #ddd; text-align: left; }
        th { background: #f5f5f5; }
        button { padding: 0.5rem 1rem; margin: 0.25rem; cursor: pointer; }
        button.active { background: #1890ff; color: white; border: none; }
        .filters { margin: 0.75rem 0; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
        .filters strong { min-width: 80px; }
        input[type="text"], input[type="number"], select { padding: 0.4rem; border: 1px solid #ddd; border-radius: 3px; }
        input[type="number"] { width: 80px; }
        label { display: flex; align-items: center; gap: 0.25rem; cursor: pointer; }
        nav { margin: 1rem 0; }
        nav a { margin-right: 1rem; }
    </style>
</head>
<body>
    <nav>
        <a href="/">Product Filter</a> | 
        <a href="/Home/Wizard">5-Step Wizard</a> | 
        <a href="/Home/Dashboard">OOB Dashboard</a>
    </nav>

    <h1>SwapState Test - Product Filter</h1>
    <p>Testing <code>[FromSwapState]</code> binding and <code>.WithState()</code> OOB updates.</p>

    <!-- Swap the ENTIRE content area so UI updates properly -->
    <div id="filter-content">
        @await Html.PartialAsync("_FilterContent", Model)
    </div>
</body>
</html>
