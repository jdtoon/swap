@using SwapStateDemo.Models
@model List<Product>
@{
    var search = ViewBag.Search as string ?? "";
    var sortBy = ViewBag.SortBy as string ?? "name";
    var currentPage = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total = (int)ViewBag.Total;
}

<div id="product-search">
    <!-- Hidden fields preserve state - these get included via hx-include="closest div" -->
    <swap-hidden name="search" value="@search" />
    <swap-hidden name="sortBy" value="@sortBy" />
    <swap-hidden name="page" value="@currentPage" />
    
    <!-- Search and Sort Controls -->
    <div class="form-row">
        <input type="text" 
               placeholder="Search products..." 
               value="@search"
               name="searchInput"
               hx-get="/Home/ProductSearch"
               hx-trigger="keyup changed delay:300ms"
               hx-target="#product-container"
               hx-vals='js:{"search": event.target.value, "sortBy": "@sortBy", "page": 1}' />
        
        <select hx-get="/Home/ProductSearch"
                hx-target="#product-container"
                hx-vals='js:{"search": "@search", "sortBy": event.target.value, "page": 1}'>
            <option value="name" selected="@(sortBy == "name")">Sort by Name</option>
            <option value="price" selected="@(sortBy == "price")">Sort by Price</option>
            <option value="stock" selected="@(sortBy == "stock")">Sort by Stock</option>
        </select>
        
        <span class="badge">@total products</span>
    </div>
    
    <!-- Results Table -->
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td><span class="badge">@product.Category</span></td>
                    <td>$@product.Price.ToString("N2")</td>
                    <td>@product.Stock</td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" style="text-align: center; color: #64748b;">No products found</td>
                </tr>
            }
        </tbody>
    </table>
    
    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="pagination">
            <button class="btn btn-secondary" 
                    hx-get="/Home/ProductSearch"
                    hx-target="#product-container"
                    hx-vals='{"search": "@search", "sortBy": "@sortBy", "page": @(currentPage - 1)}'
                    @(currentPage <= 1 ? "disabled" : "")>
                ← Prev
            </button>
            
            <span>Page @currentPage of @totalPages</span>
            
            <button class="btn btn-secondary"
                    hx-get="/Home/ProductSearch"
                    hx-target="#product-container"
                    hx-vals='{"search": "@search", "sortBy": "@sortBy", "page": @(currentPage + 1)}'
                    @(currentPage >= totalPages ? "disabled" : "")>
                Next →
            </button>
        </div>
    }
    
    <!-- State Display (for debugging/demo purposes) -->
    <div class="state-box">
        <strong>Current State:</strong> search="@search", sortBy=@sortBy, page=@currentPage
    </div>
</div>
