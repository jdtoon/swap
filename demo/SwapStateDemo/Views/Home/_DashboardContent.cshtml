@using SwapStateDemo.Models
@model List<Expense>

<div id="dashboard-content">
    <div class="form-row">
        <label>From:</label>
        <input type="date" 
               hx-get="/Home/Dashboard"
               hx-include="#dashboard-state"
               hx-target="#dashboard-content"
               hx-trigger="change"
               hx-vals='js:{"StartDate": event.target.value}' />
        
        <label>To:</label>
        <input type="date"
               hx-get="/Home/Dashboard"
               hx-include="#dashboard-state"
               hx-target="#dashboard-content"
               hx-trigger="change"
               hx-vals='js:{"EndDate": event.target.value}' />
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1rem 0;">
        <div style="background: #dbeafe; padding: 1rem; border-radius: 0.5rem; text-align: center;">
            <div style="font-size: 2rem; font-weight: bold; color: #1d4ed8;">@Model.Count</div>
            <div style="color: #64748b;">Expenses</div>
        </div>
        <div style="background: #dcfce7; padding: 1rem; border-radius: 0.5rem; text-align: center;">
            <div style="font-size: 2rem; font-weight: bold; color: #16a34a;">$@Model.Sum(e => e.Amount).ToString("N0")</div>
            <div style="color: #64748b;">Total</div>
        </div>
        <div style="background: #fef3c7; padding: 1rem; border-radius: 0.5rem; text-align: center;">
            <div style="font-size: 2rem; font-weight: bold; color: #d97706;">$@(Model.Any() ? Model.Average(e => e.Amount).ToString("N0") : "0")</div>
            <div style="color: #64748b;">Average</div>
        </div>
    </div>
    
    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var expense in Model)
            {
                <tr>
                    <td>@expense.Description</td>
                    <td>@expense.Category</td>
                    <td>$@expense.Amount.ToString("N2")</td>
                    <td>@expense.Date.ToString("MMM d")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
