@using SwapStateDemo.Models
@model CombinedPageModel

<div id="combined-content">
    <p style="background: #f0fdf4; padding: 0.75rem; border-radius: 0.375rem; margin-bottom: 1rem;">
        <strong>Pattern:</strong> Global <code>&lt;swap-state&gt;</code> syncs page-level filters via OOB. 
        Each widget has its own <code>&lt;swap-hidden&gt;</code> for local state.
    </p>
    
    <div class="grid-2">
        <!-- Widget A: Products - has its own local state -->
        <div id="products-widget" class="widget">
            <!-- Local state colocated with widget -->
            <swap-hidden name="sortBy" value="@("name")" />
            
            <h4>
                📦 Products
                <select hx-get="/Home/ProductsWidget"
                        hx-include="closest div"
                        hx-target="#products-widget"
                        hx-swap="outerHTML"
                        style="font-size: 0.8rem; padding: 0.25rem;">
                    <option value="name">Sort: Name</option>
                    <option value="price">Sort: Price</option>
                    <option value="stock">Sort: Stock</option>
                </select>
            </h4>
            
            <ul style="margin: 0; padding-left: 1.25rem;">
                @foreach (var p in Model.Products.Take(5))
                {
                    <li>@p.Name - $@p.Price.ToString("N2")</li>
                }
            </ul>
            
            <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">
                Local state: sortBy via &lt;swap-hidden&gt;
            </div>
        </div>
        
        <!-- Widget B: Expenses - has its own local state -->
        <div id="expenses-widget" class="widget">
            <!-- Local state colocated with widget -->
            <swap-hidden name="sortBy" value="@Model.LocalWidgetSort" />
            
            <h4>
                💰 Recent Expenses
                <select hx-get="/Home/ExpensesWidget"
                        hx-include="closest div"
                        hx-target="#expenses-widget"
                        hx-swap="outerHTML"
                        style="font-size: 0.8rem; padding: 0.25rem;">
                    @{
                        var sortOptions = new[] { ("date", "Date"), ("amount", "Amount"), ("category", "Category") };
                    }
                    @foreach (var (val, text) in sortOptions)
                    {
                        if (val == Model.LocalWidgetSort)
                        {
                            <option value="@val" selected>Sort: @text</option>
                        }
                        else
                        {
                            <option value="@val">Sort: @text</option>
                        }
                    }
                </select>
            </h4>
            
            <ul style="margin: 0; padding-left: 1.25rem;">
                @foreach (var e in Model.RecentExpenses)
                {
                    <li>@e.Description - $@e.Amount.ToString("N2")</li>
                }
            </ul>
            
            <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #64748b;">
                Local state: sortBy via &lt;swap-hidden&gt;
            </div>
        </div>
    </div>
    
    <div class="state-display" style="margin-top: 1rem;">
        <strong>Global State (SwapState):</strong> Tab=@Model.GlobalState.Tab, Page=@Model.GlobalState.Page
        <br>
        <strong>Widget States (swap-hidden):</strong> Each widget manages its own sort independently
    </div>
</div>
