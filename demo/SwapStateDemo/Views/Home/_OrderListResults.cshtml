@using SwapStateDemo.Models
@model (List<Order> Orders, OrderFilters Filters)

<div id="order-list-container">
    <!-- swap-hidden handles collections as comma-separated -->
    <swap-hidden name="page" value="@Model.Filters.Page" />
    <swap-hidden name="status" value="@Model.Filters.Status" />
    <swap-hidden name="fromDate" value="@Model.Filters.FromDate" />
    <swap-hidden name="toDate" value="@Model.Filters.ToDate" />
    <!-- Collection renders as "urgent,wholesale" -->
    <swap-hidden name="tags" value="@Model.Filters.Tags" />
    
    <div class="form-row">
        <select hx-get="/Home/OrderList"
                hx-include="closest div"
                hx-target="#order-list-container"
                hx-trigger="change"
                hx-vals='js:{"status": event.target.value, "page": 1}'>
            @{
                var statusOptions = new[] { ("all", "All Status"), ("pending", "Pending"), ("shipped", "Shipped"), ("delivered", "Delivered") };
            }
            @foreach (var (val, text) in statusOptions)
            {
                if (val == Model.Filters.Status)
                {
                    <option value="@val" selected>@text</option>
                }
                else
                {
                    <option value="@val">@text</option>
                }
            }
        </select>
        
        <span style="color: #64748b;">|</span>
        
        <label>Tags:</label>
        @{
            var allTags = new[] { "urgent", "wholesale", "retail", "priority" };
        }
        @foreach (var tag in allTags)
        {
            var isChecked = Model.Filters.Tags.Contains(tag);
            <label style="display: inline-flex; align-items: center; gap: 0.25rem; margin-right: 0.5rem;">
                <input type="checkbox" 
                       value="@tag" 
                       @(isChecked ? "checked" : "")
                       hx-get="/Home/OrderList"
                       hx-include="closest div"
                       hx-target="#order-list-container"
                       hx-trigger="change"
                       hx-vals='js:{
                           "tags": Array.from(document.querySelectorAll("#order-list-container input[type=checkbox]:checked")).map(c => c.value).join(","),
                           "page": 1
                       }' />
                @tag
            </label>
        }
    </div>
    
    <table>
        <thead>
            <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Status</th>
                <th>Total</th>
                <th>Tags</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>#@order.Id</td>
                    <td>@order.CustomerName</td>
                    <td>
                        <span class="badge @(order.Status == "pending" ? "badge-yellow" : order.Status == "shipped" ? "badge-blue" : "badge-green")">
                            @order.Status
                        </span>
                    </td>
                    <td>$@order.Total.ToString("N2")</td>
                    <td>
                        @foreach (var tag in order.Tags)
                        {
                            <span class="badge badge-blue">@tag</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="state-display">
        <strong>Current State:</strong> 
        status=@Model.Filters.Status, 
        tags=[@string.Join(", ", Model.Filters.Tags)]
        <br><em>Note: swap-hidden rendered tags as comma-separated string</em>
    </div>
</div>
