@using SwapStateDemo.Models
@model List<Product>

<div id="inventory-grid">
    <div class="tabs">
        <button class="tab-btn @(ViewBag.Tab == "all" ? "active" : "")"
                hx-get="/Home/InventoryGrid"
                hx-include="#inventory-state"
                hx-target="#inventory-grid"
                hx-vals='{"Tab": "all", "Page": 1}'>
            All
        </button>
        <button class="tab-btn @(ViewBag.Tab == "Electronics" ? "active" : "")"
                hx-get="/Home/InventoryGrid"
                hx-include="#inventory-state"
                hx-target="#inventory-grid"
                hx-vals='{"Tab": "Electronics", "Page": 1}'>
            Electronics
        </button>
        <button class="tab-btn @(ViewBag.Tab == "Furniture" ? "active" : "")"
                hx-get="/Home/InventoryGrid"
                hx-include="#inventory-state"
                hx-target="#inventory-grid"
                hx-vals='{"Tab": "Furniture", "Page": 1}'>
            Furniture
        </button>
        <button class="tab-btn @(ViewBag.Tab == "Accessories" ? "active" : "")"
                hx-get="/Home/InventoryGrid"
                hx-include="#inventory-state"
                hx-target="#inventory-grid"
                hx-vals='{"Tab": "Accessories", "Page": 1}'>
            Accessories
        </button>
    </div>
    
    <div class="form-row">
        <input type="text" placeholder="Search..." 
               hx-get="/Home/InventoryGrid"
               hx-include="#inventory-state"
               hx-target="#inventory-grid"
               hx-trigger="keyup changed delay:300ms"
               hx-vals='js:{"Search": event.target.value, "Page": 1}' />
        
        <label>
            <input type="checkbox"
                   hx-get="/Home/InventoryGrid"
                   hx-include="#inventory-state"
                   hx-target="#inventory-grid"
                   hx-vals='js:{"ShowArchived": event.target.checked}' />
            Show Archived
        </label>
    </div>
    
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr style="@(product.IsArchived ? "opacity: 0.5;" : "")">
                    <td>@product.Name @(product.IsArchived ? "(archived)" : "")</td>
                    <td>@product.Category</td>
                    <td>$@product.Price.ToString("N2")</td>
                    <td>@product.Stock</td>
                </tr>
            }
        </tbody>
    </table>
    
    <p style="color: #64748b; font-size: 0.875rem;">
        Showing @Model.Count of @ViewBag.Total items
    </p>
    
    <div class="state-display">
        <strong>SwapState Auto-Synced:</strong> The state container is updated via OOB swap automatically.
        <br>Check the hidden #inventory-state div in DOM.
    </div>
</div>
