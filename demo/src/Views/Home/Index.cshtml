@{
    ViewData["Title"] = "Home";
}

<div class="hero is-primary is-medium">
    <div class="hero-body">
        <div class="container has-text-centered">
            <h1 class="title is-1">
                Welcome to TaskFlow
            </h1>
            <h2 class="subtitle is-3">
                A comprehensive demo of Swap.Htmx framework features
            </h2>
            <p class="block is-size-5">
                Pure server-driven development. Zero JavaScript. Maximum productivity.
            </p>
            <div class="buttons is-centered mt-5">
                <a class="button is-large is-light" 
                   href="/Tasks" 
                   hx-get="/Tasks" 
                   hx-target="#main-content" 
                   hx-push-url="true">
                    <span class="icon">
                        <i class="fas fa-tasks"></i>
                    </span>
                    <span>View Task Board</span>
                </a>
                <a class="button is-large is-light is-outlined" 
                   href="/Demo" 
                   hx-get="/Demo" 
                   hx-target="#main-content" 
                   hx-push-url="true">
                    <span class="icon">
                        <i class="fas fa-flask"></i>
                    </span>
                    <span>Explore Demo Features</span>
                </a>
            </div>
        </div>
    </div>
</div>

<section class="section">
    <div class="container">
        <h2 class="title is-2 has-text-centered mb-6">
            What This Demo Showcases
        </h2>

        <div class="columns is-multiline">
            <div class="column is-one-third">
                <div class="box has-text-centered" style="height: 100%;">
                    <span class="icon is-large has-text-primary mb-3">
                        <i class="fas fa-3x fa-bolt"></i>
                    </span>
                    <h3 class="title is-4">Event System</h3>
                    <p>Declarative event chains that automatically handle UI updates. Emit one domain event, trigger multiple UI refreshes.</p>
                </div>
            </div>

            <div class="column is-one-third">
                <div class="box has-text-centered" style="height: 100%;">
                    <span class="icon is-large has-text-info mb-3">
                        <i class="fas fa-3x fa-exchange-alt"></i>
                    </span>
                    <h3 class="title is-4">Out-of-Band Swaps</h3>
                    <p>Update multiple DOM elements in a single response. Task board columns, stats, and activity feed all refresh independently.</p>
                </div>
            </div>

            <div class="column is-one-third">
                <div class="box has-text-centered" style="height: 100%;">
                    <span class="icon is-large has-text-success mb-3">
                        <i class="fas fa-3x fa-bell"></i>
                    </span>
                    <h3 class="title is-4">Toast Notifications</h3>
                    <p>Server-triggered toast messages that appear automatically. Success, error, warning, and info variants built-in.</p>
                </div>
            </div>

            <div class="column is-one-third">
                <div class="box has-text-centered" style="height: 100%;">
                    <span class="icon is-large has-text-warning mb-3">
                        <i class="fas fa-3x fa-server"></i>
                    </span>
                    <h3 class="title is-4">Pure Server-Side</h3>
                    <p>Zero client-side JavaScript required. All logic lives in C# controllers. Type-safe and testable.</p>
                </div>
            </div>

            <div class="column is-one-third">
                <div class="box has-text-centered" style="height: 100%;">
                    <span class="icon is-large has-text-danger mb-3">
                        <i class="fas fa-3x fa-search"></i>
                    </span>
                    <h3 class="title is-4">Real-Time Search</h3>
                    <p>Instant search and filtering with debounced input. Results update live as you type, all server-rendered.</p>
                </div>
            </div>

            <div class="column is-one-third">
                <div class="box has-text-centered" style="height: 100%;">
                    <span class="icon is-large has-text-link mb-3">
                        <i class="fas fa-3x fa-columns"></i>
                    </span>
                    <h3 class="title is-4">Kanban Board</h3>
                    <p>Full task management with drag-free status updates. Create, edit, delete, and organize tasks across columns.</p>
                </div>
            </div>
        </div>

        <div class="has-text-centered mt-6">
            <h3 class="title is-3 mb-4">Tech Stack</h3>
            <div class="tags are-large is-centered">
                <span class="tag is-primary is-light">ASP.NET Core 9</span>
                <span class="tag is-info is-light">HTMX 2.x</span>
                <span class="tag is-success is-light">Bulma CSS</span>
                <span class="tag is-warning is-light">EF Core 9</span>
                <span class="tag is-danger is-light">SQLite</span>
                <span class="tag is-link is-light">Swap.Htmx</span>
            </div>
        </div>
    </div>
</section>

<section class="section has-background-light">
    <div class="container">
        <h2 class="title is-2 has-text-centered mb-6">
            Quick Start
        </h2>

        <div class="columns">
            <div class="column is-half is-offset-one-quarter">
                <div class="content is-size-5">
                    <ol>
                        <li>Navigate to <strong>Task Board</strong> in the menu</li>
                        <li>Click <strong>New Task</strong> to create a task</li>
                        <li>Watch as the board, stats, and activity feed update automatically</li>
                        <li>Change task status with quick action buttons</li>
                        <li>Use search & filters to find specific tasks</li>
                        <li>Edit or delete tasks inline</li>
                    </ol>
                </div>
            </div>
        </div>

        <div class="has-text-centered mt-5">
            <a class="button is-primary is-large" 
               href="/Tasks" 
               hx-get="/Tasks" 
               hx-target="#main-content" 
               hx-push-url="true">
                <span class="icon">
                    <i class="fas fa-rocket"></i>
                </span>
                <span>Get Started</span>
            </a>
        </div>
    </div>
</section>
