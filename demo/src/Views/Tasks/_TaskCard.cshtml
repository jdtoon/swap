@model TaskFlow.Models.TaskItem

@{
    var priorityClass = Model.Priority switch
    {
        TaskFlow.Models.TaskPriority.Low => "is-info",
        TaskFlow.Models.TaskPriority.Medium => "is-warning",
        TaskFlow.Models.TaskPriority.High => "is-danger",
        TaskFlow.Models.TaskPriority.Critical => "is-dark",
        _ => "is-light"
    };

    var isOverdue = Model.DueDate.HasValue && Model.DueDate.Value < DateTime.UtcNow && Model.Status != TaskFlow.Models.TaskItemStatus.Done;
}

<div class="card mb-3" id="task-card-@Model.Id">
    <div class="card-content">
        <div class="media">
            <div class="media-content">
                <p class="title is-5 mb-2">@Model.Title</p>
                <p class="subtitle is-6 has-text-grey">@Model.Description</p>
            </div>
        </div>

        <div class="content">
            <div class="tags mb-2">
                <span class="tag @priorityClass">
                    <span class="icon is-small">
                        <i class="fas fa-flag"></i>
                    </span>
                    <span>@Model.Priority</span>
                </span>
                
                @if (Model.DueDate.HasValue)
                {
                    <span class="tag @(isOverdue ? "is-danger" : "is-light")">
                        <span class="icon is-small">
                            <i class="fas fa-calendar"></i>
                        </span>
                        <span>@Model.DueDate.Value.ToString("MMM dd")</span>
                    </span>
                }

                @if (!string.IsNullOrEmpty(Model.AssignedTo))
                {
                    <span class="tag is-light">
                        <span class="icon is-small">
                            <i class="fas fa-user"></i>
                        </span>
                        <span>@Model.AssignedTo</span>
                    </span>
                }
            </div>

            <div class="field is-grouped is-grouped-multiline">
                <div class="control">
                    <div class="buttons are-small">
                        @if (Model.Status != TaskFlow.Models.TaskItemStatus.Todo)
                        {
                            <button class="button is-warning is-light"
                                    hx-patch="/Tasks/ChangeStatus?id=@Model.Id&newStatus=0"
                                    hx-target="#task-card-@Model.Id"
                                    hx-swap="outerHTML">
                                <span class="icon is-small">
                                    <i class="fas fa-arrow-left"></i>
                                </span>
                                <span>To Do</span>
                            </button>
                        }

                        @if (Model.Status != TaskFlow.Models.TaskItemStatus.InProgress)
                        {
                            <button class="button is-info is-light"
                                    hx-patch="/Tasks/ChangeStatus?id=@Model.Id&newStatus=1"
                                    hx-target="#task-card-@Model.Id"
                                    hx-swap="outerHTML">
                                <span class="icon is-small">
                                    <i class="fas fa-play"></i>
                                </span>
                                <span>In Progress</span>
                            </button>
                        }

                        @if (Model.Status != TaskFlow.Models.TaskItemStatus.Done)
                        {
                            <button class="button is-success is-light"
                                    hx-patch="/Tasks/ChangeStatus?id=@Model.Id&newStatus=2"
                                    hx-target="#task-card-@Model.Id"
                                    hx-swap="outerHTML">
                                <span class="icon is-small">
                                    <i class="fas fa-check"></i>
                                </span>
                                <span>Done</span>
                            </button>
                        }
                    </div>
                </div>

                <div class="control">
                    <div class="buttons are-small">
                        <button class="button is-light"
                                hx-get="/Tasks/EditForm?id=@Model.Id"
                                hx-target="#edit-task-modal-content"
                                onclick="document.getElementById('edit-task-modal').classList.add('is-active')">
                            <span class="icon is-small">
                                <i class="fas fa-edit"></i>
                            </span>
                        </button>

                        <button class="button is-danger is-light"
                                hx-delete="/Tasks/Delete?id=@Model.Id"
                                hx-target="#task-card-@Model.Id"
                                hx-swap="outerHTML swap:1s"
                                hx-confirm="Are you sure you want to delete this task?">
                            <span class="icon is-small">
                                <i class="fas fa-trash"></i>
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            @if (Model.CompletedAt.HasValue)
            {
                <p class="help has-text-grey-light">
                    <span class="icon is-small">
                        <i class="fas fa-check-circle"></i>
                    </span>
                    Completed @Model.CompletedAt.Value.ToString("MMM dd, HH:mm")
                </p>
            }
        </div>
    </div>
</div>
