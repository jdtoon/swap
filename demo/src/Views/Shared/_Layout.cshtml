<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/lib/bulma/css/bulma.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/htmx-toast.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/htmx-transitions.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/taskboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true"></script>
</head>
<body>
    <header>
        <nav class="navbar" role="navigation" aria-label="main navigation">
            <div class="container">
                <div class="navbar-brand">
                    <a class="navbar-item" href="/">
                        <strong>
                            <span class="icon-text">
                                <span class="icon has-text-primary">
                                    <i class="fas fa-tasks"></i>
                                </span>
                                <span>TaskFlow</span>
                            </span>
                        </strong>
                    </a>
                </div>
                <div class="navbar-menu">
                    <div class="navbar-start">
                        <a class="navbar-item" href="/">
                            <span class="icon-text">
                                <span class="icon">
                                    <i class="fas fa-home"></i>
                                </span>
                                <span>Home</span>
                            </span>
                        </a>
                        <a class="navbar-item" href="/Tasks">
                            <span class="icon-text">
                                <span class="icon">
                                    <i class="fas fa-clipboard-list"></i>
                                </span>
                                <span>Task Board</span>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer has-background-light mt-6">
        <div class="content has-text-centered">
            <p class="has-text-secondary">
                <strong>TaskFlow</strong> - Built with <a href="https://github.com/your-repo/swap" class="has-text-primary">Swap.Htmx</a>
            </p>
            <p class="is-size-7 has-text-muted">
                Pure server-driven development. Zero JavaScript frameworks.
            </p>
        </div>
    </footer>

    @await Html.PartialAsync("_ToastContainer")

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/swap-toast.js" asp-append-version="true"></script>
</body>
</html>
