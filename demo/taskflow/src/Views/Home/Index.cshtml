@{
    ViewData["Title"] = "TaskFlow - Smart Task Management";
}

<section class="hero is-primary is-medium">
    <div class="hero-body">
        <div class="container has-text-centered">
            <h1 class="title is-1">
                <span class="icon is-large">
                    <i class="fas fa-tasks fa-2x"></i>
                </span>
                <br>
                TaskFlow
            </h1>
            <h2 class="subtitle is-4">
                Organize your work with a simple, powerful task board
            </h2>
            <div class="buttons is-centered mt-5">
                <a href="/Tasks" 
                   class="button is-light is-large"
                   hx-get="/Tasks"
                   hx-target="main"
                   hx-push-url="true">
                    <span class="icon">
                        <i class="fas fa-arrow-right"></i>
                    </span>
                    <span>Go to Task Board</span>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="columns is-multiline">
            <div class="column is-4">
                <div class="box has-text-centered">
                    <span class="icon is-large has-text-primary">
                        <i class="fas fa-columns fa-3x"></i>
                    </span>
                    <h3 class="title is-4 mt-4">Kanban Board</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">
                        Visualize your workflow with an intuitive kanban board. Drag tasks through To Do, In Progress, and Done columns.
                    </p>
                </div>
            </div>

            <div class="column is-4">
                <div class="box has-text-centered">
                    <span class="icon is-large has-text-primary">
                        <i class="fas fa-chart-line fa-3x"></i>
                    </span>
                    <h3 class="title is-4 mt-4">Real-Time Stats</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">
                        Track your progress with live statistics. See task counts, priorities, and completion rates at a glance.
                    </p>
                </div>
            </div>

            <div class="column is-4">
                <div class="box has-text-centered">
                    <span class="icon is-large has-text-primary">
                        <i class="fas fa-bolt fa-3x"></i>
                    </span>
                    <h3 class="title is-4 mt-4">Instant Updates</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">
                        Experience server-driven real-time updates with HTMX. No page refreshes, no JavaScript frameworks needed.
                    </p>
                </div>
            </div>

            <div class="column is-4">
                <div class="box has-text-centered">
                    <span class="icon is-large has-text-primary">
                        <i class="fas fa-search fa-3x"></i>
                    </span>
                    <h3 class="title is-4 mt-4">Smart Search</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">
                        Filter tasks instantly as you type. Search by title, description, assignee, or tags with real-time results.
                    </p>
                </div>
            </div>

            <div class="column is-4">
                <div class="box has-text-centered">
                    <span class="icon is-large has-text-primary">
                        <i class="fas fa-flag fa-3x"></i>
                    </span>
                    <h3 class="title is-4 mt-4">Priority Management</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">
                        Set priorities from Low to Critical. Visual badges help you focus on what matters most.
                    </p>
                </div>
            </div>

            <div class="column is-4">
                <div class="box has-text-centered">
                    <span class="icon is-large has-text-primary">
                        <i class="fas fa-history fa-3x"></i>
                    </span>
                    <h3 class="title is-4 mt-4">Activity Feed</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6;">
                        Never miss a change. The activity feed shows all task updates in real-time with a beautiful timeline view.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section has-background-light">
    <div class="container has-text-centered">
        <h2 class="title is-3">Built with Swap.Htmx</h2>
        <p class="subtitle is-5" style="color: var(--text-secondary);">
            A demonstration of pure server-driven development using the Swap framework
        </p>
        <div class="content mt-5">
            <p style="color: var(--text-secondary); font-weight: 600;">
                <strong style="color: var(--text-primary);">Features Showcased:</strong>
            </p>
            <div class="tags are-medium is-centered">
                <span class="tag" style="background-color: var(--primary-light); color: var(--primary); font-weight: 600;">Event-Driven Architecture</span>
                <span class="tag" style="background-color: var(--success-light); color: var(--success); font-weight: 600;">Out-of-Band Swaps</span>
                <span class="tag" style="background-color: var(--info-light); color: var(--info); font-weight: 600;">Toast Notifications</span>
                <span class="tag" style="background-color: var(--warning-light); color: #D97706; font-weight: 600;">Real-Time Updates</span>
                <span class="tag" style="background-color: var(--primary-light); color: var(--primary); font-weight: 600;">Server-Side Search</span>
                <span class="tag" style="background-color: var(--success-light); color: var(--success); font-weight: 600;">HTMX Integration</span>
            </div>
        </div>
    </div>
</section>
