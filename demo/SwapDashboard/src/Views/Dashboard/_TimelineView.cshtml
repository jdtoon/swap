@model List<SwapDashboard.Models.TaskItem>

<div id="task-timeline-view" class="bg-white rounded-lg shadow p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-6">Timeline View</h3>
    
    <div class="flow-root">
        <ul class="-mb-8">
            @{ var sortedTasks = Model.Where(t => t.DueDate.HasValue).OrderBy(t => t.DueDate).ToList(); }
            @for (int i = 0; i < sortedTasks.Count; i++)
            {
                var task = sortedTasks[i];
                var isLast = i == sortedTasks.Count - 1;
                var isOverdue = task.DueDate < DateTime.Now && task.Status != TaskStatus.Done;
                
                <li id="timeline-task-@task.Id">
                    <div class="relative pb-8">
                        @if (!isLast)
                        {
                            <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                        }
                        <div class="relative flex space-x-3">
                            <div>
                                <span class="h-8 w-8 rounded-full flex items-center justify-center ring-8 ring-white @GetStatusBgColor(task.Status)">
                                    @GetStatusIcon(task.Status)
                                </span>
                            </div>
                            <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                                <div>
                                    <p class="text-sm text-gray-900 font-medium">@task.Title</p>
                                    <p class="text-sm text-gray-500">
                                        @if (task.Assignee != null)
                                        {
                                            <span>Assigned to @task.Assignee.Name</span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400">Unassigned</span>
                                        }
                                    </p>
                                </div>
                                <div class="text-right text-sm whitespace-nowrap @(isOverdue ? "text-red-600 font-medium" : "text-gray-500")">
                                    @if (task.DueDate.HasValue)
                                    {
                                        <time datetime="@task.DueDate.Value.ToString("yyyy-MM-dd")">
                                            @task.DueDate.Value.ToString("MMM d")
                                        </time>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </li>
            }
        </ul>
    </div>
    
    @if (!sortedTasks.Any())
    {
        <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No tasks with due dates</h3>
            <p class="mt-1 text-sm text-gray-500">Add due dates to your tasks to see them in the timeline.</p>
        </div>
    }
    
    @{ var tasksWithoutDates = Model.Where(t => !t.DueDate.HasValue).ToList(); }
    @if (tasksWithoutDates.Any())
    {
        <div class="mt-8 pt-6 border-t border-gray-200">
            <h4 class="text-sm font-medium text-gray-500 mb-4">Tasks without due dates</h4>
            <ul class="space-y-2">
                @foreach (var task in tasksWithoutDates)
                {
                    <li class="flex items-center text-sm">
                        <span class="h-2 w-2 rounded-full @GetStatusDotColor(task.Status) mr-2"></span>
                        <span class="text-gray-700">@task.Title</span>
                        <span class="ml-2 px-2 py-0.5 text-xs rounded-full @GetStatusBadgeColor(task.Status)">@task.Status</span>
                    </li>
                }
            </ul>
        </div>
    }
</div>

@functions {
    string GetStatusBgColor(TaskStatus status) => status switch
    {
        TaskStatus.Todo => "bg-gray-400",
        TaskStatus.InProgress => "bg-blue-500",
        TaskStatus.Review => "bg-yellow-500",
        TaskStatus.Done => "bg-green-500",
        _ => "bg-gray-400"
    };

    string GetStatusDotColor(TaskStatus status) => status switch
    {
        TaskStatus.Todo => "bg-gray-400",
        TaskStatus.InProgress => "bg-blue-500",
        TaskStatus.Review => "bg-yellow-500",
        TaskStatus.Done => "bg-green-500",
        _ => "bg-gray-400"
    };

    string GetStatusBadgeColor(TaskStatus status) => status switch
    {
        TaskStatus.Todo => "bg-gray-100 text-gray-700",
        TaskStatus.InProgress => "bg-blue-100 text-blue-700",
        TaskStatus.Review => "bg-yellow-100 text-yellow-700",
        TaskStatus.Done => "bg-green-100 text-green-700",
        _ => "bg-gray-100 text-gray-700"
    };

    Microsoft.AspNetCore.Html.HtmlString GetStatusIcon(TaskStatus status) => status switch
    {
        TaskStatus.Done => new Microsoft.AspNetCore.Html.HtmlString("<svg class=\"h-5 w-5 text-white\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>"),
        TaskStatus.InProgress => new Microsoft.AspNetCore.Html.HtmlString("<svg class=\"h-5 w-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 10V3L4 14h7v7l9-11h-7z\"/></svg>"),
        TaskStatus.Review => new Microsoft.AspNetCore.Html.HtmlString("<svg class=\"h-5 w-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\"/><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\"/></svg>"),
        _ => new Microsoft.AspNetCore.Html.HtmlString("<svg class=\"h-5 w-5 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>")
    };
}
