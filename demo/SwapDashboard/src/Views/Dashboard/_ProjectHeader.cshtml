@model Project

<div class="flex items-center justify-between">
    <div class="flex items-center space-x-4">
        <div class="w-4 h-4 rounded-full" style="background-color: @Model.Color"></div>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">@Model.Name</h1>
            <p class="text-sm text-gray-500">@Model.Description</p>
        </div>
    </div>
    
    <div class="flex items-center space-x-3">
        @if (Model.DueDate.HasValue)
        {
            var isOverdue = Model.DueDate < DateTime.Now && Model.Progress < 100;
            <div class="flex items-center space-x-1 text-sm @(isOverdue ? "text-red-600" : "text-gray-500")">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span>Due @Model.DueDate.Value.ToString("MMM d")</span>
            </div>
        }
        
        <button class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
            </svg>
        </button>
    </div>
</div>
