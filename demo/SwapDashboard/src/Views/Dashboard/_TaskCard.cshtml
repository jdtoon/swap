@model TaskItem

@{
    var priorityColor = Model.Priority switch
    {
        TaskPriority.Urgent => "bg-red-500",
        TaskPriority.High => "bg-orange-500",
        TaskPriority.Medium => "bg-yellow-500",
        _ => "bg-gray-400"
    };
    
    var isOverdue = Model.DueDate.HasValue && Model.DueDate < DateTime.Now && Model.Status != TaskStatus.Done;
}

<div 
    id="task-card-@Model.Id"
    class="kanban-card bg-white rounded-lg p-3 shadow-sm border border-gray-200 hover:shadow-md transition-shadow"
    hx-get="/Dashboard/TaskDetail/@Model.Id"
    hx-target="#modal-container">
    
    <!-- Priority indicator -->
    <div class="flex items-center justify-between mb-2">
        <div class="flex items-center space-x-2">
            <div class="w-2 h-2 rounded-full @priorityColor"></div>
            <span class="text-xs text-gray-500 capitalize">@Model.Priority</span>
        </div>
        
        @if (Model.Status != TaskStatus.Done)
        {
            <button 
                class="text-gray-400 hover:text-green-600 transition-colors"
                hx-post="/Dashboard/CompleteTask/@Model.Id"
                hx-swap="none"
                onclick="event.stopPropagation()">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </button>
        }
        else
        {
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
        }
    </div>
    
    <!-- Title -->
    <h4 class="text-sm font-medium text-gray-900 mb-2 line-clamp-2">@Model.Title</h4>
    
    <!-- Tags -->
    @if (Model.Tags.Any())
    {
        <div class="flex flex-wrap gap-1 mb-2">
            @foreach (var tag in Model.Tags.Take(3))
            {
                <span class="text-xs px-2 py-0.5 bg-indigo-100 text-indigo-600 rounded-full">@tag</span>
            }
        </div>
    }
    
    <!-- Footer -->
    <div class="flex items-center justify-between text-xs text-gray-500 pt-2 border-t border-gray-100">
        <div class="flex items-center space-x-2">
            @if (Model.Assignee != null)
            {
                <div class="w-6 h-6 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center text-xs font-medium">
                    @Model.Assignee.Avatar
                </div>
            }
            
            @if (Model.CommentCount > 0)
            {
                <div class="flex items-center space-x-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span>@Model.CommentCount</span>
                </div>
            }
        </div>
        
        @if (Model.DueDate.HasValue)
        {
            <div class="flex items-center space-x-1 @(isOverdue ? "text-red-500" : "")">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span>@Model.DueDate.Value.ToString("MMM d")</span>
            </div>
        }
    </div>
    
</div>
