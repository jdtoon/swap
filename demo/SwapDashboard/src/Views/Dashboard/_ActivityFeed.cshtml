@model List<ActivityItem>

<div class="p-4">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Recent Activity</h2>
    
    <div class="space-y-4">
        @foreach (var activity in Model)
        {
            <partial name="_ActivityItem" model="activity" />
        }
    </div>
    
    @if (Model.Count >= 10)
    {
        <button 
            class="mt-4 w-full text-sm text-indigo-600 hover:text-indigo-800"
            hx-get="/Dashboard/LoadMoreActivities?skip=@Model.Count"
            hx-target="#activity-feed"
            hx-swap="beforeend">
            Load more
        </button>
    }
</div>
