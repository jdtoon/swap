@model List<Notification>

<div class="p-4">
    <div class="flex items-center justify-between mb-3">
        <h3 class="font-semibold text-gray-900">Notifications</h3>
        <button 
            class="text-sm text-indigo-600 hover:text-indigo-800"
            hx-post="/Dashboard/MarkAllRead"
            hx-target="#notification-dropdown">
            Mark all read
        </button>
    </div>
    
    <div class="space-y-2 max-h-80 overflow-y-auto">
        @foreach (var notification in Model)
        {
            <div class="p-3 rounded-lg @(notification.IsRead ? "bg-white" : "bg-indigo-50") hover:bg-gray-50 cursor-pointer">
                <div class="flex items-start space-x-3">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center @(notification.Type switch { 
                        "success" => "bg-green-100 text-green-600",
                        "warning" => "bg-yellow-100 text-yellow-600",
                        "error" => "bg-red-100 text-red-600",
                        _ => "bg-blue-100 text-blue-600"
                    })">
                        @switch (notification.Type)
                        {
                            case "success":
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                                break;
                            case "warning":
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                                break;
                            default:
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                break;
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-900">@notification.Title</p>
                        <p class="text-sm text-gray-500 truncate">@notification.Message</p>
                        <p class="text-xs text-gray-400 mt-1">@notification.Timestamp.ToString("MMM d, h:mm tt")</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
