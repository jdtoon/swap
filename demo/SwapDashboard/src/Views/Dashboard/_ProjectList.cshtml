@model List<Project>

<div class="p-4">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Projects</h2>
    
    <div class="space-y-1">
        @foreach (var project in Model)
        {
            <partial name="_ProjectItem" model="project" />
        }
    </div>
    
    <button class="mt-4 w-full px-3 py-2 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg flex items-center justify-center space-x-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <span>New Project</span>
    </button>
</div>
