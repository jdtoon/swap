@model DashboardStats

<div class="flex items-center space-x-4 text-sm">
    <span class="text-gray-500">
        <span class="font-semibold text-gray-900">@Model.TotalTasks</span> tasks
    </span>
    <span class="text-gray-300">|</span>
    <span class="text-green-600">
        <span class="font-semibold">@Model.CompletedTasks</span> done
    </span>
    <span class="text-gray-300">|</span>
    <span class="text-blue-600">
        <span class="font-semibold">@Model.InProgressTasks</span> in progress
    </span>
    @if (Model.OverdueTasks > 0)
    {
        <span class="text-gray-300">|</span>
        <span class="text-red-600">
            <span class="font-semibold">@Model.OverdueTasks</span> overdue
        </span>
    }
</div>
