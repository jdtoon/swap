{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Swap.Htmx": "Debug"
    }
  },
  "SwapHtmx": {
    "Diagnostics": {
      "EnableClientLogging": true,
      "EnableDevToolsPanel": true,
      "WarnOnUnhandledEvents": true,
      "WarnOnMissingOobTargets": true,
      "EnableTimingLogs": true
    }
  }
}
