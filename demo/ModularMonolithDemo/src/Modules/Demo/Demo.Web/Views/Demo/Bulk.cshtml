@{
  ViewData["Title"] = "Bulk";
}
<div class="card bg-base-100 shadow">
  <div class="card-body">
    <h2 class="card-title">Bulk Complete Todos</h2>
    <div id="bulk-todos"
         hx-get="/Demo/BulkTodos"
         hx-trigger="load, ui.todos.refreshList from:body"
         hx-target="this"
         hx-swap="innerHTML">
      <div class="loading loading-spinner"></div>
    </div>
  </div>
</div>
