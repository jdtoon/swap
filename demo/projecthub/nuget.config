<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Local development packages (highest priority) -->
    <add key="local-dev" value="../../.nuget/local" />
    <!-- Official NuGet -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <!-- Allow pre-release packages -->
    <add key="includePreRelease" value="true" />
  </config>
</configuration>