@model ProjectHub.Modules.Tasks.Contracts.TaskDto
@{
    ViewData["Title"] = Model.Title;
}

<div class="container">
    <div class="level">
        <div class="level-left">
            <div class="level-item">
                <h1 class="title">@Model.Title</h1>
            </div>
        </div>
        <div class="level-right">
            <div class="level-item">
                <a href="/tasks/@Model.Id/edit" class="button is-primary" hx-get="/tasks/@Model.Id/edit" hx-target="#main-content" hx-push-url="true">
                    <span class="icon"><i class="fas fa-edit"></i></span>
                    <span>Edit</span>
                </a>
            </div>
        </div>
    </div>

    <div class="box">
        <div class="columns">
            <div class="column">
                <div class="field">
                    <label class="label">Project</label>
                    <div class="control">
                        <p>@Model.ProjectName</p>
                    </div>
                </div>

                <div class="field">
                    <label class="label">Status</label>
                    <div class="control">
                        <span class="tag is-medium is-@GetStatusColor(Model.Status)">@Model.Status</span>
                    </div>
                </div>

                <div class="field">
                    <label class="label">Priority</label>
                    <div class="control">
                        <span class="tag is-medium is-@GetPriorityColor(Model.Priority)">@Model.Priority</span>
                    </div>
                </div>

                @if (Model.DueDate.HasValue)
                {
                    <div class="field">
                        <label class="label">Due Date</label>
                        <div class="control">
                            <p>@Model.DueDate.Value.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                }
            </div>

            <div class="column">
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="field">
                        <label class="label">Description</label>
                        <div class="control">
                            <div class="content">
                                @Model.Description
                            </div>
                        </div>
                    </div>
                }

                <div class="field">
                    <label class="label">Created</label>
                    <div class="control">
                        <p class="has-text-grey">@Model.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</p>
                    </div>
                </div>

                @if (Model.UpdatedAt.HasValue)
                {
                    <div class="field">
                        <label class="label">Last Updated</label>
                        <div class="control">
                            <p class="has-text-grey">@Model.UpdatedAt.Value.ToString("MMM dd, yyyy h:mm tt")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="buttons">
        <a href="/tasks?projectId=@Model.ProjectId" class="button is-light" hx-get="/tasks?projectId=@Model.ProjectId" hx-target="#main-content" hx-push-url="true">
            <span class="icon"><i class="fas fa-arrow-left"></i></span>
            <span>Back to Tasks</span>
        </a>
        <button class="button is-danger" 
                hx-post="/tasks/@Model.Id/delete" 
                hx-confirm="Are you sure you want to delete this task?"
                hx-target="#main-content"
                hx-swap="outerHTML">
            <span class="icon"><i class="fas fa-trash"></i></span>
            <span>Delete</span>
        </button>
    </div>
</div>

@functions {
    string GetStatusColor(ProjectHub.Modules.Tasks.Contracts.TaskStatus status)
    {
        return status switch
        {
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Backlog => "light",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Todo => "info",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.InProgress => "warning",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Review => "link",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Done => "success",
            _ => "light"
        };
    }

    string GetPriorityColor(ProjectHub.Modules.Tasks.Contracts.TaskPriority priority)
    {
        return priority switch
        {
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.Low => "light",
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.Medium => "info",
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.High => "warning",
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.Urgent => "danger",
            _ => "light"
        };
    }
}
