@model ProjectHub.Modules.Tasks.Contracts.CreateTaskDto
@{
    ViewData["Title"] = "Create Task";
    var projects = ViewBag.Projects as IEnumerable<ProjectHub.Modules.Projects.Contracts.ProjectDto>;
    var selectedProjectId = ViewBag.SelectedProjectId as int?;
}

<div class="container">
    <h1 class="title">Create Task</h1>

    <form method="post" action="/tasks/create" hx-post="/tasks/create" hx-target="#main-content" hx-swap="outerHTML">
        <div class="field">
            <label class="label" for="ProjectId">Project</label>
            <div class="control">
                <div class="select is-fullwidth">
                    <select name="ProjectId" id="ProjectId" required>
                        <option value="">Select a project...</option>
                        @if (projects != null)
                        {
                            foreach (var project in projects)
                            {
                                <option value="@project.Id" selected="@(selectedProjectId == project.Id || Model?.ProjectId == project.Id)">
                                    @project.Name
                                </option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="field">
            <label class="label" for="Title">Title</label>
            <div class="control">
                <input class="input" type="text" name="Title" id="Title" value="@Model?.Title" required maxlength="500" />
            </div>
        </div>

        <div class="field">
            <label class="label" for="Description">Description</label>
            <div class="control">
                <textarea class="textarea" name="Description" id="Description" rows="4">@Model?.Description</textarea>
            </div>
        </div>

        <div class="columns">
            <div class="column">
                <div class="field">
                    <label class="label" for="Status">Status</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select name="Status" id="Status">
                                <option value="Backlog">Backlog</option>
                                <option value="Todo" selected>Todo</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Review">Review</option>
                                <option value="Done">Done</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="column">
                <div class="field">
                    <label class="label" for="Priority">Priority</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select name="Priority" id="Priority">
                                <option value="Low">Low</option>
                                <option value="Medium" selected>Medium</option>
                                <option value="High">High</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="field">
            <label class="label" for="DueDate">Due Date</label>
            <div class="control">
                <input class="input" type="date" name="DueDate" id="DueDate" value="@Model?.DueDate?.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="field is-grouped">
            <div class="control">
                <button type="submit" class="button is-primary">
                    <span class="icon"><i class="fas fa-save"></i></span>
                    <span>Create Task</span>
                </button>
            </div>
            <div class="control">
                <a href="/tasks" class="button is-light" hx-get="/tasks" hx-target="#main-content" hx-push-url="true">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>
