@model ProjectHub.Modules.Tasks.Contracts.TaskDto
@{
    ViewData["Title"] = $"Edit {Model.Title}";
    var projects = ViewBag.Projects as IEnumerable<ProjectHub.Modules.Projects.Contracts.ProjectDto>;
}

<div class="container">
    <h1 class="title">Edit Task</h1>

    <form method="post" action="/tasks/@Model.Id/edit" hx-post="/tasks/@Model.Id/edit" hx-target="#main-content" hx-swap="innerHTML" hx-push-url="true">
        <div class="field">
            <label class="label">Project</label>
            <div class="control">
                <p class="has-text-weight-semibold">@Model.ProjectName</p>
                <p class="help">Project cannot be changed after task creation</p>
            </div>
        </div>

        <div class="field">
            <label class="label" for="Title">Title</label>
            <div class="control">
                <input class="input" type="text" name="Title" id="Title" value="@Model.Title" required maxlength="500" />
            </div>
        </div>

        <div class="field">
            <label class="label" for="Description">Description</label>
            <div class="control">
                <textarea class="textarea" name="Description" id="Description" rows="4">@Model.Description</textarea>
            </div>
        </div>

        <div class="columns">
            <div class="column">
                <div class="field">
                    <label class="label" for="Status">Status</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select name="Status" id="Status">
                                <option value="Backlog" selected="@(Model.Status == ProjectHub.Modules.Tasks.Contracts.TaskStatus.Backlog)">Backlog</option>
                                <option value="Todo" selected="@(Model.Status == ProjectHub.Modules.Tasks.Contracts.TaskStatus.Todo)">Todo</option>
                                <option value="InProgress" selected="@(Model.Status == ProjectHub.Modules.Tasks.Contracts.TaskStatus.InProgress)">In Progress</option>
                                <option value="Review" selected="@(Model.Status == ProjectHub.Modules.Tasks.Contracts.TaskStatus.Review)">Review</option>
                                <option value="Done" selected="@(Model.Status == ProjectHub.Modules.Tasks.Contracts.TaskStatus.Done)">Done</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="column">
                <div class="field">
                    <label class="label" for="Priority">Priority</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <select name="Priority" id="Priority">
                                <option value="Low" selected="@(Model.Priority == ProjectHub.Modules.Tasks.Contracts.TaskPriority.Low)">Low</option>
                                <option value="Medium" selected="@(Model.Priority == ProjectHub.Modules.Tasks.Contracts.TaskPriority.Medium)">Medium</option>
                                <option value="High" selected="@(Model.Priority == ProjectHub.Modules.Tasks.Contracts.TaskPriority.High)">High</option>
                                <option value="Urgent" selected="@(Model.Priority == ProjectHub.Modules.Tasks.Contracts.TaskPriority.Urgent)">Urgent</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="field">
            <label class="label" for="DueDate">Due Date</label>
            <div class="control">
                <input class="input" type="date" name="DueDate" id="DueDate" value="@Model.DueDate?.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="field is-grouped">
            <div class="control">
                <button type="submit" class="button is-primary">
                    <span class="icon"><i class="fas fa-save"></i></span>
                    <span>Save Changes</span>
                </button>
            </div>
            <div class="control">
                <a href="/tasks/@Model.Id" class="button is-light" hx-get="/tasks/@Model.Id" hx-target="#main-content" hx-push-url="true">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>
