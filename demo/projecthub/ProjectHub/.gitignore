## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# Node modules
**/node_modules/

# Database files
*.db
*.db-shm
*.db-wal

# Tailwind output
**/wwwroot/css/app.min.css
**/wwwroot/css/app.min.css.map

# Library Manager (libman)
**/wwwroot/lib/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
docker-data/
