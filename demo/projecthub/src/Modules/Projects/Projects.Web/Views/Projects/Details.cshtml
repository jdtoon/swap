@model ProjectHub.Modules.Projects.Contracts.ProjectDto
@{
    ViewData["Title"] = Model.Name;
    var tasks = ViewBag.Tasks as IEnumerable<ProjectHub.Modules.Tasks.Contracts.TaskDto>;
    var taskStats = ViewBag.TaskStats;
    var statusColor = Model.Status switch
    {
        "Active" => "is-success",
        "OnHold" => "is-warning",
        "Completed" => "is-info",
        _ => "is-light"
    };
}

<section class="section">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li>
                    <a href="/workspaces"
                       hx-get="/workspaces"
                       hx-target="#main-content"
                       hx-push-url="true">Workspaces</a>
                </li>
                <li>
                    <a href="/workspaces/@Model.WorkspaceId"
                       hx-get="/workspaces/@Model.WorkspaceId"
                       hx-target="#main-content"
                       hx-push-url="true">@Model.WorkspaceName</a>
                </li>
                <li>
                    <a href="/projects/workspace/@Model.WorkspaceId"
                       hx-get="/projects/workspace/@Model.WorkspaceId"
                       hx-target="#main-content"
                       hx-push-url="true">Projects</a>
                </li>
                <li class="is-active"><a href="#" aria-current="page">@Model.Name</a></li>
            </ul>
        </nav>

        <div class="level">
            <div class="level-left">
                <div class="level-item">
                    <div>
                        <h1 class="title">
                            <span class="icon has-text-primary">
                                <i class="fas fa-folder-open"></i>
                            </span>
                            @Model.Name
                        </h1>
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <p class="subtitle">@Model.Description</p>
                        }
                    </div>
                </div>
            </div>
            <div class="level-right">
                <div class="level-item">
                    <div class="buttons">
                        <a href="/projects/@Model.Id/edit"
                           hx-get="/projects/@Model.Id/edit"
                           hx-target="#main-content"
                           hx-push-url="true"
                           class="button is-light">
                            <span class="icon"><i class="fas fa-edit"></i></span>
                            <span>Edit</span>
                        </a>
                        <button class="button is-danger is-light"
                                hx-post="/projects/archive/@Model.Id"
                                hx-confirm="Archive this project?"
                                hx-target="#main-content"
                                hx-swap="innerHTML">
                            <span class="icon"><i class="fas fa-archive"></i></span>
                            <span>Archive</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="columns">
            <div class="column is-8">
                <div class="box">
                    <div class="level mb-4">
                        <div class="level-left">
                            <div class="level-item">
                                <h2 class="title is-5">
                                    <span class="icon"><i class="fas fa-tasks"></i></span>
                                    <span>Tasks</span>
                                </h2>
                            </div>
                        </div>
                        <div class="level-right">
                            <div class="level-item">
                                <div class="tags">
                                    @if (taskStats.Completed > 0)
                                    {
                                        <span class="tag is-success">@taskStats.Completed Completed</span>
                                    }
                                    @if (taskStats.InProgress > 0)
                                    {
                                        <span class="tag is-info">@taskStats.InProgress In Progress</span>
                                    }
                                    @if (taskStats.Review > 0)
                                    {
                                        <span class="tag is-warning">@taskStats.Review Review</span>
                                    }
                                    <span class="tag is-light">@taskStats.Total Total</span>
                                </div>
                            </div>
                            <div class="level-item">
                                <a href="/tasks/create?projectId=@Model.Id"
                                   hx-get="/tasks/create?projectId=@Model.Id"
                                   hx-target="#main-content"
                                   hx-push-url="true"
                                   class="button is-primary is-small">
                                    <span class="icon"><i class="fas fa-plus"></i></span>
                                    <span>New Task</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    @* Cross-module UI composition: rendering Tasks module partial *@
                    @await Html.PartialAsync("/Views/Tasks/_TaskListCompact.cshtml", tasks)

                    @if (tasks?.Any() == true)
                    {
                        <div class="buttons is-centered mt-4">
                            <a href="/tasks?projectId=@Model.Id"
                               hx-get="/tasks?projectId=@Model.Id"
                               hx-target="#main-content"
                               hx-push-url="true"
                               class="button is-light">
                                <span class="icon"><i class="fas fa-list"></i></span>
                                <span>View All Tasks</span>
                            </a>
                            <a href="/tasks/kanban?projectId=@Model.Id"
                               hx-get="/tasks/kanban?projectId=@Model.Id"
                               hx-target="#main-content"
                               hx-push-url="true"
                               class="button is-primary">
                                <span class="icon"><i class="fas fa-columns"></i></span>
                                <span>Kanban Board</span>
                            </a>
                        </div>
                    }
                </div>
            </div>

            <div class="column is-4">
                <div class="box">
                    <h2 class="title is-6">Project Details</h2>
                    
                    <div class="field">
                        <label class="label is-small">Status</label>
                        <div class="control">
                            <span class="tag @statusColor">@Model.Status</span>
                        </div>
                    </div>

                    @if (Model.StartDate.HasValue)
                    {
                        <div class="field">
                            <label class="label is-small">Start Date</label>
                            <p>@Model.StartDate.Value.ToString("MMMM dd, yyyy")</p>
                        </div>
                    }

                    @if (Model.DueDate.HasValue)
                    {
                        <div class="field">
                            <label class="label is-small">Due Date</label>
                            <p>@Model.DueDate.Value.ToString("MMMM dd, yyyy")</p>
                        </div>
                    }

                    <div class="field">
                        <label class="label is-small">Created</label>
                        <p>@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    </div>

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="field">
                            <label class="label is-small">Last Updated</label>
                            <p>@Model.UpdatedAt.Value.ToString("MMMM dd, yyyy")</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
