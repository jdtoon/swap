@model ProjectHub.Modules.Workspaces.Contracts.WorkspaceDto
@{
    ViewData["Title"] = $"Edit {Model.Name}";
}

<div class="container">
    <h1 class="title">Edit Workspace</h1>

    <form method="post" action="/workspaces/@Model.Id/edit" hx-post="/workspaces/@Model.Id/edit" hx-target="#main-content" hx-swap="innerHTML" hx-push-url="true">
        <div class="field">
            <label class="label" for="Name">Name</label>
            <div class="control">
                <input class="input" type="text" name="Name" id="Name" value="@Model.Name" required maxlength="200" />
            </div>
        </div>

        <div class="field">
            <label class="label" for="Description">Description</label>
            <div class="control">
                <textarea class="textarea" name="Description" id="Description" rows="4">@Model.Description</textarea>
            </div>
        </div>

        <div class="field">
            <label class="label" for="Color">Color</label>
            <div class="control">
                <input class="input" type="color" name="Color" id="Color" value="@(Model.Color ?? "#3273dc")" />
            </div>
            <p class="help">Choose a color to identify this workspace</p>
        </div>

        <div class="field is-grouped">
            <div class="control">
                <button type="submit" class="button is-primary">
                    <span class="icon"><i class="fas fa-save"></i></span>
                    <span>Save Changes</span>
                </button>
            </div>
            <div class="control">
                <a href="/workspaces/@Model.Id" class="button is-light" hx-get="/workspaces/@Model.Id" hx-target="#main-content" hx-push-url="true">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>
