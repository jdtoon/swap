@model IEnumerable<ProjectHub.Modules.Tasks.Contracts.TaskDto>

@if (Model?.Any() == true)
{
    <div class="task-list-compact">
        @foreach (var task in Model)
        {
            <div class="box mb-2 p-3">
                <div class="level is-mobile mb-0">
                    <div class="level-left">
                        <div class="level-item">
                            <a href="/tasks/@task.Id"
                               hx-get="/tasks/@task.Id"
                               hx-target="#main-content"
                               hx-push-url="true"
                               class="has-text-weight-semibold">
                                @task.Title
                            </a>
                        </div>
                    </div>
                    <div class="level-right">
                        <div class="level-item">
                            <span class="tag is-@GetStatusColor(task.Status)">@task.Status</span>
                        </div>
                        @if (task.Priority != ProjectHub.Modules.Tasks.Contracts.TaskPriority.Medium)
                        {
                            <div class="level-item">
                                <span class="tag is-@GetPriorityColor(task.Priority)">@task.Priority</span>
                            </div>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(task.Description))
                {
                    <p class="is-size-7 has-text-grey mt-2">@task.Description</p>
                }
            </div>
        }
    </div>
}
else
{
    <div class="notification is-light">
        <p class="has-text-centered has-text-grey">No tasks yet.</p>
    </div>
}

@functions {
    string GetStatusColor(ProjectHub.Modules.Tasks.Contracts.TaskStatus status)
    {
        return status switch
        {
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Backlog => "light",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Todo => "light",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.InProgress => "info",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Review => "warning",
            ProjectHub.Modules.Tasks.Contracts.TaskStatus.Done => "success",
            _ => "light"
        };
    }

    string GetPriorityColor(ProjectHub.Modules.Tasks.Contracts.TaskPriority priority)
    {
        return priority switch
        {
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.Low => "light",
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.Medium => "info",
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.High => "warning",
            ProjectHub.Modules.Tasks.Contracts.TaskPriority.Urgent => "danger",
            _ => "light"
        };
    }
}
