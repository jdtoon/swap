@model IEnumerable<ProjectHub.Modules.Tasks.Contracts.TaskDto>
@{
    ViewData["Title"] = "Tasks - Kanban Board";
    var projects = ViewBag.Projects as IEnumerable<ProjectHub.Modules.Projects.Contracts.ProjectDto>;
    var selectedProjectId = ViewBag.SelectedProjectId as int?;
}

<section class="section">
    <div class="container is-fluid">
        <div class="level">
            <div class="level-left">
                <div class="level-item">
                    <div>
                        <h1 class="title">Tasks - Kanban Board</h1>
                        <p class="subtitle">Drag and drop to organize your tasks</p>
                    </div>
                </div>
            </div>
            <div class="level-right">
                <div class="level-item">
                    <div class="buttons">
                        <a href="/tasks" hx-get="/tasks" hx-target="#main-content" hx-push-url="true" class="button is-light">
                            <span class="icon"><i class="fas fa-list"></i></span>
                            <span>List View</span>
                        </a>
                        <a href="/tasks/create?projectId=@selectedProjectId" hx-get="/tasks/create?projectId=@selectedProjectId" hx-target="#main-content" hx-push-url="true" class="button is-primary">
                            <span class="icon"><i class="fas fa-plus"></i></span>
                            <span>New Task</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (projects?.Any() == true)
        {
            <div class="field">
                <div class="control">
                    <div class="select">
                        <select hx-get="/tasks/kanban" 
                                hx-trigger="change" 
                                hx-target="#main-content" 
                                hx-push-url="true"
                                hx-include="this"
                                name="projectId">
                            <option value="">All Projects</option>
                            @foreach (var project in projects)
                            {
                                <option value="@project.Id" @(selectedProjectId == project.Id ? "selected" : "")>@project.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        }

        <div class="columns is-variable is-2 mt-4" style="min-height: 70vh;" id="kanban-board">
            @await Html.PartialAsync("_KanbanColumns", Model)
        </div>
    </div>
</section>

<style>
    .kanban-column {
        min-height: 500px;
        padding: 0.5rem;
    }
    
    .kanban-card {
        margin-bottom: 0.75rem;
        cursor: move;
    }
    
    .kanban-card.sortable-ghost {
        opacity: 0.4;
    }
    
    .kanban-card.sortable-drag {
        cursor: grabbing;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
// Initialize Sortable on htmx:load event (fires on initial load AND after HTMX swaps)
document.body.addEventListener('htmx:load', function(evt) {
    const kanbanBoard = document.getElementById('kanban-board');
    if (!kanbanBoard) return;
    
    const columns = kanbanBoard.querySelectorAll('.kanban-column');
    
    columns.forEach(column => {
        // Destroy existing Sortable instance if it exists
        if (column.sortableInstance) {
            column.sortableInstance.destroy();
        }
        
        // Create new Sortable instance
        column.sortableInstance = new Sortable(column, {
            group: 'kanban',
            animation: 150,
            ghostClass: 'sortable-ghost',
            dragClass: 'sortable-drag',
            onEnd: function(evt) {
                const taskId = evt.item.dataset.taskId;
                const newStatusString = evt.to.dataset.status;
                const newPosition = evt.newIndex;
                
                // Map status string to enum integer
                const statusMap = {
                    'Backlog': 0,
                    'Todo': 1,
                    'InProgress': 2,
                    'Review': 3,
                    'Done': 4
                };
                const newStatus = statusMap[newStatusString];
                
                // Use fetch with proper JSON encoding
                fetch(`/tasks/${taskId}/move`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'HX-Request': 'true'
                    },
                    body: JSON.stringify({
                        newStatus: newStatus,
                        newPosition: parseInt(newPosition)
                    })
                })
                .then(response => response.text())
                .then(html => {
                    // Manually swap the kanban board HTML
                    kanbanBoard.innerHTML = html;
                    // Trigger htmx:load to reinitialize Sortable
                    htmx.trigger(document.body, 'htmx:load');
                })
                .catch(error => {
                    console.error('Error moving task:', error);
                    // Revert on error
                    if (evt.from && evt.oldIndex !== undefined) {
                        evt.from.insertBefore(evt.item, evt.from.children[evt.oldIndex]);
                    }
                })
                .finally(() => {
                    form.remove();
                });
            }
        });
    });
});
</script>

