@model ProjectHub.Web.Controllers.DashboardStatsViewModel

<div class="columns is-multiline">
    <div class="column is-half-tablet is-one-quarter-desktop">
        <div class="box has-text-centered">
            <p class="heading">Workspaces</p>
            <p class="title is-3 has-text-primary">@Model.WorkspaceCount</p>
        </div>
    </div>
    <div class="column is-half-tablet is-one-quarter-desktop">
        <div class="box has-text-centered">
            <p class="heading">Projects</p>
            <p class="title is-3 has-text-link">@Model.ProjectCount</p>
        </div>
    </div>
    <div class="column is-half-tablet is-one-quarter-desktop">
        <div class="box has-text-centered">
            <p class="heading">Total Tasks</p>
            <p class="title is-3 has-text-info">@Model.TaskCount</p>
        </div>
    </div>
    <div class="column is-half-tablet is-one-quarter-desktop">
        <div class="box has-text-centered">
            <p class="heading">Completion</p>
            <p class="title is-3 has-text-success">@Model.CompletionPercentage%</p>
        </div>
    </div>
</div>

<div class="columns">
    <div class="column is-half">
        <div class="box">
            <h6 class="title is-6">Task Status Distribution</h6>
            <div class="content">
                <div class="level is-mobile mb-2">
                    <div class="level-left">
                        <span class="tag is-light">📋 Todo</span>
                    </div>
                    <div class="level-right">
                        <strong>@Model.TodoTaskCount</strong>
                    </div>
                </div>
                <div class="level is-mobile mb-2">
                    <div class="level-left">
                        <span class="tag is-info is-light">🔄 In Progress</span>
                    </div>
                    <div class="level-right">
                        <strong>@Model.InProgressTaskCount</strong>
                    </div>
                </div>
                <div class="level is-mobile mb-2">
                    <div class="level-left">
                        <span class="tag is-warning is-light">🔍 Review</span>
                    </div>
                    <div class="level-right">
                        <strong>@Model.ReviewTaskCount</strong>
                    </div>
                </div>
                <div class="level is-mobile mb-2">
                    <div class="level-left">
                        <span class="tag is-success is-light">✅ Done</span>
                    </div>
                    <div class="level-right">
                        <strong>@Model.CompletedTaskCount</strong>
                    </div>
                </div>
                <div class="level is-mobile">
                    <div class="level-left">
                        <span class="tag is-dark is-light">📦 Backlog</span>
                    </div>
                    <div class="level-right">
                        <strong>@Model.BacklogTaskCount</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="column is-half">
        <div class="box">
            <h6 class="title is-6">Progress Overview</h6>
            
            <!-- Progress bar -->
            <div class="field">
                <label class="label is-small">Overall Completion</label>
                <progress class="progress is-success" value="@Model.CompletedTaskCount" max="@Model.TaskCount">@Model.CompletionPercentage%</progress>
            </div>
            
            <!-- Active work indicator -->
            <div class="field">
                <label class="label is-small">Active Work</label>
                <progress class="progress is-info" value="@Model.InProgressTaskCount" max="@Model.TaskCount">
                    @(Model.TaskCount > 0 ? Math.Round((decimal)Model.InProgressTaskCount / Model.TaskCount * 100, 1) : 0)%
                </progress>
            </div>
            
            <!-- Real-time timestamp -->
            <div class="field">
                <p class="is-size-7 has-text-grey">
                    <span class="icon is-small">🕐</span>
                    Last updated: @Model.Timestamp.ToString("HH:mm:ss")
                    <span class="tag is-success is-small ml-2">Live</span>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Live data indicators -->
<div class="notification is-light is-small">
    <div class="level is-mobile">
        <div class="level-left">
            <p class="is-size-7">
                <span class="icon">📡</span>
                <strong>Real-time data:</strong> This view updates automatically via Server-Sent Events
            </p>
        </div>
        <div class="level-right">
            <span class="tag is-small is-info">
                <span class="icon is-small">⚡</span>
                <span>SSE Active</span>
            </span>
        </div>
    </div>
</div>