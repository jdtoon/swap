@using SwapShop.Views
@inject SwapShop.Services.ICartService CartService

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="htmx-config" content='{"selfRequestsOnly":true}' />
    <title>@ViewData["Title"] - SwapShop</title>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_content/Swap.Htmx/css/swap.css" asp-append-version="true" />
    
    <!-- HTMX -->
    <script src="~/lib/htmx/dist/htmx.min.js" asp-append-version="true"></script>
    <!-- Swap.Htmx -->
    <script src="~/_content/Swap.Htmx/js/swap.client.js" asp-append-version="true"></script>
</head>
<body>
    <header>
        <nav class="container">
            <ul>
                <li><strong>SwapShop</strong></li>
            </ul>
            <ul>
                <li>
                    <swap-nav to="/Products">Products</swap-nav>
                </li>
                <li>
                    <swap-nav to="/Cart">Cart <span id="@CartElements.Badge">@await Html.PartialAsync("~/Views/Cart/_CartBadge.cshtml", CartService.GetItemCount(Context.Session.Id))</span></swap-nav>
                </li>
                <li>
                    <swap-nav to="/Orders">Orders</swap-nav>
                </li>
            </ul>
        </nav>
    </header>
    
    <main id="main-content" class="container">
        @RenderBody()
    </main>

    <footer class="container">
        <div class="grid">
            <div>
                <small>SwapShop - Demonstrating Swap.Htmx · HTMX @(ViewData["HtmxVersion"] ?? "2.0.8") · <a href="https://github.com/jdtoon/swap" target="_blank">GitHub</a></small>
                <br>
                <small hx-get="/api/status" hx-trigger="load delay:2s" hx-swap="outerHTML">Checking status...</small>
            </div>
            <div>
                <partial name="_Newsletter" />
            </div>
        </div>
    </footer>

    <!-- Toast container injected by swap.client.js -->
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
