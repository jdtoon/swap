@model IEnumerable<SwapShop.Models.Review>

<div id="reviews-container">
    <h3>Customer Reviews (@Model.Count())</h3>
    
    @if (!Model.Any())
    {
        <p>No reviews yet. Be the first to review!</p>
    }
    else
    {
        <div class="reviews-list">
            @foreach (var review in Model)
            {
                <article style="margin-bottom: 1rem; padding: 1rem; background-color: var(--pico-card-background-color); border-radius: var(--pico-border-radius);">
                    <header style="margin-bottom: 0.5rem;">
                        <strong>@review.UserName</strong> 
                        <span style="float: right; color: gold;">
                            @string.Concat(Enumerable.Repeat("★", review.Rating))@string.Concat(Enumerable.Repeat("☆", 5 - review.Rating))
                        </span>
                    </header>
                    <p style="margin-bottom: 0.5rem;">@review.Comment</p>
                    <small class="text-muted">@review.CreatedAt.ToShortDateString()</small>
                </article>
            }
        </div>
    }
    
    <hr />
    
    <!-- Review Form -->
    <div id="review-form-container">
        <h4>Write a Review</h4>
        <form hx-post="/Reviews/Add" hx-swap="none">
            <!-- We need the product ID from the context or passed in. -->
            @{
                var pid = ViewData["ProductId"] ?? Context.Items["ViewData_ProductId"];
                // Fallback if model has items
                if (pid == null && Model.Any()) pid = Model.First().ProductId;
            }
            <input type="hidden" name="ProductId" value="@pid" />
            
            <div class="grid">
                <label>
                    Name
                    <input type="text" name="UserName" required placeholder="Your name" />
                </label>
                <label>
                    Rating
                    <select name="Rating" required>
                        <option value="5">5 - Excellent</option>
                        <option value="4">4 - Good</option>
                        <option value="3">3 - Average</option>
                        <option value="2">2 - Poor</option>
                        <option value="1">1 - Terrible</option>
                    </select>
                </label>
            </div>
            
            <label>
                Comment
                <textarea name="Comment" required placeholder="Share your thoughts..."></textarea>
            </label>
            
            <button type="submit">Submit Review</button>
        </form>
    </div>
</div>
