@using SwapDebtors.Models
@model Debt
@{
    var debtors = ViewData["Debtors"] as List<Debtor> ?? new List<Debtor>();
    var currencies = ViewData["Currencies"] as string[] ?? new[] { "USD", "EUR", "GBP" };
    var selectedDebtorId = ViewData["SelectedDebtorId"] as int?;
}

<div class="modal-backdrop" onclick="this.remove()">
    <article class="modal-content" onclick="event.stopPropagation()">
        <header>
            <strong>💰 Add New Debt</strong>
        </header>
        
        <form hx-post="/Debts/Create" 
              hx-target="#modal"
              hx-swap="innerHTML">
            
            <label>
                Debtor *
                <select name="DebtorId" required>
                    <option value="">Select a debtor...</option>
                    @foreach (var debtor in debtors)
                    {
                        <option value="@debtor.Id" 
                                selected="@(debtor.Id == selectedDebtorId)">
                            @debtor.Name
                        </option>
                    }
                </select>
            </label>
            
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                <label>
                    Amount *
                    <input type="number" 
                           name="Amount" 
                           step="0.01" 
                           min="0.01"
                           value="@Model?.Amount"
                           required 
                           autofocus />
                </label>
                
                <label>
                    Currency
                    <select name="Currency">
                        @foreach (var currency in currencies)
                        {
                            <option value="@currency" 
                                    selected="@(currency == (Model?.Currency ?? "USD"))">
                                @currency
                            </option>
                        }
                    </select>
                </label>
            </div>
            
            <label>
                Description *
                <input type="text" 
                       name="Description" 
                       value="@Model?.Description"
                       placeholder="What is this debt for?"
                       required />
            </label>
            
            <label>
                Due Date (optional)
                <input type="date" 
                       name="DueDate" 
                       value="@Model?.DueDate?.ToString("yyyy-MM-dd")" />
            </label>
            
            <footer style="display: flex; justify-content: flex-end; gap: 0.5rem;">
                <button type="button" class="secondary" onclick="this.closest('.modal-backdrop').remove()">
                    Cancel
                </button>
                <button type="submit">Add Debt</button>
            </footer>
        </form>
    </article>
</div>
