@model AnalyticsState

<div id="partial-conversion-rate" class="card" style="background: var(--secondary); color: white; text-align: center; padding: var(--spacing-sm);">
    <div style="font-size: 0.75rem; opacity: 0.9; margin-bottom: var(--spacing-xs);">Conversion</div>
    <div style="font-size: 1.75rem; font-weight: 700;">@Model.ConversionRate%</div>
    <div style="font-size: 0.7rem; opacity: 0.8; margin-top: var(--spacing-xs);">Target: 3.5%</div>
</div>
