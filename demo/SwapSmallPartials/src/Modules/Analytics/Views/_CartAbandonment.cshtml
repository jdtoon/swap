@model AnalyticsState

<div id="partial-cart-abandonment" class="card" style="background: var(--danger); color: white; text-align: center; padding: var(--spacing-sm);">
    <div style="font-size: 0.75rem; opacity: 0.9; margin-bottom: var(--spacing-xs);">Cart Abandon</div>
    <div style="font-size: 1.75rem; font-weight: 700;">@Model.CartAbandonmentRate%</div>
    <div style="font-size: 0.7rem; opacity: 0.8; margin-top: var(--spacing-xs);">↓ Improving</div>
</div>
