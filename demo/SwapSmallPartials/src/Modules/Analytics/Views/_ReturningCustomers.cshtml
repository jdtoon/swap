@model AnalyticsState

<div id="partial-returning-customers" class="card" style="background: var(--secondary); color: white; text-align: center; padding: var(--spacing-sm);">
    <div style="font-size: 0.75rem; opacity: 0.9; margin-bottom: var(--spacing-xs);">Returning</div>
    <div style="font-size: 1.75rem; font-weight: 700;">@Model.ReturningCustomersToday</div>
    <div style="font-size: 0.7rem; opacity: 0.8; margin-top: var(--spacing-xs);">Today</div>
</div>
