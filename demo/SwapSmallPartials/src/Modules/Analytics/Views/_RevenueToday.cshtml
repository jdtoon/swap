@model AnalyticsState

<div id="partial-revenue-today" class="card" style="background: var(--primary); color: white; text-align: center; padding: var(--spacing-sm);">
    <div style="font-size: 0.75rem; opacity: 0.9; margin-bottom: var(--spacing-xs);">Revenue Today</div>
    <div style="font-size: 1.75rem; font-weight: 700;">$@Model.RevenueToday.ToString("N0")</div>
    <div style="font-size: 0.7rem; opacity: 0.8; margin-top: var(--spacing-xs);">↑ +12.3%</div>
</div>
