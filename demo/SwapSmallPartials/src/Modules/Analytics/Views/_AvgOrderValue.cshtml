@model AnalyticsState

<div id="partial-avg-order-value" class="card" style="background: var(--primary); color: white; text-align: center; padding: var(--spacing-sm);">
    <div style="font-size: 0.75rem; opacity: 0.9; margin-bottom: var(--spacing-xs);">Avg Order</div>
    <div style="font-size: 1.75rem; font-weight: 700;">$@Model.AvgOrderValue.ToString("N0")</div>
    <div style="font-size: 0.7rem; opacity: 0.8; margin-top: var(--spacing-xs);">Per order</div>
</div>
