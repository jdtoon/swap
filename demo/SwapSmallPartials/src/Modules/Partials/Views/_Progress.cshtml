@model SwapSmallPartials.Modules.Partials.Events.Handlers.ProgressModel

@{
    var barColor = Model.Value switch
    {
        >= 80 => "var(--primary)",
        >= 50 => "var(--secondary)",
        >= 25 => "var(--warning)",
        _ => "var(--danger)"
    };
}

<div id="partial-progress-@Model.Number" class="card" style="padding: var(--spacing-sm);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-xs);">
        <span style="font-size: 0.75rem; color: var(--text-muted);">P @Model.Number</span>
        <span style="background: var(--text); color: white; padding: 0.125rem var(--spacing-xs); border-radius: var(--radius-sm); font-size: 0.75rem;">@Model.Value%</span>
    </div>
    <div style="background: var(--border); height: 0.5rem; border-radius: var(--radius-sm); overflow: hidden; margin-bottom: var(--spacing-xs);">
        <div style="background: @barColor; height: 100%; width: @Model.Value%; transition: width 0.3s ease;"></div>
    </div>
    <div style="display: flex; gap: var(--spacing-xs);">
        <button class="btn btn-danger" 
                style="flex: 1; padding: var(--spacing-xs); font-size: 0.75rem;"
                hx-post="/partials/progress/@Model.Number/decrease" 
                hx-swap="none">
            -10
        </button>
        <button class="btn btn-primary" 
                style="flex: 1; padding: var(--spacing-xs); font-size: 0.75rem;"
                hx-post="/partials/progress/@Model.Number/increase" 
                hx-swap="none">
            +10
        </button>
    </div>
</div>
