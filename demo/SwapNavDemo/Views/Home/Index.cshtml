@{
    ViewData["Title"] = "swap-nav Demo";
}

<h2>Welcome to the &lt;swap-nav&gt; Demo</h2>
<p>
    This demo showcases the new <span class="inline-code">&lt;swap-nav&gt;</span> tag helper 
    that simplifies SPA-style navigation in Swap.Htmx applications.
</p>

<div class="demo-section">
    <h3><span>✨</span> The Problem</h3>
    <p>Before <span class="inline-code">&lt;swap-nav&gt;</span>, navigation links required verbose, repetitive markup:</p>
    
    <div class="vs-block">
        <div class="before">
            <h4>❌ Before (verbose)</h4>
            <div class="code-block" style="font-size: 0.75rem;">
<span class="tag">&lt;a</span> <span class="attr">href</span>=<span class="value">"/Products"</span>
   <span class="attr">hx-get</span>=<span class="value">"/Products"</span>
   <span class="attr">hx-target</span>=<span class="value">"#main-content"</span>
   <span class="attr">hx-push-url</span>=<span class="value">"true"</span><span class="tag">&gt;</span>Products<span class="tag">&lt;/a&gt;</span>
            </div>
        </div>
        <div class="after">
            <h4>✅ After (clean)</h4>
            <div class="code-block" style="font-size: 0.75rem;">
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/Products"</span><span class="tag">&gt;</span>Products<span class="tag">&lt;/swap-nav&gt;</span>
            </div>
        </div>
    </div>
</div>

<div class="demo-section">
    <h3><span>🚀</span> Features</h3>
    <div class="feature-grid">
        <div class="feature-card">
            <h4>🎯 Auto Target</h4>
            <p>Automatically uses configured default target (<span class="inline-code">#main-content</span>)</p>
        </div>
        <div class="feature-card">
            <h4>📍 Auto Push URL</h4>
            <p>Browser history updated automatically (disable with <span class="inline-code">push-url="false"</span>)</p>
        </div>
        <div class="feature-card">
            <h4>🎨 Full Styling</h4>
            <p>All HTML attributes pass through - class, style, id, data-*, etc.</p>
        </div>
        <div class="feature-card">
            <h4>🔌 HTMX Compatible</h4>
            <p>All hx-* attributes work: hx-vals, hx-swap, hx-indicator, etc.</p>
        </div>
    </div>
</div>

<div class="demo-section">
    <h3><span>📝</span> Usage Examples</h3>
    
    <h4>Basic Navigation</h4>
    <div class="code-block">
<span class="comment">&lt;!-- Simple navigation --&gt;</span>
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/Products"</span><span class="tag">&gt;</span>Products<span class="tag">&lt;/swap-nav&gt;</span>

<span class="comment">&lt;!-- With query parameters --&gt;</span>
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/Products?category=electronics"</span><span class="tag">&gt;</span>Electronics<span class="tag">&lt;/swap-nav&gt;</span>
    </div>
    
    <h4>With Styling</h4>
    <div class="code-block">
<span class="comment">&lt;!-- Button-styled nav link --&gt;</span>
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/Featured"</span> <span class="attr">class</span>=<span class="value">"btn btn-primary"</span><span class="tag">&gt;</span>
    ⭐ Featured
<span class="tag">&lt;/swap-nav&gt;</span>
    </div>
    
    <h4>With HTMX Attributes</h4>
    <div class="code-block">
<span class="comment">&lt;!-- Pass values via hx-vals --&gt;</span>
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/Search"</span> <span class="attr">hx-vals</span>=<span class="value">'{"q": "htmx", "page": 1}'</span><span class="tag">&gt;</span>Search<span class="tag">&lt;/swap-nav&gt;</span>

<span class="comment">&lt;!-- Custom target --&gt;</span>
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/QuickView"</span> <span class="attr">hx-target</span>=<span class="value">"#sidebar"</span><span class="tag">&gt;</span>Quick View<span class="tag">&lt;/swap-nav&gt;</span>

<span class="comment">&lt;!-- No URL push (for modals, tabs, etc) --&gt;</span>
<span class="tag">&lt;swap-nav</span> <span class="attr">to</span>=<span class="value">"/Modal"</span> <span class="attr">push-url</span>=<span class="value">"false"</span><span class="tag">&gt;</span>Open Modal<span class="tag">&lt;/swap-nav&gt;</span>
    </div>
</div>

<div class="demo-section">
    <h3><span>⚙️</span> Configuration</h3>
    <div class="code-block">
<span class="comment">// Program.cs</span>
builder.Services.AddSwapHtmx(options =>
{
    <span class="comment">// Default target for &lt;swap-nav&gt; (default: "#main-content")</span>
    options.DefaultNavigationTarget = <span class="value">"#main-content"</span>;
    
    <span class="comment">// Auto-suppress layout for HTMX requests - no _ViewStart.cshtml needed!</span>
    options.AutoSuppressLayout = <span class="value">true</span>;
});
    </div>
</div>

<div class="demo-section">
    <h3><span>🔄</span> Auto-Generated Constants</h3>
    <p>The source generator automatically creates constants for your views and element IDs:</p>
    <div class="code-block">
<span class="comment">// Auto-generated SwapViews class</span>
SwapViews.Home.Index        <span class="comment">// "~/Views/Home/Index.cshtml"</span>
SwapViews.Home.Dashboard    <span class="comment">// "~/Views/Home/_Dashboard.cshtml"</span>
SwapViews.Shared.Layout     <span class="comment">// "~/Views/Shared/_Layout.cshtml"</span>

<span class="comment">// Auto-generated SwapElements class (from id="..." in .cshtml)</span>
SwapElements.MainContent    <span class="comment">// "main-content"</span>
SwapElements.QuickPanel     <span class="comment">// "quick-panel"</span>
    </div>
    <p style="margin-top: 1rem;">
        <span class="badge badge-info">TIP</span>
        Add <span class="inline-code">&lt;AdditionalFiles Include="Views\**\*.cshtml" /&gt;</span> to your .csproj
    </p>
</div>

<div class="demo-section">
    <h3><span>🎉</span> Try It!</h3>
    <p>Click the navigation links in the sidebar to see <span class="inline-code">&lt;swap-nav&gt;</span> in action.</p>
    <div style="margin-top: 1rem;">
        <swap-nav to="/Home/Dashboard" class="btn btn-primary">Go to Dashboard</swap-nav>
        <swap-nav to="/Home/Products" class="btn btn-secondary">Browse Products</swap-nav>
    </div>
</div>
