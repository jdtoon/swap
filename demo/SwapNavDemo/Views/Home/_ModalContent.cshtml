<div id="modal-container">
    <div class="modal-backdrop">
        <div class="modal">
            <h3>🪟 Modal Content</h3>
            <p>This modal was loaded using <code>pushUrl: false</code></p>
            <p>The URL didn't change - you can't bookmark this modal state.</p>
            
            <div style="background: #fef3c7; padding: 0.75rem; border-radius: 0.375rem; margin: 1rem 0;">
                <code>.WithNavigation("/modal", target: "#modal-container", pushUrl: false)</code>
            </div>
            
            <button type="button" onclick="document.getElementById('modal-container').innerHTML=''" 
                    style="padding: 0.5rem 1rem; background: #64748b; color: white; border: none; border-radius: 0.375rem; cursor: pointer;">
                Close Modal
            </button>
        </div>
    </div>
</div>
