@model IEnumerable<SwapNavDemo.Controllers.EmailMessage>

<div id="main-content">
    <h2>📥 Inbox</h2>
    <p>You have @Model.Count() messages</p>
    
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #f1f5f9; text-align: left;">
                <th style="padding: 0.75rem;">From</th>
                <th style="padding: 0.75rem;">Subject</th>
                <th style="padding: 0.75rem;">Received</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var msg in Model)
            {
                <tr style="border-bottom: 1px solid #e2e8f0; @(msg.IsRead ? "" : "font-weight: bold;")">
                    <td style="padding: 0.75rem;">@msg.From</td>
                    <td style="padding: 0.75rem;">@msg.Subject</td>
                    <td style="padding: 0.75rem;">@msg.ReceivedAt.ToString("MMM d, h:mm tt")</td>
                </tr>
            }
        </tbody>
    </table>
    
    <div style="margin-top: 1rem; padding: 1rem; background: #f0fdf4; border-radius: 0.375rem;">
        <strong>✅ Navigated via:</strong>
        <code>.WithNavigation("/Home/Inbox")</code>
    </div>
</div>
