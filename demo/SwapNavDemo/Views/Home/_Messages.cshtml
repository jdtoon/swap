@model IEnumerable<SwapNavDemo.Controllers.ChatMessage>

<div id="main-content">
    <h2>💬 Messages</h2>
    <p>Recent conversations</p>
    
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        @foreach (var msg in Model)
        {
            <div style="background: #f8fafc; padding: 1rem; border-radius: 0.5rem; border-left: 3px solid #2563eb;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <strong>@msg.Sender</strong>
                    <span style="color: #64748b; font-size: 0.875rem;">@msg.SentAt.ToString("h:mm tt")</span>
                </div>
                <p style="margin: 0; color: #475569;">@msg.Text</p>
            </div>
        }
    </div>
    
    <div style="margin-top: 1rem; padding: 1rem; background: #f0fdf4; border-radius: 0.375rem;">
        <strong>✅ Navigated via:</strong>
        <code>.WithNavigation("/Home/Messages").WithSuccessToast("...")</code>
    </div>
</div>
