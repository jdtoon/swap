<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - SwapNavDemo</title>
    <script src="https://unpkg.com/htmx.org@2.0.8"></script>
    <script src="/_content/Swap.Htmx/js/swap.client.js"></script>
    <link rel="stylesheet" href="/_content/Swap.Htmx/css/swap.css" />
    <style>
        * { box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0; 
            padding: 0;
            background: #f5f5f5;
        }
        .app-container {
            display: grid;
            grid-template-columns: 280px 1fr;
            grid-template-rows: auto 1fr;
            min-height: 100vh;
        }
        header {
            grid-column: 1 / -1;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        header h1 { margin: 0; font-size: 1.5rem; }
        header h1 span { font-weight: normal; opacity: 0.8; font-size: 0.9rem; }
        nav {
            background: #1e293b;
            padding: 1.5rem 1rem;
        }
        nav h3 {
            color: #94a3b8;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin: 1.5rem 0 0.75rem;
            padding: 0 0.75rem;
        }
        nav h3:first-child { margin-top: 0; }
        
        /* swap-nav styling - it outputs <a> tags so we style those */
        nav a {
            display: block;
            padding: 0.75rem 1rem;
            margin-bottom: 0.25rem;
            color: #e2e8f0;
            text-decoration: none;
            border-radius: 0.5rem;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        nav a:hover { 
            background: rgba(255,255,255,0.1);
            color: white;
        }
        nav a.active { 
            background: rgba(255,255,255,0.15);
            color: white;
        }
        
        #main-content {
            padding: 2rem;
            background: white;
            overflow-y: auto;
        }
        .demo-section {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }
        .demo-section h3 { 
            margin-top: 0; 
            color: #334155;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .code-block {
            background: #1e293b;
            color: #e2e8f0;
            padding: 1rem 1.25rem;
            border-radius: 0.5rem;
            font-family: 'Monaco', 'Consolas', 'Fira Code', monospace;
            font-size: 0.85rem;
            margin: 1rem 0;
            overflow-x: auto;
            line-height: 1.6;
        }
        .code-block .comment { color: #64748b; }
        .code-block .tag { color: #7dd3fc; }
        .code-block .attr { color: #fbbf24; }
        .code-block .value { color: #86efac; }
        .vs-block {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin: 1rem 0;
        }
        .vs-block > div {
            padding: 1rem;
            border-radius: 0.5rem;
        }
        .vs-block .before {
            background: #fef2f2;
            border: 1px solid #fecaca;
        }
        .vs-block .after {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
        }
        .vs-block h4 {
            margin: 0 0 0.5rem;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .vs-block .before h4 { color: #dc2626; }
        .vs-block .after h4 { color: #16a34a; }
        .btn {
            display: inline-block;
            padding: 0.625rem 1.25rem;
            border: none;
            border-radius: 0.375rem;
            cursor: pointer;
            font-size: 0.875rem;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
            text-decoration: none;
            color: white;
        }
        .btn-primary { background: #6366f1; }
        .btn-primary:hover { background: #4f46e5; }
        .btn-secondary { background: #64748b; }
        .btn-secondary:hover { background: #475569; }
        .btn-success { background: #16a34a; }
        .btn-success:hover { background: #15803d; }
        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
            margin: 1rem 0;
        }
        .feature-card {
            background: white;
            padding: 1.25rem;
            border-radius: 0.5rem;
            border: 1px solid #e2e8f0;
        }
        .feature-card h4 {
            margin: 0 0 0.5rem;
            color: #334155;
        }
        .feature-card p {
            margin: 0;
            color: #64748b;
            font-size: 0.9rem;
        }
        .inline-code {
            background: #f1f5f9;
            padding: 0.125rem 0.375rem;
            border-radius: 0.25rem;
            font-family: monospace;
            font-size: 0.85em;
            color: #6366f1;
        }
        #toast-container {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 1000;
        }
        .badge {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 9999px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .badge-new { background: #dbeafe; color: #1d4ed8; }
        .badge-info { background: #f0fdf4; color: #16a34a; }
    </style>
</head>
<body>
    <div class="app-container">
        <header>
            <h1>🧭 SwapNavDemo <span>| &lt;swap-nav&gt; Tag Helper</span></h1>
            <span class="badge badge-new">NEW in v1.1</span>
        </header>
        
        <nav>
            <h3>📍 Basic Navigation</h3>
            <!-- NEW: swap-nav tag helper - clean and simple! -->
            <swap-nav to="/Home/Dashboard">📊 Dashboard</swap-nav>
            <swap-nav to="/Home/Products">📦 Products</swap-nav>
            <swap-nav to="/Home/Orders">🛒 Orders</swap-nav>
            <swap-nav to="/Home/Settings">⚙️ Settings</swap-nav>
            
            <h3>🎯 With Parameters</h3>
            <!-- Pass query params in the URL -->
            <swap-nav to="/Home/Products?category=electronics">💻 Electronics</swap-nav>
            <swap-nav to="/Home/Products?category=clothing">👕 Clothing</swap-nav>
            
            <!-- Or use hx-vals for dynamic params -->
            <swap-nav to="/Home/Search" hx-vals='{"q": "htmx"}'>🔍 Search "htmx"</swap-nav>
            
            <h3>🎨 Styled Links</h3>
            <!-- All HTML attributes work -->
            <swap-nav to="/Home/Featured" class="btn btn-primary" style="margin: 0.5rem;">
                ⭐ Featured
            </swap-nav>
            <swap-nav to="/Home/Sale" class="btn btn-success" style="margin: 0.5rem;">
                🏷️ On Sale
            </swap-nav>
            
            <h3>🔧 Advanced</h3>
            <!-- Override default target -->
            <swap-nav to="/Home/QuickView" hx-target="#quick-panel" hx-swap="innerHTML show:#quick-panel:top">👁️ Quick View</swap-nav>
            
            <!-- No URL push (for modals, etc) -->
            <swap-nav to="/Home/ModalContent" push-url="false" hx-target="#modal-slot">
                🪟 Open Modal
            </swap-nav>
        </nav>
        
        <main id="main-content">
            @RenderBody()
        </main>
    </div>
    
    <div id="modal-slot"></div>
    <div id="quick-panel" style="position: fixed; bottom: 1rem; right: 1rem; width: 350px; background: white; border-radius: 0.75rem; box-shadow: 0 10px 40px rgba(0,0,0,0.2); z-index: 100; max-height: 300px; overflow: auto;"></div>
    <div id="toast-container"></div>
</body>
</html>
