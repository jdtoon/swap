@model dynamic
@using TaskFlow.Models
@using TaskFlow.Views
@using TaskStatus = TaskFlow.Models.TaskStatus;

@{
    var task = (TaskItem)Model.Task;
    var project = (Project?)Model.Project;
    var assignee = (TeamMember?)Model.Assignee;
}

<div class="task-details">
    <div class="task-details-header">
        <h2>@task.Title</h2>
        <button hx-get="/tasks" 
                hx-target="main" 
                hx-push-url="true" 
                class="btn btn-outline">
            Back to Board
        </button>
    </div>

    <div class="task-details-content">
        <div class="task-details-section">
            <h3>Description</h3>
            <p>@(string.IsNullOrEmpty(task.Description) ? "No description provided." : task.Description)</p>
        </div>

        <div class="task-details-meta">
            <div class="meta-item">
                <label>Status</label>
                <span class="badge status-@task.Status.ToString().ToLower()">@task.Status</span>
            </div>

            <div class="meta-item">
                <label>Priority</label>
                <span class="badge priority-@task.Priority.ToString().ToLower()">@task.Priority</span>
            </div>

            <div class="meta-item">
                <label>Project</label>
                <span>@(project?.Name ?? "Unknown")</span>
            </div>

            <div class="meta-item">
                <label>Assignee</label>
                <span>@(assignee?.Name ?? "Unassigned")</span>
            </div>

            <div class="meta-item">
                <label>Created</label>
                <span>@task.CreatedAt.ToString("MMM d, yyyy h:mm tt")</span>
            </div>

            @if (task.DueDate.HasValue)
            {
                <div class="meta-item">
                    <label>Due Date</label>
                    <span class="@(task.DueDate.Value < DateTime.UtcNow && task.Status != TaskStatus.Done ? "text-danger" : "")">
                        @task.DueDate.Value.ToString("MMM d, yyyy")
                        @if (task.DueDate.Value < DateTime.UtcNow && task.Status != TaskStatus.Done)
                        {
                            <span class="overdue-badge">OVERDUE</span>
                        }
                    </span>
                </div>
            }

            @if (task.CompletedAt.HasValue)
            {
                <div class="meta-item">
                    <label>Completed</label>
                    <span>@task.CompletedAt.Value.ToString("MMM d, yyyy h:mm tt")</span>
                </div>
            }
        </div>

        <div class="task-details-section">
            <h3>Comments</h3>
            <div id="@CommentElements.List(task.Id)" 
                 class="comments-list"
                 hx-get="/tasks/@task.Id/comments" 
                 hx-trigger="load" 
                 hx-swap="innerHTML">
                <p class="loading">Loading comments...</p>
            </div>

            <form hx-post="/tasks/@task.Id/comments" 
                  hx-target="body" 
                  hx-swap="none" 
                  class="comment-form">
                <textarea name="Content" 
                          placeholder="Add a comment..." 
                          rows="3" 
                          required></textarea>
                <button type="submit" class="btn btn-primary">Add Comment</button>
            </form>
        </div>
    </div>
</div>

<style>
    .task-details {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2rem;
        background: var(--color-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
    }

    .task-details-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--color-border);
    }

    .task-details-content {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .task-details-section h3 {
        margin-bottom: 1rem;
        color: var(--color-primary);
    }

    .task-details-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .meta-item label {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .meta-item span {
        font-size: 1rem;
    }

    .badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 0.875rem;
    }

    .overdue-badge {
        color: var(--color-danger);
        font-weight: 700;
        margin-left: 0.5rem;
    }

    .text-danger {
        color: var(--color-danger);
    }

    .comments-list {
        min-height: 100px;
        margin-bottom: 1rem;
    }

    .comment-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .comment-form textarea {
        padding: 0.75rem;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        font-family: inherit;
        font-size: 0.95rem;
        resize: vertical;
    }

    .loading {
        color: var(--color-text-muted);
        font-style: italic;
    }
</style>
