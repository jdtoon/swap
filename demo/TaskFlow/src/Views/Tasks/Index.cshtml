@model dynamic
@{
    ViewData["Title"] = "Tasks";
}
@using TaskFlow.Models
@using TaskFlow.Views
@using TaskStatus = TaskFlow.Models.TaskStatus;

@{
    var tasks = (List<TaskItem>)Model.Tasks;
    var todoTasks = tasks.Where(t => t.Status == TaskStatus.Todo).ToList();
    var inProgressTasks = tasks.Where(t => t.Status == TaskStatus.InProgress).ToList();
    var reviewTasks = tasks.Where(t => t.Status == TaskStatus.Review).ToList();
    var doneTasks = tasks.Where(t => t.Status == TaskStatus.Done).ToList();
}

<h1>Task Board 
    <small style="color: #666; font-size: 0.5em;">
        <span id="sse-status-tasks" style="color: orange;">Connecting to SSE...</span>
    </small>
</h1>

<div class="kanban-board" hx-ext="sse" sse-connect="/tasks/stream">
    <!-- Hidden SSE Listeners for OOB updates -->
    <div style="display:none" sse-swap="task-column-todo-update" hx-swap="none"></div>
    <div style="display:none" sse-swap="task-column-inprogress-update" hx-swap="none"></div>
    <div style="display:none" sse-swap="task-column-review-update" hx-swap="none"></div>
    <div style="display:none" sse-swap="task-column-done-update" hx-swap="none"></div>

    <div class="kanban-column">
        <h3 class="column-header todo">📝 To Do</h3>
        <div id="@TaskElements.Column(TaskStatus.Todo)" class="task-list">
            @await Html.PartialAsync(TaskViews.TaskColumn, todoTasks)
        </div>
    </div>

    <div class="kanban-column">
        <h3 class="column-header in-progress">⚡ In Progress</h3>
        <div id="@TaskElements.Column(TaskStatus.InProgress)" class="task-list">
            @await Html.PartialAsync(TaskViews.TaskColumn, inProgressTasks)
        </div>
    </div>

    <div class="kanban-column">
        <h3 class="column-header review">👀 Review</h3>
        <div id="@TaskElements.Column(TaskStatus.Review)" class="task-list">
            @await Html.PartialAsync(TaskViews.TaskColumn, reviewTasks)
        </div>
    </div>

    <div class="kanban-column">
        <h3 class="column-header done">✅ Done</h3>
        <div id="@TaskElements.Column(TaskStatus.Done)" class="task-list">
            @await Html.PartialAsync(TaskViews.TaskColumn, doneTasks)
        </div>
    </div>
</div>

<!-- New Task Form -->
<div class="new-task-section">
    <h3>Create New Task</h3>
    <form hx-post="/tasks" hx-target="body" hx-swap="none">
        <input type="text" name="Title" placeholder="Task title" required />
        <textarea name="Description" placeholder="Description"></textarea>
        
        <select name="ProjectId" required>
            <option value="">Select Project</option>
            @foreach (var project in Model.Projects)
            {
                <option value="@project.Id">@project.Name</option>
            }
        </select>

        <select name="Priority">
            <option value="@TaskPriority.Low">Low</option>
            <option value="@TaskPriority.Medium" selected>Medium</option>
            <option value="@TaskPriority.High">High</option>
            <option value="@TaskPriority.Critical">Critical</option>
        </select>

        <select name="AssigneeId">
            <option value="">Unassigned</option>
            @foreach (var member in Model.TeamMembers)
            {
                <option value="@member.Id">@member.Name</option>
            }
        </select>

        <button type="submit">Create Task</button>
    </form>
</div>

<script>
    // SSE connection status indicator
    document.body.addEventListener('htmx:sseOpen', function(evt) {
        const statusEl = document.getElementById('sse-status-tasks');
        if (statusEl) {
            statusEl.textContent = 'Live Updates Connected ✓';
            statusEl.style.color = '#10b981';
        }
    });

    document.body.addEventListener('htmx:sseError', function(evt) {
        const statusEl = document.getElementById('sse-status-tasks');
        if (statusEl) {
            statusEl.textContent = 'Connection Error';
            statusEl.style.color = '#ef4444';
        }
    });

    document.body.addEventListener('htmx:sseClose', function(evt) {
        const statusEl = document.getElementById('sse-status-tasks');
        if (statusEl) {
            statusEl.textContent = 'Reconnecting...';
            statusEl.style.color = '#f59e0b';
        }
    });
</script>
