@model TaskItem
@using TaskFlow.Models
@using TaskFlow.Views
@using TaskStatus = TaskFlow.Models.TaskStatus;

<div id="@TaskElements.Card(Model.Id)" class="task-card priority-@Model.Priority.ToString().ToLower()">
    <div class="task-header">
        <h4>@Model.Title</h4>
        <div class="task-actions">
            <button hx-delete="/tasks/@Model.Id" 
                    hx-confirm="Delete this task?"
                    class="btn-icon">🗑️</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="task-description">@Model.Description</p>
    }

    <div class="task-meta">
        @if (Model.AssigneeId != null)
        {
            <span class="assignee">👤 @Model.AssigneeId</span>
        }
        <span class="priority priority-@Model.Priority.ToString().ToLower()">
            @Model.Priority
        </span>
    </div>

    <!-- Status change buttons -->
    <div class="status-actions">
        @if (Model.Status != TaskStatus.Todo)
        {
            <button hx-patch="/tasks/@Model.Id/status" 
                    hx-vals='{"status": "@((int)TaskStatus.Todo)"}'
                    class="btn-sm">◀ To Do</button>
        }
        @if (Model.Status == TaskStatus.Todo)
        {
            <button hx-patch="/tasks/@Model.Id/status" 
                    hx-vals='{"status": "@((int)TaskStatus.InProgress)"}'
                    class="btn-sm">Start ▶</button>
        }
        @if (Model.Status == TaskStatus.InProgress)
        {
            <button hx-patch="/tasks/@Model.Id/status" 
                    hx-vals='{"status": "@((int)TaskStatus.Review)"}'
                    class="btn-sm">Review ▶</button>
        }
        @if (Model.Status == TaskStatus.Review)
        {
            <button hx-patch="/tasks/@Model.Id/status" 
                    hx-vals='{"status": "@((int)TaskStatus.Done)"}'
                    class="btn-sm">Done ✓</button>
        }
    </div>

    <!-- Comments section -->
    <div class="task-comments">
        <div id="@CommentElements.List(Model.Id)" class="comments-list">
            @* Comments loaded dynamically *@
        </div>
        <form hx-post="/tasks/@Model.Id/comments" hx-target="body" hx-swap="none" class="comment-form">
            <input type="text" name="Content" placeholder="Add a comment..." />
            <button type="submit">💬</button>
        </form>
    </div>
</div>
