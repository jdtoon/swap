@model int
@using TaskFlow.Views

<span id="@NotificationElements.Bell" 
      class="notification-link"
      hx-get="/notifications/bell" 
      hx-trigger="every 30s"
      hx-swap="outerHTML"
      hx-on:click="window.location.href='/notifications/list'"
      style="cursor: pointer;">
    🔔
    @if (Model > 0)
    {
        <span class="notification-badge">@Model</span>
    }
</span>
