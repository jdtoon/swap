@model List<TeamMember>
@using TaskFlow.Services
@inject ITeamService TeamService

<h2>Team Members</h2>
<div class="team-grid">
    @foreach (var member in Model)
    {
        var taskCount = TeamService.GetActiveTaskCount(member.Id);
        <div class="team-member">
            <span class="member-avatar" style="background-color: @member.AvatarColor">
                @member.Name[0]
            </span>
            <div class="member-info">
                <strong>@member.Name</strong>
                <span class="status-indicator @(member.IsOnline ? "online" : "offline")">
                    @(member.IsOnline ? "● Online" : "○ Offline")
                </span>
                <small class="task-count">@taskCount active tasks</small>
                @if (!member.IsOnline && member.LastSeenAt.HasValue)
                {
                    <small>Last seen @member.LastSeenAt.Value.ToString("MMM d, h:mm tt")</small>
                }
            </div>
        </div>
    }
</div>
