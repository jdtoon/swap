@{
    ViewData["Title"] = "Dashboard";
    var model = (dynamic)Model;
}
@using TaskFlow.Models
@using TaskFlow.Views
@inject TaskFlow.Services.IProjectService ProjectService

<div class="dashboard" hx-ext="sse" sse-connect="/dashboard/stream">
    <!-- Hidden SSE Listeners for OOB updates -->
    <div style="display:none" sse-swap="stats-update" hx-swap="none"></div>
    <div style="display:none" sse-swap="team-update" hx-swap="none"></div>
    <div style="display:none" sse-swap="activity-update" hx-swap="none"></div>
    <div style="display:none" sse-swap="project-progress-update" hx-swap="none"></div>

    <h1>Team Dashboard 
        <small style="color: #666; font-size: 0.5em;">
            <span id="sse-status" style="color: orange;">Connecting to SSE...</span>
        </small>
    </h1>

    <!-- SSE Test Button -->
    <div style="margin: 1rem 0; padding: 1rem; background: #f0f9ff; border: 1px solid #bfdbfe; border-radius: 8px;">
        <h3 style="margin-top: 0;">SSE Test Controls</h3>
        <p style="margin: 0.5rem 0;">Click the button below to create a test task. The dashboard stats should update in real-time via SSE!</p>
        <button hx-post="/dashboard/test-sse" 
                hx-swap="none"
                class="btn btn-primary"
                style="padding: 0.5rem 1rem; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer;">
            Create Test Task (Triggers SSE Update)
        </button>
    </div>

    <!-- Stats Section (SSE auto-update) -->
    <div id="@DashboardElements.Stats" class="stats-grid">
        @{ await Html.RenderPartialAsync(DashboardViews.Stats, (TeamStats)model.Stats); }
    </div>

    <!-- Team Presence -->
    <div id="@DashboardElements.TeamList" class="team-section">
        @{ await Html.RenderPartialAsync(DashboardViews.TeamList, (List<TeamMember>)model.TeamMembers); }
    </div>

    <!-- Recent Activity Feed (SSE-powered) -->
    <div id="@DashboardElements.Activity" class="activity-feed">
        @{ await Html.RenderPartialAsync(DashboardViews.Activity, (List<Activity>)model.Activities); }
    </div>

    <!-- Projects Overview -->
    <div class="projects-overview">
        <h2>Projects</h2>
        <div id="@DashboardElements.Projects">
            @{ await Html.RenderPartialAsync(DashboardViews.ProjectsOverview, (List<Project>)model.Projects); }
        </div>
    </div>
</div>
