@{
    ViewData["Title"] = "Dashboard";
    var model = (dynamic)Model;
}
@using TaskFlow.Models
@using TaskFlow.Views
@inject TaskFlow.Services.IProjectService ProjectService

<div class="dashboard" sse-connect="/dashboard/stream">
    <h1>Team Dashboard</h1>

    <!-- Stats Section -->
    <div id="@DashboardElements.Stats" class="stats-grid">
        @{ await Html.RenderPartialAsync(DashboardViews.Stats, (TeamStats)model.Stats); }
    </div>

    <!-- Team Presence -->
    <div id="@DashboardElements.TeamList" class="team-section">
        @{ await Html.RenderPartialAsync(DashboardViews.TeamList, (List<TeamMember>)model.TeamMembers); }
    </div>

    <!-- Recent Activity Feed (SSE-powered) -->
    <div id="@DashboardElements.Activity" class="activity-feed">
        @{ await Html.RenderPartialAsync(DashboardViews.Activity, (List<Activity>)model.Activities); }
    </div>

    <!-- Projects Overview -->
    <div class="projects-overview">
        <h2>Projects</h2>
        @foreach (var project in (List<Project>)model.Projects)
        {
            <div class="project-summary">
                <h3>@project.Name</h3>
                <div id="@ProjectElements.Progress(project.Id)">
                    @{ await Html.RenderPartialAsync(ProjectViews.ProgressBar, ProjectService.GetProgress(project.Id)); }
                </div>
            </div>
        }
    </div>
</div>
