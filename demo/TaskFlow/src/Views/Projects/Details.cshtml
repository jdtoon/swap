@model dynamic
@{
    Layout = "_Layout";
    ViewData["Title"] = $"{Model.Project.Name} - TaskFlow";
}
@using System.Linq
@using TaskFlow.Models

@{
    var tasks = (List<TaskItem>)Model.Tasks;
}

<div class="container">
    <div class="project-header">
        <div>
            <h1>@Model.Project.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Project.Description))
            {
                <p class="project-description">@Model.Project.Description</p>
            }
        </div>
        <div class="project-actions">
            <button class="btn btn-outline" 
                    hx-get="/projects" 
                    hx-target="main"
                    hx-push-url="true">
                Back to Projects
            </button>
        </div>
    </div>

    <div class="project-stats">
        <div class="stat-card">
            <h3>Progress</h3>
            <div class="progress-display">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: @(Model.Progress)%"></div>
                </div>
                <span class="progress-text">@(Model.Progress)%</span>
            </div>
        </div>

        <div class="stat-card">
            <h3>Task Breakdown</h3>
            <div class="task-stats">
                <div class="stat-item">
                    <span class="stat-label">To Do:</span>
                    <span class="stat-value">@Model.Breakdown[TaskFlow.Models.TaskStatus.Todo]</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">In Progress:</span>
                    <span class="stat-value">@Model.Breakdown[TaskFlow.Models.TaskStatus.InProgress]</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Done:</span>
                    <span class="stat-value">@Model.Breakdown[TaskFlow.Models.TaskStatus.Done]</span>
                </div>
            </div>
        </div>
    </div>

    <div class="project-tasks">
        <h2>Tasks</h2>
        @if (tasks.Any())
        {
            <div class="task-list">
                @foreach (var task in tasks)
                {
                    <div class="task-item">
                        <div class="task-info">
                            <h4>@task.Title</h4>
                            <p>@task.Description</p>
                            <div class="task-meta">
                                <span class="task-status status-@task.Status.ToString().ToLower()">
                                    @task.Status
                                </span>
                                <span class="task-assignee">@task.AssigneeId</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">No tasks in this project yet.</p>
        }
    </div>
</div>

<style>
    .project-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .project-description {
        color: var(--text-muted);
        margin-top: 0.5rem;
    }

    .project-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--card-bg);
        padding: 1.5rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
    }

    .stat-card h3 {
        margin: 0 0 1rem 0;
        font-size: 0.875rem;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .progress-display {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .progress-display .progress-bar {
        flex: 1;
        height: 24px;
    }

    .progress-display .progress-text {
        font-weight: 600;
        font-size: 1.25rem;
    }

    .task-stats {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .stat-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .stat-label {
        color: var(--text-muted);
    }

    .stat-value {
        font-weight: 600;
        font-size: 1.125rem;
    }

    .project-tasks h2 {
        margin-bottom: 1rem;
    }

    .task-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .task-item {
        background: var(--card-bg);
        padding: 1.25rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
    }

    .task-info h4 {
        margin: 0 0 0.5rem 0;
    }

    .task-info p {
        color: var(--text-muted);
        margin: 0 0 0.75rem 0;
    }

    .task-meta {
        display: flex;
        gap: 1rem;
        align-items: center;
        font-size: 0.875rem;
    }

    .task-status {
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-weight: 500;
    }

    .status-todo {
        background: #f3f4f6;
        color: #374151;
    }

    .status-inprogress {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-done {
        background: #d1fae5;
        color: #065f46;
    }

    .task-assignee {
        color: var(--text-muted);
    }

    .empty-state {
        text-align: center;
        color: var(--text-muted);
        padding: 3rem;
        background: var(--card-bg);
        border-radius: 8px;
        border: 1px dashed var(--border-color);
    }
</style>
