<div id="quick-note-widget" class="quick-note" style="background: var(--color-surface); padding: 1rem; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--color-border); width: 300px;">
    <h6 style="margin-bottom: 0.5rem; font-size: 0.85rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Quick Note</h6>
    <form hx-post="/api/quicknote" hx-swap="none" hx-on::after-request="this.reset()">
        <div style="display: flex; gap: 0.5rem;">
            <input type="text" name="note" placeholder="Jot something down..." required 
                   style="flex: 1; padding: 0.4rem 0.8rem; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 0.9rem;" />
            <button type="submit" 
                    style="background: var(--gradient-primary); color: white; border: none; padding: 0.4rem 0.8rem; border-radius: var(--radius-sm); cursor: pointer; font-size: 0.9rem; font-weight: 500;">
                Save
            </button>
        </div>
    </form>
    <ul id="quick-notes-list" style="list-style: none; padding: 0; margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.4rem; max-height: 100px; overflow-y: auto;">
        <!-- Notes will appear here -->
    </ul>
</div>
