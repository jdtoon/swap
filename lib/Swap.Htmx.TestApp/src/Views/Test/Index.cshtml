@{
    ViewData["Title"] = "Framework Feature Tests";
}

<div class="content">
    <h1 class="title is-1">Swap.Htmx Framework Tests</h1>
    <p class="subtitle">Manual testing for toasts, OOB swaps, and SSE features</p>

    <!-- Server-Sent Events -->
    <section class="section">
        <h2 class="title is-3">Server-Sent Events (SSE)</h2>
        <div class="box">
            <p class="mb-4">Real-time HTML streaming from server to client using SSE (server → client only).</p>
            <div class="buttons">
                <a class="button is-primary" href="/test/sse">
                    Go to SSE Demo
                </a>
            </div>
        </div>
    </section>

    

    <!-- Toast Tests -->
    <section class="section">
        <h2 class="title is-3">Toast Notifications</h2>
        <div class="box">
            <div class="buttons">
                <button class="button is-success" 
                        hx-post="/test/toast/success" 
                        hx-target="#toast-result"
                        data-test-id="toast-success">
                    Success Toast
                </button>
                <button class="button is-danger" 
                        hx-post="/test/toast/error" 
                        hx-target="#toast-result"
                        data-test-id="toast-error">
                    Error Toast
                </button>
                <button class="button is-warning" 
                        hx-post="/test/toast/warning" 
                        hx-target="#toast-result"
                        data-test-id="toast-warning">
                    Warning Toast
                </button>
                <button class="button is-info" 
                        hx-post="/test/toast/info" 
                        hx-target="#toast-result"
                        data-test-id="toast-info">
                    Info Toast
                </button>
            </div>
            <div id="toast-result" class="mt-4" data-test-id="toast-result"></div>
        </div>
    </section>

    <!-- OOB Swap Tests -->
    <section class="section">
        <h2 class="title is-3">Out-of-Band Swaps</h2>
        
        <!-- Single OOB -->
        <div class="box">
            <h3 class="title is-5">Single OOB Update</h3>
            <div class="columns">
                <div class="column">
                    <button class="button is-primary" 
                            hx-post="/test/oob/single" 
                            hx-target="#oob-result"
                            data-test-id="oob-single">
                        Update Secondary Panel (OOB)
                    </button>
                    <div id="oob-result" class="mt-4" data-test-id="oob-result"></div>
                </div>
                <div class="column">
                    <div id="secondary-panel" class="box has-background-light" data-test-id="secondary-panel">
                        <p class="has-text-centered">Secondary panel - will update OOB</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Multiple OOB -->
        <div class="box">
            <h3 class="title is-5">Multiple OOB Updates</h3>
            <button class="button is-primary" 
                    hx-post="/test/oob/multiple" 
                    hx-target="#oob-result"
                    data-test-id="oob-multiple">
                Update All Panels (OOB)
            </button>
            <div class="columns mt-4">
                <div class="column">
                    <div id="panel-1" class="box has-background-light" data-test-id="panel-1">
                        <p class="has-text-centered">Panel 1</p>
                    </div>
                </div>
                <div class="column">
                    <div id="panel-2" class="box has-background-light" data-test-id="panel-2">
                        <p class="has-text-centered">Panel 2</p>
                    </div>
                </div>
                <div class="column">
                    <div id="panel-3" class="box has-background-light" data-test-id="panel-3">
                        <p class="has-text-centered">Panel 3</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Counter with OOB (innerHTML strategy) -->
        <div class="box">
            <h3 class="title is-5">OOB with innerHTML Strategy</h3>
            <div class="columns">
                <div class="column">
                    <form hx-post="/test/oob/counter" hx-target="#oob-result">
                        <input type="hidden" name="count" id="count-value" value="0">
                        <button type="submit" class="button is-primary" data-test-id="oob-counter">
                            Increment Counter
                        </button>
                    </form>
                </div>
                <div class="column">
                    <div id="counter-display" class="box has-background-info-light" data-test-id="counter-display">
                        <p class="has-text-centered">Count: 0</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Combined Tests -->
    <section class="section">
        <h2 class="title is-3">Combined Features</h2>
        <div class="box">
            <h3 class="title is-5">Toast + OOB Together</h3>
            <div class="columns">
                <div class="column">
                    <button class="button is-link" 
                            hx-post="/test/combined" 
                            hx-target="#oob-result"
                            data-test-id="combined">
                        Toast + OOB Update
                    </button>
                </div>
                <div class="column">
                    <div id="status-panel" class="box has-background-light" data-test-id="status-panel">
                        <p class="has-text-centered">Status: Ready</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        // Update counter hidden input when OOB updates counter display
        document.body.addEventListener('htmx:afterSwap', function(evt) {
            if (evt.detail.target.id === 'oob-result') {
                const counterDisplay = document.getElementById('counter-display');
                if (counterDisplay) {
                    const match = counterDisplay.textContent.match(/Count: (\d+)/);
                    if (match) {
                        document.getElementById('count-value').value = match[1];
                    }
                }
            }
        });
    </script>
}
