## Project Structure Deep Dive

### Working Across Layers

**Adding a new feature (example: Products):**

**1. Domain layer (entities + interfaces):**

```csharp
// Domain/Entities/Product.cs
public class Product
{
    public int Id { get; set; }
    public string Name { get; set; } = string.Empty;
    public decimal Price { get; set; }
    public bool InStock { get; set; }
}

// Domain/Interfaces/IProductRepository.cs
public interface IProductRepository
{
    Task<IEnumerable<Product>> GetAllAsync();
    Task<Product?> GetByIdAsync(int id);
    Task AddAsync(Product product);
    Task SaveChangesAsync();
}

// Domain/Events/DomainEvents.cs
public static string ProductCreated => "entity.created:product";
```

**2. Infrastructure layer (data access):**

```csharp
// Infrastructure/Data/AppDbContext.cs
public DbSet<Product> Products => Set<Product>();

protected override void OnModelCreating(ModelBuilder modelBuilder)
{
    modelBuilder.Entity<Product>(entity =>
    {
        entity.HasKey(e => e.Id);
        entity.Property(e => e.Name).IsRequired().HasMaxLength(200);
        entity.HasIndex(e => e.InStock);
    });
}

// Infrastructure/Repositories/ProductRepository.cs
public class ProductRepository : IProductRepository
{
    private readonly AppDbContext _context;
    
    public ProductRepository(AppDbContext context)
    {
        _context = context;
    }
    
    public async Task<IEnumerable<Product>> GetAllAsync()
    {
        return await _context.Products.ToListAsync();
    }
    
    public async Task<Product?> GetByIdAsync(int id)
    {
        return await _context.Products.FindAsync(id);
    }
    
    public async Task AddAsync(Product product)
    {
        await _context.Products.AddAsync(product);
    }
    
    public async Task SaveChangesAsync()
    {
        await _context.SaveChangesAsync();
    }
}
```

**3. Application layer (business logic):**

```csharp
// Application/Interfaces/IProductService.cs
public interface IProductService
{
    Task<IEnumerable<Product>> GetAllProductsAsync();
    Task CreateProductAsync(string name, decimal price, bool inStock);
}

// Application/Services/ProductService.cs
public class ProductService : IProductService
{
    private readonly IProductRepository _repository;
    private readonly IEventBus _eventBus;
    
    public ProductService(IProductRepository repository, IEventBus eventBus)
    {
        _repository = repository;
        _eventBus = eventBus;
    }
    
    public async Task<IEnumerable<Product>> GetAllProductsAsync()
    {
        return await _repository.GetAllAsync();
    }
    
    public async Task CreateProductAsync(string name, decimal price, bool inStock)
    {
        if (string.IsNullOrWhiteSpace(name))
            throw new ArgumentException("Name is required");
        
        if (price < 0)
            throw new ArgumentException("Price must be positive");
        
        var product = new Product
        {
            Name = name,
            Price = price,
            InStock = inStock
        };
        
        await _repository.AddAsync(product);
        await _repository.SaveChangesAsync();
        
        _eventBus.Fire(DomainEvents.ProductCreated);
    }
}
```

**4. Web layer (controllers + views):**

```csharp
// Web/Controllers/ProductsController.cs
public class ProductsController : SwapController
{
    private readonly IProductService _productService;
    
    public ProductsController(IProductService productService)
    {
        _productService = productService;
    }
    
    [HttpGet]
    public async Task<IActionResult> Index()
    {
        var products = await _productService.GetAllProductsAsync();
        return View(products);
    }
    
    [HttpGet]
    public async Task<IActionResult> List()
    {
        var products = await _productService.GetAllProductsAsync();
        return PartialView("_ProductList", products);
    }
    
    [HttpPost]
    public async Task<IActionResult> Create(string name, decimal price, bool inStock)
    {
        await _productService.CreateProductAsync(name, price, inStock);
        return Ok();
    }
}

// Web/Events/SwapEventChains.cs
events.Chain(
    DomainEvents.ProductCreated,
    "ui.refreshProductList",
    "ui.showToast");
```

**5. Create migration:**

```bash
dotnet ef migrations add AddProduct -p src/Infrastructure -s src/Web
dotnet ef database update -p src/Infrastructure -s src/Web
```

**6. Register services:**

```csharp
// Web/Extensions/ServiceCollectionExtensions.cs
services.AddScoped<IProductRepository, ProductRepository>();
services.AddScoped<IProductService, ProductService>();
```

