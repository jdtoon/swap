```bash
dotnet test
```

### Run Specific Test Project

```bash
dotnet test test/Unit
dotnet test test/Integration
```

### Watch Mode

```bash
dotnet watch test --project test/Integration
```

### Writing Unit Tests (Application Layer)

```csharp
// test/Unit/TodoServiceTests.cs
public class TodoServiceTests
{
    [Fact]
    public async Task CreateTodoAsync_Should_Fire_Event()
    {
        // Arrange
        var mockRepo = new Mock<ITodoRepository>();
        var mockEventBus = new Mock<IEventBus>();
        var service = new TodoService(mockRepo.Object, mockEventBus.Object);
        
        // Act
        await service.CreateTodoAsync("Test Todo");
        
        // Assert
        mockRepo.Verify(r => r.AddAsync(It.IsAny<TodoItem>()), Times.Once);
        mockEventBus.Verify(e => e.Fire(DomainEvents.TodoCreated), Times.Once);
    }
    
    [Fact]
    public async Task CreateTodoAsync_With_Empty_Title_Should_Throw()
    {
        // Arrange
        var mockRepo = new Mock<ITodoRepository>();
        var mockEventBus = new Mock<IEventBus>();
        var service = new TodoService(mockRepo.Object, mockEventBus.Object);
        
        // Act & Assert
        await Assert.ThrowsAsync<ArgumentException>(
            () => service.CreateTodoAsync(""));
    }
}
```

### Writing Integration Tests (Web Layer)

```csharp
// test/Integration/TodoFlowTests.cs
public class TodoFlowTests : IClassFixture<HtmxTestFixture<Program>>
{
    private readonly HtmxTestClient<Program> _client;
    
    public TodoFlowTests(HtmxTestFixture<Program> fixture)
    {
        _client = fixture.Client;
    }
    
    [Fact]
    public async Task Should_Create_And_Display_Todo()
    {
        // Arrange
        var formData = new Dictionary<string, string>
        {
            ["title"] = "Integration Test Todo"
        };
        
        // Act
        var response = await _client.HtmxPostAsync("/Todos/Create", formData);
        
        // Assert
        response.AssertSuccess();
        response.AssertHasSwapEvent(DomainEvents.TodoCreated);
        
        var list = await _client.HtmxGetAsync("/Todos/List");
        await list.AssertContainsAsync("Integration Test Todo");
    }
}
```

**Available assertions:**
- `AssertSuccess()` — 2xx status code
- `AssertPartialViewAsync()` — Response is a partial view
- `AssertContainsAsync(text)` — HTML contains text
- `AssertHasSwapEvent(name)` — Event was fired
- `AssertHxRedirect(url)` — HTMX redirect header present

