## Real-World Examples

### Product Management System

**Domain events:**

```csharp
// Domain/Events/DomainEvents.cs
public static class DomainEvents
{
    // Product events
    public static string ProductCreated => "entity.created:product";
    public static string ProductUpdated => "entity.updated:product";
    public static string ProductDeleted => "entity.deleted:product";
    public static string ProductInventoryLow => "product.inventoryLow";
    public static string ProductPriceChanged => "product.priceChanged";
}
```

**Application service:**

```csharp
// Application/Services/ProductService.cs
public async Task CreateProductAsync(string name, decimal price, int stock)
{
    var product = new Product
    {
        Name = name,
        Price = price,
        Stock = stock
    };
    
    await _repository.AddAsync(product);
    await _repository.SaveChangesAsync();
    
    _eventBus.Fire(DomainEvents.ProductCreated);
    
    if (stock < 10)
        _eventBus.Fire(DomainEvents.ProductInventoryLow);
}

public async Task UpdatePriceAsync(int id, decimal newPrice)
{
    var product = await _repository.GetByIdAsync(id);
    if (product == null)
        throw new KeyNotFoundException();
    
    product.Price = newPrice;
    await _repository.SaveChangesAsync();
    
    _eventBus.Fire(DomainEvents.ProductUpdated);
    _eventBus.Fire(DomainEvents.ProductPriceChanged);
}
```

**Event chains:**

```csharp
// Web/Events/SwapEventChains.cs
events.Chain(
    DomainEvents.ProductCreated,
    "ui.refreshProductList",
    "ui.showToast");

events.Chain(
    DomainEvents.ProductInventoryLow,
    "ui.showWarningToast",
    "ui.refreshStats");

events.Chain(
    DomainEvents.ProductPriceChanged,
    "ui.refreshProductList");
```

**Views:**

```html
<!-- Product list -->
<div id="product-list"
     hx-get="/Products/List"
     hx-trigger="ui.refreshProductList from:body">
</div>

<!-- Stats panel -->
<div id="stats"
     hx-get="/Dashboard/Stats"
     hx-trigger="ui.refreshStats from:body">
</div>
```

### Order Processing System

**Domain events:**

```csharp
// Domain/Events/DomainEvents.cs
public static string OrderCreated => "entity.created:order";
public static string OrderPaid => "order.paid";
public static string OrderShipped => "order.shipped";
public static string OrderCancelled => "order.cancelled";
```

**Application service:**

```csharp
// Application/Services/OrderService.cs
public async Task ProcessPaymentAsync(int orderId)
{
    var order = await _repository.GetByIdAsync(orderId);
    if (order == null)
        throw new KeyNotFoundException();
    
    // Process payment logic
    order.Status = OrderStatus.Paid;
    order.PaidAt = DateTime.UtcNow;
    
    await _repository.SaveChangesAsync();
    
    _eventBus.Fire(DomainEvents.OrderPaid);
}

public async Task ShipOrderAsync(int orderId, string trackingNumber)
{
    var order = await _repository.GetByIdAsync(orderId);
    if (order == null)
        throw new KeyNotFoundException();
    
    order.Status = OrderStatus.Shipped;
    order.TrackingNumber = trackingNumber;
    
    await _repository.SaveChangesAsync();
    
    _eventBus.Fire(DomainEvents.OrderShipped);
}
```

**Event chains:**

```csharp
// Web/Events/SwapEventChains.cs
events.Chain(
    DomainEvents.OrderCreated,
    "ui.refreshOrderList",
    "ui.refreshStats",
    "ui.showToast");

events.Chain(
    DomainEvents.OrderPaid,
    "ui.refreshOrderList",
    "ui.showToast");

events.Chain(
    DomainEvents.OrderShipped,
    "ui.refreshOrderList",
    "ui.showToast",
    "ui.sendEmailNotification");
