## Testing Event Flows

### Unit Tests (Application Layer)

```csharp
// test/Unit/TodoServiceTests.cs
public class TodoServiceTests
{
    [Fact]
    public async Task CreateTodoAsync_Should_Fire_TodoCreated_Event()
    {
        // Arrange
        var mockRepo = new Mock<ITodoRepository>();
        var mockEventBus = new Mock<IEventBus>();
        var service = new TodoService(mockRepo.Object, mockEventBus.Object);
        
        // Act
        await service.CreateTodoAsync("Test Todo");
        
        // Assert
        mockEventBus.Verify(e => e.Fire(DomainEvents.TodoCreated), Times.Once);
    }
    
    [Fact]
    public async Task DeleteTodoAsync_Should_Fire_TodoDeleted_Event()
    {
        // Arrange
        var mockRepo = new Mock<ITodoRepository>();
        var mockEventBus = new Mock<IEventBus>();
        var service = new TodoService(mockRepo.Object, mockEventBus.Object);
        
        // Act
        await service.DeleteTodoAsync(1);
        
        // Assert
        mockEventBus.Verify(e => e.Fire(DomainEvents.TodoDeleted), Times.Once);
    }
}
```

### Integration Tests (Web Layer)

```csharp
// test/Integration/TodoFlowTests.cs
public class TodoFlowTests : IClassFixture<HtmxTestFixture<Program>>
{
    private readonly HtmxTestClient<Program> _client;
    
    public TodoFlowTests(HtmxTestFixture<Program> fixture)
    {
        _client = fixture.Client;
    }
    
    [Fact]
    public async Task Creating_Todo_Should_Fire_Correct_Events()
    {
        // Arrange
        var formData = new Dictionary<string, string>
        {
