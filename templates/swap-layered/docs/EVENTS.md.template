## Firing Events in Application Layer

**Application services fire domain events via `IEventBus`:**

```csharp
// Application/Services/TodoService.cs
public class TodoService : ITodoService
{
    private readonly ITodoRepository _repository;
    private readonly IEventBus _eventBus;
    
    public TodoService(ITodoRepository repository, IEventBus eventBus)
    {
        _repository = repository;
        _eventBus = eventBus;
    }
    
    public async Task CreateTodoAsync(string title)
    {
        // Business rule validation
        if (string.IsNullOrWhiteSpace(title))
            throw new ArgumentException("Title is required", nameof(title));
        
        var todo = new TodoItem
        {
            Title = title,
            CreatedAt = DateTime.UtcNow,
            IsComplete = false
        };
        
        await _repository.AddAsync(todo);
        await _repository.SaveChangesAsync();
        
        // Fire domain event
        _eventBus.Fire(DomainEvents.TodoCreated);
    }
    
    public async Task ToggleTodoAsync(int id)
    {
        var todo = await _repository.GetByIdAsync(id);
        if (todo == null)
            throw new KeyNotFoundException($"Todo {id} not found");
        
        todo.IsComplete = !todo.IsComplete;
        
        if (todo.IsComplete)
            todo.CompletedAt = DateTime.UtcNow;
        else
            todo.CompletedAt = null;
        
        await _repository.SaveChangesAsync();
        
        // Fire appropriate domain events
        _eventBus.Fire(DomainEvents.TodoUpdated);
        
        if (todo.IsComplete)
            _eventBus.Fire(DomainEvents.TodoCompleted);
    }
    
    public async Task DeleteTodoAsync(int id)
    {
        await _repository.DeleteAsync(id);
        await _repository.SaveChangesAsync();
        
        _eventBus.Fire(DomainEvents.TodoDeleted);
    }
}
```

**IEventBus abstraction:**

```csharp
// Application/Interfaces/IEventBus.cs
public interface IEventBus
{
    void Fire(string eventName);
    void Fire(string eventName, object data);
}
```

