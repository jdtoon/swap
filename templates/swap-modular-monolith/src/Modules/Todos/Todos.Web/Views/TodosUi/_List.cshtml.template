@model List<{{ProjectName}}.Modules.Todos.Contracts.TodoItemDto>

<div id="todos-list-panel">
    <ul class="space-y-2">
    @if (Model == null || !Model.Any())
    {
        <li class="text-gray-500 italic">No todos yet. Add one above.</li>
    }
    else
    {
        @foreach (var item in Model)
        {
            @await Html.PartialAsync("_Item", item)
        }
    }
    </ul>
</div>
