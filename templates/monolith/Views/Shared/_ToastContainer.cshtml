<!-- HTMX Toast Container - Uses hx-on for declarative event handling -->
<div id="toast-container" 
     hx-on::show-toast="
        // HTMX wraps JSON trigger values in event.detail.value
        const detail = event.detail.value || event.detail || {};
        const container = document.getElementById('toast-container');
        if (container) {
            const toast = document.createElement('div');
            toast.className = 'toast toast-' + (detail.type || 'info');
            toast.textContent = detail.message || 'Operation completed';
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 3500);
        }
     ">
</div>
