<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - {{ProjectName}}</title>
    <link rel="stylesheet" href="~/css/app.min.css" asp-append-version="true" />
    <script src="~/lib/htmx/htmx.min.js" asp-append-version="true"></script>
</head>
<body>
    <header>
        <nav class="navbar bg-base-100 shadow-lg">
            <div class="container mx-auto">
                <div class="flex-1">
                    <a class="btn btn-ghost text-xl" href="/">{{ProjectName}}</a>
                </div>
                <div class="flex-none">
                    <ul class="menu menu-horizontal px-1">
                        <li><a href="/">Home</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container mx-auto p-4">
        @RenderBody()
    </main>

    <footer class="footer footer-center p-4 bg-base-300 text-base-content mt-8">
        <aside>
            <p>Built with <strong>Swap</strong> - The Rails of .NET</p>
        </aside>
    </footer>

    <!-- Global Toast Container -->
    <div id="toast-container" class="toast toast-end"></div>

    <script>
        // Global Toast notification handler - HTMX fires custom events from HX-Trigger header
        document.addEventListener('DOMContentLoaded', function() {
            document.body.addEventListener('showToast', function(event) {
                const toastData = event.detail.value;
                const toastContainer = document.getElementById('toast-container');
                
                const toast = document.createElement('div');
                toast.className = `alert alert-${toastData.type === 'success' ? 'success' : 'error'} shadow-lg`;
                toast.innerHTML = `
                    <div>
                        <span>${toastData.message}</span>
                    </div>
                `;
                
                toastContainer.appendChild(toast);
                
                // Auto-remove after 3 seconds
                setTimeout(() => {
                    toast.remove();
                }, 3000);
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
