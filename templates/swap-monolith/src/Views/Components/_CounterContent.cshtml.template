@model int
@{
  var name = (string)(ViewData["Name"] ?? "a");
}
<div class="flex items-center gap-3">
  <div class="stat">
    <div class="stat-title">Value</div>
    <div class="stat-value">@Model</div>
  </div>
  <button class="btn btn-primary"
          hx-post="/Components/Increment?name=@name">
    Increment @name.ToUpper()
  </button>
</div>
