## Firing Events in Controllers

### Basic Event Fire

```csharp
[HttpPost]
public IActionResult AddTodo(string title)
{
    var todo = new TodoItem { Title = title };
    _db.TodoItems.Add(todo);
    _db.SaveChanges();
    
    _events.Fire(SwapEvents.Entity.Created("todo"));
    
    return PartialView("_TodoItem", todo);
}
```

### Fire with Toast Message

```csharp
[HttpDelete]
public IActionResult Delete(int id)
{
    var todo = _db.TodoItems.Find(id);
    if (todo == null) return NotFound();
    
    _db.TodoItems.Remove(todo);
    _db.SaveChanges();
    
    _events.Fire(SwapEvents.Entity.Deleted("todo"));
    _events.Toast(ToastType.Success, "Todo deleted!");
    
    return Ok();
}
```

### Fire Multiple Events

```csharp
[HttpPut]
public IActionResult ToggleTodo(int id)
{
    var todo = _db.TodoItems.Find(id);
    if (todo == null) return NotFound();
    
    todo.IsComplete = !todo.IsComplete;
    _db.SaveChanges();
    
    _events.Fire(SwapEvents.Entity.Updated("todo"));
    _events.Fire(SwapEvents.UI.RefreshStats);
    
    return PartialView("_TodoItem", todo);
}
```

