## Testing Event Flows

### Integration Test Example

```csharp
[Fact]
public async Task Creating_Todo_Should_Fire_Correct_Events()
{
    // Arrange
    var formData = new Dictionary<string, string>
    {
        ["title"] = "Test Todo"
    };
    
    // Act
    var response = await _client.HtmxPostAsync("/Home/AddTodo", formData);
    
    // Assert
    response.AssertSuccess();
    response.AssertHasSwapEvent(SwapEvents.Entity.Created("todo"));
    response.AssertHasSwapEvent(SwapEvents.UI.Refresh);
    response.AssertHasSwapEvent(SwapEvents.UI.ShowToast);
}
```

### Verify Event Chain Registration

```csharp
[Fact]
public void Event_Chains_Should_Be_Registered()
{
    var services = new ServiceCollection();
    services.AddSwapEvents();
    
    var sp = services.BuildServiceProvider();
    var events = sp.GetRequiredService<ISwapEvents>();
    
    // Verify chains are registered
    Assert.Contains(SwapEvents.Entity.Created("todo"), events.GetChains());
}
```

