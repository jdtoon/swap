</span>

<!-- Stats panel refreshes on any cart change -->
<div id="stats"
     hx-get="/Dashboard/Stats"
     hx-trigger="ui.refreshStats from:body">
</div>
```

### Notification System

**EventNames.cs:**
```csharp
public static class NotificationEvents
{
    public const string New = "notification.new";
    public const string Read = "notification.read";
}
```

**SwapEventChains.cs:**
```csharp
events.Chain(
    NotificationEvents.New,
    SwapEvents.UI.RefreshStats);

events.Chain(
    NotificationEvents.Read,
    SwapEvents.UI.RefreshStats);
```

**Controller:**
```csharp
[HttpPost]
public IActionResult SendNotification(int userId, string message)
{
    var notification = new Notification
    {
        UserId = userId,
        Message = message,
        CreatedAt = DateTime.UtcNow
    };
    
    _db.Notifications.Add(notification);
    _db.SaveChanges();
    
    _events.Fire(NotificationEvents.New);
    
    return Ok();
}
```

**View:**
```html
<!-- Notification bell badge -->
<span id="notification-count"
      hx-get="/Notifications/UnreadCount"
      hx-trigger="notification.new from:body, notification.read from:body"
      class="badge badge-error">
    0
</span>

<!-- Notification dropdown -->
<div id="notification-list"
     hx-get="/Notifications/List"
     hx-trigger="notification.new from:body">
    <!-- Notification items -->
</div>
```

### Multi-Step Wizard

**EventNames.cs:**
