{
  "$schema": "http://json.schemastore.org/template",
  "author": "jdtoon",
  "classifications": [ "Web", "MVC", "Htmx" ],
  "name": "Swap.Htmx MVC App",
  "identity": "Swap.Htmx.Mvc",
  "shortName": "swap-mvc",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "SwapMvc",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "SwapMvc.csproj" }
  ],
  "symbols": {
    "UseLocalRef": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Use local project reference instead of NuGet package",
      "defaultValue": "false"
    },
    "IncludeSse": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include HTMX SSE extension",
      "defaultValue": "false"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "IncludeSse",
          "exclude": [
            "SwapMvc.csproj",
            "libman.json",
            "Views/Shared/_Layout.cshtml"
          ],
          "rename": {
            "SwapMvc.Sse.csproj": "SwapMvc.csproj",
            "libman.Sse.json": "libman.json",
            "Views/Shared/_Layout.Sse.cshtml": "Views/Shared/_Layout.cshtml"
          }
        },
        {
          "condition": "!IncludeSse",
          "exclude": [
            "SwapMvc.Sse.csproj",
            "libman.Sse.json",
            "Views/Shared/_Layout.Sse.cshtml"
          ]
        }
      ]
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
