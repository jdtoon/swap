{
  "version": "1.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "provider": "unpkg",
      "library": "htmx.org@2.0.8",
      "destination": "wwwroot/lib/htmx",
      "files": [
        "dist/htmx.min.js"
      ]
    },
    {
      "provider": "unpkg",
      "library": "htmx-ext-sse@2.2.4",
      "destination": "wwwroot/lib/htmx/ext",
      "files": [
        "sse.js"
      ]
    },
    {
      "library": "@tailwindcss/browser@4.1.18",
      "destination": "wwwroot/lib/tailwindcss",
      "files": [
        "dist/index.global.min.js"
      ]
    },
    {
      "provider": "unpkg",
      "library": "daisyui@5.5.14",
      "destination": "wwwroot/lib/daisyui/"
    }
  ]
}
