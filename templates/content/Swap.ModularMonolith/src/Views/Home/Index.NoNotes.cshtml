@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-6">
    <h1 class="text-2xl font-bold">Dashboard</h1>
    <p class="text-base-content/60">Welcome to your modular monolith</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <!-- Welcome Card -->
    <div class="card bg-base-200 shadow-sm">
        <div class="card-body">
            <h2 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Swap.Htmx
            </h2>
            <p class="text-base-content/70">Server-driven reactive web applications with HTMX and source generators.</p>
        </div>
    </div>

    <!-- Getting Started Card -->
    <div class="card bg-base-200 shadow-sm">
        <div class="card-body">
            <h2 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                Getting Started
            </h2>
            <ul class="text-sm space-y-1 text-base-content/70">
                <li>• Add modules in <code class="text-xs bg-base-300 px-1 rounded">Modules/</code></li>
                <li>• Register in <code class="text-xs bg-base-300 px-1 rounded">Program.cs</code></li>
                <li>• Configure in <code class="text-xs bg-base-300 px-1 rounded">MvcExtensions.cs</code></li>
            </ul>
        </div>
    </div>

    <!-- Architecture Card -->
    <div class="card bg-base-200 shadow-sm">
        <div class="card-body">
            <h2 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                Architecture
            </h2>
            <ul class="text-sm space-y-1 text-base-content/70">
                <li><span class="font-medium">Infrastructure/</span> - Cross-cutting</li>
                <li><span class="font-medium">Data/</span> - DB context</li>
                <li><span class="font-medium">Modules/</span> - Features</li>
                <li><span class="font-medium">Views/</span> - Shared views</li>
            </ul>
        </div>
    </div>
</div>
