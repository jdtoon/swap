{
  "$schema": "http://json.schemastore.org/template",
  "author": "jdtoon",
  "classifications": ["Web", "MVC", "Htmx", "Modular", "Monolith"],
  "name": "Swap.Htmx Modular Monolith",
  "identity": "Swap.Htmx.ModularMonolith",
  "shortName": "swap-modular",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "SwapModularMonolith",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "src/SwapModularMonolith.csproj" },
    { "path": "SwapModularMonolith.sln" }
  ],
  "symbols": {
    "UseLocalRef": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Use local project reference instead of NuGet package",
      "defaultValue": "false"
    },
    "IncludeSse": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Include SSE real-time support",
      "defaultValue": "false"
    },
    "SkipSampleModule": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Skip the sample Notes module",
      "defaultValue": "false"
    },
    "IncludeSampleModule": {
      "type": "computed",
      "value": "!SkipSampleModule"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "IncludeSse",
          "exclude": [
            "src/libman.json"
          ],
          "rename": {
            "src/libman.Sse.json": "src/libman.json"
          }
        },
        {
          "condition": "!IncludeSse",
          "exclude": [
            "src/libman.Sse.json"
          ]
        },
        {
          "condition": "SkipSampleModule",
          "exclude": [
            "src/Modules/Notes/**/*",
            "tests/NotesControllerTests.cs",
            "src/Views/_ViewImports.cshtml"
          ],
          "rename": {
            "src/Views/_ViewImports.NoNotes.cshtml": "src/Views/_ViewImports.cshtml"
          }
        },
        {
          "condition": "!SkipSampleModule && !IncludeSse",
          "exclude": [
            "src/Views/Shared/_Layout.NoNotes.cshtml",
            "src/Views/Shared/_Layout.Sse.cshtml",
            "src/Views/Shared/_Layout.Sse.NoNotes.cshtml",
            "src/Views/Home/Index.NoNotes.cshtml",
            "src/Views/_ViewImports.NoNotes.cshtml"
          ]
        },
        {
          "condition": "!SkipSampleModule && IncludeSse",
          "exclude": [
            "src/Views/Shared/_Layout.cshtml",
            "src/Views/Shared/_Layout.NoNotes.cshtml",
            "src/Views/Shared/_Layout.Sse.NoNotes.cshtml",
            "src/Views/Home/Index.NoNotes.cshtml",
            "src/Views/_ViewImports.NoNotes.cshtml"
          ],
          "rename": {
            "src/Views/Shared/_Layout.Sse.cshtml": "src/Views/Shared/_Layout.cshtml"
          }
        },
        {
          "condition": "SkipSampleModule && !IncludeSse",
          "exclude": [
            "src/Views/Shared/_Layout.cshtml",
            "src/Views/Shared/_Layout.Sse.cshtml",
            "src/Views/Shared/_Layout.Sse.NoNotes.cshtml",
            "src/Views/Home/Index.cshtml"
          ],
          "rename": {
            "src/Views/Shared/_Layout.NoNotes.cshtml": "src/Views/Shared/_Layout.cshtml",
            "src/Views/Home/Index.NoNotes.cshtml": "src/Views/Home/Index.cshtml"
          }
        },
        {
          "condition": "SkipSampleModule && IncludeSse",
          "exclude": [
            "src/Views/Shared/_Layout.cshtml",
            "src/Views/Shared/_Layout.NoNotes.cshtml",
            "src/Views/Shared/_Layout.Sse.cshtml",
            "src/Views/Home/Index.cshtml"
          ],
          "rename": {
            "src/Views/Shared/_Layout.Sse.NoNotes.cshtml": "src/Views/Shared/_Layout.cshtml",
            "src/Views/Home/Index.NoNotes.cshtml": "src/Views/Home/Index.cshtml"
          }
        }
      ]
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
