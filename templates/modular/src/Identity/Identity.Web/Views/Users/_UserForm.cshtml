@model Identity.Application.Contracts.Users.CreateUserDto

<h2 class="subtitle">Create New User</h2>

<form hx-post="/Users/Create" hx-swap="none">
    <div asp-validation-summary="All" class="notification is-danger is-light"></div>

    <div class="field">
        <label class="label" asp-for="Email"></label>
        <div class="control has-icons-left">
            <input class="input" type="email" asp-for="Email" placeholder="user@example.com" required />
            <span class="icon is-small is-left">
                <i class="fas fa-envelope"></i>
            </span>
        </div>
        <span asp-validation-for="Email" class="help is-danger"></span>
    </div>

    <div class="field">
        <label class="label" asp-for="Password"></label>
        <div class="control has-icons-left">
            <input class="input" type="password" asp-for="Password" placeholder="••••••••" required />
            <span class="icon is-small is-left">
                <i class="fas fa-lock"></i>
            </span>
        </div>
        <span asp-validation-for="Password" class="help is-danger"></span>
        <p class="help">Minimum 6 characters</p>
    </div>

    <div class="field">
        <label class="label" asp-for="FullName"></label>
        <div class="control has-icons-left">
            <input class="input" type="text" asp-for="FullName" placeholder="John Doe" />
            <span class="icon is-small is-left">
                <i class="fas fa-user"></i>
            </span>
        </div>
        <span asp-validation-for="FullName" class="help is-danger"></span>
    </div>

    <div class="field">
        <label class="label" asp-for="PhoneNumber"></label>
        <div class="control has-icons-left">
            <input class="input" type="tel" asp-for="PhoneNumber" placeholder="+1234567890" />
            <span class="icon is-small is-left">
                <i class="fas fa-phone"></i>
            </span>
        </div>
        <span asp-validation-for="PhoneNumber" class="help is-danger"></span>
    </div>

    <div class="field">
        <label class="checkbox">
            <input type="checkbox" asp-for="EmailConfirmed" />
            Email Confirmed
        </label>
    </div>

    <div class="field">
        <label class="checkbox">
            <input type="checkbox" asp-for="PhoneNumberConfirmed" />
            Phone Number Confirmed
        </label>
    </div>

    <div class="field">
        <label class="checkbox">
            <input type="checkbox" asp-for="IsActive" checked />
            Active
        </label>
    </div>

    <div class="field is-grouped">
        <div class="control">
            <button type="submit" class="button is-primary">
                <span class="icon">
                    <i class="fas fa-save"></i>
                </span>
                <span>Create User</span>
            </button>
        </div>
        <div class="control">
            <button type="button" 
                    class="button is-light"
                    onclick="document.getElementById('user-form-container').innerHTML = '<p class=\'has-text-grey has-text-centered\'>Select \'Add User\' or click \'Edit\' on a user to begin</p>'">
                Cancel
            </button>
        </div>
    </div>
</form>
