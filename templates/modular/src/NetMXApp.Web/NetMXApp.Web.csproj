<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>NetMXApp.Web</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- NetMX Framework Packages -->
    <PackageReference Include="NetMX.Core" Version="0.1.0-*" />
    <PackageReference Include="NetMX.Ddd.Domain" Version="0.1.0-*" />
    <PackageReference Include="NetMX.Ddd.Application.Contracts" Version="0.1.0-*" />
    <PackageReference Include="NetMX.Ddd.Application" Version="0.1.0-*" />
    <PackageReference Include="NetMX.EntityFrameworkCore" Version="0.1.0-*" />
    <PackageReference Include="NetMX.AspNetCore.Core" Version="0.1.0-*" />
    <PackageReference Include="NetMX.AspNetCore.Mvc" Version="0.1.0-*" />
    
    <!-- Entity Framework Core -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.10">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    
    <!-- Database Provider (PostgreSQL by default) -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.4" />
  </ItemGroup>

  <!-- 
    Modules: Add modules explicitly using 'netmx add module <ModuleName>'
    Example: netmx add module Identity
    This keeps the template minimal and lets you add only what you need.
  -->

</Project>
