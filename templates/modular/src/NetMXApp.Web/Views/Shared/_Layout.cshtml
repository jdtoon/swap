<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NetMX App</title>
    <link rel="stylesheet" href="~/lib/bulma/css/bulma.min.css" />
    <link rel="stylesheet" href="~/NetMXApp.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar is-light" role="navigation" aria-label="main navigation">
        <div class="navbar-brand">
            <a class="navbar-item" asp-area="" asp-controller="Home" asp-action="Index">
                <strong>NetMX App</strong>
            </a>
        </div>

        <div class="navbar-menu">
            <div class="navbar-start">
                <a class="navbar-item" asp-area="" asp-controller="Home" asp-action="Index">
                    Home
                </a>
                
                <a class="navbar-item" asp-area="" asp-controller="Home" asp-action="Privacy">
                    Privacy
                </a>
            </div>
        </div>
    </nav>

    <section class="section">
        <div class="container">
            @RenderBody()
        </div>
    </section>

    <footer class="footer">
        <div class="content has-text-centered">
            <p>
                &copy; 2025 - NetMX App - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/htmx/dist/htmx.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
