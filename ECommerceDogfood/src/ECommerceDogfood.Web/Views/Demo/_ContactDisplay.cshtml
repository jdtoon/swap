@model ContactViewModel

<div id="contact-display" class="box has-background-light">
    <div class="columns is-vcentered">
        <div class="column">
            <p class="title is-5">@Model.Name</p>
            <p class="subtitle is-6">@Model.Email</p>
            <span class="tag @(Model.Active ? "is-success" : "is-danger")">
                @(Model.Active ? "Active" : "Inactive")
            </span>
        </div>
        <div class="column is-narrow">
            <button class="button is-info" 
                    hx-get="/Demo/EditContact" 
                    hx-target="#contact-container" 
                    hx-swap="innerHTML">
                <span class="icon">
                    <i class="fas fa-edit"></i>
                </span>
                <span>Edit</span>
            </button>
        </div>
    </div>
</div>
