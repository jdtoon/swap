@model List<ItemViewModel>

<table class="table is-fullwidth is-striped is-hoverable">
    <thead>
        <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr id="item-@item.Id">
                <td>@item.Name</td>
                <td>$@item.Price.ToString("F2")</td>
                <td>
                    <span class="tag @(item.InStock ? "is-success" : "is-warning")">
                        @(item.InStock ? "In Stock" : "Out of Stock")
                    </span>
                </td>
                <td>
                    <button class="button is-danger is-small" 
                            hx-delete="/Demo/DeleteItem?id=@item.Id" 
                            hx-target="#item-@item.Id" 
                            hx-confirm="Are you sure you want to delete @item.Name?">
                        <span class="icon is-small">
                            <i class="fas fa-trash"></i>
                        </span>
                        <span>Delete</span>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="notification is-warning has-text-centered">
        All items have been deleted. Refresh the page to reset.
    </div>
}
